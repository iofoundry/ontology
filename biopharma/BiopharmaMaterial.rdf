<!DOCTYPE rdf:RDF [
	<!ENTITY bfo "http://purl.obolibrary.org/obo/">
	<!ENTITY bmic-material "https://spec.industrialontologies.org/ontology/biopharma/BiopharmaMaterial/">
	<!ENTITY dc "http://purl.org/dc/elements/1.1/">
	<!ENTITY dcterms "http://purl.org/dc/terms/">
	<!ENTITY dtype "http://www.linkedmodel.org/schema/dtype#">
	<!ENTITY iof-av "https://spec.industrialontologies.org/ontology/annotation/">
	<!ENTITY iof-construct "https://spec.industrialontologies.org/ontology/construct/">
	<!ENTITY iof-core "https://spec.industrialontologies.org/ontology/core/Core/">
	<!ENTITY iof-ind "https://spec.industrialontologies.org/ontology/individual/">
	<!ENTITY owl "http://www.w3.org/2002/07/owl#">
	<!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#">
	<!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#">
	<!ENTITY skos "http://www.w3.org/2004/02/skos/core#">
	<!ENTITY xsd "http://www.w3.org/2001/XMLSchema#">
]>
<rdf:RDF xml:base="https://spec.industrialontologies.org/ontology/biopharma/BiopharmaMaterial/"
	xmlns:bfo="http://purl.obolibrary.org/obo/"
	xmlns:bmic-material="https://spec.industrialontologies.org/ontology/biopharma/BiopharmaMaterial/"
	xmlns:dc="http://purl.org/dc/elements/1.1/"
	xmlns:dcterms="http://purl.org/dc/terms/"
	xmlns:dtype="http://www.linkedmodel.org/schema/dtype#"
	xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
	xmlns:iof-construct="https://spec.industrialontologies.org/ontology/construct/"
	xmlns:iof-core="https://spec.industrialontologies.org/ontology/core/Core/"
	xmlns:iof-ind="https://spec.industrialontologies.org/ontology/individual/"
	xmlns:owl="http://www.w3.org/2002/07/owl#"
	xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
	xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
	xmlns:skos="http://www.w3.org/2004/02/skos/core#"
	xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
	
	<owl:Ontology rdf:about="https://spec.industrialontologies.org/ontology/biopharma/BiopharmaMaterial/">
		<rdfs:label xml:lang="en-US">Biopharma Material Ontology</rdfs:label>
		<dcterms:abstract>This module contains terms and relations enabling representation of material types and their associated properties. Terms for characterizing material usages in internal operation systems are also included (e.g., consumable, process intermediate, final product…).</dcterms:abstract>
		<dcterms:contributor>Adlane Rebai, Millipore Sigma</dcterms:contributor>
		<dcterms:contributor>Ana Nikolov, OAGi</dcterms:contributor>
		<dcterms:contributor>Boonserm Kulvatunyou, NIST</dcterms:contributor>
		<dcterms:contributor>Cameron Gibbs, CrownPoint Technologies, LLC</dcterms:contributor>
		<dcterms:contributor>Gabriela Henning, NIST</dcterms:contributor>
		<dcterms:contributor>Jan Kemper, AstraZeneca</dcterms:contributor>
		<dcterms:contributor>Marie-Aude Coutouly, Millipore Sigma</dcterms:contributor>
		<dcterms:contributor>Melissa Weller, CrownPoint Technologies, LLC</dcterms:contributor>
		<dcterms:contributor>Milos Drobnjakovic, OAGi</dcterms:contributor>
		<dcterms:contributor>Stephen J. Granite, CrownPoint Technologies, LLC</dcterms:contributor>
		<dcterms:contributor>Stephen Kahmann, CrownPoint Technologies, LLC</dcterms:contributor>
		<dcterms:creator>NIIMBL BD-1 Ontology Group</dcterms:creator>
		<dcterms:license rdf:datatype="&xsd;anyURI">http://opensource.org/licenses/MIT</dcterms:license>
		<dcterms:title>NIIMBL Material Ontology</dcterms:title>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/MolecularEntity/"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/ReferenceOntologyCandidates/"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/"/>
		<owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202602/biopharma/BiopharmaMaterial/"/>
		<iof-av:copyright>Copyright (c) 2022, 2023, 2024, 2025, 2026 Open Applications Group</iof-av:copyright>
		<iof-av:maturity rdf:resource="&iof-ind;Released"/>
	</owl:Ontology>
	
	<owl:Class rdf:about="&iof-construct;Absorbance">
		<rdfs:subClassOf rdf:resource="&iof-construct;OpticalQuality"/>
		<rdfs:label>absorbance</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000061</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Lambert-Beer&apos;s law states that absorbance is equal to the product of molar coefficient of absorbance of an absorbing compound in a medium times its concentration in the medium times path length of the electromagnetic radiation passing through the medium.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>optical quality inhering in a material entity that is the logarithm of the ratio of incident electromagnetic radiation intensity to transmitted electromagnetic radiation intensity for a specified wavelength and specified path through that material entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;AcidicChargeVariantImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ProteinChargeVariantImpurityRole"/>
		<rdfs:label>acidic charge variant impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC5392216/ and https://www.chromatographyonline.com/view/charge-variant-profiling-biopharmaceuticals and https://www.agilent.com/cs/library/applications/compendium-chargevariant-advancebio-5994-0034EN-us-agilent.pdf?srsltid=AfmBOorRMu0dQH4wotghCeKwXSMCdNuuNsAEkA06EkLXupvMO6SBKJaN</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>protein charge variant impurity role that is held by a protein, protein fragment, or molecular population of such entities that differs from a reference form of the same protein by having a lower net electric charge or isoelectric point</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Adhesion">
		<rdfs:subClassOf rdf:resource="&iof-construct;Pressure"/>
		<rdfs:label>adhesion</rdfs:label>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Age">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>age</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000011</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality inhering in a material entity by virtue of how long the bearer has existed</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Amount">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>amount</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000179</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality of a whole that is the number of entities that are part of the whole</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;AmountOfSubstance">
		<rdfs:subClassOf rdf:resource="&iof-construct;Amount"/>
		<rdfs:label>amount of substance</rdfs:label>
		<skos:altLabel>molar amount</skos:altLabel>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000166</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality inhered in a portion of material that is a size that is proportional to the number of elementary entities present</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;AntifoamingAgent">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000040"/>
		<rdfs:label>antifoaming agent</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;BFO_0000040">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;AntifoamingAgentRole"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>Polydimethylsiloxane serving as an antifoam in a mammalian cell culture bioreactor to minimize surface foaming; Silicone-based antifoam used during protein purification to prevent foam buildup in chromatographic buffers</skos:example>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/CHEBI_77973</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>See expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material entity with an antifoaming agent role</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;AntifoamingAgentRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ProtectiveAgentRole"/>
		<rdfs:label>antifoaming agent role</rdfs:label>
		<skos:example>Polydimethylsiloxane serving as an antifoam in a mammalian cell culture bioreactor to minimize surface foaming; Silicone-based antifoam used during protein purification to prevent foam buildup in chromatographic buffers</skos:example>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/CHEBI_77973</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>This role is typically realized during mixing, aeration, fermentation, or other processing steps where gas–liquid interfaces promote foam generation. Substances bearing this role are often surfactants or hydrophobic agents that disrupt bubble stability and ensure process continuity</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role held by a material entity when it is used, or planned to be used, in a process to reduce or prevent the formation of foam in a liquid that participates in that process</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ApparentSolubility">
		<rdfs:subClassOf rdf:resource="&iof-construct;SolubilityLimit"/>
		<rdfs:label>apparent saturation concentration</rdfs:label>
		<iof-av:adaptedFrom>https://doi.usp.org/USPNF/USPNF_M2248_03_01.html and https://www.pmda.go.jp/files/000270228.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Apparent solubility is an operational, method-dependent quantity and does not necessarily equal the equilibrium solubility under the same conditions. It may be higher than equilibrium solubility when transient supersaturation occurs, or lower than equilibrium solubility when dissolution is incomplete because insufficient time is allowed to reach thermodynamic equilibrium. Apparent solubility therefore depends on protocol details such as mixing and agitation, order of addition, temperature history and hold time.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>solution saturation concentration of a solute that can remain dissolved under a specified set of conditions without establishing thermodynamic equilibrium</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Area">
		<rdfs:subClassOf rdf:resource="&iof-construct;TwoDimensionalPhysicalExtent"/>
		<rdfs:label>area</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001323</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>two-dimensional physical extent of a material entity over a particular surface</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Bacterium">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000030"/>
		<rdfs:label>bacterium</rdfs:label>
		<iof-av:adaptedFrom>https://pubmed.ncbi.nlm.nih.gov/19819658/ and https://www.britannica.com/science/bacteria</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>single-celled organism that does not contain membrane-bound organelles and whose ribosomes are of the bacterial type</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;BasalCultureMedium">
		<rdfs:subClassOf rdf:resource="&iof-construct;CultureMedium"/>
		<rdfs:label>basal culture medium</rdfs:label>
		<owl:disjointWith rdf:resource="&iof-construct;CompleteCultureMedium"/>
		<skos:example>MEM (Minimum Essential Medium); DMEM (Dulbecco’s Modified Eagle Medium)</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html</iof-av:adaptedFrom>
		<iof-av:counterExample>Serum-free chemically defined medium with recombinant growth factors.</iof-av:counterExample>
		<iof-av:explanatoryNote>Basal media are the foundational culture media formulations that provide essential salts, amino acids, vitamins, and energy sources for cell survival and minimal maintenance. They generally require supplementation with serum, recombinant proteins, or other additives to support robust proliferation. In biomanufacturing, basal media serve as the backbone of media development workflows and are often combined with feeds or supplements, such as chemically defined nutrient solutions, in fed-batch processes.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>culture medium containing the basic minimum components necessary to support cell survival and very limited proliferation, typically including salts, amino acids, vitamins, and a carbon source, but lacking serum, proteins, or growth factors</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;BasicChargeVariantImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ProteinChargeVariantImpurityRole"/>
		<rdfs:label>basic charge variant impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC5392216/ and https://www.chromatographyonline.com/view/charge-variant-profiling-biopharmaceuticals and https://www.agilent.com/cs/library/applications/compendium-chargevariant-advancebio-5994-0034EN-us-agilent.pdf?srsltid=AfmBOorRMu0dQH4wotghCeKwXSMCdNuuNsAEkA06EkLXupvMO6SBKJaN</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>protein charge variant impurity role that is held by a protein, protein fragment, or molecular population of such entities that differs from a reference form of the same protein by having a higher net electric charge or isoelectric point</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Bioburden">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>bioburden</rdfs:label>
		<iof-av:adaptedFrom>https://www.sigmaaldrich.com/US/en/applications/microbiological-testing/bioburden-testing?srsltid=AfmBOooIv6z3mhn24wCBPWkNZ1d0tqxlOup_y_ and https://www.biophorum.com/download/cvp-case-study-interactive-version/</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) In sterilization and aseptic processing contexts, bioburden is commonly assessed prior to a sterilization or other microbicidal process and is used to characterize the microbial challenge presented to that process
2) This quality refers only to viable microorganisms such as bacteria, yeast, or mold present within or on a material entity. It excludes viruses, endotoxins, and non-viable biological matter, which are represented by separate quality attributes.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>quality of a material entity that is the extent to which viable microorganisms are present in or on the surface of the material entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;BiologicalActivity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:label>biological activity</rdfs:label>
		<iof-av:adaptedFrom>https://database.ich.org/sites/default/files/Q6B%20Guideline.pdf</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>capability of a drug substance or drug product to achieve a defined biological effect</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;BiologicalSequenceVariantClassifier">
		<rdfs:subClassOf rdf:resource="&iof-construct;DrugProductRelatedImpurityRole"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;roleOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;MolecularEntityPopulation">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000172"/>
										<owl:allValuesFrom>
											<owl:Class>
												<owl:unionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="&iof-construct;DeoxyribonucleicAcid">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-construct;Peptide">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-construct;Protein">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-construct;RibonucleicAcid">
													</rdf:Description>
												</owl:unionOf>
											</owl:Class>
										</owl:allValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;DeoxyribonucleicAcid">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-construct;Peptide">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-construct;Protein">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-construct;RibonucleicAcid">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>biological sequence variant impurity role</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/SO_0001060 and https://www.cancer.gov/publications/dictionaries/genetics-dictionary/def/variant and https://www.rapidnovor.com/sequence-variant-analysis-monoclonal-antibodies/#:~:text=Variant%20Analysis%20Service-,Introduction,variants%20and%20their%20associated%20risks.</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>product related impurity role that is held by a DNA molecule, RNA molecule, peptide, protein, or molecular population of such molecules whose primary structure has a biological sequence that differs at one or more positions from a specified reference sequence due to substitution, insertion, deletion, or truncation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;BioproductionSupportingFunction">
		<rdfs:subClassOf rdf:resource="&iof-construct;CultureMediumSpecializedFunction"/>
		<rdfs:label>bioproduction supporting function</rdfs:label>
		<skos:example>Hybridoma Myeloma Cell Culture Media</skos:example>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/topics/engineering/production-medium#:~:text=The%20production%20media%20have%20the,cost%20and%20to%20enhance%20yields and https://www.fishersci.com/us/en/browse/90217078/hybridoma-myeloma-cell-culture-media</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>culture medium specialized function that enables the generation of a desired biological product by sustaining cellular activity under production conditions</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;BufferSolution">
		<rdfs:subClassOf rdf:resource="&iof-construct;Solution"/>
		<rdfs:label>buffer solution</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;Solution">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasFunction"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;BufferingCapacity"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/NCIT_C70815 and https://www.fda.gov/files/drugs/published/pH-Adjuster-Webinar-Slides.pdf</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>solution consisting of a mixture of a weak acid and its conjugate base or a weak base and its conjugate acid which is resistant to pH changes upon addition of an acidic or basic component</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;BufferingAgentRole">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000023"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;roleOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&bfo;BFO_0000040">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000127"/>
										<owl:someValuesFrom rdf:resource="&iof-construct;BufferingCapacity"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&bfo;BFO_0000040">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000194"/>
										<owl:someValuesFrom rdf:resource="&iof-construct;BufferingCapacity"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>buffering agent role</rdfs:label>
		<skos:example>mixture of sodium phosphate monobasic and dibasic salts playing a buffer role in cell-culture medium to maintain pH near neutrality; combination of Tris base and Tris-HCl playing a buffer role in electrophoretic buffer solution to maintain pH around 8; pair of HEPES and its conjugate acid playing a buffer role in tissue-culture medium to maintain physiological pH; combination of carbon dioxide and sodium bicarbonate playing a buffer role in mammalian cell-culture medium to stabilize pH under CO₂ atmosphere; mixture of histidine and histidine hydrochloride playing a buffer role in monoclonal-antibody formulation to stabilize pH during storage;</skos:example>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/CHEBI_35225</iof-av:adaptedFrom>
		<iof-av:counterExample>sodium chloride solution adjusting ionic strength but not buffering pH;
phenol red acting as a pH indicator rather than stabilizer;pure acetic acid lacking conjugate base and unable to resist pH change; hydrochloric acid solution changing rather than maintaining pH</iof-av:counterExample>
		<iof-av:explanatoryNote>A buffer role inheres in a material entity that serves as the material basis of buffering capacity in a system. The role connects the substance or combination of substances to the capacity by which the system resists a change in hydrogen-ion concentration when small amounts of acid or base are added. The role may also be assigned to powders or concentrated materials before they are dissolved, reflecting the planned use of those substances to establish buffering capacity once introduced into a solution.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role of a material entity when it is added or planned to be added to a solution, typically aqueous, to resist changes in pH upon the introduction of small amounts of acid or base</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;BufferingCapacity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capacity"/>
		<rdfs:label>buffering capacity</rdfs:label>
		<iof-av:adaptedFrom>https://www.med.unc.edu/pharm/sondeklab/wp-content/uploads/sites/868/2018/10/buffers_calbiochem.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Buffering capacity is influenced by the concentration of the buffering species, the proximity of their pKₐ values, and the relationship between solution pH and pKₐ. In mixtures of weak acids and bases, buffering capacities are additive, and higher overall concentrations confer greater resistance to pH changes. Buffer effectiveness is maximal when the pH of the solution equals the pKₐ of the buffering species, where the acid and its conjugate base are present in equal proportion. Effective buffering is generally maintained within ±1 pH unit of the pKₐ; beyond this range, the capacity to resist pH change diminishes significantly.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>capacity of a solution to resist changes in hydrogen ion concentration (pH) when an acid or base is added</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;BulkDensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;MassDensity"/>
		<rdfs:label>bulk density</rdfs:label>
		<skos:altLabel>apparent density</skos:altLabel>
		<iof-av:adaptedFrom>https://en.wikipedia.org/wiki/Bulk_density</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>mass density that is the mass per total volume occupied by a collection of particles, including any void volume between the particles and any pore volume within the particles.</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CakingPropensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Propensity"/>
		<rdfs:label>caking propensity</rdfs:label>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/science/article/pii/S0032591017301511 and https://www.sciencedirect.com/science/article/abs/pii/S1004954118308747</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Caking propensity is typically realized when a bulk powder experiences particular environmental and mechanical conditions over time, such as during storage, transport, or handling. Conditions such as humidity/moisture exposure, temperature, and applied or self-weight consolidation can strongly influence whether and how rapidly caking develops.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>disposition of a particulate material entity to transform from a free-flowing state into lumps or a coherent solid mass</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Capacity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:label>capacity</rdfs:label>
		<rdfs:comment>placeholder for IOF mid-level team to define</rdfs:comment>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Cell">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000030"/>
		<rdfs:label xml:lang="en-US">cell</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/Material/"/>
		<skos:example>CHO-K1 cell; HeLa cell; T cell isolated from peripheral blood;Freshly isolated hepatocyte; Hematopoietic stem cell isolated from bone marrow</skos:example>
		<iof-av:directSource>http://purl.obolibrary.org/obo/CL_0000000</iof-av:directSource>
		<iof-av:explanatoryNote>1) From CL term: The definition of cell is intended to represent all cells, and thus a cell is defined as a material entity and not an anatomical structure, which implies that it is part of an organism (or the entirety of one).
2) In the cell line ontology the term is directly under material entity. However, given the definitional criteria of a plasma membrane and maximal connectedness of cell compartments, the cell has been put under object within the ontology.</iof-av:explanatoryNote>
		<iof-av:firstOrderLogicAxiom>Cell(x) → Object(x)</iof-av:firstOrderLogicAxiom>
		<iof-av:isPrimitive rdf:datatype="&xsd;boolean">true</iof-av:isPrimitive>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">object of anatomical origin (part of or deriving from an organism) that has as its parts a maximally connected cell compartment surrounded by a plasma membrane</iof-av:naturalLanguageDefinition>
		<iof-av:primitiveRationale>There are currently insufficient constructs to represent cellular components or cell derivation</iof-av:primitiveRationale>
		<iof-av:semiFormalNaturalLanguageAxiom>if x is a &apos;cell&apos; then x is an &apos;object&apos;</iof-av:semiFormalNaturalLanguageAxiom>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellBank">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000027"/>
		<rdfs:label>cell bank</rdfs:label>
		<iof-av:adaptedFrom>https://www.ema.europa.eu/en/documents/scientific-guideline/ich-q-5-d-derivation-and-characterisation-cell-substrates-used-production-biotechnologicalbiological-products-step-5_en.pdf and https://extranet.who.int/prequal/glossary-acronyms/s#:~:text=A%20master%20seed%20lot%20</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>object aggregate that has as parts cryopreserved cell aliquots derived from a single source culture, prepared and stored under defined conditions, and maintained as a referenceable lot to provide consistent starting material for research, development, manufacturing, or the generation of new cell banks</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellCount">
		<rdfs:subClassOf rdf:resource="&iof-construct;Count"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isCountOf"/>
				<owl:allValuesFrom rdf:resource="&iof-construct;Cell"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;BFO_0000040">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;CellPopulation"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>cell count</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000184</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>amount of cells within a whole</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellCulture">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000040"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;CultureMedium"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;CulturedCellPopulation"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">cell culture</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/Material/"/>
		<skos:altLabel xml:lang="en-US">culture broth</skos:altLabel>
		<skos:example>CHO Suspension Culture in CD-CHO Medium; HEK293 Monolayer in DMEM + 10% FBS;</skos:example>
		<iof-av:adaptedFrom>OBI:0001876</iof-av:adaptedFrom>
		<iof-av:counterExample>In situ cells are observed and studied within their natural tissue context without being cultured or removed, e.g., neurons, alveolar epithelial cells; Post-centrifugation cell pellet; Uninoculated Culture Medium; Glass Slide with Fixed Cells (No Live Media); Tissue Biopsy in PBS Buffer</iof-av:counterExample>
		<iof-av:explanatoryNote>A cell culture includes the cells in culture, as well as the media and all additives in which the cells are being grown or in which they are stored.</iof-av:explanatoryNote>
		<iof-av:firstOrderLogicAxiom>CellCulture(x) → MaterialEntity(x) ∧ ∃y (CultureMedium(y) ∧ hasContinuantPartAtAllTimes(x, y)) ∧ ∃z (CulturedCellPopulation(z) ∧ hasContinuantPartAtAllTimes(x, z))</iof-av:firstOrderLogicAxiom>
		<iof-av:isPrimitive rdf:datatype="&xsd;boolean">true</iof-av:isPrimitive>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">material entity that has cultured cells and the media in which they are being propagated or stored as parts</iof-av:naturalLanguageDefinition>
		<iof-av:primitiveRationale>There is currently a lack of a constituency relation (is made of) in this release. It is expected that that relation will be available in the next release of IOF Core</iof-av:primitiveRationale>
		<iof-av:semiFormalNaturalLanguageAxiom>if x is a &apos;cell culture&apos; then x is a &apos;material entity&apos; and x &apos;has continuant part at all times&apos; some &apos;culture medium&apos; and x &apos;has continuant part at all times&apos;  some &apos;cultured cell population&apos;</iof-av:semiFormalNaturalLanguageAxiom>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellCultureDerivedImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ManufacturingProcessRelatedImpurityRole"/>
		<rdfs:label>cell culture-derived impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://database.ich.org/sites/default/files/Q6B%20Guideline.pdf and https://www.ema.europa.eu/en/documents/scientific-guideline/draft-ich-guideline-q11-development-and-manufacture-drug-substances-chemical-entities-and-biotechnological-biological-entities_en.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Cell culture derived impurity role applies to substances that originate from what the cell culture contains or uses (e.g., media components; media supplements; inducers; antibiotics; antifoam agents), and that may remain in downstream or later manufacturing intermediates. This impurity category does not include materials originating from the cell host or production cell line itself, and does not mean the substance is a cell, cell part, or host-cell molecule, but only that its source is the cell culture environment or the materials present within it.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>manufacturing process related impurity role held by a material entity that originates from a material that is part of the cell culture</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellDensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;NumberDensity"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;CellCount"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;BFO_0000040">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;Cell"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>cell density</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000181</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Cell density is commonly reported as cells per unit volume (e.g. cells/mL) or cells per unit area (e.g. cells/cm²), depending on how the cell population is distributed in the material entity being studied. It characterizes how many cells occupy a specified portion of material space and is an important parameter for interpreting cellular behaviour such as growth, viability, differentiation, gene expression, and responses to environmental conditions. In practice, cell density may be obtained by direct or automated counting methods or indirectly from surrogate readouts such as optical density at 600 nm (OD600).</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>number density of a population of cells</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellLine">
		<rdfs:subClassOf rdf:resource="&iof-construct;CulturedCellPopulation"/>
		<rdfs:label xml:lang="en-US">cell line</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/Material/"/>
		<skos:example>HeLa cells; HEK293 cells; Vero cells</skos:example>
		<iof-av:adaptedFrom>CLO:0000031 and https://www.fda.gov/media/78428/download</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) A cell line is typically stored in a cell bank and used to ensure consistent and reproducible performance across experimental or manufacturing contexts.
2) The term excludes freshly isolated or short-lived primary cultures.</iof-av:explanatoryNote>
		<iof-av:firstOrderLogicAxiom>CellLine(x) → CulturedCellPopulation(x)</iof-av:firstOrderLogicAxiom>
		<iof-av:isPrimitive rdf:datatype="&xsd;boolean">true</iof-av:isPrimitive>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">cultured cell population that is derived from a primary cell source and that has been propagated through repeated subculture under defined conditions, resulting in a genetically stable and homogeneous population of cells with a shared propagation history</iof-av:naturalLanguageDefinition>
		<iof-av:primitiveRationale>There are insufficient constructs to define necessary and sufficient conditions.</iof-av:primitiveRationale>
		<iof-av:semiFormalNaturalLanguageAxiom>if x is a &apos;cell line&apos; then x is a &apos;cultured cell population&apos;</iof-av:semiFormalNaturalLanguageAxiom>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellLineLineage">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000182"/>
		<rdfs:label xml:lang="en-US">cell line lineage</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/Material/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;BFO_0000182">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000184"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;CellLine"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:altLabel>cell line history</skos:altLabel>
		<skos:example>HEK293 history: derived from human embryonic kidney cells transfected with adenovirus 5 DNA; selected for stable growth in culture;</skos:example>
		<iof-av:adaptedFrom>CLO:0000171</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>The cell line lineage may include the original cell type from a tissue and organism that derives the cell line cell. It may also include the cell line passage and cell culturing information.</iof-av:explanatoryNote>
		<iof-av:firstOrderLogicDefinition>CellLineLineage(x) ↔ History(x) ∧ ∃y(CellLine(y) ∧ historyOf(x, y))</iof-av:firstOrderLogicDefinition>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">history of the development of a cell line</iof-av:naturalLanguageDefinition>
		<iof-av:semiFormalNaturalLanguageDefinition>every instance of &apos;cell line lineage&apos; is defined as exactly an instance of &apos;history&apos; that &apos;is history of&apos; some &apos;cell line&apos;</iof-av:semiFormalNaturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellPopulation">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000027"/>
		<rdfs:label xml:lang="en-US">cell population</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/Material/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;BFO_0000027">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000115"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;Cell"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000115"/>
						<owl:allValuesFrom rdf:resource="&iof-construct;Cell"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>CHO Cell Line;  FACS-isolated CD4+ T cell population; Red blood cell pellet; freshly isolated hepatocytes from mouse liver</skos:example>
		<iof-av:firstOrderLogicDefinition>CellPopulation(x) ↔ ObjectAggregate(x) ∧ ∃y(Cell(y) ∧ hasMemberPartAtSomeTime(x, y)) ∧ ∀z(hasMemberPartAtSomeTime(x, z) → Cell(z))</iof-av:firstOrderLogicDefinition>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">object aggregate which only has cells as its member parts</iof-av:naturalLanguageDefinition>
		<iof-av:semiFormalNaturalLanguageDefinition>every instance of &apos;cell population&apos; is defined as exactly an instance of &apos;object aggregate&apos; that &apos;has member part at some time&apos; some &apos;cell&apos; and &apos;has member part at some time&apos; only &apos;cell&apos;</iof-av:semiFormalNaturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellProliferationSupportingFunction">
		<rdfs:subClassOf rdf:resource="&iof-construct;CultureMediumSpecializedFunction"/>
		<rdfs:label>cell proliferation supporting function</rdfs:label>
		<skos:example>Human-Mesenchymal-XF-Expansion-Medium</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html</iof-av:adaptedFrom>
		<iof-av:counterExample>chemically defined production medium optimized for antibody yield may maintain cell viability but does not primarily function as a proliferation medium</iof-av:counterExample>
		<iof-av:naturalLanguageDefinition>culture medium specialized function that enables cells in culture to divide and remain viable by supplying appropriate nutrients and physicochemical conditions for proliferation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellSubstrateDerivedImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ManufacturingProcessRelatedImpurityRole"/>
		<rdfs:label>cell substrate-derived impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://database.ich.org/sites/default/files/Q6B%20Guideline.pdf and https://www.ema.europa.eu/en/documents/scientific-guideline/draft-ich-guideline-q11-development-and-manufacture-drug-substances-chemical-entities-and-biotechnological-biological-entities_en.pdf</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>manufacturing process related impurity role held by a material entity that originates from the host organism or cell line</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CellViabilityRatio">
		<rdfs:subClassOf rdf:resource="&iof-construct;RelativeAbundance"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;TotalCellCount"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;ViableCellCount"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;BFO_0000040">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;CellPopulation"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>cell viability ratio</rdfs:label>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/topics/biochemistry-genetics-and-molecular-biology/cell-viability</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) Cell viability is often reported as the ratio of viable cells to the total cell count (e.g. “95 % viable”) and serves as a critical indicator of cellular health in research, biomanufacturing, and cytotoxicity assessments
2) Although the ratio is defined over a specified cell population, this quality may inhere in a broader material entity that contains that population (e.g., a cell culture, suspension, or culture aliquot), with the specified population providing the comparison basis for the ratio</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>relative abundance that is the number of viable cells in a cell population relative to the total number of cells in that population</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ChemicallyDefinedCultureMedium">
		<rdfs:subClassOf rdf:resource="&iof-construct;SerumFreeCultureMedium"/>
		<rdfs:label>chemically defined culture medium</rdfs:label>
		<skos:example>ExpiCHO Expression Medium is chemically defined, serum-free, used in high-density fed-batch processes</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html</iof-av:adaptedFrom>
		<iof-av:counterExample>Media with plasma-derived transferrin (without purity specification) is not strictly chemically defined unless concentration is characterized</iof-av:counterExample>
		<iof-av:explanatoryNote>Chemically defined media (CDM) are culture media composed only of pure, quantified ingredients of known chemical identity and concentration. They exclude animal-derived serum and complex additives such as yeastolate, peptones, or hydrolysates. Recombinant proteins (e.g., insulin, transferrin) may be included provided their identity and concentration are specified. CDMs improve control, reproducibility, and lot-to-lot consistency, simplify downstream purification, and enhance comparability between experiments or production runs. In biopharmaceutical manufacturing, they are favored for reducing regulatory concerns associated with serum and undefined additives. CDMs can function as standalone formulations or as the foundation for serum-free processes.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>culture medium in which every component and its concentration is precisely known and reproducible, containing only chemically characterized compounds such as amino acids, vitamins, salts, trace elements, and energy sources, and excluding any undefined components like serum or hydrolysates</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ClonedCellLine">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellLine"/>
		<rdfs:label xml:lang="en-US">cloned cell line</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/Material/"/>
		<skos:example>CHO DG44 clone 5F7 – a clonal derivative of CHO DG44 cells selected for high monoclonal antibody productivity; Jurkat E6-1 – a cloned subline of Jurkat cells used in T cell signaling research</skos:example>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/topics/biochemistry-genetics-and-molecular-biology/cell-clone#:~:text=Clone%20of%20cells%20is%20a,ignored%20that%20may%20be%20different and CLO:0000177</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) A cloned cell line consists of cells that are genetically identical with respect to antigen recognition, gene sequence, and key phenotypic traits. It represents a uniform lineage of cells with shared ancestry and consistent functional characteristics.
2) Regulatory standards in biologics require proof of monoclonality for a production cell line. This implies that it originates from a single progenitor cell, regardless of whether one calls it a clone or a line. In practice, a clone is the starting point for development: once selected and scaled, it becomes a permanent cell line with specific attributes used for product manufacture.
3) FDA considers monoclonality essential: production cell lines must originate from a single progenitor cell to ensure consistent and safe product characteristics. Each clone selected after transfection or genetic manipulation is treated as a distinct cell line, subject to full characterization (identity, purity, adventitious agent testing, etc.)</iof-av:explanatoryNote>
		<iof-av:firstOrderLogicAxiom>ClonedCellLine(x) → CellLine(x)</iof-av:firstOrderLogicAxiom>
		<iof-av:isPrimitive rdf:datatype="&xsd;boolean">true</iof-av:isPrimitive>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">cell line that originates from a single ancestral cell</iof-av:naturalLanguageDefinition>
		<iof-av:primitiveRationale>There are insufficient constructs to define necessary and sufficient conditions.</iof-av:primitiveRationale>
		<iof-av:semiFormalNaturalLanguageAxiom>if x is a &apos;cloned cell line&apos; then x is a &apos;cell line&apos;</iof-av:semiFormalNaturalLanguageAxiom>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Color">
		<rdfs:subClassOf rdf:resource="&iof-construct;OpticalQuality"/>
		<rdfs:label>color</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000014</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>optical quality that is a composite chromatic quality composed of hue, saturation, and intensity parts</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CompendialGradeClassifier">
		<rdfs:subClassOf rdf:resource="&iof-construct;MaterialGradeClassifier"/>
		<rdfs:label>compendial grade classifier</rdfs:label>
		<iof-av:adaptedFrom>https://www.uspnf.com/sites/default/files/usp_pdf/EN/USPNF/generalNoticesandRequirementsFinal.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>A compendial grade classifier is used when the meaning of the “grade” is anchored in a pharmacopeial monograph rather than something like a supplier datasheet or an internal specification. In this setting, “compendial” denotes that the material is associated with an official pharmacopeial standard and is expected to meet the monograph’s specified tests and acceptance criteria to demonstrate compliance. Examples of pharmacopeias include USP and Ph. Eur.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material grade classifier that classifies a material entity as satisfying (conforming to the requirements) stated in an applicable pharmacopeial monograph</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CompleteCultureMedium">
		<rdfs:subClassOf rdf:resource="&iof-construct;CultureMedium"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;BasalCultureMedium"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;MediaSupplement"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>complete culture medium</rdfs:label>
		<skos:example>DMEM + 10 % FBS</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Complete media are culture media that provide all nutrients and signaling components required for the routine maintenance and growth of a given cell line. They are commonly prepared by supplementing a basal medium with 5–20% animal serum or, in serum-free and chemically defined systems, by adding recombinant proteins, hormones, and lipids. Formulations can be tailored to specific cell types or processes, such as hybridoma expansion or stem cell maintenance. In both research and manufacturing, the distinction is important: basal media supply the nutritional foundation, while complete media are designed to fully support cell culture without additional basal supplementation.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>culture medium that consists of a basal medium supplemented with additional components, such as serum, proteins, growth factors, hormones, or other nutrients, sufficient to support robust cell growth, proliferation, and metabolic activity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Concentration">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000145"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isConcentrationOf"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;BFO_0000040">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000175"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;MixedMaterial"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Volume"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Amount">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-construct;Mass">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;MixedMaterial"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>concentration</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000033</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality of a mixture that is the amount or mass of a component of the mixture relative to the total volume of the mixture</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Conductivity">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>conductivity</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001585</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality inhering in a bearer by virtue of the bearer&apos;s disposition to transmit of an entity through a medium</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ContaminantRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ImpurityRole"/>
		<rdfs:label>contaminant role</rdfs:label>
		<iof-av:adaptedFrom>https://database.ich.org/sites/default/files/Q6B%20Guideline.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) Manufacturing contaminants are adventitiously introduced materials that were not intended to be present in the manufacturing process, and in biopharmaceutical manufacturing they include chemical or biochemical materials (e.g., microbial proteases) and microbial species.
2) This role is intended to distinguish contaminants from process-associated impurities that arise from planned or inherent aspects of executing the intended process.
3)  Regulators expect manufacturing programs to prioritize avoidance, or controlled removal to meet drug substance or drug product specifications, using appropriate in-process acceptance criteria or measurable action thresholds for the affected material stream, while recognizing that adventitious viral or mycoplasma contamination is not managed by allowable-range action limits, and instead requires control strategies guided by dedicated ICH viral-safety and cell-substrate characterization guidance, as part of validated contamination-prevention or mitigation safeguards</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role held by a material entity when it is adventitiously introduced during a manufacturing process</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Count">
		<rdfs:subClassOf rdf:resource="&iof-construct;Amount"/>
		<rdfs:label>count</rdfs:label>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CryoprotectiveAgentRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ProtectiveAgentRole"/>
		<rdfs:label>cryoprotective agent role</rdfs:label>
		<skos:example>Dimethyl sulfoxide (DMSO) added to freezing medium for cell preservation; Glycerol solution protecting microbial cultures during storage at low temperatures</skos:example>
		<iof-av:adaptedFrom>http://id.nlm.nih.gov/mesh/D003451 and http://purl.obolibrary.org/obo/NCIT_C53306</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) This role is realized through collective physicochemical effects that stabilize water structure, maintain osmotic and hydration balance, and preserve molecular or cellular integrity during cooling and thawing, largely by preventing the formation of large ice crystals and reducing other forms of cold-induced damage. 
2) The term “environment” covers any relevant physical or chemical setting such as a solution, suspension, or culture medium. 
3) The role applies to both single substances and formulated mixtures such as cryoprotective solutions.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role of a material entity that is added or planned to be added to an environment to protect other materials from the harmful effects of freezing temperatures</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CultureMedium">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000040"/>
		<rdfs:label xml:lang="en-US">culture medium</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/Material/"/>
		<skos:example>DMEM;LB agar;HEK293</skos:example>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC7417654/pdf/fbioe-08-00911.pdf and https://www.sigmaaldrich.com/US/en/technical-documents/technical-article/microbiological-testing/microbial-culture-media-preparation/types-of-media-in-microbiology?srsltid=AfmBOopAW7ApixpJ8J-96cmEfgfSiT8dX8wszs06BrclD3tYImJkEcYV</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) “Specific metabolic activity” refers to those metabolic processes that are intentionally supported or induced by the medium in a manufacturing or experimental context. This includes the synthesis and secretion of desired biomolecules (e.g., recombinant proteins, metabolites) or the replication and viability of cells when the cells themselves are the intended product. It excludes background or non-targeted metabolic processes such as basal energy maintenance or stress responses not relevant to the production goal.
2) In the context of biomanufacturing, “specific metabolic activity” typically refers to the set of biochemical processes carried out by microorganisms or cells that result in the synthesis, modification, and/or secretion of desired biological products. This includes processes such as the expression of recombinant proteins (e.g., monoclonal antibodies, enzymes), production of metabolites (e.g., amino acids, organic acids, antibiotics), or replication of the cells themselves when they are the product. These activities require the uptake and transformation of nutrients and are influenced by the composition and physicochemical properties of the culture medium.
4)Some types of culture media also include selection agents or antibiotics to suppress the growth of unwanted or contaminating organisms.</iof-av:explanatoryNote>
		<iof-av:firstOrderLogicAxiom>CultureMedium(x) → MaterialEntity(x)</iof-av:firstOrderLogicAxiom>
		<iof-av:isPrimitive rdf:datatype="&xsd;boolean">true</iof-av:isPrimitive>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">material entity that is a solid or liquid aqueous formulation that provides essential nutrients (such as carbon, nitrogen, vitamins, and minerals) and controlled physicochemical conditions (such as pH and osmotic balance) required for the growth, maintenance, or specific metabolic activity of microorganisms or cells</iof-av:naturalLanguageDefinition>
		<iof-av:primitiveRationale>There are insufficient constructs to accurately represent the structure and the capabilities that the media has in this release. They will be treated in great detail for a subsequent release orienting around upstream.</iof-av:primitiveRationale>
		<iof-av:semiFormalNaturalLanguageAxiom>if x is a &apos;culture medium&apos; then x is a &apos;material entity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CultureMediumSpecializedFunction">
		<rdfs:subClassOf rdf:resource="&iof-construct;DesignedFunction"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000197"/>
				<owl:allValuesFrom rdf:resource="&iof-construct;CultureMedium"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000197"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;CultureMedium"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;satisfiesRequirement"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;RequirementSpecification"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>culture medium specialized function</rdfs:label>
		<skos:example>Human-Mesenchymal-XF-Expansion-Medium; Hybridoma Myeloma Cell Culture Media</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>designed function that inheres in a culture medium and is specified to satisfy the nutritional or signaling requirements of a particular cell type, tissue,microorganism or application, often achieved through selective supplements or tailored nutrient formulations</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CultureMediumSupplementRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;MaterialComponentRole"/>
		<rdfs:label>culture medium supplement role</rdfs:label>
		<skos:example>Albumin stock solution bearing a media supplement role when added to serum-free medium to stabilize cells; ITS+3 Liquid Media Supplement (100×), a defined mixture of insulin, human transferrin, sodium selenite, linoleic acid, oleic acid ) added to serum-free medium to support viability and specialized functions; G418 (geneticin) added to impose selective pressure on a stable CHO line; 10% DMSO added to a cryopreservation medium for cell banking</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html and https://www.thermofisher.com/rs/en/home/life-science/cell-culture/mammalian-cell-culture/media-supplements.html</iof-av:adaptedFrom>
		<iof-av:counterExample>Albumin used as a blocking agent in immunoassays; Dulbecco’s Modified Eagle Medium (DMEM), a complete culture medium formulation providing baseline nutrients, is a culture medium and not a media supplement; Sterile water used as a solvent to reconstitute culture medium powder</iof-av:counterExample>
		<iof-av:explanatoryNote>1) This role is context-dependent: a substance only counts as a media supplement when it is actually used or planned to be used to supplement culture media. The same chemical could serve other purposes in other settings (for example, insulin as a therapeutic drug). However, many commercial products (such as ITS mixes, lipid concentrates, or amino acid solutions) are specifically formulated and sold for use as media supplements. In practice, these preparations almost always bear a media supplement role.
2) Role may be held by single components and their solutions (such as insulin, transferrin, or glutamine) or prepared mixtures supplied as concentrated supplement solutions (e.g., ITS+3, MEM non-essential amino acids).
3) Media supplements are  distinct from the medium itself (basal/complete formulations are not “supplements”). A component that is part of a basal recipe does not bear this role but a component added on top of a basal medium does.
4) Media supplements are separate from nutrient feeds and the additions during cultivation specifically to replenish depleted nutrients should be modeled under nutrient feed role</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material component role held by a material entity when it is added or planned to be added to culture media to enrich or modify the medium composition or functional properties</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CulturePreservationFunction">
		<rdfs:subClassOf rdf:resource="&iof-construct;CultureMediumSpecializedFunction"/>
		<rdfs:label>culture preservation function</rdfs:label>
		<skos:example>cryopreservation medium has a function to maintain cell viability under cryogenic conditions</skos:example>
		<iof-av:adaptedFrom>https://www.thermofisher.com/search/browse/category/us/en/90217066</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>culture medium specialized function that maintains cell viability and structural integrity during storage and transport by providing physicochemical conditions and protective components that minimize cellular stress under refrigerated or cryogenic conditions</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CulturedCell">
		<rdfs:subClassOf rdf:resource="&iof-construct;Cell"/>
		<rdfs:label xml:lang="en-US">cultured cell</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/Material/"/>
		<skos:example>CHO-K1 cell;HeLa cell</skos:example>
		<iof-av:adaptedFrom>https://www.thermofisher.com/rs/en/home/references/gibco-cell-culture-basics/introduction-to-cell-culture.html and http://purl.obolibrary.org/obo/CL_0000010</iof-av:adaptedFrom>
		<iof-av:counterExample>Freshly isolated hepatocyte; Hematopoietic stem cell isolated from bone marrow</iof-av:counterExample>
		<iof-av:explanatoryNote xml:lang="en-US">1)Cultured cells are typically immortalized, meaning they retain the capacity to proliferate indefinitely under suitable growth conditions; in contrast, primary cells such as those directly isolated from a patient without genetic or oncogenic modification undergo a limited number of mitotic divisions before entering senescence or undergoing cell death
		2) A blurred line would be the case of the CAR-T cell therapy situation where the cells are often taken directly from the patient, modified (not immortalized), expanded in a bioreactor and then infused back into the patient. In this case, CAR-T cells are still considered cultured cells because they are subjected to ex vivo cultivation under controlled, artificial conditions. After being isolated from a patient (typically as primary T cells), they are genetically modified and then expanded in bioreactors or culture vessels using defined media, gas control, and temperature regulation. Although they are not immortalized, they undergo proliferation outside their native environment. This fulfills the defining criteria of a cultured cell as one that grows in an artificial, controlled setting. Their classification as cultured reflects the environmental and procedural context, not the permanence or origin of the cell line.</iof-av:explanatoryNote>
		<iof-av:firstOrderLogicAxiom>CulturedCell(x) → Cell(x)</iof-av:firstOrderLogicAxiom>
		<iof-av:isPrimitive rdf:datatype="&xsd;boolean">true</iof-av:isPrimitive>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">cell that is grown, maintained, or adapted to grow in a controlled artificial environment that supports its survival and proliferation</iof-av:naturalLanguageDefinition>
		<iof-av:primitiveRationale>There are currently inssuficient constructs to adequately represent adapt to grow in artificial environment.</iof-av:primitiveRationale>
		<iof-av:semiFormalNaturalLanguageAxiom>if x is a &apos;cultured cell&apos; then x is a &apos;cell&apos;</iof-av:semiFormalNaturalLanguageAxiom>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;CulturedCellPopulation">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellPopulation"/>
		<rdfs:label xml:lang="en-US">cultured cell population</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/Material/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;CellPopulation">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000115"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;CulturedCell"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000115"/>
						<owl:allValuesFrom rdf:resource="&iof-construct;CulturedCell"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>population of CHO-K1 cell; population of HeLa cell;</skos:example>
		<iof-av:adaptedFrom>OBI:0100060</iof-av:adaptedFrom>
		<iof-av:firstOrderLogicDefinition>CulturedCellPopulation(x) ↔ CellPopulation(x) ∧ ∃y(CulturedCell(y) ∧ hasMemberPartAtSomeTime(x, y)) ∧ ∀z(hasMemberPartAtSomeTime(x, z) → CulturedCell(z))</iof-av:firstOrderLogicDefinition>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">cell population which only has cultured cells as its member parts</iof-av:naturalLanguageDefinition>
		<iof-av:semiFormalNaturalLanguageDefinition>every instance of &apos;cultured cell population&apos; is defined as exactly an instance of &apos;cell population&apos; that &apos;has member part at some time&apos; some &apos;cultured cell&apos; and &apos;has member part at some time&apos; only &apos;cultured cell&apos;</iof-av:semiFormalNaturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Dead">
		<rdfs:subClassOf rdf:resource="&iof-construct;Viability"/>
		<rdfs:label>dead</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001422</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality inhering in a bearer by virtue of the cessation of the bearer&apos;s life.</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;DeadCellCount">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellCount"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isCountOf"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Cell">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;hasQuality"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;Dead"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>dead cell count</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000187</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>cell count of the partition of dead cells</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;DeadCellDensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellDensity"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;DeadCellCount"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>dead cell density</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000361</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>cell density of the partition of dead cells</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;DegradationProductImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;DrugProductRelatedImpurityRole"/>
		<rdfs:label>degradation product impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://database.ich.org/sites/default/files/Q3B%28R2%29%20Guideline.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Chemical change may be caused by, for example, light, temperature, pH, or water, or by reaction with an excipient and/or the immediate container closure system.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>product related impurity role that is held by a molecular entity or molecular entity population that differs from the reference drug substance as a result of a chemical change occurring during manufacture and/or storage of the drug product</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Density">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000145"/>
		<rdfs:label>density</rdfs:label>
	</owl:Class>
	
	<owl:ObjectProperty rdf:about="&iof-construct;DependsOnBearerPart">
		<rdfs:subPropertyOf rdf:resource="&owl;topObjectProperty"/>
		<rdfs:label>depends on bearer part</rdfs:label>
		<rdfs:domain rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:range rdf:resource="&bfo;BFO_0000040"/>
		<iof-av:naturalLanguageDefinition>relation between a quality q and a material entity m that holds when q inheres in some material entity x, m is part of x, and q specifically depends on m</iof-av:naturalLanguageDefinition>
	</owl:ObjectProperty>
	
	<owl:Class rdf:about="&iof-construct;Diameter">
		<rdfs:subClassOf rdf:resource="&iof-construct;Length"/>
		<rdfs:label>diameter</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001334</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>length of a material entity that is the maximal straight-line spatial extent of that entity through its center between two boundary points lying on opposite sides of a circular cross-section</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;DissolutionRole">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000023"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000054"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;PlannedProcess">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;hasSpecifiedOutput"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;Solution"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>dissolution role</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/role#AFRL_0000274</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>role held by a material entity that is realized in a dissolution process in which it participates in forming a solution</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;DissolvedOxygenSaturationRatio">
		<rdfs:subClassOf rdf:resource="&iof-construct;SolutionSaturationRatio"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Concentration">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;isConcentrationOf"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-construct;Dioxygen">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
												<owl:someValuesFrom rdf:resource="&iof-construct;SoluteRole"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;SolubilityLimit">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;isConcentrationOf"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-construct;Dioxygen">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
												<owl:someValuesFrom rdf:resource="&iof-construct;SoluteRole"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>dissolved oxygen saturation ratio</rdfs:label>
		<iof-av:explanatoryNote>The dissolved oxygen saturation concentration (and therefore the dissolved oxygen saturation ratio) is condition-dependent, varying with temperature, salinity (or ionic strength), total pressure, and the oxygen partial pressure in the gas phase in contact with the liquid. In bioprocessing practice, “100% DO” is commonly defined as equilibrium with air at approximately 21% O₂ (at the prevailing total pressure), rather than equilibrium with pure oxygen, unless otherwise specified.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>ratio that is the dissolved oxygen concentration in a liquid solution relative to the dissolved oxygen saturation concentration in that liquid</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;DownstreamDerivedImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ManufacturingProcessRelatedImpurityRole"/>
		<rdfs:label>downstream-derived impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://database.ich.org/sites/default/files/Q6B%20Guideline.pdf</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>manufacturing process related impurity role held by a material entity that originates from a material that is involved in a downstream manufacturing process</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;DrugPotency">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000194"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;BiologicalActivity"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>drug potency</rdfs:label>
		<iof-av:adaptedFrom>https://www.ema.europa.eu/en/documents/scientific-guideline/guideline-development-production-characterisation-and-specification-monoclonal-antibodies-and-related-products-revision-1_en.pdf and  https://www.ema.europa.eu/en/documents/scientific-guideline/ich-q-6-b-test-procedures-and-acceptance-criteria-biotechnologicalbiological-products-step-5_en.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>According to ICH Q6B, the measure of potency must be directly tied to a specific product attribute that reflects its relevant biological properties. The guideline emphasizes that potency is established through an assay that demonstrates the product’s intended biological effect, and that this assay is essential for ensuring consistency and control throughout manufacturing. 
The resource also clarifies that potency is distinct from a physicochemical measure of protein content; it must reflect a biological function and cannot be replaced by purely analytical measurements. Potency therefore serves as a critical quality attribute used to confirm that batches have the expected level of biological activity and meet acceptance criteria defined in the regulatory submission</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>quality of a drug substance or drug product and is the degree of its biological activity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;DrugProductRelatedImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ImpurityRole"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;roleOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;MolecularEntity">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-construct;MolecularEntityPopulation">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>drug product related impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://database.ich.org/sites/default/files/Q6B%20Guideline.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) In this context, molecular variant means a form related to the intended drug substance or drug product that differs in primary structure or higher order structure, and that is not part of the defined product composition or specification at the relevant stage. Examples include processing precursors (e.g., proinsulin, signal-peptide-containing forms), sequence-altered forms (e.g., substitutions, insertions, deletions, truncations), residue-modified forms (e.g., deamidated Asn, oxidized Met), clipped or bond-cleaved forms (e.g., fragments from peptide-bond cleavage, missing chain segments) and aggregated forms (e.g., non-native dimers, oligomers)
2) This definition is intended for products whose primary intended product is a molecular entity (or molecular population), and it excludes cell-based products as the intended product.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>impurity role held by a molecular entity or molecular entity population that is a molecular variant of the targeted drug product or drug substance and does not have properties comparable to those of the desired product with respect to activity, efficacy, and safety</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;DustingPropensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Propensity"/>
		<rdfs:label>dusting propensity</rdfs:label>
		<iof-av:naturalLanguageDefinition>disposition of a powdered material entity to generate airborne particulate matter</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ElectricCharge">
		<rdfs:subClassOf rdf:resource="&iof-construct;ElectricalQuality"/>
		<rdfs:label>electric charge</rdfs:label>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ElectricalConductivity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Conductivity"/>
		<rdfs:label>electrical conductivity</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001585</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality of a material entity that is the extent to which the material entity conducts electric charge</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ElectricalQuality">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>electrical quality</rdfs:label>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;EmulsionPropensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Propensity"/>
		<rdfs:label>emulsion propensity</rdfs:label>
		<iof-av:naturalLanguageDefinition>disposition of a material entity to form an emulsion</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;EquilibriumSolubility">
		<rdfs:subClassOf rdf:resource="&iof-construct;SolubilityLimit"/>
		<rdfs:label>equilibrium saturation concentration</rdfs:label>
		<iof-av:adaptedFrom>https://doi.usp.org/USPNF/USPNF_M2248_03_01.html and https://goldbook.iupac.org/terms/view/S05740</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Equilibrium solubility is the saturation limit at thermodynamic equilibrium: the greatest amount of a solute that can remain dissolved under specified conditions while coexisting in equilibrium with a separate phase of that solute (e.g., a solid/crystalline phase, precipitate, separate liquid phase, or gas phase). The value depends on the stated conditions, including temperature, pressure, and solvent composition, and in many practical systems also depends on pH, ionic strength, and the presence of other solutes or additives. Equilibrium solubility can be reported in multiple composition forms (e.g., molarity, molality, mass concentration, mass fraction, mole fraction), provided the solute, solvent, and equilibrium conditions are specified.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>solubility saturation concentration of a particular solute at thermodynamic equilibrium</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ExpansionCultureMedium">
		<rdfs:subClassOf rdf:resource="&iof-construct;SpecializedCultureMedium"/>
		<rdfs:label>expansion culture medium</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;ExpansionCultureMedium">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasFunction"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;CellProliferationSupportingFunction"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>Human-Mesenchymal-XF-Expansion-Medium</skos:example>
		<iof-av:adaptedFrom>https://www.thermofisher.com/rs/en/home/references/gibco-cell-culture-basics/cell-culture-environment/culture-media.html and https://www.labome.com/method/Cell-Culture-Media-A-Review.html</iof-av:adaptedFrom>
		<iof-av:counterExample>chemically defined production medium optimized for antibody yield may maintain cell viability but does not primarily function as a proliferation medium</iof-av:counterExample>
		<iof-av:naturalLanguageDefinition>specialized culture medium with a cell proliferation supporting function</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ExtinctionCoefficient">
		<rdfs:subClassOf rdf:resource="&iof-construct;OpticalQuality"/>
		<rdfs:label>extinction coefficient</rdfs:label>
		<iof-av:adaptedFrom>https://www.fda.gov/media/182387/download</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>optical quality of a material entity that is the degree to which the material entity absorbs or reflects radiation or light at a particular wavelength</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ExtractableAndLeachableImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ImpurityRole"/>
		<rdfs:label>extractable and leachable impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://www.ema.europa.eu/en/documents/scientific-guideline/draft-ich-q3e-guideline-extractables-leachables_en.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) This role groups cases commonly termed extractables and leachables:
Extractables: material entities intentionally extracted from manufacturing components/systems, packaging components, or delivery device components under specified laboratory test conditions; often treated as potential leachables for a given target material and use scenario.
Leachables: material entities that migrate from manufacturing components/systems, packaging components, or delivery device components into a target material under established conditions of manufacture and/or labeled storage conditions (or, more generally, established handling/transport/use conditions).
2) “Artifact that contacts the target material” includes, for example, containers/closures, bags, tubing, filters, seals/gaskets, connectors, pumps, and relevant equipment surfaces.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>impurity role that inheres in a material entity in virtue of that material entity being present in a target material as a result of transfer from an artifact that contacts the target material</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Filterability">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:label>filterability</rdfs:label>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/topics/chemistry/filterability and  https://www.cytivalifesciences.com/en/us/insights/how-to-run-a-filterability-test-for-bioprocess-development</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) Filterability is realized in filtration and concerns the tendency of a fluid–solids mixture to continue passing through a filtration medium rather than rapidly forming deposits that reduce permeability or cause plugging. 
2) The bearer can be any fluid with suspended solids with slurries and suspensions being common examples.
3)  Filterability can vary with the amount and character of suspended solids, properties of the continuous phase, and the filtration medium used. Practical indications of poor filterability include early blockage, marked decline in throughput, or rapid increase in resistance during filtration.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>capability of a fluid containing suspended solids to pass through a filtration medium during a filtration process without undue blockage or loss of permeability</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Flowability">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:label>flowability</rdfs:label>
		<iof-av:adaptedFrom>https://www.usp.org/sites/default/files/usp/document/harmonization/gen-chapter/20230428HSm99885.pdf  and https://en.wikipedia.org/wiki/Flowability and http://purl.allotrope.org/ontologies/quality#AFQ_0000144</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Flowability is assessed relative to a handling context and conditions (e.g., gravity discharge, pouring, conveying, pumping, geometry such as hoppers/orifices, temperature and humidity, consolidation history). In bioprocessing and pharmaceutical settings, the term is most commonly applied to powders and granular solids and evaluated using operational tests such as angle of repose, flow through an orifice, and indices derived from bulk and tapped density.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>capability of a material entity to move by flow in a particular process</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Foamability">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:label>foamability</rdfs:label>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/science/article/abs/pii/S0001868619303021 and https://link.springer.com/article/10.1007/s43938-023-00039-0</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Foamability is realized when process conditions that promote foam formation occur, for example agitation, mixing, pumping, spraying, or gas introduction. Hence, foamability should be assessed under specified process conditions, because the realized amount of foam depends on both mixture composition and the process conditions.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>capability of a liquid to form foam during a particular process</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Fraction">
		<rdfs:subClassOf rdf:resource="&iof-construct;Ratio"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;MixedMaterial"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>fraction</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000172</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>ratio of one constitutent (part) to all constituents of a mixture</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Homogeneity">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>homogeneity</rdfs:label>
		<iof-av:adaptedFrom>https://goldbook.iupac.org/terms/view/H02845</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Homogeneity is always relative to what is being evaluated (e.g., a particular analyte, particle size fraction, moisture content, pH, osmolality, optical density). Accordingly, the same quantity of material may be homogeneous with respect to one analyte or property yet heterogeneous with respect to another, because different constituents or properties can vary differently across the material (for example, a powder blend may be homogeneous in total mass fraction of a salt but heterogeneous in trace element distribution; a reconstituted medium may be homogeneous in bulk pH but heterogeneous in dissolved gas concentration immediately after mixing).</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>quality of a material entity that is the extent to which a particular constituent of that material entity, or a particular quality of that material entity, is uniformly distributed throughout that material entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;HomogenousMixture">
		<rdfs:subClassOf rdf:resource="&iof-construct;MixedMaterial"/>
		<rdfs:label>homogenous mixture</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/material#AFM_0001035</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>mixed material that has the same proportions of its components throughout a given sample</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;HostCellProteinImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellSubstrateDerivedImpurityRole"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;roleOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Protein">
							</rdf:Description>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;MolecularEntityPopulation">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000115"/>
										<owl:allValuesFrom rdf:resource="&iof-construct;Protein"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>host cell protein impurity role</rdfs:label>
		<iof-av:abbreviation>HCP impurity role</iof-av:abbreviation>
		<iof-av:adaptedFrom>https://database.ich.org/sites/default/files/Q6B%20Guideline.pdf</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>cell-substrate-derived impurity role held by a protein or protein population that originates from the host organism or cell line</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Hygroscopicity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:label>hygroscopicity</rdfs:label>
		<iof-av:adaptedFrom>https://goldbook.iupac.org/terms/view/15197 and https://en.wikipedia.org/wiki/Hygroscopy</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Hygroscopicity is typically realized under ambient storage or handling conditions as moisture uptake from air (commonly water vapour).</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>capability of a material entity to attract and hold moisture from the surrounding environment</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Impurity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Ratio"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;DependsOnBearerPart"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;BFO_0000040">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;ImpurityRole"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>impurity</rdfs:label>
		<owl:disjointWith rdf:resource="&iof-construct;Purity"/>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000222</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality that inheres in a material entity by virtue of the extent to which the material entity consists of material that is considered an impurity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;InfectedHostCell">
		<rdfs:subClassOf rdf:resource="&iof-construct;Cell"/>
		<rdfs:label>infected host cell</rdfs:label>
		<skos:example>A HEK293 cell that has been infected by an adenovirus vector; MDCK cell infected by influenza virus; A CHO cell infected by vesicular stomatitis virus (VSV)</skos:example>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/NCIT_C93037</iof-av:adaptedFrom>
		<iof-av:counterExample>A HEK293T cell that has been transduced with a replication-deficient AAV vector to express a therapeutic gene</iof-av:counterExample>
		<iof-av:naturalLanguageDefinition>cell that is infected by a virus or another type of microorganism</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;IntactMolecularWeight">
		<rdfs:subClassOf rdf:resource="&iof-construct;MolarMass"/>
		<rdfs:label>intact molecular weight</rdfs:label>
		<iof-av:abbreviation>intact MW</iof-av:abbreviation>
		<iof-av:adaptedFrom>https://www.fda.gov/media/182387/download</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>molar mass that is the quality of a molecular entity or population of molecular entities considered in its whole, intact form, without intentional fragmentation, cleavage, or removal of any of its covalently bound parts</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;IntermediateStockSolution">
		<rdfs:subClassOf rdf:resource="&iof-construct;Solution"/>
		<rdfs:label>intermediate stock solution</rdfs:label>
		<skos:example>A 0.1 M NaCl solution prepared from a 1 M stock and used to prepare a 1 mM NaCl solution for an assay</skos:example>
		<iof-av:adaptedFrom>http://champ-project.org/images/ontology/cao.owl#CAO_000142</iof-av:adaptedFrom>
		<iof-av:counterExample>A 50 mM Tris-HCl buffer prepared from a 1 M stock and used directly in an assay</iof-av:counterExample>
		<iof-av:naturalLanguageDefinition>solution prepared by diluting a stock solution and subsequently used to prepare additional dilutions</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;IsoelectricPoint">
		<rdfs:subClassOf rdf:resource="&iof-construct;ElectricalQuality"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;NetElectricCharge">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;MolecularEntity"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;MolecularEntity"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>isoelectric point</rdfs:label>
		<skos:altLabel>pI</skos:altLabel>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/NCIT_C54157</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality that is the quality of a molecular entity that is the pH at which that entity has zero net charge in a homogeneous aqueous mixture and does not migrate in an electric field</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Length">
		<rdfs:subClassOf rdf:resource="&iof-construct;OneDimensionalPhysicalExtent"/>
		<rdfs:label>length</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000122</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>one dimensional physical extent that is the quality of a material entity that is the spatial extent of that entity between two boundary points along a particular direction</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;LightLevel">
		<rdfs:subClassOf rdf:resource="&iof-construct;OpticalQuality"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;BFO_0000029">
							</rdf:Description>
							<rdf:Description rdf:about="&bfo;BFO_0000040">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>light level</rdfs:label>
		<iof-av:naturalLanguageDefinition>optical quality of a site or material entity that is the amount of light present at or within it</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ManufacturingProcessRelatedImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ImpurityRole"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;roleOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;BFO_0000040">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000056"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;ManufacturingProcess"/>
							</owl:Restriction>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000175"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:unionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-construct;MaterialProduct">
											</rdf:Description>
											<rdf:Description rdf:about="&iof-construct;ProcessIntermediateMaterial">
											</rdf:Description>
										</owl:unionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>manufacturing process related impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://www.fda.gov/media/182387/download and https://database.ich.org/sites/default/files/Q6B%20Guideline.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Manufacturing impurity role can be held by a material entity when its presence in a process material, production intermediate, or product is attributable to planned or inherent aspects of manufacturing execution.
Examples include residual process materials and intermediates (for example reagents, solvents, cleaning agents, process intermediates, and byproducts) and material introduced via intended product-contact equipment or consumables (for example wear particles, lubricants, extractables, and leachables from vessels, tubing, filters, and resins</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>impurity role held by a material entity that is part of a production intermediate or product and originates from a material entity involved in a manufacturing process</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Mass">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>mass</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000125</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality that inheres in a bearer by virtue of the proportion of the bearer&apos;s amount of matter</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MassConcentration">
		<rdfs:subClassOf rdf:resource="&iof-construct;Concentration"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Mass"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>mass concentration</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000167</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>concentration that is the mass of a component of the mixture relative to the total volume of the mixture</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MassDensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Density"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Mass"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;PhysicalSize"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>mass density</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001019</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality which inheres in a bearer by virtue of some influence is exerted by the bearer&apos;s mass per unit size</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MassFraction">
		<rdfs:subClassOf rdf:resource="&iof-construct;Fraction"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Mass"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>mass fraction</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000173</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>fraction pertaining the mass of a constituent divided by the total mass of all constituents in the mixture</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MasterCellBank">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellBank"/>
		<rdfs:label>master cell bank</rdfs:label>
		<iof-av:adaptedFrom>https://www.ema.europa.eu/en/documents/scientific-guideline/ich-q-5-d-derivation-and-characterisation-cell-substrates-used-production-biotechnologicalbiological-products-step-5_en.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>The master cell bank is the definitive, long-term preserved reference lot of a cell line. It serves as the primary source for the generation of working cell banks, but it may also be used directly as a production or study starting material when required. Preparation and characterization of the master cell bank must comply with ICH Q5D requirements, including full documentation of cell origin and banking procedures, and rigorous testing to confirm identity, purity (absence of microbial, viral, or other adventitious agents), and stability. Depending on the cell type and intended use, additional evaluations such as tumorigenicity or karyology are also required.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>cell bank produced in a single preparation event from a well-characterized cell line or clone, stored under validated cryogenic conditions, and established as the authoritative reference lot for direct use or the generation of further banks</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MaterialDifferentiationInducer">
		<rdfs:subClassOf rdf:resource="&iof-construct;MaterialFunctionalInducer"/>
		<rdfs:label>material differentiation inducer</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;MaterialFunctionalInducer">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;MaterialDifferentiationInducerRole"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>IL-7 and IL-15 solutions are used as differentiation inducers when added to CAR-T cell cultures to promote memory T-cell phenotype; Activin A is a differentiation inducer when added to human pluripotent stem cell cultures to direct differentiation toward definitive endoderm lineage</skos:example>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC10215625/ and https://pmc.ncbi.nlm.nih.gov/articles/PMC9043864/</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material entity with a material differentiation inducer role</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MaterialDifferentiationInducerRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;MaterialFunctionalInducerRole"/>
		<rdfs:label>material differentiation inducer role</rdfs:label>
		<skos:example>IL-7 and IL-15 solution bearing a differentiation inducer role when added to CAR-T cell cultures to promote memory T-cell phenotype; Activin A bearing a differentiation inducer role when added to human pluripotent stem cell cultures to direct differentiation toward definitive endoderm lineage</skos:example>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC10215625/ and https://pmc.ncbi.nlm.nih.gov/articles/PMC9043864/</iof-av:adaptedFrom>
		<iof-av:counterExample>Glucose feed added to sustain T-cell metabolism</iof-av:counterExample>
		<iof-av:explanatoryNote>Differentiation inducers are commonly cytokines, growth factors, or small molecules that alter developmental programs in culture</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role held by a material entity when it is added, or planned to be added, to a cell culture to activate signaling pathways that drive cell fate decisions, lineage commitment, or functional specialization</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MaterialFunctionalInducer">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000040"/>
		<rdfs:label>material functional inducer</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;BFO_0000040">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;MaterialFunctionalInducerRole"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>IL-7 and IL-15 solutions are used as differentiation inducers when added to CAR-T cell cultures to promote memory T-cell phenotype; Tetracycline is a production inducer when added to a mammalian cell culture to activate a Tet-regulated promoter driving recombinant protein expression.</skos:example>
		<iof-av:explanatoryNote>See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material entity with a material functional inducer role</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MaterialFunctionalInducerRole">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000023"/>
		<rdfs:label>material functional inducer role</rdfs:label>
		<iof-av:explanatoryNote>Functional inducers are distinct from standard nutrients or media supplements. They do not merely sustain viability or growth, but instead initiate or modulate a specific cellular function. In other words while media supplements support or maintain inherent cellular activities; they do not by themselves activate new pathways. In contrast, functional inducers are used to trigger or redirect specific pathways or functions (e.g., IPTG induction of the lac operon, tetracycline induction of recombinant protein expression).</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role held by a material entity when it is added, or planned to be added, to a cell culture, organism, or microbial community in order to trigger, enhance, or repress a specific cellular activity or pathway beyond baseline nutrient support</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MaterialGradeClassifier">
		<rdfs:subClassOf rdf:resource="&iof-construct;Classifier"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;classifies"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;BFO_0000040">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;satisfiesRequirement"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;RequirementSpecification"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>material grade classifier</rdfs:label>
		<iof-av:adaptedFrom>https://alliancechemical.com/blogs/articles/chemicalgrades and https://www.biopharminternational.com/view/role-quality-standards-biomanufacturing-raw-materials and https://www.biopharminternational.com/view/case-study-pharmacopoeia-compliance-excipients-and-raw-materials-0</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Material grade is a practical classification used to communicate that a material has been sourced, tested, and documented against a defined requirement set issued by a specific organization (for example, a pharmacopeia, a standards body, or a supplier). In chemical supply contexts, grades such as technical, ACS/reagent, USP/FCC/food, and water-treatment grade are used to distinguish different expectation levels for impurities, documentation, and suitability for a particular use. In biopharmaceutical manufacturing, grade distinctions are often framed operationally by what is purchased and how it is tested and governed, including compendial and multi-compendial grades (aligned to one or more monographs), and reagent grade (generally less preferred for regulated manufacture).</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>classifier that classifies a material entity into an organization- or authority-defined class of suitability for use, based on the material entity’s conformance to a documented set of acceptance requirements and associated controls</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MaterialHomogeneity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Homogeneity"/>
		<rdfs:label>material homogeneity</rdfs:label>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MaterialMetabolicInducer">
		<rdfs:subClassOf rdf:resource="&iof-construct;MaterialFunctionalInducer"/>
		<rdfs:label>material metabolic inducer</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;MaterialFunctionalInducer">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;MaterialMetabolicInducerRole"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>Lactose as a metabolic inducer in E. coli cell culture via lac operon activation.;Arabinose serving as a metabolic inducer in gut microbial communities.;Hydrocarbons acting as metabolic inducers in soil bacteria activating catabolic pathways.</skos:example>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC3815394/</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material entity with a material metabolic inducer role</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MaterialMetabolicInducerRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;MaterialFunctionalInducerRole"/>
		<rdfs:label>material metabolic inducer role</rdfs:label>
		<skos:example>Lactose as a metabolic inducer in E. coli cell culture via lac operon activation.; Arabinose serving as a metabolic inducer in gut microbial communities.;Hydrocarbons acting as metabolic inducers in soil bacteria activating catabolic pathways.</skos:example>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC3815394/</iof-av:adaptedFrom>
		<iof-av:counterExample>Sodium butyrate added to a HEK293 culture to boost viral vector yield</iof-av:counterExample>
		<iof-av:explanatoryNote>Metabolic inducers are most often substrates, substrate analogues, or related metabolites that relieve repression or otherwise activate transcription of genes for metabolic activity. They serve to adapt cellular metabolism to nutrient availability or environmental conditions, whether in controlled laboratory cultures, whole organisms, or natural microbial communities (e.g., soil, gut, biofilms).</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role held by a material entity when it is added, or planned to be added, to a cell culture, organism, or microbial community to activate expression of enzymes or pathways involved in the utilization or regulation of metabolites</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MaterialProductionInducer">
		<rdfs:subClassOf rdf:resource="&iof-construct;MaterialFunctionalInducer"/>
		<rdfs:label>material production inducer</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;MaterialFunctionalInducer">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;MaterialProductionInducerRole"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>Tetracycline is a production inducer when added to a mammalian cell culture to activate a Tet-regulated promoter driving recombinant protein expression.</skos:example>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC8015268/pdf/nihms-1685084.pdf and https://microbialcellfactories.biomedcentral.com/articles/10.1186/s12934-024-02523-w</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material entity with a material production inducer role</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MaterialProductionInducerRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;MaterialFunctionalInducerRole"/>
		<rdfs:label>material production inducer role</rdfs:label>
		<skos:example>Tetracycline bearing a production inducer role when added to a mammalian cell culture to activate a Tet-regulated promoter driving recombinant protein expression.</skos:example>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC8015268/pdf/nihms-1685084.pdf and https://microbialcellfactories.biomedcentral.com/articles/10.1186/s12934-024-02523-w</iof-av:adaptedFrom>
		<iof-av:counterExample>Glucose feed added to sustain metabolism and cell viability, which supports growth but does not trigger synthesis of a specific target product.</iof-av:counterExample>
		<iof-av:explanatoryNote>Production inducers are used in engineered culture systems to control when and how product formation occurs. They may be chemical compounds (e.g., tetracycline, arabinose, sodium butyrate) or environmental triggers (e.g., temperature shift, pH, light). The same compound may bear other roles in different contexts (for example, tetracycline as a therapeutic antibiotic). Environmental triggers such as temperature shifts, pH changes, oxygen limitation, or nutrient depletion can also induce product formation, but these are not material entities and do not bear a production inducer role.These will be modeled separately in a future version.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role held by a material entity when it is added, or planned to be added, to a cell culture to trigger the synthesis of a target product</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MediaSupplement">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000040"/>
		<rdfs:label>media supplement</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;BFO_0000040">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;CultureMediumSupplementRole"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>Albumin is a media supplement when added to serum-free medium to stabilize cells; ITS+3 Liquid Media Supplement (100×), a defined mixture of insulin, human transferrin, sodium selenite, linoleic acid, oleic acid ) added to serum-free medium to support viability and specialized functions; G418 (geneticin) added to impose selective pressure on a stable CHO line; 10% DMSO added to a cryopreservation medium for cell banking</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html and https://www.thermofisher.com/rs/en/home/life-science/cell-culture/mammalian-cell-culture/media-supplements.html</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material entity with a media supplement role</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Miscibility">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:label>miscibility</rdfs:label>
		<iof-av:adaptedFrom>https://www.sigmaaldrich.com/RS/en/technical-documents/technical-article/analytical-chemistry/purification/solvent-miscibility-table and https://goldbook.iupac.org/terms/view/MT07230</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) Miscibility concerns whether combined materials form one phase rather than separating into multiple phases (e.g., liquid–liquid layering or solid–liquid phase separation). The term is used most often for liquids, but it can also be applied to gases and solid phases.
2) Whether a single phase exists depends on properties of the components, including chemical structure, molar-mass distribution, and molecular architecture.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>capability of two or more material entities, when combined as a mixture, to form and maintain a single homogeneous phase rather than separating into multiple phases</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MixedMaterial">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000040"/>
		<rdfs:label>mixed material</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/material#AFM_0001038</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>material entity that consists of different kinds of grains if you inspect it at a higher level of granularity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MoistureContent">
		<rdfs:subClassOf rdf:resource="&iof-construct;Ratio"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Mass">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;Water"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>moisture content</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/NCIT_C210204</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>The &quot;defined reference mass&quot; can be the Total Mass (Wet Basis) or the Dry Solids Mass (Dry Basis).</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>ratio that is the mass of water contained in a material entity relative to a defined reference mass of that material entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MolarConcentration">
		<rdfs:subClassOf rdf:resource="&iof-construct;Concentration"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;AmountOfSubstance"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>molar concentration</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000168</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>concentration that is the molar amount of a component of the mixture relative to the total volume of the mixture</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MolarMass">
		<rdfs:subClassOf rdf:resource="&iof-construct;Mass"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;MolecularEntity">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-construct;MolecularEntityPopulation">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">molar mass</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/biopharma/Material/"/>
		<skos:altLabel>molecular weight</skos:altLabel>
		<skos:example>The molar mass of albumin is 66.5 kDa; The molar mass of a particular antibody mixture that contains a percentage of mAb dimers is 175 kDa while a population without dimers would have a molar mass of 150 kDa; The molar mass for a population of high density polyethylene polymer is 300 000 g/mol; molar mass of glucose is 180 g/mol; molar mass of sodium chloride is 58.44 g/mol</skos:example>
		<iof-av:adaptedFrom>https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11238-Substances/MolecularWeight and PATO:0001681</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) The value of molecular weight is typically expressed in daltons (Da) or grams per mole (g/mol) 
2) In case of a heterogenous population of molecular entities it can be a regular average or a weighted awerage whereby the weigthing depends on the application
3) Molar mass includes small molecules, charged species, ionic compounds (treated as a defined unit), and macromolecular complexes such as proteins with tertiary or quaternary structure. It excludes isolated atoms and unspecified atomic groups (e.g. R-groups)</iof-av:explanatoryNote>
		<iof-av:firstOrderLogicAxiom>MolarMass(x) → Quality(x)</iof-av:firstOrderLogicAxiom>
		<iof-av:isPrimitive rdf:datatype="&xsd;boolean">true</iof-av:isPrimitive>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">quality that is the quality of a molecular entity or population of molecular entities, and is either the mass of one mole of that single entity, or the average mass of one mole of molecules in the population</iof-av:naturalLanguageDefinition>
		<iof-av:primitiveRationale>There are insufficient constructs to define necessary and sufficient conditions.</iof-av:primitiveRationale>
		<iof-av:semiFormalNaturalLanguageAxiom>if x is a &apos;molar mass&apos; then x is a &apos;quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MolecularCarrierRole">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000023"/>
		<rdfs:label>molecular carrier role</rdfs:label>
		<skos:example>serum albumin carrying fatty acids in extracellular fluid; ferritin carrying iron atoms in its core; liposome encapsulating siRNA for cellular uptake; polyethylene glycol (PEG) acting as a carrier to improve drug solubility</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html and https://pub.uni-bielefeld.de/record/2943695 and https://pubmed.ncbi.nlm.nih.gov/30290072/</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>This role applies to molecular or particulate materials such as proteins, lipids, polymers, or engineered nanoparticles that transiently associate with other molecular entities to facilitate their distribution, solubility, or localization. It is distinct from logistical or container-level carriers used in supply chain contexts, which operate at the level of physical object transport.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role held by a material entity that enables the transport, stabilization, or delivery of one or more molecular entities within a physical, chemical, or biological system without undergoing permanent chemical transformation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;MorphologicalQuality">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>morphological quality</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000051</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality of a material entity inhering in the bearer by virtue of the bearer&apos;s size or shape or structure</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Mycoplasma">
		<rdfs:subClassOf rdf:resource="&iof-construct;Bacterium"/>
		<rdfs:label>mycoplasma</rdfs:label>
		<iof-av:adaptedFrom>https://www.sartorius.com/en/knowledge/science-snippets/what-is-mycoplasma-693938 and https://www.sciencedirect.com/science/article/abs/pii/S1045105610000783?via%3Dihub and https://analyticalsciencejournals.onlinelibrary.wiley.com/doi/epdf/10.1002/bit.27436</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Mycoplasma are wall-less bacteria with small genomes and minimal cellular architecture, which enables close association with mammalian cells and evasion of many routine microbiological detection approaches. In biopharmaceutical manufacturing, they are recognized as critical microbial contaminants of mammalian cell culture based processes. Their presence can alter cellular metabolism, affect gene expression, reduce viable cell density, and compromise product quality and safety. Because their size and lack of a rigid cell wall allow them to pass standard sterilizing filters and escape visual inspection, control strategies rely on validated multi-method detection workflows.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>bacterium that lacks a cell wall and is capable of infecting mammalian cells</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;NetElectricCharge">
		<rdfs:subClassOf rdf:resource="&iof-construct;ElectricCharge"/>
		<rdfs:label>net electric charge</rdfs:label>
		<iof-av:adaptedFrom>https://www.britannica.com/science/electric-charge and https://openstax.org/books/physics/pages/18-1-electrical-charges-conservation-of-charge-and-transfer-of-charge</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>net electric charge is equal to the algebraic sum of all positive and negative electric charges borne by that entity</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>quality that is the overall electric charge of a material entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;NonGlycosylatedMolecularWeight">
		<rdfs:subClassOf rdf:resource="&iof-construct;MolarMass"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Glycoprotein">
							</rdf:Description>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;MolecularEntityPopulation">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000172"/>
										<owl:someValuesFrom rdf:resource="&iof-construct;Glycoprotein"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>non-glycosylated molecular weight</rdfs:label>
		<iof-av:adaptedFrom>https://www.fda.gov/media/182387/download</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>molar mass that is the quality of a glycoprotein or a population of glycoproteins and is the mass of that entity when all covalently attached glycan moieties have been removed</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;NumberDensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Density"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Amount"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;PhysicalSize"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>number density</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000180</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality that is the amount of countable objects per unit size</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;NumberFraction">
		<rdfs:subClassOf rdf:resource="&iof-construct;Fraction"/>
		<rdfs:label>number fraction</rdfs:label>
		<iof-av:naturalLanguageDefinition>fraction pertaining the count of a constituent divided by the total count of all constituents in the mixture</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;NutrientFeed">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000040"/>
		<rdfs:label>nutrient feed</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;BFO_0000040">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;NutrientFeedRole"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>concentrated glucose feed pumped to maintain glucose above a target setpoint; galactose feed added to modulate glycosylation; feed solution containing glucose, amino acids, vitamins, trace metals, and lipids added during cultivation to support high cell density and balanced metabolism</skos:example>
		<iof-av:adaptedFrom>https://www.bioprocessintl.com/biochemicals-raw-materials/nutrient-supplementation-strategies-for-biopharmaceutical-production</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material entity with a nutrient feed role</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;NutrientFeedRole">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000023"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;roleOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;BFO_0000040">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-construct;MolecularEntity">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
												<owl:someValuesFrom rdf:resource="&iof-construct;MolecularNutrientRole"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>nutrient feed role</rdfs:label>
		<skos:example>concentrated glucose feed pumped to maintain glucose above a target setpoint; galactose feed added to modulate glycosylation; feed solution containing glucose, amino acids, vitamins, trace metals, and lipids added during cultivation to support high cell density and balanced metabolism</skos:example>
		<iof-av:adaptedFrom>https://www.bioprocessintl.com/biochemicals-raw-materials/nutrient-supplementation-strategies-for-biopharmaceutical-production</iof-av:adaptedFrom>
		<iof-av:counterExample>IPTG induction; glucose already present in the medium</iof-av:counterExample>
		<iof-av:explanatoryNote>This role applies to additions that are part of a controlled feeding strategy after inoculation. The purpose of nutrient feeds can include sustaining cell growth and viability, preventing nutrient depletion, extending the productive phase, optimizing productivity, or steering metabolic activity to achieve desired product quality attributes (e.g., modulating glycosylation). Feeds are often chemically defined solutions and can be single or multicomponent solutioncontaining glucose, amino acids, vitamins, trace elements, and sometimes lipids, but may also be provided as powders or slurries in some settings.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role held by a material entity when it is added or planned to be added to a cell cuture during cultivation or production to modulate a particular nutrient</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;OneDimensionalPhysicalExtent">
		<rdfs:subClassOf rdf:resource="&iof-construct;PhysicalSize"/>
		<rdfs:label>one dimensional phyiscal extent</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001708</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>physical size that is the spatial extent of a material entity in one dimension</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;OpticalClarity">
		<rdfs:subClassOf rdf:resource="&iof-construct;OpticalQuality"/>
		<rdfs:label>optical clarity</rdfs:label>
		<iof-av:naturalLanguageDefinition>optical quality of a liquid that is the extent to which the liquid transmits light with minimal scattering from suspended or colloidal matter</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;OpticalQuality">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>optical quality</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001300</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality that inheres in a material entity by virtue of how that material entity interacts with electromagnetic radiation that is light</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Osmolality">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000145"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Mass">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;Solution"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Solution"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>osmolality</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0002027 and https://www.ncbi.nlm.nih.gov/sites/books/NBK567764/</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Osmolarity is a colligative property in the sense that it depends primarily on the number of dissolved particles (osmotically active entities) rather than their chemical identity; it expresses this particle concentration on a volume-of-solution basis (i.e., osmoles of solute per liter of solution)</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>quality of a solution that is the amount of osmotically active solute entities in that solution per unit mass of solvent</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Osmolarity">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000145"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Volume">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;Solution"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Solution"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>osmolarity</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001655 and https://www.ncbi.nlm.nih.gov/sites/books/NBK567764/</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality of a solution that is the amount of osmotically active solute entities in that solution per unit volume of that solution</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;PartialPressure">
		<rdfs:subClassOf rdf:resource="&iof-construct;Pressure"/>
		<rdfs:label>partial pressure</rdfs:label>
		<iof-av:adaptedFrom>https://goldbook.iupac.org/terms/view/P04819</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>pressure that is the contribution of a particular gaseous constituent of a gas mixture to the total pressure of that mixture</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ParticleSizeDistribution">
		<rdfs:subClassOf rdf:resource="&iof-construct;MorphologicalQuality"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;PhysicalSize"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>particle size distribution</rdfs:label>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/topics/chemistry/particle-size-distribution</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>morphological quality of a particle population that is the overall make-up of the physical sizes of the particles present in that population</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ParticulateLoad">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>particulate load</rdfs:label>
		<iof-av:naturalLanguageDefinition>quality of a material entity that is the extent to which particulate matter is present in the material entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Photostability">
		<rdfs:subClassOf rdf:resource="&iof-construct;Stability"/>
		<rdfs:label>photostability</rdfs:label>
		<iof-av:adaptedFrom>https://www.ema.europa.eu/en/documents/scientific-guideline/ich-q-1-b-photostability-testing-new-active-substances-and-medicinal-products-step-5_en.pdf and https://www.collinsdictionary.com/us/dictionary/english/photostability#:~:text=the%20ability%20of%20a%20material,due%20to%20exposure%20to%20light</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>stability that is the capability of a material entity to resist change in one or more of its attributes during a process in which the material entity is exposed to light</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;PhysicalShape">
		<rdfs:subClassOf rdf:resource="&iof-construct;MorphologicalQuality"/>
		<rdfs:label>physical shape</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000052</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Examples of structural features include points, edges, surfaces and holes</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>quality that inheres in a material entity by virtue of the ratios of distances between structural features of that material entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;PhysicalSize">
		<rdfs:subClassOf rdf:resource="&iof-construct;MorphologicalQuality"/>
		<rdfs:label>physical size</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000117</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality of a material entity that is the spatial extent of that entity in one or more spatial dimensions</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;PhysicalStructure">
		<rdfs:subClassOf rdf:resource="&iof-construct;MorphologicalQuality"/>
		<rdfs:label>physical structure</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000141</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>This quality concerns the organization of parts (spatial arrangement and connectivity) at whatever granularity is relevant (e.g., anatomical regions, microstructure, particle packing, macromolecular conformation).</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>morphology quality inhering in a bearer by virtue of the relative positions, shapes, arrangement, and connectivity of the bearer’s parts, which together constitute the pattern underlying the bearer’s form</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Porosity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Ratio"/>
		<rdfs:label>porosity</rdfs:label>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/topics/engineering/porosity and https://www.iso.org/obp/ui#iso:std:iso:3252:ed-6:v1:en:term:3.3.48</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>ratio that is the pore or void volume of a material entity relative to the total volume of that material entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;PrecipitationPropensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Propensity"/>
		<rdfs:label>precipitation propensity</rdfs:label>
		<iof-av:naturalLanguageDefinition>disposition of a material entity to form insoluble solid phases from dissolved components</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;PreservationCultureMedium">
		<rdfs:subClassOf rdf:resource="&iof-construct;SpecializedCultureMedium"/>
		<rdfs:label>preservation culture medium</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;SpecializedCultureMedium">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasFunction"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;CulturePreservationFunction"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:altLabel>transport and preservation medium</skos:altLabel>
		<skos:example>cryopreservation medium</skos:example>
		<iof-av:adaptedFrom>https://www.thermofisher.com/search/browse/category/us/en/90217066</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Transport and preservation media are designed to support the safe transfer and storage of cells by minimizing physiological stress and preventing loss of viability. They may include cryoprotective agents for ultra-low temperature storage or stabilizing components for refrigerated transport. These formulations are typically sterile, liquid, and may be animal-origin-free or xeno-free. Certain products are optimized for particular cell types, such as mammalian or pluripotent stem cells.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>specialized culture medium with a culture preservation function</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Pressure">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000145"/>
		<rdfs:label>pressure</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001025</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality that inheres in a bearer by virtue of the bearer&apos;s amount of force per unit area it exerts</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;PrimaryStructure">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000164"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;BiologicalSequence"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;DeoxyribonucleicAcid">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-construct;Peptide">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-construct;Protein">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-construct;RibonucleicAcid">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>primary structure</rdfs:label>
		<iof-av:adaptedFrom>http://www.bioassayontology.org/bao#BAO_0000013</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>examples of modifications include methylated, phosphorylated, etc.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>quality of a biological macromolecule (DNA, RNA,peptide or protein) concretizing its sequence, which could either be unmodified&apos; (native) or modified</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ProductTiter">
		<rdfs:subClassOf rdf:resource="&iof-construct;Concentration"/>
		<rdfs:label>product titer</rdfs:label>
		<iof-av:explanatoryNote>1) In this context, ‘target product’ denotes the specified substance of interest for the manufacturing objective and may be a drug substance, process intermediate, or other designated active or functional component. Product titer is evaluated at a specified time point and may vary over time due to dilution, degradation, or changes in process volume.”
2) Here, process material means a material that is being transformed or modified in a manufacturing process, including process intermediate material and the material product. It does not include raw materials or consumables.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>concentration that is a quality of a process material that is the concentration of a target product in the process material</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ProductionCultureMedium">
		<rdfs:subClassOf rdf:resource="&iof-construct;SpecializedCultureMedium"/>
		<rdfs:label>production culture medium</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;SpecializedCultureMedium">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasFunction"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;BioproductionSupportingFunction"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>Hybridoma Myeloma Cell Culture Media</skos:example>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/topics/engineering/production-medium#:~:text=The%20production%20media%20have%20the,cost%20and%20to%20enhance%20yields. and https://www.fishersci.com/us/en/browse/90217078/hybridoma-myeloma-cell-culture-media</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>specialized culture medium with a bioproduction supporting function</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Propensity">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000016"/>
		<rdfs:label>propensity</rdfs:label>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ProtectiveAgentRole">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000023"/>
		<rdfs:label>protective agent role</rdfs:label>
		<skos:example>Dimethyl sulfoxide (DMSO) added to freezing medium for cell preservation; Poloxamer 188 (Pluronic F-68) is a surface-active nonionic polymer used in cell culture media to reduce shear stress from agitation and sparging</skos:example>
		<iof-av:explanatoryNote>Covers protection from physical, mechanical, thermal, chemical, or radiative stress. Subclasses are defined by the stressor type, for example cryoprotective agent role and shearprotective agent role. This notion is distinct from clinical “protective agents” used to prevent disease or treat poisoning and should not be mapped to CHEBI:50267.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role of a material entity that is added or planned to be added to an environment to protect other materials within that environment from stress or damage</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ProteinChargeVariantImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;DrugProductRelatedImpurityRole"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;roleOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;MolecularEntityPopulation">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000172"/>
										<owl:allValuesFrom>
											<owl:Class>
												<owl:unionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="&iof-construct;Protein">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-construct;ProteinFragment">
													</rdf:Description>
												</owl:unionOf>
											</owl:Class>
										</owl:allValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;Protein">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-construct;ProteinFragment">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>protein charge variant impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC5392216/ and https://www.chromatographyonline.com/view/charge-variant-profiling-biopharmaceuticals and https://www.agilent.com/cs/library/applications/compendium-chargevariant-advancebio-5994-0034EN-us-agilent.pdf?srsltid=AfmBOorRMu0dQH4wotghCeKwXSMCdNuuNsAEkA06EkLXupvMO6SBKJaN</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>product related impurity role that is held by a protein, protein fragment, or molecular population of such entities that differs from a reference form of the same protein by having a distinct net electric charge or isoelectric point</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ProteinFreeCultureMedium">
		<rdfs:subClassOf rdf:resource="&iof-construct;SerumFreeCultureMedium"/>
		<rdfs:label>protein free culture medium</rdfs:label>
		<skos:example>CHO protein-free media used for recombinant protein production (e.g., PF-CHO, CD-PF)</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html</iof-av:adaptedFrom>
		<iof-av:counterExample>Hydrolysate-containing medium (includes peptides)</iof-av:counterExample>
		<iof-av:explanatoryNote>Protein-free media are a subclass of serum-free media formulated to exclude added proteins and peptides, such as albumin, transferrin, or hydrolysates. They typically rely on amino acids, vitamins, salts, trace elements, lipids, and carbon sources to support cell metabolism. The absence of proteins reduces contamination risk, simplifies downstream purification, and improves consistency of media characterization. However, many cell types require adaptation to thrive in protein-free formulations, as they lack carrier proteins, growth factors, and other macromolecular supports.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>serum free culture medium that does not include any proteins, peptides, or hydrolysates</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ProteinHighMolecularWeighVarianttImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ProteinSizeVariantClassifier"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;roleOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;MolecularEntityPopulation">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000172"/>
										<owl:allValuesFrom>
											<owl:Class>
												<owl:unionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="&iof-construct;Protein">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-construct;ProteinAggregate">
													</rdf:Description>
												</owl:unionOf>
											</owl:Class>
										</owl:allValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;Protein">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-construct;ProteinAggregate">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>protein high molecular weight variant impurity role</rdfs:label>
		<owl:disjointWith rdf:resource="&iof-construct;ProteinLowMolecularWeightVariantImpurityRole"/>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC3564875/ and https://pmc.ncbi.nlm.nih.gov/articles/PMC9980510/ and https://www.biopharminternational.com/view/protein-impurities-pose-challenges</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>protein size variant impurity role that is held by a protein, protein aggregate, or molecular population of such entities that has a molecular weight or size greater than a reference form of the same protein</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ProteinLowMolecularWeightVariantImpurityRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ProteinSizeVariantClassifier"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;roleOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;MolecularEntityPopulation">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000172"/>
										<owl:allValuesFrom>
											<owl:Class>
												<owl:unionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="&iof-construct;Protein">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-construct;ProteinFragment">
													</rdf:Description>
												</owl:unionOf>
											</owl:Class>
										</owl:allValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;Protein">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-construct;ProteinFragment">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>protein low molecular weight variant impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://www.agilent.com/cs/library/applications/application-intact-protein-analysis-1290-bio-5994-3021en-agilent.pdf?srsltid=AfmBOord0gYpA_izWG5ho6VxaMiEr6N9eFGWe1h-RuEb88akGHX2gVrA and https://www.biopharminternational.com/view/protein-impurities-pose-challenges and https://www.sciencedirect.com/science/article/pii/S0022354922003392</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>protein size variant impurity role that is held by a protein, or molecular population of such entities that has a molecular weight or size lower than a reference form of the same protein</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ProteinSecondaryStructure">
		<rdfs:subClassOf rdf:resource="&iof-construct;PhysicalStructure"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Protein"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>protein secondary structure</rdfs:label>
		<iof-av:adaptedFrom>https://www.fda.gov/media/182387/download</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality of a protein that is the three-dimensional arrangement of its backbone segments, which depends primarily on hydrogen bonds between amino acid residues in the polypeptide chain and is characterized independently of side-chain interactions</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ProteinSizeVariantClassifier">
		<rdfs:subClassOf rdf:resource="&iof-construct;DrugProductRelatedImpurityRole"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;roleOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;MolecularEntityPopulation">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000172"/>
										<owl:allValuesFrom>
											<owl:Class>
												<owl:unionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="&iof-construct;Protein">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-construct;ProteinAggregate">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-construct;ProteinFragment">
													</rdf:Description>
												</owl:unionOf>
											</owl:Class>
										</owl:allValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-construct;Protein">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-construct;ProteinAggregate">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-construct;ProteinFragment">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>protein size variant impurity role</rdfs:label>
		<iof-av:adaptedFrom>https://pmc.ncbi.nlm.nih.gov/articles/PMC3564875/ and https://pmc.ncbi.nlm.nih.gov/articles/PMC9980510/ and https://www.biopharminternational.com/view/protein-impurities-pose-challenges and https://link.springer.com/article/10.1186/s41120-024-00096-x and https://www.fda.gov/media/182387/download</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>product related impurity role that is held by a protein, protein fragment, protein aggregate, or molecular population of such entities that differs from a reference form of the same protein by having a distinct molecular weight or size</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ProteinTertiaryStructure">
		<rdfs:subClassOf rdf:resource="&iof-construct;PhysicalStructure"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Protein"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>protein tertiary structure</rdfs:label>
		<iof-av:adaptedFrom>https://www.fda.gov/media/182387/download</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality of a protein that is the overall three-dimensional arrangement aristing from conformation of its polypeptide chain, including the spatial organization of its secondary structure elements relative to one another</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Purity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Ratio"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;DependsOnBearerPart"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:complementOf>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&bfo;BFO_0000040">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
										<owl:someValuesFrom rdf:resource="&iof-construct;ImpurityRole"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:complementOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>purity</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000209</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality that inheres in a material entity by virtue of the extent to which the material entity consists of material that is not considered an impurity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;QualityHomogeneity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Homogeneity"/>
		<rdfs:label>quality homogeneity</rdfs:label>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Radius">
		<rdfs:subClassOf rdf:resource="&iof-construct;Length"/>
		<rdfs:label>radius</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0002390</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>length of a material entity that is the straight-line spatial extent of that entity from its center to a boundary point on a circular cross-section</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Ratio">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000145"/>
		<rdfs:label>ratio</rdfs:label>
		<iof-av:directSource>http://purl.allotrope.org/ontologies/quality#AFQ_0000005</iof-av:directSource>
		<iof-av:naturalLanguageDefinition>relational quality that is the proportion of the magnitude of two qualities of the same kind</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Reconstitutability">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:label>reconstitutability</rdfs:label>
		<iof-av:naturalLanguageDefinition>capability of a dried or concentrated material entity to, when combined with an appropriate solvent, form a liquid mixture that satisfies a particular set of usage requirements</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;RefractiveIndex">
		<rdfs:subClassOf rdf:resource="&iof-construct;OpticalQuality"/>
		<rdfs:label>refractive index</rdfs:label>
		<iof-av:directSource>http://purl.allotrope.org/ontologies/quality#AFQ_0000292</iof-av:directSource>
		<iof-av:naturalLanguageDefinition>optical quality inhered in a material by virtue of how fast light travels through the material</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;RelativeAbundance">
		<rdfs:subClassOf rdf:resource="&iof-construct;Ratio"/>
		<rdfs:label>relative abundance</rdfs:label>
		<skos:example>% of high-mannose species at the end of a fed-batch step; relative abundance of a sequence variant in a drug substance lot</skos:example>
		<iof-av:adaptedFrom>https://goldbook.iupac.org/terms/view/14415 and https://www.wisdomlib.org/concept/relative-abundance</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) Relative abundance is defined only after choosing a defined group of material entities (the comparison basis). The group may be very small (e.g., the set of glycoform entities considered for one protein in one material) or very large (e.g., all atoms of an element in the universe).
2) The numerator may be the amount of one member of the group or the combined amount of a subset of members. The denominator is the total amount across the entire defined group of material entities.
3) In many analytical settings, the amounts used in the ratio are estimated from instrument responses according to a stated method and reporting convention
4) The defined group used for the numerator and denominator provides the comparison basis for the ratio. The quality may inhere in a broader material entity that contains the members of that group (e.g., a culture, mixture, intermediate pool, or product lot), with the group specifying what the relative abundance is computed over.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>ratio that is the amount of a specified member or subset of a defined group of material entities relative to the total amount of that group</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;RelativeHumidity">
		<rdfs:subClassOf rdf:resource="&iof-construct;SaturationRatio"/>
		<rdfs:label>relative humidity</rdfs:label>
		<iof-av:naturalLanguageDefinition>saturation ratio that is the extent to which water vapor is present in the mixture relative to the amount of water vapor required for saturation at the same temperature</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SaturationRatio">
		<rdfs:subClassOf rdf:resource="&iof-construct;Ratio"/>
		<rdfs:label>saturation ratio</rdfs:label>
		<iof-av:explanatoryNote>The saturation limit is the limiting (maximum) value of the corresponding saturation-relevant quality for that material entity under those conditions (e.g., concentration relative to saturation concentration; water-vapor partial pressure relative to saturation vapor pressure).</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>ratio that is the saturation-relevant quality of a material entity relative to the saturation limit of that material entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Serum">
		<rdfs:subClassOf rdf:resource="&iof-construct;HomogenousMixture"/>
		<rdfs:label>serum</rdfs:label>
		<iof-av:adaptedFrom>https://www.cancer.gov/publications/dictionaries/cancer-terms/def/serum and https://aiche.onlinelibrary.wiley.com/doi/10.1002/btpr.2706 and https://www.sigmaaldrich.com/RS/en/technical-documents/technical-article/cell-culture-and-cell-culture-analysis/mammalian-cell-culture/serum-cell-tissue-faq?srsltid=AfmBOoqsTcOCHsAwgJqKH161qBbhuNQnVpAj3Pp091G9mogrrQMyek82</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Serum is added to cell culture media as a complex, biologically derived supplement that supports cell viability and growth. It provides a broad spectrum of nutrients, growth factors, hormones, carrier proteins, and attachment or protective factors that collectively promote proliferation and maintain homeostasis in cultured cells. Because serum is obtained from blood and not chemically defined, its molecular composition can vary significantly between production lots and source populations.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>homogeneous mixture that is obtained from blood following coagulation and removal of cells and clotting factors</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SerumContainingCultureMedium">
		<rdfs:subClassOf rdf:resource="&iof-construct;CompleteCultureMedium"/>
		<rdfs:label>serum containing culture medium</rdfs:label>
		<owl:disjointWith rdf:resource="&iof-construct;SerumFreeCultureMedium"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;CompleteCultureMedium">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;Serum"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>RPMI-1640 + 10% horse serum is commonly used for hematopoietic cell lines.</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html</iof-av:adaptedFrom>
		<iof-av:counterExample>Serum-free chemically defined medium;culture medium with hydrolysates (yeastolate, soy peptone, etc.) but no animal serum</iof-av:counterExample>
		<iof-av:explanatoryNote>Serum-containing media are historically the most common type of complete culture media, typically supplemented with fetal bovine serum (FBS), calf serum, horse serum, or other animal sera. Serum provides a complex, undefined mix of nutrients, hormones, adhesion factors, binding proteins, protease inhibitors, and detoxifying agents, making such media broadly supportive of many cell types. However, the presence of serum introduces lot-to-lot variability and potential contaminants, including adventitious agents, endotoxin, and mycoplasma. In biomanufacturing, serum use raises regulatory concerns, and the trend has shifted toward serum-free and chemically defined media to improve reproducibility and control.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>complete culture medium that contains serum</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SerumFreeCultureMedium">
		<rdfs:subClassOf rdf:resource="&iof-construct;CompleteCultureMedium"/>
		<rdfs:label>serum free culture medium</rdfs:label>
		<skos:example>CD-CHO (chemically defined CHO medium) contains recombinant insulin and transferrin, no serum</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html</iof-av:adaptedFrom>
		<iof-av:counterExample>CHO production medium supplemented with bovine serum albumin (BSA from serum)</iof-av:counterExample>
		<iof-av:explanatoryNote>Serum-free media are complete culture media formulated without animal-derived serum, reducing the variability and risks associated with serum-containing formulations. They provide essential nutrients and may include recombinant proteins (e.g., insulin, transferrin), chemically defined lipids, trace elements, or other additives to support robust cell culture. Serum-free media improve reproducibility, simplify downstream purification, and are widely used in biomanufacturing because they reduce regulatory concerns and enhance lot-to-lot consistency. Many serum-free formulations are also chemically defined, but some still include hydrolysates or other complex additives.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>complete culture medium that contains no animal-derived serum</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ShearprotectiveAgentRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;ProtectiveAgentRole"/>
		<rdfs:label>shear protective agent role</rdfs:label>
		<skos:altLabel>shear protectant role</skos:altLabel>
		<skos:example>Poloxamer 188 (Pluronic F-68) is a surface-active nonionic polymer used in cell culture media to reduce shear stress from agitation and sparging; CMC blend used to increase viscosity and protect suspended materials from shear damage</skos:example>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/science/article/abs/pii/S2211926422003071#:~:text=In%20addition%2C%20shear%20protectants%20are,scale%20(500%20L%20fermenter). and https://www.merckmillipore.com/deepweb/assets/sigmaaldrich/product/documents/264/391/poloxamer-optimized-tb1249en-mk.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) This role is realized through physicochemical effects that reduce hydrodynamic stress generated by agitation, pumping, or gas sparging. Materials with this role often act by increasing viscosity, forming protective films, or modulating bubble and interface dynamics to lessen shear exposure. 
2) The term “environment” refers broadly to any liquid or multiphase system such as cell culture media, fermentation broths, or formulation buffers. 
3) The role applies to both single substances and complex mixtures whose protective effects arise from bulk material behavior.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role of a material entity that is added or planned to be added to an environment to protect other materials within that environment from mechanical damage caused by shear stress</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Solubility">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000054"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;PlannedProcess">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000057"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;Solvent"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;capabilityOf"/>
				<owl:someValuesFrom rdf:resource="&bfo;BFO_0000040"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>solubility</rdfs:label>
		<iof-av:naturalLanguageDefinition>capability of a material entity to be dissolved in a particuar solvent</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SolubilityLimit">
		<rdfs:subClassOf rdf:resource="&iof-construct;Concentration"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isConcentrationOf"/>
				<owl:allValuesFrom rdf:resource="&iof-construct;Solute"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Solution"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>solution saturation concentration</rdfs:label>
		<iof-av:adaptedFrom>https://chem.libretexts.org/Courses/Heartland_Community_College/HCC%3A_Chem_161/12%3A_Solutions/12.3%3A_Solubility_Limit_and_Saturation</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Specified conditions refers to the particular set of environmental and compositional parameters under which a solubility limit is stated. Examples include temperature; pressure (especially for gases); solvent identity and solvent composition (including mixtures); the composition and identity of any coexisting phase that constrains equilibrium (e.g., gas-phase partial pressures or the identity/polymorph of a solid phase); and solution-chemistry factors such as pH, ionic strength, and the presence and concentrations of other solutes or additives (e.g., salts, cosolvents, complexing agents, surfactants). Reported solubility limits are conditional on the stated condition set, and values may not be comparable across differing condition sets</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>concentration that is the quality of a solution that is the concentration of a dissolved solute in that solution at saturation under specified conditions</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Solute">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000040"/>
		<rdfs:label>solute</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;BFO_0000040">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;SoluteRole"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/role#AFRL_0000270</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material entity with a solute role</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SoluteRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;DissolutionRole"/>
		<rdfs:label>solute role</rdfs:label>
		<owl:disjointWith rdf:resource="&iof-construct;SolventRole"/>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/role#AFRL_0000270</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>dissolution role held by a material entity that is realized in a dissolution process where it is dispersed or dissolved within another substance (the solvent) to form a solution.</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Solution">
		<rdfs:subClassOf rdf:resource="&iof-construct;HomogenousMixture"/>
		<rdfs:label>solution</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;HomogenousMixture">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;Solute"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;Solvent"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/material#AFM_0000012</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>homogeneous mixture composed of one phase where particles are not visible to the naked eye and the solution does not scatter a light beam</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SolutionSaturationRatio">
		<rdfs:subClassOf rdf:resource="&iof-construct;SaturationRatio"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;SolubilityLimit"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Concentration">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;isConcentrationOf"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;Solute"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Solution"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>solution saturation ratio</rdfs:label>
		<iof-av:adaptedFrom>https://goldbook.iupac.org/terms/view/S05476</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>saturation ratio that is the concentration of a solute in a solution relative to the saturation concentration of that solute in the solution</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Solvent">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000040"/>
		<rdfs:label>solvent</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;BFO_0000040">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasRole"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;SolventRole"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/role#AFRL_0000269</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material entity with a solvent role</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SolventRole">
		<rdfs:subClassOf rdf:resource="&iof-construct;DissolutionRole"/>
		<rdfs:label>solvent role</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/role#AFRL_0000269</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>The bearer of solvent role may be a pure substance or a mixture (e.g., a buffer or culture medium)</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>dissolution role held by a material entity that is realized in a dissolution process where it dissolves another substance (the solute) to form a solution.</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SpecializedCultureMedium">
		<rdfs:subClassOf rdf:resource="&iof-construct;CultureMedium"/>
		<rdfs:label>specialized culture medium</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;CultureMedium">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;hasFunction"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;CultureMediumSpecializedFunction"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example>Human-Mesenchymal-XF-Expansion-Medium; Hybridoma Myeloma Cell Culture Media</skos:example>
		<iof-av:adaptedFrom>https://www.labome.com/method/Cell-Culture-Media-A-Review.html</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Specialized media are culture media developed from basal or chemically defined formulations and optimized for specific biological contexts. They may contain tailored supplements such as growth factors, cytokines, or differentiation-inducing agents, and are used either to maintain a desired cell phenotype (e.g., pluripotent stem cells) or to drive a specific outcome (e.g., neuronal differentiation, hybridoma antibody secretion). Specialized media are frequently supplied as ready-to-use commercial products and may be serum-containing or chemically defined depending on the application. They are important tools in both research and biomanufacturing, where controlled and reproducible conditions are required for specialized processes.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>culture medium that has a  culture medium specialized function</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SpecificSurfaceArea">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000145"/>
		<rdfs:label>specific surface area</rdfs:label>
		<iof-av:naturalLanguageDefinition>quality of solids that is the total surface area of a material per unit of mass, solid or bulk volume, or cross-sectional area</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Stability">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:label>stability</rdfs:label>
		<iof-av:adaptedFrom>https://database.ich.org/sites/default/files/Q1A%28R2%29%20Guideline.pdf and https://goldbook.iupac.org/terms/view/08027</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>capability of a material entity to resist change in one or more of its attributes during a particular process</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;StockSolution">
		<rdfs:subClassOf rdf:resource="&iof-construct;Solution"/>
		<rdfs:label>stock solution</rdfs:label>
		<iof-av:adaptedFrom>https://goldbook.iupac.org/terms/view/09050 and https://www.sciencedirect.com/topics/mathematics/stock-solution</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) A stock solution is usually of a greater concentration than is needed for the chemical purpose and is diluted to give the required concentration before use.
2) Because the solute concentration is accurately known, stock solutions allow reproducible preparation of dilutions or direct additions in planned processes. Their reliability depends on correct preparation and appropriate storage conditions, since degradation or evaporation can introduce concentration errors over time.
3) Dilutions of a stock solution result in creating of a working solution or an intermediate stock solution</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>solution with an accurately known solute concentration prepared so that smaller volumes can be used directly or diluted as needed for use in a planned process</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SupersaturatedState">
		<rdfs:subClassOf rdf:resource="&iof-construct;MaterialState"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000167"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Solution"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>supersaturated state</rdfs:label>
		<iof-av:adaptedFrom>https://goldbook.iupac.org/terms/view/12730</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Prevailing conditions in this context are the environmental and compositional variables that determine the solute’s equilibrium solubility for that solution at that time, typically including temperature and pH, and, where relevant, solvent composition (e.g., cosolvents), ionic strength, and the presence of other solutes/excipients that measurably shift solubility.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>material state of a solution in which the dissolved solute concentration stays above the solute’s equilibrium solubility in the same solvent under the prevailing conditions for the duration of the state</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SurfaceTension">
		<rdfs:subClassOf rdf:resource="&iof-construct;Adhesion"/>
		<rdfs:label>surface tension</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001461 and https://goldbook.iupac.org/terms/view/S06192</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality of a liquid that is the unbalanced cohesive force acting on molecules at the liquid’s surface as a result of intermolecular attractions, thereby resisting an increase in the liquid’s surface area</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;SurfactantRole">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000023"/>
		<rdfs:label>surfactant role</rdfs:label>
		<skos:example>Polysorbate 80 added to culture medium to improve wetting and dispersion; Sodium dodecyl sulfate added to aqueous buffer to reduce interfacial tension</skos:example>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/CHEBI_35195</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>The term “medium” refers broadly to any surrounding phase system such as liquid, gas, or solid, not only to culture media. Materials with this role are used to promote wetting, dispersion, emulsification, or cleaning, and may consist of single compounds or formulated mixtures.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>role of a material entity that is added or planned to be added to lower the surface tension of a medium or the interfacial tension between a medium and other phases, and that becomes positively adsorbed at liquid–vapor or other interfaces</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;TapDensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;MassDensity"/>
		<rdfs:label>tap density</rdfs:label>
		<iof-av:adaptedFrom>https://www.3p-instruments.com/measurement-methods/density-tapping-volumetry/</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>mass density that is the mass per volume occupied by a collection of particles after being tapped until no further volume change is observed</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ThermalStability">
		<rdfs:subClassOf rdf:resource="&iof-construct;Stability"/>
		<rdfs:label>thermal stability</rdfs:label>
		<iof-av:naturalLanguageDefinition>stability that is the capability of a material entity to resist change in one or more of its attributes during a process in which the material entity is exposed to a particular temperature condition</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ThreeDimensionalPhysicalExtent">
		<rdfs:subClassOf rdf:resource="&iof-construct;PhysicalSize"/>
		<rdfs:label>three dimensional physical extent</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001710</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>physical size that is the spatial extent of a material entity in three dimensions</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;TotalCellCount">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellCount"/>
		<rdfs:label>total cell count</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000186</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>cell count over a mereological sum of a partitioned aggregate of cells</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;TotalCellDensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellDensity"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;TotalCellCount"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>total cell density</rdfs:label>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/topics/medicine-and-dentistry/cell-density and https://www.sigmaaldrich.com/US/en/technical-documents/protocol/analytical-chemistry/photometry-and-reflectometry/cell-density-measurement-by-od600-method?srsltid=AfmBOoqxMLTlROXCkIoHCGlcNFWUSSZvftakFCMkyCL5l9gpB-s7B3yL and http://purl.allotrope.org/ontologies/quality#AFQ_0000181</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>cell density of the total partition of cells</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Turbidity">
		<rdfs:subClassOf rdf:resource="&iof-construct;OpticalQuality"/>
		<rdfs:label>turbidity</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000290</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>optical quality that is the apparent absorbance of incident light due to scattering</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;TwoDimensionalPhysicalExtent">
		<rdfs:subClassOf rdf:resource="&iof-construct;PhysicalSize"/>
		<rdfs:label>two dimensional physical extent</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001709</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>physical size that is the spatial extent of a material entity in two dimensions</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Viability">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>viability</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000169</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality inhering in a bearer or a population by virtue of the bearer&apos;s disposition to survive and develop normally or the number of surviving individuals in a given population</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Viable">
		<rdfs:subClassOf rdf:resource="&iof-construct;Viability"/>
		<rdfs:label>viable</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000719</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality inhering in a bearer or a population by virtue of the bearer&apos;s ability to survive or the long term survival ability of a given population</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ViableCellCount">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellCount"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isCountOf"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Cell">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;hasQuality"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;Viable"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>viable cell count</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000185</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>cell count of the partition of viable cells</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;ViableCellDensity">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellDensity"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;ViableCellCount"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>viable cell density</rdfs:label>
		<iof-av:acronym>VCD</iof-av:acronym>
		<iof-av:adaptedFrom>https://www.sartorius.com/download/501934/online-monitoring-of-viable-cell-concentrations-in-small-bioreactors-data.pdf and http://purl.allotrope.org/ontologies/quality#AFQ_0000182</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>Viable cell density accounts for only those cells that are alive and capable of maintaining essential physiological activities such as metabolism, growth, and proliferation. It is commonly reported as viable cells per unit volume (e.g. cells/mL) or per unit area (e.g. cells/cm²).</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>cell density of the partition of viable cells</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Virus">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000030"/>
		<rdfs:label>virus</rdfs:label>
		<iof-av:adaptedFrom>http://id.nlm.nih.gov/mesh/D014780</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>organism whose genome is composed of DNA or RNA, but not both, that lacks independent metabolism and can replicate only within living host cells</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;VirusSeed">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000027"/>
		<rdfs:label>virus seed</rdfs:label>
		<skos:example>master virus seed stock for production of an adenovirus-based vaccine, consisting of multiple frozen aliquots derived from a single characterized virus preparation; working virus seed vials prepared from the master virus seed and used to initiate manufacturing of viral vectors for gene therapy production</skos:example>
		<iof-av:adaptedFrom>https://www.ema.europa.eu/en/documents/scientific-guideline/ich-q5ar2-guideline-viral-safety-evaluation-biotechnology-products-derived-cell-lines-human-or-animal-origin-step-5_en.pdf and https://extranet.who.int/prequal/glossary-acronyms/s#:~:text=A%20master%20seed%20lot%20</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>object aggregate that has as parts aliquots of a virus preparation derived from a single, well-defined virus source, prepared and stored under controlled conditions, and maintained as a referenceable lot to provide consistent starting material for research, development, manufacturing, or the generation of new virus seeds</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Viscosity">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:label>viscosity</rdfs:label>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/topics/engineering/fluid-viscosity and https://pmc.ncbi.nlm.nih.gov/articles/PMC1258811/ and http://purl.obolibrary.org/obo/PATO_0000992</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) Viscosity is a material quality grounded in interactions among constituents of a fluid. In solutions and suspensions it reflects, among other factors, solvent–solute interactions, concentration, molecular association or aggregation, and the size and shape of dissolved or suspended entities. These features condition the degree of internal friction opposing relative motion within the fluid. 
2) In fluid mechanics, viscosity characterizes how readily a fluid undergoes motion under shear generated by agitation, pressure-driven flow, or gravity-driven flow. 
3) In bioprocessing and formulation, viscosity affects mixing efficiency and mixing time, the shear environment experienced by cells or particles, pumpability and pressure drop, filtration behavior, and the maintenance of homogeneous distributions of solutes or suspended matter.
4) Process actions such as adjusting temperature or formulation composition may be used to manage viscosity so that transfer and mixing operations remain predictable and controlled.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>quality of a fluid that is its resistance to shear deformation, manifested as internal friction opposing relative motion between adjacent parts of the fluid</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Volume">
		<rdfs:subClassOf rdf:resource="&iof-construct;ThreeDimensionalPhysicalExtent"/>
		<rdfs:label>volume</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000918</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>three dimensional spatial extent that is quality of a material entity and is the amount of three dimensional space the material entity occupies</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;VolumeFraction">
		<rdfs:subClassOf rdf:resource="&iof-construct;Fraction"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Volume"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>volume fraction</rdfs:label>
		<iof-av:adaptedFrom>http://purl.allotrope.org/ontologies/quality#AFQ_0000169</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>fraction pertaining the volume of a constituent divided by the total volume of all constituents in the mixture</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Water">
		<rdfs:subClassOf rdf:resource="&iof-construct;HomogenousMixture"/>
		<rdfs:label>water</rdfs:label>
		<iof-av:explanatoryNote>1) This class represents materials whose predominant constituent is water and that contain only low-level impurities arising from production, handling, or environmental exchange, without any intentionally added solutes. It is intended to capture the common, practical meaning of “water” as used in scientific, industrial, and pharmaceutical settings. For most modeling purposes, this is the appropriate class for representing water because real-world water is almost never a fully chemically pure substance and does not consist solely of H₂O molecules.
2) This class is explicitly distinct from the molecular entity “water,” which represents the H₂O molecule as a chemical species. The molecular entity should be used only when referring to water at the level of individual molecules or chemical reactions, whereas this class should be used for bulk water materials, water grades, and water handled as part of processes. 
3) The class excludes aqueous solutions with intentionally added solutes and mixtures in which water is not the principal constituent.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>homogenous mixture composed predominantly of water molecules and containing only low-level impurities that arise from production, handling, or environmental exchange</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;WaterForInjection">
		<rdfs:subClassOf rdf:resource="&iof-construct;Water"/>
		<rdfs:label>water for injection</rdfs:label>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-construct;Water">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-construct;classifiedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-construct;WaterForInjectionClassifier"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:explanatoryNote>See the expanded definition under the corresponding classifier class</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>water that is classified by a water for injection classifier</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;WaterForInjectionClassifier">
		<rdfs:subClassOf rdf:resource="&iof-construct;CompendialGradeClassifier"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;classifies"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-construct;Water">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-construct;hasQuality"/>
								<owl:someValuesFrom rdf:resource="&iof-construct;Purity"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>water for injection classifier</rdfs:label>
		<iof-av:adaptedFrom>https://www.fda.gov/inspections-compliance-enforcement-and-criminal-investigations/inspection-technical-guides/water-pharmaceutical-use and https://www.ema.europa.eu/en/documents/scientific-guideline/note-guidance-quality-water-pharmaceutical-use_en.pdf and https://www.cytivalifesciences.com/en/us/insights/what-is-water-for-injection</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) The Water for Injection (WFI) grade is a compendial classification applied to water when conformance to an applicable WFI monograph has been demonstrated. In the European context, the EMA guideline points to compliance with the European Pharmacopoeia WFI monograph. In the U.S. context, FDA inspection guidance frames WFI as a USP monograph-defined water grade.
2) In regulatory and GMP practice, “WFI” is best treated as a compendial-grade designation: a batch of water is WFI because it meets the WFI monograph requirements, and it can lose that designation if storage/distribution conditions allow microbial proliferation or endotoxin risk to rise</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>compendial grade classifier that classifies a water that conforms to the requirements stated in a Water for Injection pharmacopeial monograph and thus has very high purity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Weight">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000019"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;isPhysicallyGroundedIn"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;Mass"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>weight</rdfs:label>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0000128</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>quality of a material entity that is the magnitude of the gravitational force exerted on that entity by a gravitational field, in virtue of the entity’s mass</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;Wettability">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capability"/>
		<rdfs:label>wettability</rdfs:label>
		<iof-av:adaptedFrom>1) Being wetted means a liquid spreads over a solid material and maintains contact with it at the solid–liquid interface, rather than beading up into discrete droplets, under the prevailing interfacial conditions.
2)Wettability is realized in liquid–solid contact situations and is influenced by interfacial interactions between the solid and the liquid and by the surrounding phase. The same concept applies to a continuous solid surface and to particulate or granular solids, where the capability is manifested through wetting of the available solid surfaces and, at the bulk level, through penetration of liquid into the material and reduction of persistent dry regions. In practice, contact angles are a common way to operationalize wettability for smooth surfaces, while powders are often characterized through liquid uptake, immersion, or penetration behaviors.</iof-av:adaptedFrom>
		<iof-av:adaptedFrom>https://www.sciencedirect.com/topics/materials-science/wettability and https://store.astm.org/d7334-08.html and https://www.iso.org/obp/ui#iso:std:iso:862:ed-1:v1:en:term:99 and https://onlinelibrary.wiley.com/doi/abs/10.1002/ppsc.200400931</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition>capability of a solid material to be wetted by a liquid</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;WorkingCellBank">
		<rdfs:subClassOf rdf:resource="&iof-construct;CellBank"/>
		<rdfs:label>working cell bank</rdfs:label>
		<iof-av:adaptedFrom>https://www.ema.europa.eu/en/documents/scientific-guideline/ich-q-5-d-derivation-and-characterisation-cell-substrates-used-production-biotechnologicalbiological-products-step-5_en.pdf</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>The source cells are expanded into a homogeneous suspension from one or more vials of the master cell bank, dispensed into multiple uniform containers, and cryopreserved under validated long-term storage conditions. The resulting working cell bank serves as the routine production cell source, allowing repeated use while minimizing the need to access the master cell bank directly.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>cell bank that has as members cryopreserved cell aliquots prepared from one or more aliquots of a master cell bank and stored under validated cryogenic conditions for routine operational use in research development or manufacturing</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;WorkingSolution">
		<rdfs:subClassOf rdf:resource="&iof-construct;Solution"/>
		<rdfs:label>working solution</rdfs:label>
		<skos:example>50 mM Tris-HCl prepared by diluting a 1 M Tris stock solution for use in an enzymatic assay</skos:example>
		<iof-av:adaptedFrom>https://www.fda.gov/regulatory-information/search-fda-guidance-documents/m10-bioanalytical-method-validation-and-study-sample-analysis and http://champ-project.org/images/ontology/cao.owl#CAO_000214</iof-av:adaptedFrom>
		<iof-av:counterExample>A 1 M Tris-HCl stock solution stored for later dilutions</iof-av:counterExample>
		<iof-av:explanatoryNote>Working solutions are derived from stock solutions and adjusted to the concentrations required for assays, buffer systems, culture additives, or other procedures. They are intended for immediate or short-term use and are usually less concentrated than the stock from which they are prepared.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>solution prepared by diluting a stock or intermediate stock solution to the concentration required for direct use in a planned process that is not itself a dilution process</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;WorkingVolume">
		<rdfs:subClassOf rdf:resource="&iof-construct;Volume"/>
		<rdfs:label>working volume</rdfs:label>
		<iof-av:explanatoryNote>Working volume as defined here is distinct from working volume capacity, which is a vessel capacity, and from total vessel volume, which is a geometric container volume of the vessel</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>volume that is a quality of process material and that is the amount of space occupied by that process material in a vessel</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-construct;WorkingVolumeCapacity">
		<rdfs:subClassOf rdf:resource="&iof-construct;Capacity"/>
		<rdfs:label>working volume capacity</rdfs:label>
		<iof-av:adaptedFrom>https://a-z-singleuse.org/singleuse/en/Glossary/W/Working+volume+%28bioreactor%29.html</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>1) “Normal operating conditions” covers the vessel’s intended mode of operation and practical constraints such as mixing, gas transfer, control and sensing, headspace and foaming margin, and safe operation.
2) For bioreactors, the usable operating liquid volume is typically a fraction of the bioreactor’s total volume and depends on the bioreactor design and operating mode.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>capacity that is the capability of a vessel to contain a volume of process material under normal operating conditions</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:ObjectProperty rdf:about="&iof-construct;isAmountOf">
		<rdfs:subPropertyOf rdf:resource="&iof-construct;DependsOnBearerPart"/>
		<rdfs:label>is amount of</rdfs:label>
	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&iof-construct;isConcentrationOf">
		<rdfs:subPropertyOf rdf:resource="&iof-construct;DependsOnBearerPart"/>
		<rdfs:label>is concentration of</rdfs:label>
		<rdfs:domain rdf:resource="&iof-construct;Concentration"/>
		<rdfs:range rdf:resource="&bfo;BFO_0000040"/>
		<iof-av:naturalLanguageDefinition>relation between a concentration q and a material entity m that holds when q inheres in some material entity x, m is part of x, and q specifically depends on m</iof-av:naturalLanguageDefinition>
	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&iof-construct;isCountOf">
		<rdfs:subPropertyOf rdf:resource="&iof-construct;isAmountOf"/>
		<rdfs:label>is count of</rdfs:label>
		<rdfs:domain rdf:resource="&iof-construct;Amount"/>
	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&iof-construct;isFractionOf">
		<rdfs:subPropertyOf rdf:resource="&iof-construct;DependsOnBearerPart"/>
		<rdfs:label>is fraction of</rdfs:label>
		<rdfs:domain rdf:resource="&iof-construct;Fraction"/>
	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&iof-construct;isPartialPressureOf">
		<rdfs:subPropertyOf rdf:resource="&iof-construct;DependsOnBearerPart"/>
		<rdfs:label>is partial pressure of</rdfs:label>
		<rdfs:domain rdf:resource="&iof-construct;PartialPressure"/>
		<rdfs:range rdf:resource="&bfo;BFO_0000040"/>
		<iof-av:naturalLanguageDefinition>relation between a partial pressure q and a material entity m that holds when q inheres in some material entity x, m is part of x, and q specifically depends on m</iof-av:naturalLanguageDefinition>
	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&iof-construct;isPhysicallyGroundedIn">
		<rdf:type rdf:resource="&owl;TransitiveProperty"/>
		<rdfs:subPropertyOf rdf:resource="&owl;topObjectProperty"/>
		<rdfs:label>is physically grounded in</rdfs:label>
	</owl:ObjectProperty>
	
	<owl:Class rdf:about="&iof-construct;pH">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000145"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-construct;qualityOf"/>
				<owl:someValuesFrom rdf:resource="&iof-construct;HomogenousMixture"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>pH</rdfs:label>
		<skos:altLabel>acidity</skos:altLabel>
		<iof-av:adaptedFrom>http://purl.obolibrary.org/obo/PATO_0001842 and http://purl.obolibrary.org/obo/NCIT_C45997</iof-av:adaptedFrom>
		<iof-av:explanatoryNote>In common scientific and biopharmaceutical usage, “pH” and “acidity” are treated as interchangeable terms, which is reflected here by providing “acidity” as an alternative label. Although pH is formally a logarithmic transformation of hydrogen-ion activity, the distinction between the underlying hydrogen-ion concentration and its logarithmic representation is routinely collapsed in industry practice. Conventionally, pH is defined as the negative decimal logarithm of the hydrogen-ion activity, yielding a dimensionless scalar quantity commonly reported on a scale near 0 to 14. This quality inheres in a homogeneous typically aqueous phase of a material; in heterogeneous systems, pH refers specifically to that aqueous phase, not to the heterogeneous material as a whole.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition>quality of a homogeneous mixture that is the concentration or activity of hydrogen ions in that mixture</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:AllDisjointClasses>
		<owl:members rdf:parseType="Collection">
			<rdf:Description rdf:about="&iof-construct;Cell">
			</rdf:Description>
			<rdf:Description rdf:about="&iof-construct;CellCulture">
			</rdf:Description>
			<rdf:Description rdf:about="&iof-construct;CultureMedium">
			</rdf:Description>
			<rdf:Description rdf:about="&iof-construct;CulturedCellPopulation">
			</rdf:Description>
		</owl:members>
	</owl:AllDisjointClasses>
	<owl:AllDisjointClasses>
		<owl:members rdf:parseType="Collection">
			<rdf:Description rdf:about="&iof-construct;Osmolality">
			</rdf:Description>
			<rdf:Description rdf:about="&iof-construct;Osmolarity">
			</rdf:Description>
			<rdf:Description rdf:about="&iof-construct;Pressure">
			</rdf:Description>
			<rdf:Description rdf:about="&iof-construct;pH">
			</rdf:Description>
		</owl:members>
	</owl:AllDisjointClasses>
</rdf:RDF>