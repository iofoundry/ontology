<rdf:RDF xml:base="https://spec.industrialontologies.org/ontology/biopharma/PSOAClassLevelMappingExample"
	xmlns:bfo="http://purl.obolibrary.org/obo/"
	xmlns:bmic-manufacturingexecution="https://spec.industrialontologies.org/ontology/biopharma/ManufacturingExecution/"
	xmlns:bmic-material="https://spec.industrialontologies.org/ontology/biopharma/Material/"
