    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test4-ProductionOrder -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test4-ProductionOrder">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/ObjectiveSpecification"/>
        <construct:isAchievedByAtSomeTime rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProductProductionProcess1"/>
        <rdfs:comment>General Class axioms:

ObjectiveSpecification and (isAchievedByAtSomeTime some ProductProductionProcess) SubClassOf ProductionOrder</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test5-InspectionPlan -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test5-InspectionPlan">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlanSpecification"/>
        <construct:prescribes rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProductInspectionProcess1"/>
        <rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some ProductInspectionProcess) SubClassOf InspectionPlan</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test6-MaterialHandlingPlan -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test6-MaterialHandlingPlan">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlanSpecification"/>
        <obo:BFO_0000110 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#1-prescribes-MachineTransferProcess"/>
        <rdfs:comment>General Class axioms:

PlanSpecification and (&apos;has continuant part at all times&apos; some (prescribes some MachineTransferProcess)) SubClassOf MaterialHandlingPlan</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test7-ProcessPlan -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test7-ProcessPlan">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlanSpecification"/>
        <obo:BFO_0000111 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#InspectionPlan1"/>
        <obo:BFO_0000111 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ObjectiveSpecification1"/>
        <rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some (&apos;occurrent part of&apos; some ProductProductionProcess)) SubClassOf ProcessPlan</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test8-ProductionPlan -->

