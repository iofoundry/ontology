        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/ActionSpecification"/>
        <construct:prescribes rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ManufacturingOperation1"/>
        <rdfs:comment>General Class axioms:

ActionSpecification and (prescribes some ManufacturingOperation) SubClassOf OperationSpecification</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test10-Machine -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test10-Machine">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test11-ProductionMachine -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test11-ProductionMachine">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/Machine"/>
        <rdfs:comment>SubClass Of:

Machine
 and (hasRole some 
    (EquipmentRole
     and (&apos;has realization&apos; only ManufacturingProcess)))</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test12-ProductionTool -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test12-ProductionTool">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:comment>SubClass Of:

hasRole some 
    (EquipmentRole
     and (&apos;has realization&apos; only ManufacturingProcess))

MaterialArtifact</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test13-AgentialCapability -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test13-AgentialCapability">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/Capability"/>
        <rdfs:comment>Equivalent To:

Capability
 and (capabilityOf some Agent)</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test14-OperatorRole -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test14-OperatorRole">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/AgentRole"/>
        <rdfs:comment>General Class axioms:

DesignSpecification and (prescribes some MaterialProduct) SubClassOf MaterialProductSpecification</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test15-ProductInspectionProcess -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test15-ProductInspectionProcess">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/BusinessProcess"/>
        <rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some ProductInspectionProcess) SubClassOf InspectionPlan</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test16-ManufacturingEnterpriseProcess -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test16-ManufacturingEnterpriseProcess">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:comment>SubClass Of:

&apos;has occurrent part&apos; some ManufacturingProcess

Planned Process</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test17-ManufacturingOperation -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test17-ManufacturingOperation">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/ManufacturingEnterpriseProcess"/>
        <rdfs:comment>SubClass Of:

ManufacturingEnterpriseProcess
 and (&apos;has participant at some time&apos; some 
    (&apos;material entity&apos;
     and (hasRole some 
        (EquipmentRole or OperatorRole))))
 and (&apos;has proper occurrent part&apos; some ProcessStep)</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test18-ProcessStep -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test18-ProcessStep">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/ManufacturingEnterpriseProcess"/>
        <rdfs:comment>SubClass Of:

ManufacturingEnterpriseProcess
 and (&apos;has proper occurrent part&apos; some ManufacturingProcess)</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test19-MachineTransferProcess -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test19-MachineTransferProcess">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialLocationChangeProcess"/>
        <rdfs:comment>SubClass Of:

MaterialLocationChangeProcess
 and (&apos;has participant at some time&apos; some 
    (&apos;material entity&apos;
     and ( inverse (&apos;location of at all times&apos;) some 
        (ProductionMachine
         and (&apos;located in at all times&apos; some site)
         and (&apos;exists at&apos; some 
            (&apos;temporal instant&apos;
             and ((&apos;first instant of&apos; some &apos;temporal region&apos;)
             and ( inverse (&apos;occupies temporal region&apos;) some PlannedProcess))))))
     and ( inverse (&apos;location of at all times&apos;) some 
        (ProductionMachine
         and (&apos;located in at all times&apos; some site)
         and (&apos;exists at&apos; some 
            (&apos;temporal instant&apos;
             and (&apos;last instant of&apos; some 
                (&apos;temporal region&apos;
                 and ( inverse (&apos;occupies temporal region&apos;) some PlannedProcess)))))))))</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test2-ProcessStepSpecification -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test2-ProcessStepSpecification">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/ActionSpecification"/>
