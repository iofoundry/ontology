        <rdfs:comment>General Class axioms:

ActionSpecification and (prescribes some ProcessStep) SubClassOf ProcessStepSpecification</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test20-SetupProcess -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test20-SetupProcess">
