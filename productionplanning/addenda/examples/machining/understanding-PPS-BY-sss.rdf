        <rdfs:comment>SubClass Of:

PlannedProcess</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test3-MaterialProductSpecification -->

