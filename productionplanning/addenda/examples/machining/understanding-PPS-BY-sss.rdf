        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlanSpecification"/>
        <obo:BFO_0000110 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#InspectionPlan1"/>
        <obo:BFO_0000111 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProductionOrder1"/>
        <rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some ProductProductionProcess) SubClassOf ProductionPlan</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test9-Operator -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test9-Operator">
        <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/construct/Agent"/>
        <rdfs:comment>Equivalent To:

Agent
 and (hasRole some OperatorRole)</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#1-prescribes-MachineTransferProcess -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#1-prescribes-MachineTransferProcess">
        <construct:prescribes rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#MachineTransferProcess1"/>
    </owl:NamedIndividual>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // General axioms
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
