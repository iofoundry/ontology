]>
<rdf:RDF xml:base="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/"
	xmlns="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2/"
	xmlns:annotation="https://spec.industrialontologies.org/ontology/annotation/"
	xmlns:construct="https://spec.industrialontologies.org/ontology/construct/"
	xmlns:dc="http://purl.org/dc/elements/1.1/"
	xmlns:obo="http://purl.obolibrary.org/obo/"
	xmlns:owl="http://www.w3.org/2002/07/owl#"
	xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
	xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
	xmlns:skos="http://www.w3.org/2004/02/skos/core#"
	xmlns:terms="http://purl.org/dc/terms/"
	xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
	
	<owl:Ontology rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/">
		<rdfs:comment>This is a testing on individual level for the &quot;initial version of Production planning ontology (https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/) - version 202502&quot;</rdfs:comment>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202502/productionplanning/ProductionPlanning/"/>
	</owl:Ontology>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#1-prescribes-MachineTransferProcess">
		<construct:prescribes rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MachineTransferProcess1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#2-occurentpartof-ProductProductionProcess">
		<obo:BFO_0000132 rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProductProductionProcess1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Agent1">
		<rdf:type rdf:resource="&construct;Agent"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Agreement1">
		<rdf:type rdf:resource="&construct;Agreement"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#EquipmentRole1">
		<rdf:type rdf:resource="&construct;EquipmentRole"/>
		<obo:BFO_0000054 rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ManufacturingProcess1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ICE1">
		<rdf:type rdf:resource="&construct;ObjectiveSpecification"/>
		<obo:BFO_0000110 rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialProductSpecification1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#InspectionPlan1">
		<rdf:type rdf:resource="&construct;InspectionPlan"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Machine1">
		<rdf:type rdf:resource="&construct;Machine"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MachineTransferProcess1">
		<rdf:type rdf:resource="&construct;MachineTransferProcess"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ManufacturingOperation1">
		<rdf:type rdf:resource="&construct;ManufacturingOperation"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ManufacturingProcess1">
		<rdf:type rdf:resource="&construct;ManufacturingProcess"/>
	</owl:NamedIndividual>
	
	<owl:Class rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialEntity">
	</owl:Class>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialEntity1">
		<rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialEntity"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialHandlingPlan1">
		<rdf:type rdf:resource="&construct;MaterialHandlingPlan"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialProduct1">
		<rdf:type rdf:resource="&construct;MaterialProduct"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialProductSpecification1">
		<rdf:type rdf:resource="&construct;MaterialProductSpecification"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ObjectiveSpecification1">
		<rdf:type rdf:resource="&construct;ObjectiveSpecification"/>
		<obo:BFO_0000110 rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialProductSpecification1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#OperationSpecification1">
		<rdf:type rdf:resource="&construct;OperationSpecification"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#OperatorRole1">
		<rdf:type rdf:resource="&construct;OperatorRole"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#PlanSpecification1">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProcessPlan1">
		<rdf:type rdf:resource="&construct;ProcessPlan"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProcessStep1">
		<rdf:type rdf:resource="&construct;ProcessStep"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProcessStepSpecification1">
		<rdf:type rdf:resource="&construct;ProcessStepSpecification"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProductInspectionProcess1">
		<rdf:type rdf:resource="&construct;ProductInspectionProcess"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProductProductionProcess1">
		<rdf:type rdf:resource="&construct;ProductProductionProcess"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProductionOrder1">
		<rdf:type rdf:resource="&construct;ProductionOrder"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProductionTool1">
		<rdf:type rdf:resource="&construct;ProductionTool"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test01-OperationSpecification">
		<rdf:type rdf:resource="&construct;ActionSpecification"/>
		<rdfs:comment>General Class axioms:

ActionSpecification and (prescribes some ManufacturingOperation) SubClassOf OperationSpecification</rdfs:comment>
		<construct:prescribes rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ManufacturingOperation1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test02-ProcessStepSpecification">
		<rdf:type rdf:resource="&construct;ActionSpecification"/>
		<rdfs:comment>General Class axioms:

ActionSpecification and (prescribes some ProcessStep) SubClassOf ProcessStepSpecification</rdfs:comment>
		<construct:prescribes rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProcessStep1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test03-MaterialProductSpecification">
		<rdf:type rdf:resource="&construct;DesignSpecification"/>
		<rdfs:comment>General Class axioms:

DesignSpecification and (prescribes some MaterialProduct) SubClassOf MaterialProductSpecification</rdfs:comment>
		<construct:prescribes rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialProduct1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test04-ProductionOrder">
		<rdf:type rdf:resource="&construct;ObjectiveSpecification"/>
		<rdfs:comment>General Class axioms:

ObjectiveSpecification and (isAchievedByAtSomeTime some ProductProductionProcess) SubClassOf ProductionOrder</rdfs:comment>
		<construct:isAchievedByAtSomeTime rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProductProductionProcess1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test05-InspectionPlan">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
		<rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some ProductInspectionProcess) SubClassOf InspectionPlan</rdfs:comment>
		<construct:prescribes rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProductInspectionProcess1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test06-MaterialHandlingPlan">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
		<rdfs:comment>General Class axioms:

PlanSpecification and (&apos;has continuant part at all times&apos; some (prescribes some MachineTransferProcess)) SubClassOf MaterialHandlingPlan</rdfs:comment>
		<obo:BFO_0000110 rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#1-prescribes-MachineTransferProcess"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test07-ProcessPlan">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
		<rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some (&apos;occurrent part of&apos; some ProductProductionProcess)) SubClassOf ProcessPlan</rdfs:comment>
		<construct:prescribes rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#2-occurentpartof-ProductProductionProcess"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test07E-ProcessPlan">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
		<rdfs:comment>Equivalent To:

PlanSpecification
 and (&apos;has proper continuant part at all times&apos; only 
    (ObjectiveSpecification
     and (&apos;has continuant part at all times&apos; some MaterialProductSpecification)))
 and (&apos;has proper continuant part at all times&apos; only 
    (OperationSpecification or ProcessStepSpecification))</rdfs:comment>
		<obo:BFO_0000111 rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#OperationSpecification1"/>
		<obo:BFO_0000111 rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/3-HTB-ObjectiveSpec"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test08-ProductionPlan">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
		<rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some ProductProductionProcess) SubClassOf ProductionPlan</rdfs:comment>
		<obo:BFO_0000110 rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#InspectionPlan1"/>
		<obo:BFO_0000111 rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#ProductionOrder1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test09-Operator">
		<rdf:type rdf:resource="&construct;Agent"/>
		<rdfs:comment>Equivalent To:

Agent
 and (hasRole some OperatorRole)</rdfs:comment>
		<construct:hasRole rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#OperatorRole1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test10-Machine">
		<rdf:type rdf:resource="&construct;MaterialArtifact"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test11-ProductionMachine">
		<rdf:type rdf:resource="&construct;Machine"/>
		<rdfs:comment>SubClass Of:

Machine
 and (hasRole some 
    (EquipmentRole
     and (&apos;has realization&apos; only ManufacturingProcess)))</rdfs:comment>
		<construct:hasRole rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#EquipmentRole1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test12-ProductionTool">
		<rdf:type rdf:resource="&construct;MaterialArtifact"/>
		<rdfs:comment>SubClass Of:

hasRole some 
    (EquipmentRole
     and (&apos;has realization&apos; only ManufacturingProcess))

MaterialArtifact</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test13-AgentialCapability">
		<rdf:type rdf:resource="&construct;Capability"/>
		<rdfs:comment>Equivalent To:

Capability
 and (capabilityOf some Agent)</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test14-OperatorRole">
		<rdf:type rdf:resource="&construct;AgentRole"/>
		<rdfs:comment>General Class axioms:

DesignSpecification and (prescribes some MaterialProduct) SubClassOf MaterialProductSpecification</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test15-ProductInspectionProcess">
		<rdf:type rdf:resource="&construct;BusinessProcess"/>
		<rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some ProductInspectionProcess) SubClassOf InspectionPlan</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test16-ManufacturingEnterpriseProcess">
		<rdf:type rdf:resource="&construct;PlannedProcess"/>
		<rdfs:comment>SubClass Of:

&apos;has occurrent part&apos; some ManufacturingProcess

Planned Process</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test17-ManufacturingOperation">
		<rdf:type rdf:resource="&construct;ManufacturingEnterpriseProcess"/>
		<rdfs:comment>SubClass Of:

ManufacturingEnterpriseProcess
 and (&apos;has participant at some time&apos; some 
    (&apos;material entity&apos;
     and (hasRole some 
        (EquipmentRole or OperatorRole))))
 and (&apos;has proper occurrent part&apos; some ProcessStep)</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test18-ProcessStep">
		<rdf:type rdf:resource="&construct;ManufacturingEnterpriseProcess"/>
		<rdfs:comment>SubClass Of:

ManufacturingEnterpriseProcess
 and (&apos;has proper occurrent part&apos; some ManufacturingProcess)</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test19-MachineTransferProcess">
		<rdf:type rdf:resource="&construct;MaterialLocationChangeProcess"/>
		<rdfs:comment>SubClass Of:

MaterialLocationChangeProcess
 and (&apos;has participant at some time&apos; some 
    (&apos;material entity&apos;
     and ( inverse (&apos;location of at all times&apos;) some 
        (ProductionMachine
         and (&apos;located in at all times&apos; some site)
         and (&apos;exists at&apos; some 
            (&apos;temporal instant&apos;
             and ((&apos;first instant of&apos; some &apos;temporal region&apos;)
             and ( inverse (&apos;occupies temporal region&apos;) some PlannedProcess))))))
     and ( inverse (&apos;location of at all times&apos;) some 
        (ProductionMachine
         and (&apos;located in at all times&apos; some site)
         and (&apos;exists at&apos; some 
            (&apos;temporal instant&apos;
             and (&apos;last instant of&apos; some 
                (&apos;temporal region&apos;
                 and ( inverse (&apos;occupies temporal region&apos;) some PlannedProcess)))))))))</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#Test20-SetupProcess">
		<rdf:type rdf:resource="&construct;PlannedProcess"/>
		<rdfs:comment>SubClass Of:

PlannedProcess</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/3-HTB-ObjectiveSpec">
		<obo:BFO_0000110 rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialProductSpecification1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/Test03E-MaterialProductSpecification">
		<rdf:type rdf:resource="&construct;DesignSpecification"/>
		<rdfs:comment>Equivalent To:

DesignSpecification
 and (prescribes only MaterialProduct)</rdfs:comment>
		<construct:prescribes rdf:resource="https://spec.industrialontologies.org/ontology/productionplanning/ProductionPlanning/ReasoningTest-V1/#MaterialProduct1"/>
	</owl:NamedIndividual>
	
	<owl:Class>
		<rdfs:subClassOf rdf:resource="&construct;ProductionMachine"/>
		<owl:intersectionOf rdf:parseType="Collection">
			<rdf:Description rdf:about="&construct;Machine">
			</rdf:Description>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&construct;hasRole"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&construct;EquipmentRole">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&obo;BFO_0000054"/>
								<owl:allValuesFrom rdf:resource="&construct;ManufacturingProcess"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</owl:intersectionOf>
	</owl:Class>
</rdf:RDF>