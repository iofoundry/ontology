	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#MachineTransferProcess1">
		<rdf:type rdf:resource="&construct;MachineTransferProcess"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ManufacturingOperation1">
		<rdf:type rdf:resource="&construct;ManufacturingOperation"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ManufacturingProcess1">
		<rdf:type rdf:resource="&construct;ManufacturingProcess"/>
	</owl:NamedIndividual>
	
	<owl:Class rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#MaterialEntity">
	</owl:Class>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#MaterialEntity1">
		<rdf:type rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#MaterialEntity"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#MaterialHandlingPlan1">
