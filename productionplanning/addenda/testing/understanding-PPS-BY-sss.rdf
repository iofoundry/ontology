	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#MaterialProduct1">
		<rdf:type rdf:resource="&construct;MaterialProduct"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#MaterialProductSpecification1">
		<rdf:type rdf:resource="&construct;MaterialProductSpecification"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ObjectiveSpecification1">
		<obo:BFO_0000110 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#MaterialProductSpecification1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#OperationSpecification1">
		<rdf:type rdf:resource="&construct;OperationSpecification"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#OperatorRole1">
		<rdf:type rdf:resource="&construct;OperatorRole"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#PlanSpecification1">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProcessPlan1">
		<rdf:type rdf:resource="&construct;ProcessPlan"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProcessStep1">
		<rdf:type rdf:resource="&construct;ProcessStep"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProcessStepSpecification1">
		<rdf:type rdf:resource="&construct;ProcessStepSpecification"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProductInspectionProcess1">
		<rdf:type rdf:resource="&construct;ProductInspectionProcess"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProductProductionProcess1">
		<rdf:type rdf:resource="&construct;ProductProductionProcess"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProductionOrder1">
		<rdf:type rdf:resource="&construct;ProductionOrder"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProductionTool1">
		<rdf:type rdf:resource="&construct;ProductionTool"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test1-OperationSpecification">
		<rdf:type rdf:resource="&construct;ActionSpecification"/>
		<rdfs:comment>General Class axioms:

ActionSpecification and (prescribes some ManufacturingOperation) SubClassOf OperationSpecification</rdfs:comment>
		<construct:prescribes rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ManufacturingOperation1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test10-Machine">
		<rdf:type rdf:resource="&construct;MaterialArtifact"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test11-ProductionMachine">
		<rdf:type rdf:resource="&construct;Machine"/>
		<rdfs:comment>SubClass Of:

Machine
 and (hasRole some 
    (EquipmentRole
     and (&apos;has realization&apos; only ManufacturingProcess)))</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test12-ProductionTool">
		<rdf:type rdf:resource="&construct;MaterialArtifact"/>
		<rdfs:comment>SubClass Of:

hasRole some 
    (EquipmentRole
     and (&apos;has realization&apos; only ManufacturingProcess))

MaterialArtifact</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test13-AgentialCapability">
		<rdf:type rdf:resource="&construct;Capability"/>
		<rdfs:comment>Equivalent To:

Capability
 and (capabilityOf some Agent)</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test14-OperatorRole">
		<rdf:type rdf:resource="&construct;AgentRole"/>
		<rdfs:comment>General Class axioms:

DesignSpecification and (prescribes some MaterialProduct) SubClassOf MaterialProductSpecification</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test15-ProductInspectionProcess">
		<rdf:type rdf:resource="&construct;BusinessProcess"/>
		<rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some ProductInspectionProcess) SubClassOf InspectionPlan</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test16-ManufacturingEnterpriseProcess">
		<rdf:type rdf:resource="&construct;PlannedProcess"/>
		<rdfs:comment>SubClass Of:

&apos;has occurrent part&apos; some ManufacturingProcess

Planned Process</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test17-ManufacturingOperation">
		<rdf:type rdf:resource="&construct;ManufacturingEnterpriseProcess"/>
		<rdfs:comment>SubClass Of:

ManufacturingEnterpriseProcess
 and (&apos;has participant at some time&apos; some 
    (&apos;material entity&apos;
     and (hasRole some 
        (EquipmentRole or OperatorRole))))
 and (&apos;has proper occurrent part&apos; some ProcessStep)</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test18-ProcessStep">
		<rdf:type rdf:resource="&construct;ManufacturingEnterpriseProcess"/>
		<rdfs:comment>SubClass Of:

ManufacturingEnterpriseProcess
 and (&apos;has proper occurrent part&apos; some ManufacturingProcess)</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test19-MachineTransferProcess">
		<rdf:type rdf:resource="&construct;MaterialLocationChangeProcess"/>
		<rdfs:comment>SubClass Of:

MaterialLocationChangeProcess
 and (&apos;has participant at some time&apos; some 
    (&apos;material entity&apos;
     and ( inverse (&apos;location of at all times&apos;) some 
        (ProductionMachine
         and (&apos;located in at all times&apos; some site)
         and (&apos;exists at&apos; some 
            (&apos;temporal instant&apos;
             and ((&apos;first instant of&apos; some &apos;temporal region&apos;)
             and ( inverse (&apos;occupies temporal region&apos;) some PlannedProcess))))))
     and ( inverse (&apos;location of at all times&apos;) some 
        (ProductionMachine
         and (&apos;located in at all times&apos; some site)
         and (&apos;exists at&apos; some 
            (&apos;temporal instant&apos;
             and (&apos;last instant of&apos; some 
                (&apos;temporal region&apos;
                 and ( inverse (&apos;occupies temporal region&apos;) some PlannedProcess)))))))))</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test2-ProcessStepSpecification">
		<rdf:type rdf:resource="&construct;ActionSpecification"/>
		<rdfs:comment>General Class axioms:

ActionSpecification and (prescribes some ProcessStep) SubClassOf ProcessStepSpecification</rdfs:comment>
		<construct:prescribes rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProcessStep1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test20-SetupProcess">
		<rdf:type rdf:resource="&construct;PlannedProcess"/>
		<rdfs:comment>SubClass Of:

PlannedProcess</rdfs:comment>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test3-MaterialProductSpecification">
		<rdf:type rdf:resource="&construct;DesignSpecification"/>
		<rdfs:comment>General Class axioms:

DesignSpecification and (prescribes some MaterialProduct) SubClassOf MaterialProductSpecification</rdfs:comment>
		<construct:prescribes rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#MaterialProduct1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test4-ProductionOrder">
		<rdf:type rdf:resource="&construct;ObjectiveSpecification"/>
		<rdfs:comment>General Class axioms:

ObjectiveSpecification and (isAchievedByAtSomeTime some ProductProductionProcess) SubClassOf ProductionOrder</rdfs:comment>
		<construct:isAchievedByAtSomeTime rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProductProductionProcess1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test5-InspectionPlan">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
		<rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some ProductInspectionProcess) SubClassOf InspectionPlan</rdfs:comment>
		<construct:prescribes rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProductInspectionProcess1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test6-MaterialHandlingPlan">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
		<rdfs:comment>General Class axioms:

PlanSpecification and (&apos;has continuant part at all times&apos; some (prescribes some MachineTransferProcess)) SubClassOf MaterialHandlingPlan</rdfs:comment>
		<obo:BFO_0000110 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#1-prescribes-MachineTransferProcess"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test7-ProcessPlan">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
		<rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some (&apos;occurrent part of&apos; some ProductProductionProcess)) SubClassOf ProcessPlan</rdfs:comment>
		<construct:prescribes rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#2-occurentpartof-ProductProductionProcess"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test7E-ProcessPlan">
		<rdf:type rdf:resource="&construct;ProcessPlan"/>
		<obo:BFO_0000111 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ICE1"/>
		<obo:BFO_0000111 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#OperationSpecification1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test8-ProductionPlan">
		<rdf:type rdf:resource="&construct;PlanSpecification"/>
		<rdfs:comment>General Class axioms:

PlanSpecification and (prescribes some ProductProductionProcess) SubClassOf ProductionPlan</rdfs:comment>
		<obo:BFO_0000110 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#InspectionPlan1"/>
		<obo:BFO_0000111 rdf:resource="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#ProductionOrder1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="http://www.semanticweb.org/ss748014/ontologies/2025/11/untitled-ontology-2#Test9-Operator">
		<rdf:type rdf:resource="&construct;Agent"/>
		<rdfs:comment>Equivalent To:

Agent
 and (hasRole some OperatorRole)</rdfs:comment>
	</owl:NamedIndividual>
	
	<rdf:Description rdf:about="&construct;ActionSpecification">
		<owl:disjointWith rdf:resource="&construct;ObjectiveSpecification"/>
	</rdf:Description>
	
	<owl:Class>
		<rdfs:subClassOf rdf:resource="&construct;ProductionMachine"/>
		<owl:intersectionOf rdf:parseType="Collection">
			<rdf:Description rdf:about="&construct;Machine">
			</rdf:Description>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&construct;hasRole"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&construct;EquipmentRole">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&obo;BFO_0000054"/>
								<owl:allValuesFrom rdf:resource="&construct;ManufacturingProcess"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</owl:intersectionOf>
	</owl:Class>
</rdf:RDF>