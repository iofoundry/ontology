	<rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/core/Core/IngredientSlot">
		<rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/InformationSlot/</rdfs:isDefinedBy>
		<AnnotationVocabulary:firstOrderLogicAxiom>InformationSlot(s) ∧ ∃a&apos;, b&apos; (slotOf(s, a&apos;) ∧ fills(b&apos;, s) ∧ ∀a, b (prescribes(a&apos;,a) ∧ prescribes(b&apos;,b) → isMadeOfAtAllTimes(b, a))) → IngredientSlot(s)</AnnotationVocabulary:firstOrderLogicAxiom>
		<AnnotationVocabulary:firstOrderLogicDefinition>IngredientSlot(s) ↔ InformationSlot(s) ∧ ∃a&apos;, b&apos; (slotOf(s, a&apos;) ∧ fills(b&apos;, s) ∧ ∀a, b (describes(a&apos;,a) ∧ describes(b&apos;,b) → isMadeOfAtAllTime(b,a)))</AnnotationVocabulary:firstOrderLogicDefinition>
	</rdf:Description>
	
	<rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/core/Core/RoleSlot">
		<rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/InformationSlot/</rdfs:isDefinedBy>
		<AnnotationVocabulary:firstOrderLogicAxiom>InformationSlot(s) ∧ ∃a&apos;, b&apos; (slotOf(s, a&apos;) ∧ fills(b&apos;, s) ∧ ∀a, b (describes(a&apos;,a) ∧ describes(b&apos;,b) → hasRole(a, b))) → RoleSlot(s)</AnnotationVocabulary:firstOrderLogicAxiom>
		<AnnotationVocabulary:firstOrderLogicDefinition>RoleSlot(s) ↔ InformationSlot(s) ∧ ∃a&apos;, b&apos; (slotOf(s, a&apos;) ∧ fills(b&apos;, s) ∧ ∀a, b (describes(a&apos;,a) ∧ describes(b&apos;,b) → hasRole(a, b)))</AnnotationVocabulary:firstOrderLogicDefinition>
	</rdf:Description>
	
