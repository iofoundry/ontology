	<owl:Ontology rdf:about="https://spec.industrialontologies.org/ontology/core/InformationSlot/">
		<rdfs:label>information slot ontology</rdfs:label>
		<dc:license>http://opensource.org/licenses/MIT</dc:license>
		<terms:abstract>This ontology defines constructs related to representing the structure and semantic of information content entities.</terms:abstract>
		<terms:creator>Arkopaul Sarkar, Natioanl Institute of Standards and Technology</terms:creator>
		<terms:publisher>Industrial Ontology Foundry</terms:publisher>
		<terms:title>Information Slot Ontology</terms:title>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202502/core/Core/"/>
		<AnnotationVocabulary:copyright>Copyright (c) 2022, 2023 Open Applications Group</AnnotationVocabulary:copyright>
	</owl:Ontology>
	
