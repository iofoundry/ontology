	</owl:Class>
	
	<owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/TimeSlot">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationSlot"/>
		<rdfs:comment xml:lang="en">time slot</rdfs:comment>
		<rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/InformationSlot/</rdfs:isDefinedBy>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/InformationSlot">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFiller"/>
						<owl:allValuesFrom>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/TemporalDurationValueExpression">
									</rdf:Description>
									<rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/TemporalInstantValueExpression">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:allValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
	</owl:Class>
	
