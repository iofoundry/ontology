		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
		<rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/InformationSlot/</rdfs:isDefinedBy>
	</owl:Class>
	
	<owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/Joint">
		<rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
		<rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/InformationSlot/</rdfs:isDefinedBy>
	</owl:Class>
	
	<owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/JointSpecification">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignSpecification"/>
		<rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/InformationSlot/</rdfs:isDefinedBy>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignSpecification">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasSlot"/>
						<owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/ConnectorSlot"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
	</owl:Class>
	
	<owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/LocationSlot">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationSlot"/>
		<rdfs:label xml:lang="en">location slot</rdfs:label>
		<rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/InformationSlot/</rdfs:isDefinedBy>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/InformationSlot">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFiller"/>
						<owl:allValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/PhysicalLocationIdentifier"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/isSlotOf"/>
						<owl:allValuesFrom>
							<owl:Restriction>
								<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000004">
											</rdf:Description>
											<owl:Class>
												<owl:complementOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000006"/>
											</owl:Class>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:allValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<AnnotationVocabulary:firstOrderLogicAxiom>InformationSlot(s) ∧ ∃a&apos;, b&apos; (slotOf(s, a&apos;) ∧ fills(b&apos;, s) ∧ ∀a, b (describes(a&apos;,a) ∧ describes(b&apos;,b) → locatedInAtSomeTimes(a, b))) → LocationSlot(s)</AnnotationVocabulary:firstOrderLogicAxiom>
		<AnnotationVocabulary:firstOrderLogicDefinition>LocationSlot(s) ↔ InformationSlot(s) ∧ ∃a&apos;, b&apos; (slotOf(s, a&apos;) ∧ fills(b&apos;, s) ∧ ∀a, b (describes(a&apos;,a) ∧ describes(b&apos;,b) → locatedInAtSomeTimes(a, b)))</AnnotationVocabulary:firstOrderLogicDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact">
	</owl:Class>
	
	<owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialComponent">
	</owl:Class>
	
	<owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/ParticipantSlot">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationSlot"/>
		<rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/InformationSlot/</rdfs:isDefinedBy>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/InformationSlot">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFiller"/>
						<owl:allValuesFrom>
							<owl:Restriction>
								<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
								<owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
							</owl:Restriction>
						</owl:allValuesFrom>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/isSlotOf"/>
						<owl:allValuesFrom>
							<owl:Restriction>
								<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
								<owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
							</owl:Restriction>
						</owl:allValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
	</owl:Class>
	
