	<owl:Class>
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/JointSpecification"/>
		<owl:intersectionOf rdf:parseType="Collection">
			<rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignSpecification">
			</rdf:Description>
			<owl:Restriction>
				<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasSlot"/>
				<owl:someValuesFrom>
					<owl:Restriction>
						<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFiller"/>
						<owl:someValuesFrom>
							<owl:Restriction>
								<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/prescribes"/>
								<owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
							</owl:Restriction>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:someValuesFrom>
			</owl:Restriction>
			<owl:Restriction>
				<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/prescribes"/>
				<owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/Joint"/>
			</owl:Restriction>
			<owl:Restriction>
				<owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasSlot"/>
				<owl:onClass rdf:resource="https://spec.industrialontologies.org/ontology/construct/ConnectorSlot"/>
				<owl:maxQualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:maxQualifiedCardinality>
			</owl:Restriction>
		</owl:intersectionOf>
	</owl:Class>
	<owl:Class>
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/LocationSlot"/>
		<owl:intersectionOf rdf:parseType="Collection">
			<rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/InformationSlot">
