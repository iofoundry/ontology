						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000004">
									</rdf:Description>
									<owl:Class>
										<owl:complementOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000006"/>
									</owl:Class>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:allValuesFrom>
			</owl:Restriction>
		</owl:intersectionOf>
	</owl:Class>
	<owl:Class>
