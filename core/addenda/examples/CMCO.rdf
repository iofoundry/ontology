		<CMCO:hasBlaName>Vial Thaw into a Shake Flask</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000202">
		<rdfs:subClassOf rdf:resource="https://ontology.merck.com/ontology/MMFGO/MMFGO_0000035"/>
