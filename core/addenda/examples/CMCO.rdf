		<rdfs:label>L-arginine monohydrochloride</rdfs:label>
		<skos:altLabel>L-arginine monochloride</skos:altLabel>
		<skos:definition>A basic amino acid salt used as a stabilizer or solubilizer in protein formulations to reduce aggregation.</skos:definition>
		<CMCO:hasBlaName>L-arginine monohydrochloride</CMCO:hasBlaName>
	</owl:NamedIndividual>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000087">
		<rdfs:subClassOf rdf:resource="&Core;PieceOfEquipment"/>
		<rdfs:label>temperature controlled cabinet</rdfs:label>
		<skos:definition>Enclosure used to maintain validated temperature conditions for storage of temperature-sensitive pharmaceutical materials.</skos:definition>
		<CMCO:hasPkmName>Incubator</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000090">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MembraneFilter"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&Core;isInputOf"/>
				<owl:someValuesFrom rdf:resource="&CMCO;CMCO_0000222"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>0.2-mkm bioburden reduction filter</rdfs:label>
		<skos:altLabel>0.2-mkm bioburden reducing filter</skos:altLabel>
		<skos:definition>A filter with a 0.2-micrometer pore size rating that is used to remove microorganisms from a fluid stream.</skos:definition>
		<CMCO:hasBlaName>0.2µm bioburden reduction filter</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000091">
		<rdfs:subClassOf rdf:resource="https://ontology.merck.com/ontology/MPARK-APP/MPARK-APP_0000003"/>
		<rdfs:label>downstream process area</rdfs:label>
		<skos:altLabel>downstream purification area</skos:altLabel>
		<skos:definition>Controlled facility area where post-harvest operations such as purification, viral clearance, and formulation are performed.</skos:definition>
		<CMCO:hasPkmName>Downstream</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000092">
		<rdfs:subClassOf rdf:resource="https://ontology.merck.com/ontology/MPARK-APP/MPARK-APP_0000003"/>
		<rdfs:label>upstream process area</rdfs:label>
		<skos:definition>A manufacturing area for cell culture operations including vial thaw, inoculum expansion, and antibody production.</skos:definition>
		<CMCO:hasPkmName>Upstream</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000093">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/result#AFR_0002036"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&qudt1;hasUnit"/>
				<owl:someValuesFrom rdf:resource="&obo;UO_0000175"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>unformulated bulk concentration</rdfs:label>
		<skos:definition>Measured concentration of purified drug substance prior to formulation.</skos:definition>
		<CMCO:hasBlaName>Unformulated Bulk Concentration</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:NamedIndividual rdf:about="&CMCO;CMCO_0000102">
		<rdf:type rdf:resource="&owl;Class"/>
		<rdfs:subClassOf rdf:resource="&MDO;MDO_0005370"/>
		<rdfs:label>inoculum expansion in shake flasks</rdfs:label>
		<skos:definition>A cell culture step where cells are grown in flasks to increase cell mass.</skos:definition>
		<CMCO:hasBlaName>Inoculum Expansion in Shake Flasks</CMCO:hasBlaName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&CMCO;CMCO_0000103">
		<rdf:type rdf:resource="&owl;Class"/>
		<rdfs:subClassOf rdf:resource="&MDO;MDO_0005370"/>
		<rdfs:label>inoculum expansion in a rocker bag</rdfs:label>
		<skos:definition>A cell culture step where cells are grown in a bag on a rocking platform to increase cell mass.</skos:definition>
		<CMCO:hasBlaName>Inoculum Expansion in a Rocker Bag</CMCO:hasBlaName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&CMCO;CMCO_0000104">
		<rdf:type rdf:resource="&owl;Class"/>
		<rdfs:subClassOf rdf:resource="&MDO;MDO_0005370"/>
		<rdfs:label>inoculum expansion in a bioreactor</rdfs:label>
		<skos:definition>A cell culture step where cells are grown in a bioreactor to increase cell mass.</skos:definition>
		<CMCO:hasBlaName>Inoculum Expansion in a Bioreactor</CMCO:hasBlaName>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&CMCO;CMCO_0000105">
		<rdf:type rdf:resource="&owl;Class"/>
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/StorageProcess"/>
		<rdfs:label>freezing and storage</rdfs:label>
		<skos:definition>The process where material is brought to cryogenic or sub-zero conditions, followed by storage to maintain stability and viability until use.</skos:definition>
		<CMCO:hasBlaName>Freezing and Storage</CMCO:hasBlaName>
		<CMCO:hasPkmName>Freezing and Storage</CMCO:hasPkmName>
	</owl:NamedIndividual>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000106">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/ProcessIntermediateMaterial"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&CMCO;hasInProcessControl"/>
				<owl:someValuesFrom rdf:resource="&MDO;MDO_0009969"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&Core;isInputOf"/>
				<owl:someValuesFrom rdf:resource="&obo;CHMO_0001210"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>cation exchange chromatography load</rdfs:label>
		<skos:altLabel>CEX load</skos:altLabel>
		<skos:definition>The process fluid, at a specific pH and conductivity, that is introduced to a cation exchange column to facilitate the binding of the target molecule(s) to the negatively charged functional groups of the chromatography resin.</skos:definition>
		<CMCO:hasBlaName>CEX Load</CMCO:hasBlaName>
		<CMCO:hasPkmName>Cation-Exchange Chromatography Load</CMCO:hasPkmName>
		<AnnotationVocabulary:acronym>CEXL</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000107">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/ProcessIntermediateMaterial"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&CMCO;hasInProcessControl"/>
				<owl:someValuesFrom rdf:resource="http://purl.allotrope.org/ontologies/quality#AFQ_0000227"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&CMCO;hasInProcessControl"/>
				<owl:someValuesFrom rdf:resource="&MDO;MDO_0001087"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&CMCO;hasInProcessControl"/>
				<owl:someValuesFrom rdf:resource="&MDO;MDO_0009969"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&Core;isOutputOf"/>
				<owl:someValuesFrom rdf:resource="&obo;CHMO_0001210"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>cation exchange chromatography product</rdfs:label>
		<skos:altLabel>CEX product</skos:altLabel>
		<skos:definition>The eluate fraction containing the target protein after displacement from the cation exchange resin using increased ionic strength or pH shift.</skos:definition>
		<CMCO:hasBlaName>CEX Product</CMCO:hasBlaName>
		<AnnotationVocabulary:acronym>CEXP</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000108">
		<rdfs:subClassOf rdf:resource="&Core;PieceOfEquipment"/>
		<rdfs:label>bioprocessing container</rdfs:label>
		<skos:altLabel>bioprocess container</skos:altLabel>
		<skos:definition>A single-use or reusable vessel designed for aseptic handling, mixing, or storage of biopharmaceutical materials during upstream or downstream processing.</skos:definition>
		<CMCO:hasPkmName>Bioprocess Bag</CMCO:hasPkmName>
		<AnnotationVocabulary:acronym>BPC</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000109">
		<rdfs:subClassOf rdf:resource="&obo;NCIT_C38013"/>
		<rdfs:label>proven acceptable range</rdfs:label>
		<skos:definition>A characterized range of a process parameter that consistently yields product meeting quality criteria when operated within, without affecting other parameters outside their normal range.</skos:definition>
		<CMCO:hasBlaName>Proven Acceptable Range</CMCO:hasBlaName>
		<CMCO:hasPkmName>PAR</CMCO:hasPkmName>
		<AnnotationVocabulary:acronym>PAR</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000110">
		<rdfs:subClassOf rdf:resource="&obo;NCIT_C38013"/>
		<rdfs:label>normal operating range</rdfs:label>
		<skos:definition>A region around target operating conditions reflecting typical variability during routine manufacturing.</skos:definition>
		<CMCO:hasBlaName>Normal Operating Range</CMCO:hasBlaName>
		<CMCO:hasPkmName>NOR</CMCO:hasPkmName>
		<AnnotationVocabulary:acronym>NOR</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000117">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/material#AFM_0001104"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&Core;hasRole"/>
				<owl:someValuesFrom rdf:resource="&CMCO;CMCO_0000268"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>low pH titration solution</rdfs:label>
		<skos:altLabel>low pH titrant</skos:altLabel>
		<skos:definition>An acidic buffer solution used to adjust pH during purification or viral inactivation steps, typically in the range of pH 3-4, ensuring protein stability and pathogen clearance.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000126">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/material#AFM_0001104"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&Core;hasRole"/>
				<owl:someValuesFrom rdf:resource="&CMCO;CMCO_0000271"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>conductivity titrant</rdfs:label>
		<skos:definition>A solution added during chromatography or buffer exchange to adjust ionic strength, monitored via conductivity to control protein elution or buffer composition.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000140">
		<rdfs:subClassOf rdf:resource="&MDO;MDO_0005390"/>
		<rdfs:label>low pH titration</rdfs:label>
		<skos:definition>Controlled addition of acidic solution to adjust pH during viral inactivation or purification, typically to pH 3-4, ensuring protein stability and pathogen clearance.</skos:definition>
		<CMCO:hasBlaName>Low pH Titration</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000141">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/material#AFM_0000012"/>
		<rdfs:label>strip solution</rdfs:label>
		<skos:definition>A solution used in chromatography to remove bound impurities or regenerate the column by disrupting interactions between the resin and retained molecules.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000142">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/material#AFM_0000012"/>
		<rdfs:label>pre-equilibration solution</rdfs:label>
		<skos:definition>A solution used to condition chromatography columns or filters before sample loading, ensuring consistent ionic strength and pH for optimal binding of target molecules.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000143">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/material#AFM_0000012"/>
		<rdfs:label>storage solution</rdfs:label>
		<skos:definition>A solution specifically designed to hold a sanitized material component, such as a column or a filter between uses, ensuring its integrity, cleanliness, and readiness for the next round of use.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000144">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/material#AFM_0000012"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&Core;hasRole"/>
				<owl:someValuesFrom rdf:resource="&CMCO;CMCO_0000269"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>neutralization solution</rdfs:label>
		<skos:definition>A solution used to restore physiological pH after low pH treatment, typically in viral inactivation steps, ensuring protein functionality and compatibility with downstream processes.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000145">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/result#AFR_0000951"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&qudt1;hasUnit"/>
				<owl:someValuesFrom rdf:resource="&obo;UO_0000033"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>culture duration</rdfs:label>
		<skos:definition>The total time cells are maintained in culture from inoculation to end of culture, impacting cell viability, productivity, and product quality.</skos:definition>
		<CMCO:hasBlaName>Culture Duration</CMCO:hasBlaName>
		<CMCO:hasPkmName>Culture Duration</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000146">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/result#AFR_0000951"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&qudt1;hasUnit"/>
				<owl:someValuesFrom rdf:resource="&obo;UO_0000032"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>media pre-conditioning duration</rdfs:label>
		<skos:definition>The time period during which culture media is held under specific conditions before use, allowing stabilization or equilibration to ensure culture performance.</skos:definition>
		<CMCO:hasBlaName>Media pre-Conditioning Duration</CMCO:hasBlaName>
		<CMCO:hasPkmName>Media Preconditioning Duration</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000147">
		<rdfs:subClassOf rdf:resource="&MDO;MDO_0004710"/>
		<rdfs:label>CAS name</rdfs:label>
		<skos:definition>The unique chemical name assigned by the Chemical Abstracts Service (CAS) to a substance, used for unambiguous identification in regulatory and scientific contexts.</skos:definition>
		<CMCO:hasPkmName>CAS Name</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000148">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/QualityAttributeSpecification"/>
		<rdfs:label>compendial reference</rdfs:label>
		<skos:definition>A citation to an official pharmacopeial monograph (e.g., USP, Ph. Eur.) that defines quality standards for a substance, method, or product used in pharmaceutical manufacturing.</skos:definition>
		<CMCO:hasBlaName>Compendial Reference</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000149">
		<rdfs:subClassOf rdf:resource="&obo;NCIT_C134263"/>
		<rdfs:label>conductivity maximum</rdfs:label>
		<skos:definition>The upper limit of conductivity allowed during a process step (e.g., chromatography), ensuring buffer conditions remain within validated specifications for protein stability and separation.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000150">
		<rdfs:subClassOf rdf:resource="&obo;NCIT_C134263"/>
		<rdfs:label>conductivity minimum</rdfs:label>
		<skos:definition>The lowest allowable conductivity value during a process step (e.g., chromatography), ensuring sufficient ionic strength for protein binding or stability.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000151">
		<rdfs:subClassOf rdf:resource="&MDO;MDO_0004710"/>
		<rdfs:label>generic name INN</rdfs:label>
		<skos:definition>The International Nonproprietary Name (INN) is the globally recognized name assigned by WHO to identify the active ingredient in a medicine, ensuring consistency across countries.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000152">
		<rdfs:subClassOf rdf:resource="&MDO;MDO_0004710"/>
		<rdfs:label>generic name USAN</rdfs:label>
		<skos:definition>The United States Adopted Name (USAN) is the nonproprietary name assigned by the USAN Council for drugs marketed in the U.S., used in labeling and regulatory documentation.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000153">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/FailureModeCode"/>
		<rdfs:label>high alarm</rdfs:label>
		<skos:definition>A predefined upper threshold for a process parameter that, when exceeded, triggers a warning requiring the operators attention but not immediate shutdown.</skos:definition>
		<CMCO:hasBlaName>High Alarm</CMCO:hasBlaName>
		<CMCO:hasPkmName>High</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000154">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/FailureModeCode"/>
		<rdfs:label>high high alarm</rdfs:label>
		<skos:definition>A critical upper threshold for a process parameter that, when exceeded, triggers immediate shutdown or emergency response to prevent harm or product loss.</skos:definition>
		<CMCO:hasBlaName>High High Alarm</CMCO:hasBlaName>
		<CMCO:hasPkmName>High High</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000155">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/ControlStrategy"/>
		<rdfs:label>in-process control</rdfs:label>
		<skos:definition>Tests performed during manufacturing to monitor and, if necessary, adjust the process to ensure product quality and compliance with specifications.</skos:definition>
		<CMCO:hasBlaName>In-Process Control</CMCO:hasBlaName>
		<AnnotationVocabulary:acronym>IPC</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000156">
		<rdfs:subClassOf rdf:resource="&CMCO;CMCO_0000155"/>
		<rdfs:label>in-process control maximum</rdfs:label>
		<skos:definition>The highest acceptable value for a monitored parameter during production, beyond which corrective action or rejection may be required to maintain product quality.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000157">
		<rdfs:subClassOf rdf:resource="&CMCO;CMCO_0000155"/>
		<rdfs:label>in-process control minimum</rdfs:label>
		<skos:definition>The lowest acceptable value for a monitored parameter during production, below which product quality may be compromised, and corrective action is required.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000158">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/FailureModeCode"/>
		<rdfs:label>low alarm</rdfs:label>
		<skos:definition>A predefined lower limit for a process parameter that, when breached, triggers a warning requiring operator attention but not immediate shutdown.</skos:definition>
		<CMCO:hasBlaName>Low Alarm</CMCO:hasBlaName>
		<CMCO:hasPkmName>Low</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000159">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/FailureModeCode"/>
		<rdfs:label>low low alarm</rdfs:label>
		<skos:definition>A critical lower threshold for a process parameter that, when breached, triggers immediate shutdown or emergency response to prevent harm or product loss.</skos:definition>
		<CMCO:hasBlaName>Low Low Alarm</CMCO:hasBlaName>
		<CMCO:hasPkmName>Low Low</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000160">
		<rdfs:subClassOf rdf:resource="&MDO;MDO_0004710"/>
		<rdfs:label>media turbidity</rdfs:label>
		<skos:definition>A measure of the cloudiness or haziness of culture media, typically caused by suspended cells or particulates, used as an indicator of cell growth, contamination, or media quality.</skos:definition>
		<CMCO:hasPkmName>Turbidity</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000161">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/ERPCode"/>
		<rdfs:subClassOf rdf:resource="&Core;Identifier"/>
		<rdfs:label>MKV number</rdfs:label>
		<skos:definition>A unique identifier used internally by manufacturers or regulatory bodies to track specific materials, formulations, or batches; not a standardized regulatory term.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000162">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/result#AFR_0001586"/>
		<rdfs:label>target osmolality</rdfs:label>
		<skos:definition>The desired osmolality range (typically 280–330 mOsm/kg) of a cell culture medium or formulation buffer, optimized to support cell viability, productivity, and protein stability.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000163">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/result#AFR_0001586"/>
		<rdfs:label>osmolality maximum</rdfs:label>
		<skos:definition>The upper limit of osmolality tolerated in a process step or formulation, beyond which cell viability or protein stability may be compromised.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000164">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/result#AFR_0001586"/>
		<rdfs:label>osmolality minimum</rdfs:label>
		<skos:definition>The lowest acceptable osmolality value in a process or formulation, below which cells may lyse or protein aggregation may occur, affecting yield and quality.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000165">
		<rdfs:subClassOf rdf:resource="&obo;UO_0000196"/>
		<rdfs:label>pH maximum</rdfs:label>
		<skos:definition>The highest allowable pH value in a process step or formulation, beyond which protein stability, solubility, or activity may be compromised.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000166">
		<rdfs:subClassOf rdf:resource="&obo;UO_0000196"/>
		<rdfs:label>pH minimum</rdfs:label>
		<skos:definition>The lowest acceptable pH value in a process step or formulation, below which protein denaturation, aggregation, or loss of activity may occur.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000167">
		<rdfs:subClassOf rdf:resource="&Core;InformationContentEntity"/>
		<rdfs:label>parameter classification</rdfs:label>
		<skos:definition>Categorization of process parameters based on their impact on product quality, typically as critical, key, or non-critical, guiding control strategy and regulatory documentation.</skos:definition>
		<CMCO:hasPkmName>Parameter Type</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000168">
		<rdfs:subClassOf rdf:resource="&Core;RequirementSpecification"/>
		<rdfs:label>release specification</rdfs:label>
		<skos:definition>A set of predefined criteria that a drug substance or product must meet before being approved for distribution, ensuring identity, purity, potency, and safety determined by analytical methods.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000169">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/ERPCode"/>
		<rdfs:label>SAP material identifier</rdfs:label>
		<skos:altLabel>SAP material ID</skos:altLabel>
		<skos:definition>A unique alphanumeric code assigned within SAP ERP systems to track and manage materials, formulations, or components used in pharmaceutical manufacturing.</skos:definition>
		<CMCO:hasPkmName>Material ID</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000170">
		<rdfs:subClassOf rdf:resource="&MDO;MDO_0004710"/>
		<rdfs:label>SAP material name</rdfs:label>
		<skos:definition>The descriptive name that is assigned to a material in SAP ERP systems, used for internal tracking, inventory control, and regulatory documentation alignment.</skos:definition>
		<CMCO:hasPkmName>Material Name</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000171">
		<rdfs:subClassOf rdf:resource="&Core;RequirementSpecification"/>
		<rdfs:label>specification market</rdfs:label>
		<skos:definition>The geographic region or regulatory jurisdiction for which a product specification is defined, reflecting local regulatory requirements and product performance expectations.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000172">
		<rdfs:subClassOf rdf:resource="&Core;RequirementSpecification"/>
		<rdfs:label>specification type</rdfs:label>
		<skos:definition>A classification of specifications based on their purpose, such as release, shelf-life, in-process, or stability, guiding testing strategy and regulatory compliance.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000173">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/result#AFR_0000951"/>
		<rdfs:label>storage duration</rdfs:label>
		<skos:definition>The validated time period during which a product remains stable under defined storage conditions, typically aligned with its shelf-life and supported by stability data.</skos:definition>
		<CMCO:hasPkmName>Storage Duration</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000174">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/result#AFR_0001584"/>
		<rdfs:label>storage temperature</rdfs:label>
		<skos:definition>The temperature range within which a product must be stored to maintain its stability and efficacy, determined by stability studies and regulatory guidelines.</skos:definition>
		<CMCO:hasPkmName>Storage Temperature</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000175">
		<rdfs:subClassOf rdf:resource="&Core;Identifier"/>
		<rdfs:label>supplier material identifier</rdfs:label>
		<skos:altLabel>supplier material ID</skos:altLabel>
		<skos:definition>A unique code assigned by a supplier to identify a specific material, used for traceability, procurement, and regulatory documentation.</skos:definition>
		<CMCO:hasPkmName>Material ID</CMCO:hasPkmName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000176">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/GeospatialLocation"/>
		<rdfs:label>supplier site address</rdfs:label>
		<skos:definition>The physical location of a supplier’s manufacturing or distribution facility, required for regulatory submissions and quality agreements.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000177">
		<rdfs:subClassOf rdf:resource="&MDO;MDO_0004710"/>
		<rdfs:label>target density</rdfs:label>
		<skos:definition>The desired mass per unit volume of a solution or formulation, used to ensure consistency in concentration and process performance.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000179">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/QualityAttribute"/>
		<rdfs:label>potential critical quality attribute</rdfs:label>
		<skos:altLabel>drug substance potential critical quality attribute</skos:altLabel>
		<skos:definition>A property of a drug substance or product that may impact safety or efficacy and requires evaluation to determine if it should be classified as a Critical Quality Attribute (CQA).</skos:definition>
		<AnnotationVocabulary:acronym>pCQA</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000180">
		<rdfs:subClassOf rdf:resource="&obo;NCIT_C25709"/>
		<rdfs:label>endotoxin units</rdfs:label>
		<skos:definition>A standardized measure of bacterial endotoxin activity, expressed in EU (Endotoxin Units), used to set safety limits for parenteral drug products.</skos:definition>
		<AnnotationVocabulary:acronym>EU</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000182">
		<rdfs:subClassOf rdf:resource="&Core;InformationContentEntity"/>
		<rdfs:label>limit of in vitro cell age</rdfs:label>
		<obo:IAO_0000115>The maximum number of times a cell population can divide when cultured outside of a living organism (i.e., in vitro), before it stops proliferating and enters a state of senescence or dies.</obo:IAO_0000115>
		<skos:definition>The maximum number of times a cell population can divide when cultured outside of a living organism (i.e., in vitro), before it stops proliferating and enters a state of senescence or dies.</skos:definition>
		<AnnotationVocabulary:acronym>LIVCA</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000183">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PieceofTransportEquipment"/>
		<rdfs:label>shippable storage module</rdfs:label>
		<skos:definition>A validated container system designed to maintain required environmental conditions (e.g., temperature, humidity) during transport and storage of pharmaceutical materials or products.</skos:definition>
		<AnnotationVocabulary:acronym>SSM</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000184">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/ProcessIntermediateMaterial"/>
		<rdfs:label>ultrafiltration and diafiltration product</rdfs:label>
		<skos:altLabel>UF/DF product</skos:altLabel>
		<skos:altLabel>ultrafiltration/diafiltration product</skos:altLabel>
		<skos:definition>A drug substance or intermediate that has undergone ultrafiltration and diafiltration to concentrate and exchange buffer, typically used in downstream purification of biologics.</skos:definition>
		<CMCO:hasBlaName>Ultrafiltration/Diafiltration Product</CMCO:hasBlaName>
		<AnnotationVocabulary:acronym>UFP</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000186">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/CriticalQualityAttribute"/>
		<rdfs:label>microbiological purity</rdfs:label>
		<skos:definition>The absence or acceptable limit of viable microorganisms in a pharmaceutical product, ensuring safety and compliance with pharmacopeial standards.</skos:definition>
		<CMCO:hasBlaName>Microbiological Purity</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000187">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/CriticalQualityAttribute"/>
		<rdfs:label>excipient level</rdfs:label>
		<skos:altLabel>level of the excipient</skos:altLabel>
		<skos:definition>The quantitative amount of an inactive substance (excipient) present in a pharmaceutical formulation, specified to ensure product stability, safety, and performance without affecting drug bioavailability or efficacy.</skos:definition>
		<CMCO:hasBlaName>Excipient Level</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000188">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/CriticalQualityAttribute"/>
		<rdfs:label>charge variants level</rdfs:label>
		<skos:altLabel>charge variants percentage</skos:altLabel>
		<skos:definition>Proportion of protein isoforms differing in net charge due to post-translational modifications, used to assess product heterogeneity and quality.</skos:definition>
		<CMCO:hasBlaName>Charge Variants</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000189">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/CriticalQualityAttribute"/>
		<rdfs:label>aggregation level</rdfs:label>
		<skos:altLabel>aggregate content</skos:altLabel>
		<skos:altLabel>aggregation degree</skos:altLabel>
		<skos:altLabel>aggregation extent</skos:altLabel>
		<skos:altLabel>aggregation percentage</skos:altLabel>
		<skos:definition>Proportion of protein molecules forming non-native aggregates, monitored to ensure product stability and minimize immunogenicity.</skos:definition>
		<CMCO:hasBlaName>Aggregation</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000190">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/CriticalQualityAttribute"/>
		<rdfs:label>fragmentation level</rdfs:label>
		<skos:altLabel>fragmentation degree</skos:altLabel>
		<skos:altLabel>fragmentation extent</skos:altLabel>
		<skos:altLabel>fragmentation percentage</skos:altLabel>
		<skos:altLabel>fragments content</skos:altLabel>
		<skos:definition>Proportion of protein molecules cleaved into smaller fragments due to stress or degradation, affecting potency and pharmacokinetics.</skos:definition>
		<CMCO:hasBlaName>Fragmentation</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000191">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/CriticalQualityAttribute"/>
		<rdfs:label>host cell protein level</rdfs:label>
		<skos:altLabel>host cell protein impurity level</skos:altLabel>
		<skos:definition>The concentration of residual process related proteins from the Host Cell expression system observed in the biomanufacturing process, monitored to ensure safety, purity and to minimize immunogenicity risk.</skos:definition>
		<CMCO:hasBlaName>Host Cell Protein</CMCO:hasBlaName>
		<AnnotationVocabulary:acronym>HCP</AnnotationVocabulary:acronym>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000192">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/CriticalQualityAttribute"/>
		<rdfs:label>adventitious agents level</rdfs:label>
		<skos:altLabel>adventitious agents impurity level</skos:altLabel>
		<skos:definition>The absence or acceptable limit of unintended microbial or viral contaminants in biopharmaceuticals, ensured through validated testing and risk mitigation strategies proving acceptable product safety.</skos:definition>
		<CMCO:hasBlaName>Adventitious Agents</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000193">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/CriticalQualityAttribute"/>
		<rdfs:label>host cell-specific virus level</rdfs:label>
		<skos:altLabel>host cell-specific virus impurity level</skos:altLabel>
		<skos:definition>The concentration or presence of viruses endogenous to the host cell line, monitored to ensure viral safety of the final product.</skos:definition>
		<CMCO:hasBlaName>Host Cell-Specific Virus</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000194">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/CriticalQualityAttribute"/>
		<rdfs:label>residual protein A ligand level</rdfs:label>
		<skos:altLabel>residual protein A ligand impurity level</skos:altLabel>
		<skos:definition>The amount of Protein A ligand leached from affinity chromatography resin into the product, monitored as a process-related impurity due to potential immunogenicity.</skos:definition>
		<CMCO:hasBlaName>Residual Protein A Ligand</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000195">
		<rdfs:subClassOf rdf:resource="&CMCO;CMCO_0000179"/>
		<rdfs:label>oxidation level</rdfs:label>
		<skos:altLabel>oxidation (CDRW102)</skos:altLabel>
		<skos:altLabel>oxidation degree</skos:altLabel>
		<skos:altLabel>oxidation extent</skos:altLabel>
		<skos:definition>The degree of oxidative modifications on certain amino acid residues of proteins, such as cysteine, methionine or tryptophan oxidation, impacting stability, solubility, potency, and immunogenicity.</skos:definition>
		<CMCO:hasBlaName>Oxidation (CDRW102)</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000196">
		<rdfs:subClassOf rdf:resource="&CMCO;CMCO_0000179"/>
		<rdfs:label>free thiol/disulfide reduction level</rdfs:label>
		<skos:definition>Level of free thiol groups or reduced disulfide bonds in proteins, indicating potential structural instability, oxidative stress, and altered biological activity.</skos:definition>
		<CMCO:hasBlaName>Free Thiol/Disulfide Reduction</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000197">
		<rdfs:subClassOf rdf:resource="&CMCO;CMCO_0000179"/>
		<rdfs:label>tyrosine sulfation level</rdfs:label>
		<skos:altLabel>Tyr sulfation level</skos:altLabel>
		<skos:definition>The degree of post-translational sulfation of tyrosine residues, which may affect receptor binding, enhance protein-protein interactions and pharmacokinetics; typically assessed during characterization.</skos:definition>
		<CMCO:hasBlaName>Tyr Sulfation</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000198">
		<rdfs:subClassOf rdf:resource="&obo;NCIT_C38013"/>
		<rdfs:label>in-process control range</rdfs:label>
		<skos:definition>The validated range within which critical process parameters are maintained during manufacturing to ensure consistent product quality, safety, potency, and process performance.</skos:definition>
		<CMCO:hasBlaName>In-Process Control Range</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000199">
		<rdfs:subClassOf rdf:resource="http://purl.allotrope.org/ontologies/material#AFM_0001104"/>
		<rdfs:label>pH control solution</rdfs:label>
	</owl:Class>
	
