					<rdf:Description rdf:about="&obo;BFO_0000004">
					</rdf:Description>
					<owl:Class>
						<owl:complementOf rdf:resource="&obo;BFO_0000006"/>
					</owl:Class>
				</owl:intersectionOf>
			</owl:Class>
		</rdfs:range>
		<skos:definition xml:lang="en">b located in c at some time =Def for some time t (b and c are independent continuants and not spatial regions, and the spatial region which b occupies at t is a (proper or improper) continuant part of the spatial region which c occupies at t)</skos:definition>
		<skos:prefLabel xml:lang="en">located in at some time</skos:prefLabel>
	</owl:ObjectProperty>
	
