	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&obo;BFO_0000113">
		<rdfs:subPropertyOf rdf:resource="&obo;BFO_0000218"/>
		<rdfs:label xml:lang="en">has material basis at all times</rdfs:label>
