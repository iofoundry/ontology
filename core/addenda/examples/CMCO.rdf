	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&obo;BFO_0000221">
		<rdfs:label xml:lang="en">first instant of</rdfs:label>
		<rdfs:label>first instant of</rdfs:label>
		<dc:identifier>268-BFO</dc:identifier>
		<rdfs:domain rdf:resource="&obo;BFO_0000203"/>
		<rdfs:range rdf:resource="&obo;BFO_0000008"/>
		<owl:inverseOf rdf:resource="&obo;BFO_0000222"/>
		<skos:definition xml:lang="en">temporal instant t first instant of temporal region t&apos; =Def t precedes all temporal parts of t&apos; other than t</skos:definition>
		<skos:example xml:lang="en">An hour starting at midnight yesterday has first instant midnight yesterday.</skos:example>
		<skos:prefLabel xml:lang="en">first instant of</skos:prefLabel>
	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&obo;BFO_0000222">
		<rdf:type rdf:resource="&owl;FunctionalProperty"/>
		<rdfs:label xml:lang="en">has first instant</rdfs:label>
		<rdfs:label>has first instant</rdfs:label>
		<dc:identifier>261-BFO</dc:identifier>
		<rdfs:domain rdf:resource="&obo;BFO_0000008"/>
		<rdfs:range rdf:resource="&obo;BFO_0000203"/>
		<skos:definition xml:lang="en">t has first instant t&apos; =Def t&apos; first instant of t</skos:definition>
		<skos:example xml:lang="en">The first hour of a year has first instant midnight on December 31.</skos:example>
		<skos:prefLabel xml:lang="en">has first instant</skos:prefLabel>
	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&obo;BFO_0000223">
		<rdfs:label xml:lang="en">last instant of</rdfs:label>
		<rdfs:label>last instant of</rdfs:label>
		<dc:identifier>269-BFO</dc:identifier>
		<rdfs:domain rdf:resource="&obo;BFO_0000203"/>
		<rdfs:range rdf:resource="&obo;BFO_0000008"/>
		<owl:inverseOf rdf:resource="&obo;BFO_0000224"/>
		<skos:definition xml:lang="en">temporal instant t last instant of temporal region t&apos; =Def all temporal parts of t&apos; other than t precede t</skos:definition>
		<skos:example xml:lang="en">Last midnight is the last instant of yesterday.</skos:example>
		<skos:prefLabel xml:lang="en">last instant of</skos:prefLabel>
	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&obo;BFO_0000224">
