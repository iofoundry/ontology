				<owl:someValuesFrom rdf:resource="&obo;NCIT_C95533"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>neutralized viral inactivation product</rdfs:label>
		<skos:definition>A process intermediate resulting from low-pH viral inactivation that has been neutralized to restore physiological pH for downstream processing.</skos:definition>
		<CMCO:hasBlaName>Neutralized Viral Inactivation Product</CMCO:hasBlaName>
		<AnnotationVocabulary:acronym>NVIP</AnnotationVocabulary:acronym>
	</owl:Class>
	
