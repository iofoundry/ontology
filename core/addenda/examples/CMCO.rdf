		<rdfs:subPropertyOf rdf:resource="&obo;BFO_0000174"/>
		<rdfs:label xml:lang="en">has proper continuant part at all times</rdfs:label>
		<rdfs:label>has proper continuant part at all times</rdfs:label>
		<dc:identifier>227-BFO</dc:identifier>
