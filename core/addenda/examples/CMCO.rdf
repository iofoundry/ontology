	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&obo;BFO_0000127">
		<rdfs:label xml:lang="en">material basis of at some time</rdfs:label>
		<rdfs:label>material basis of at some time</rdfs:label>
