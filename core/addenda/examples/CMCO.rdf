			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>freezing and storage recipe process stage</rdfs:label>
		<skos:definition>Controlled freezing and long-term storage of drug substance or product to preserve stability and prevent degradation, often at -20°C or -80°C.</skos:definition>
		<CMCO:hasBlaName>Freezing and Storage</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000036">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/KeyProcessParameter"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&qudt1;hasUnit"/>
				<owl:someValuesFrom rdf:resource="&obo;NCIT_C120814"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>filter load</rdfs:label>
		<skos:definition>The total volume or mass of process fluid passed through a filter before reaching its capacity or requiring replacement, impacting filtration efficiency.</skos:definition>
		<CMCO:hasBlaName>Filter Load</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000037">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/CriticalProcessParameter"/>
