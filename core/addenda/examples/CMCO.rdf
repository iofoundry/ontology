			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&obo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&CMCO;CMCO_0000294"/>
			</owl:Restriction>
