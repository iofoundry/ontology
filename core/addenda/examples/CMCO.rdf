				<owl:someValuesFrom rdf:resource="&obo;NCIT_C25472"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>number of product contact cycles</rdfs:label>
		<skos:definition>The count of times a reusable component contacts product during manufacturing, relevant for assessing material integrity and contamination risk.</skos:definition>
		<CMCO:hasBlaName>Number of Product Contact Cycles</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000038">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/ProcessParameter"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&qudt1;hasUnit"/>
				<owl:someValuesFrom rdf:resource="&MDO;MDO_0010254"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>resin load</rdfs:label>
		<skos:definition>The mass or volume of process fluid applied to a chromatography column per unit volume of resin, impacting binding capacity and separation efficiency.</skos:definition>
		<CMCO:hasBlaName>Resin Load</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000039">
		<rdfs:subClassOf rdf:resource="&obo;BFO_0000019"/>
		<rdfs:label>in vitro viruses level</rdfs:label>
		<skos:altLabel>in vitro viruses contamination level</skos:altLabel>
		<skos:altLabel>in vitro viruses measurement</skos:altLabel>
		<skos:definition>Quantitative measure of viral particles present in cell culture supernatant or process intermediates, assessed via infectivity or PCR-based assays.</skos:definition>
		<CMCO:hasBlaName>In Vitro Viruses</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000040">
		<rdfs:subClassOf rdf:resource="&obo;BFO_0000019"/>
		<rdfs:label>minute murine virus level</rdfs:label>
		<skos:altLabel>minute murine virus contamination level</skos:altLabel>
		<skos:definition>Concentration of Minute Virus of Mice (MVM), a parvovirus used as a model for viral clearance validation due to its small size and resistance to inactivation.</skos:definition>
		<CMCO:hasBlaName>Minute Murine Virus</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000043">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/ProcessIntermediateMaterial"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&Core;isInputOf"/>
				<owl:someValuesFrom rdf:resource="&obo;NCIT_C95533"/>
