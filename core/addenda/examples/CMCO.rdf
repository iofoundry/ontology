					<rdf:Description rdf:about="&obo;BFO_0000020">
					</rdf:Description>
				</owl:unionOf>
			</owl:Class>
		</rdfs:range>
		<skos:definition xml:lang="en">a g-dependent continuant c is concretized by an s-dependent continuant or process b at all times =Def for all times t, b exists at t implies (b concretizes c at t)</skos:definition>
		<skos:prefLabel xml:lang="en">is concretized by at all times</skos:prefLabel>
	</owl:ObjectProperty>
	
