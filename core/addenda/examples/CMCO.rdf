		<rdfs:subPropertyOf rdf:resource="&obo;BFO_0000059"/>
		<rdfs:label xml:lang="en">concretizes at all times</rdfs:label>
		<rdfs:label>concretizes at all times</rdfs:label>
		<dc:identifier>257-BFO</dc:identifier>
		<rdfs:domain>
			<owl:Class>
				<owl:unionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&obo;BFO_0000015">
					</rdf:Description>
					<rdf:Description rdf:about="&obo;BFO_0000020">
					</rdf:Description>
				</owl:unionOf>
			</owl:Class>
		</rdfs:domain>
		<rdfs:range rdf:resource="&obo;BFO_0000031"/>
		<skos:definition xml:lang="en">an s-dependent continuant b concretizes a g-dependent continuant c at all times =Def for all times t, b exists at t implies (c is the pattern or content which b shares at t with actual or potential copies)</skos:definition>
		<skos:prefLabel xml:lang="en">concretizes at all times</skos:prefLabel>
	</owl:ObjectProperty>
	
	<owl:ObjectProperty rdf:about="&obo;BFO_0000165">
		<rdfs:subPropertyOf rdf:resource="&obo;BFO_0000058"/>
