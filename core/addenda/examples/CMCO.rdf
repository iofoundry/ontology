		<rdfs:range rdf:resource="&obo;BFO_0000002"/>
		<skos:definition xml:lang="en">b has continuant part c at all times =Def for all times t, b exists at t implies (b and c are continuants &amp; b is a part of c at t)</skos:definition>
		<skos:prefLabel xml:lang="en">has continuant part at all times</skos:prefLabel>
	</owl:ObjectProperty>
	
