		<rdfs:label>final filtration and filling recipe process stage</rdfs:label>
		<skos:altLabel>final filtration and fill process stage</skos:altLabel>
		<skos:definition>Final sterile filtration followed by aseptic filling into containers under controlled conditions to ensure product sterility and compliance with CGMP.</skos:definition>
		<CMCO:hasBlaName>Final Filtration and Fill</CMCO:hasBlaName>
	</owl:Class>
	
	<owl:Class rdf:about="&CMCO;CMCO_0000015">
		<rdfs:subClassOf rdf:resource="https://ontology.merck.com/ontology/MMFGO/MMFGO_0000032"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&obo;BFO_0000110"/>
