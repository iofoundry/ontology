		<rdfs:label>monoclonal antibody recipe process</rdfs:label>
		<skos:definition>A structured sequence of operations for producing monoclonal antibodies, including cell line development, upstream cultivation, downstream purification, formulation, and fill-finish.</skos:definition>
	</owl:Class>
	
	<owl:Class rdf:about="https://ontology.merck.com/ontology/MMFGO/MMFGO_0000032">
		<rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/RecipeProcessStage"/>
		<rdfs:label>monoclonal antibody recipe process stage</rdfs:label>
		<skos:definition>A defined segment within the mAb manufacturing workflow, such as cell culture, purification, or formulation, each with specific objectives and controls.</skos:definition>
	</owl:Class>
	
