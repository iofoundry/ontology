<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE rdf:RDF [
	<!ENTITY AnnotationVocabulary "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/">
	<!ENTITY annotation "https://spec.industrialontologies.org/ontology/annotation/">
	<!ENTITY construct "https://spec.industrialontologies.org/ontology/construct/">
	<!ENTITY dc "http://purl.org/dc/elements/1.1/">
	<!ENTITY owl "http://www.w3.org/2002/07/owl#">
	<!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#">
	<!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#">
	<!ENTITY skos "http://www.w3.org/2004/02/skos/core#">
	<!ENTITY terms "http://purl.org/dc/terms/">
	<!ENTITY xsd "http://www.w3.org/2001/XMLSchema#">
]>
<rdf:RDF xml:base="https://spec.industrialontologies.org/ontology/core/InformationSlot/data/case1"
	xmlns:AnnotationVocabulary="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"
	xmlns:annotation="https://spec.industrialontologies.org/ontology/annotation/"
	xmlns:construct="https://spec.industrialontologies.org/ontology/construct/"
	xmlns:dc="http://purl.org/dc/elements/1.1/"
	xmlns:owl="http://www.w3.org/2002/07/owl#"
	xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
	xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
	xmlns:skos="http://www.w3.org/2004/02/skos/core#"
	xmlns:terms="http://purl.org/dc/terms/"
	xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
	
	<owl:Ontology rdf:about="https://spec.industrialontologies.org/ontology/core/InformationSlot/data/case1">
		<rdfs:comment>ex:n4 a c:ComponentParthoodSlot .
ex:hostN4 a c:InformationContentEntity ; c:isAbout ex:oN4 .
ex:oN4 a bfo:BFO_0000003 .   # occurrent
ex:n4 c:isSlotOf ex:hostN4 .</rdfs:comment>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202502/core/Core/"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/core/InformationSlot/"/>
	</owl:Ontology>
	
	<owl:NamedIndividual rdf:about="&construct;hostN4">
		<rdf:type rdf:resource="&construct;InformationContentEntity"/>
		<construct:isAbout rdf:resource="&construct;oN4"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&construct;n4">
		<rdf:type rdf:resource="&construct;ComponentParthoodSlot"/>
		<construct:isSlotOf rdf:resource="&construct;hostN4"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&construct;oN4">
		<rdf:type rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&construct;s_bad">
		<rdf:type rdf:resource="&construct;InformationSlot"/>
		<construct:isSlotOf rdf:resource="&construct;x1"/>
	</owl:NamedIndividual>
	
	<owl:NamedIndividual rdf:about="&construct;x1">
		<rdf:type rdf:resource="&construct;InformationContentEntity"/>
	</owl:NamedIndividual>

</rdf:RDF>