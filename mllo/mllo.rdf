<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE rdf:RDF [
	<!ENTITY bfo "http://purl.obolibrary.org/obo/">
	<!ENTITY dc "http://purl.org/dc/elements/1.1/">
	<!ENTITY dcterms "http://purl.org/dc/terms/">
	<!ENTITY foaf "http://xmlns.com/foaf/0.1/">
	<!ENTITY iof-av "https://spec.industrialontologies.org/ontology/annotation/">
	<!ENTITY iof-constr "https://spec.industrialontologies.org/ontology/construct/">
	<!ENTITY iof-ind "https://spec.industrialontologies.org/ontology/individual/">
	<!ENTITY oboInOwl "http://www.geneontology.org/formats/oboInOwl#">
	<!ENTITY owl "http://www.w3.org/2002/07/owl#">
	<!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#">
	<!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#">
	<!ENTITY skos "http://www.w3.org/2004/02/skos/core#">
	<!ENTITY swo "http://www.ebi.ac.uk/swo/">
	<!ENTITY xsd "http://www.w3.org/2001/XMLSchema#">
]>
<rdf:RDF xml:base="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"
	xmlns:bfo="http://purl.obolibrary.org/obo/"
	xmlns:dc="http://purl.org/dc/elements/1.1/"
	xmlns:dcterms="http://purl.org/dc/terms/"
	xmlns:foaf="http://xmlns.com/foaf/0.1/"
	xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
	xmlns:iof-constr="https://spec.industrialontologies.org/ontology/construct/"
	xmlns:iof-ind="https://spec.industrialontologies.org/ontology/individual/"
	xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#"
	xmlns:owl="http://www.w3.org/2002/07/owl#"
	xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
	xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
	xmlns:skos="http://www.w3.org/2004/02/skos/core#"
	xmlns:swo="http://www.ebi.ac.uk/swo/"
	xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
	
	<owl:Ontology rdf:about="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/">
		<rdfs:label xml:lang="en-US">machine learning lifecycle ontology</rdfs:label>
		<dcterms:abstract xml:lang="en-US">The Machine Learning Lifecycle Ontology provides terms for representing machine learning algorithms, models, datasets, features, training, execution, evaluation, deployment, and related lifecycle artifacts in alignment with the Industrial Ontology Foundry Core Ontology.</dcterms:abstract>
		<dcterms:contributor>Boonserm Kulvatunyou, NIST</dcterms:contributor>
		<dcterms:contributor>Hyunwoong Ko, ASU</dcterms:contributor>
		<dcterms:contributor xml:lang="en-US">Perawit Charoenwut, NIST</dcterms:contributor>
		<dcterms:creator xml:lang="en-US">IOF Machine Learning Lifecycle Ontology Working Group</dcterms:creator>
		<dcterms:license rdf:datatype="&xsd;anyURI">http://opensource.org/licenses/MIT</dcterms:license>
		<dcterms:title xml:lang="en-US">Industrial Ontology Foundry (IOF) Machine Learning Lifecycle Ontology</dcterms:title>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/"/>
		<owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202601/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:versionInfo xml:lang="en-US">202601 provisional candidate for IOF working group review</owl:versionInfo>
		<skos:changeNote xml:lang="en-US">2026-05-14: Migrated the MLLO candidate to IOF IRI Structure and Format V2.4, including flattened construct IRIs, provisional ontology metadata, and required construct definition annotations for working group review.</skos:changeNote>
		<iof-av:copyright>Copyright (c) 2026 Open Applications Group</iof-av:copyright>
		<iof-av:maturity rdf:resource="&iof-ind;Provisional"/>
	</owl:Ontology>
	
	<owl:Class rdf:about="&bfo;IAO_0000025">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">programming language</rdfs:label>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">A language in which source code is written, intended to executed/run by a software interpreter. Programming languages are ways to write instructions that specify what to do, and sometimes, how to do it.</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&bfo;IAO_0000027">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">data item</rdfs:label>
		<skos:example xml:lang="en-US">Data items include counts of things, analyte concentrations, and statistical summaries.</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">An information content entity that is intended to be a truthful statement about something (modulo, e.g., measurement precision or other systematic errors) and is constructed/acquired by a method which reliably tends to produce (approximately) truthful statements.</iof-av:naturalLanguageDefinition>
		<iof-av:synonym xml:lang="en">data</iof-av:synonym>
	</owl:Class>
	
	<owl:Class rdf:about="&bfo;IAO_0000098">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">data format specification</rdfs:label>
		<iof-av:directSource xml:lang="en">OBI_0000187</iof-av:directSource>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">A data format specification is the information content borne by the document published defining the specification.
Example: The ISO document specifying what encompasses an XML document; The instructions in a XSD file</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&bfo;IAO_0000100">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">data set</rdfs:label>
		<skos:example xml:lang="en-US">Intensity values in a CEL file or from multiple CEL files comprise a dataset (as opposed to the CEL files themselves).</skos:example>
		<iof-av:directSource xml:lang="en">OBI_0000042</iof-av:directSource>
		<iof-av:explanatoryNote xml:lang="en-US">1.The intention is that this term represent collections of like data. So this isn&apos;t for, e.g. the whole contents of a cel file, which includes parameters, metadata etc. This is more like java arrays of a certain rather specific type
2. Data sets are aggregates and thus must include two or more data items. We have chosen not to add logical axioms to make this restriction.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">Information content entity that is an aggregate of data items of the same type that have something in common. Averages and distributions can be determined for datasets.</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&bfo;STATO_0000225">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">probability distribution</rdfs:label>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">A probability distribution is an information content entity that specifies the probability of the value of a random variable.

For a discrete random variable, a mathematical formula that gives the probability of each value of the variable.

For a continuous random variable, a curve described by a mathematical formula which specifies, by way of areas under the curve, the probability that the variable falls within a particular interval.</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&bfo;STATO_0000531">
		<rdfs:subClassOf rdf:resource="&bfo;STATO_0000225"/>
		<rdfs:label xml:lang="en-US">prior probability distribution</rdfs:label>
		<iof-av:adaptedFrom>Oxford Dictionary of Statistics: 10.1093/acref/9780199541454.001.0001</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">a prior probability distribution is a probability distribution used as input to a Bayesian model to represent a priori knowledge about a model parameter. Along with the acquired/observed data, it is used to compute a posterior distribution according to the Bayes theorem.</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:AnnotationProperty rdf:about="&owl;qualifiedCardinality">
	</owl:AnnotationProperty>
	
	<owl:AnnotationProperty rdf:about="&iof-av;abbreviation">
	</owl:AnnotationProperty>
	
	<owl:AnnotationProperty rdf:about="&iof-av;adaptedFrom">
	</owl:AnnotationProperty>
	
	<owl:AnnotationProperty rdf:about="&iof-av;directSource">
	</owl:AnnotationProperty>
	
	<owl:AnnotationProperty rdf:about="&iof-av;explanatoryNote">
	</owl:AnnotationProperty>
	
	<owl:AnnotationProperty rdf:about="&iof-av;informationContentEntityLocation">
		<rdfs:label xml:lang="en-US">information content entity location</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">this annotation property serves the purpose of identifying where an information content entity that is not fully stored in a knowledge graph (e.g., only its metadata is present) is located for the purpose of retrieving it to conduct non-knowledge graph analysis (e.g., PCA). In case of a file system the data should be stored as a relative path</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">annotation property that identifies the location of an information content entity within a database, file system, or online resource</iof-av:naturalLanguageDefinition>
	</owl:AnnotationProperty>
	
	<owl:AnnotationProperty rdf:about="&iof-av;naturalLanguageDefinition">
	</owl:AnnotationProperty>
	
	<owl:AnnotationProperty rdf:about="&iof-av;synonym">
	</owl:AnnotationProperty>
	
	<owl:Class rdf:about="&iof-constr;ActionSelectionObjective">
		<rdfs:subClassOf rdf:resource="&iof-constr;ModelExecutionObjective"/>
		<rdfs:label xml:lang="en-US">action selection objective</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">an RNN is used for selecting the next control action in a bioreactor co-culture growth based on the state of the environment (e.g. nutrient availability, population of each cell type)</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">model execution objective to output an optimal action within a given environment</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ActionSpecification">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ActivationFunction">
		<rdfs:subClassOf rdf:resource="&iof-constr;MathematicalFunction"/>
		<rdfs:label xml:lang="en-US">activation function</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">an activation function is typically a non-linear transformation of the output of the neural network layer</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">function that prescribes how an output of a neural network layer is modified</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;AdamOptimizer">
		<rdfs:subClassOf rdf:resource="&iof-constr;OptimizationAlgorithm"/>
		<rdfs:label xml:lang="en-US">adam optimizer</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">optimization algorithm that prescribes how to find a minimum or a maximum by adaptive moment estimation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Algorithm">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;AlgorithmCharacteristic">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntityCharacteristic"/>
		<rdfs:label xml:lang="en-US">algorithm characteristic</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;informationContentEntityCharacteristicOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;Algorithm"/>
			</owl:Restriction>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity characteristic of an algorithm</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;AlgorithmVerbosity">
		<rdfs:subClassOf rdf:resource="&iof-constr;ConfigurationVariable"/>
		<rdfs:label xml:lang="en-US">algorithm verbosity</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">algorithm characteristic that specifies the amount of runtime information an encoded algorithm reports during execution</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ArtificialNeuralNetwork">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningModel"/>
		<rdfs:label xml:lang="en-US">artificial neural network</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningModel">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;NeuralNetworkLayer"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning model which consists of a collection of connected units or nodes called artificial neurons, which loosely model the neurons in a biological brain</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ArtificialNeuralNetworkTrainingAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTrainingAlgorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&bfo;BFO_0000057"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;ArtificialNeuralNetwork"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">artificial neural network training algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning algorithm that prescribes the training of an artificial neural network</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;AssociationRuleLearningAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTrainingAlgorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&bfo;BFO_0000057"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;AssociationRuleModel"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">association rule learning algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning algorithm that prescribes how an association rule model is trained</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;AssociationRuleModel">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningModel"/>
		<rdfs:label xml:lang="en-US">association rule model</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning model that finds the relations between features and determines the reliability of those associations</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;AveragePoolingLayer">
		<rdfs:subClassOf rdf:resource="&iof-constr;PoolingLayer"/>
		<rdfs:label xml:lang="en-US">average pooling layer</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">pooling layer that reduces input data dimensions by computing the average value of elements within a defined region</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Backpropagation">
		<rdfs:subClassOf rdf:resource="&iof-constr;ArtificialNeuralNetworkTrainingAlgorithm"/>
		<rdfs:label xml:lang="en-US">backpropagation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">the gradients are calculated during an optimization process</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">artificial neural network training algorithm that prescribes how the weights of neurons should be updated based on their gradients</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;BatchSize">
		<rdfs:subClassOf rdf:resource="&iof-constr;Hyperparameter"/>
		<rdfs:label xml:lang="en-US">batch size</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:directSource>https://medium.com/geekculture/how-does-batch-size-impact-your-model-learning-2dd34d9fb1fa</iof-av:directSource>
		<iof-av:explanatoryNote xml:lang="en-US">sample in the case of supervised learning consists of the input feature vector as well as the target variable</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">parameter that defines the number of samples to work through before updating the internal model parameters</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;BayesianAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTrainingAlgorithm"/>
		<rdfs:label xml:lang="en-US">bayesian algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">training a neural network with a prior probability distribution for neural network weights; utilization of prior distribution for loss regularization</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning algorithm that prescribes how bayesian statistics is used in training a machine learning model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;CategoricalFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;Feature"/>
		<rdfs:label xml:lang="en-US">categorical feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;Feature">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ClassificationScheme"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">&quot;low risk&quot; value of a process parameter that is prescribed by a risk analysis classification scheme</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature that can have only a limited, and usually fixed, number of possible values prescribed by some classification scheme</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ClassificationAccuracy">
		<rdfs:subClassOf rdf:resource="&iof-constr;PerformanceMetric"/>
		<rdfs:label xml:lang="en-US">classification accuracy</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">performance metric that prescribes how to assess the percentage of correctly classified inputs</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ClassificationObjective">
		<rdfs:subClassOf rdf:resource="&iof-constr;PredictionObjective"/>
		<rdfs:label xml:lang="en-US">classification objective</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">A CNN model has the objective to classify the input images into categories that represent if the object on the picture is an animal or not</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">prediction objective to categorize the input</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ClassificationScheme">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:allValuesFrom rdf:resource="&iof-constr;ValueExpression"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">classification scheme</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">binary classification scheme of &quot;true&quot; &quot;false&quot; that has no implicit ordering meaning, the classification scheme of &quot;low&quot; &quot;medium&quot; &quot;high&quot; that has explicit ordering whereby &quot;low&quot;&lt;&quot;medium&quot;&lt;&quot;high&quot;</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity that prescribes the values that a categorical value expression can have</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Cluster">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningModelComponent"/>
		<rdfs:label xml:lang="en-US">cluster</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning model component that consists of a number of samples used in model input that are grouped together</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ClusteringAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTrainingAlgorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;ClusteringModel"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">clustering algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">hierarchical clustering algorithm</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning algorithm that prescribes how a clustering model is generated</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ClusteringModel">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningModel"/>
		<rdfs:label xml:lang="en-US">clustering model</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningModel">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;Cluster"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DataDescriptionObjective"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">hierarchical clustering model, k means clustering model</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning model which consists of clusters that are determined by some underlying similarity between a subset of features in the training set that was used to train the model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ComplexNumberFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;NumericalFeature"/>
		<rdfs:label xml:lang="en-US">complex number feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">numeric feature whose values are complex numbers</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ComputingProcess">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ConfigurationSetting">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">configuration variable setting</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;InformationContentEntity">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isConfigurationSettingOfAtSomeTime"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ConfigurationVariable"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">&quot;4&quot; is the value of a batch size hyperparameter that is set for a particular training of a CNN model</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity that specifies the value of a configuration variable</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ConfigurationVariable">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">configuration variable</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">batch size for machine learning training, number of neighbors for KNN model generation, weight of a neuron, intercept of a linear regression model</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity whose value influences the output or behavior of an encoded algorithm of which it is a part</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ConfigurationVariableSet">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;ConfigurationVariable"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">configuration variable set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">collection of configuration variables that belong to a particular encoded algorithm</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ConfigurationVariableSettingSet">
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;ConfigurationSetting">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-constr;ConfigurationVariableSettingSet">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">configuration variable setting set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;InformationContentEntity">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isConfigurationSettingSetOfAtSomeTime"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ConfigurationVariableSet"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity that consists of configuration settings that belong to a configuration variable set</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ContinuousNumericFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;NumericalFeature"/>
		<rdfs:label xml:lang="en-US">continuous numeric feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">numeric feature whose values are real numbers</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ConvolutionalLayer">
		<rdfs:subClassOf rdf:resource="&iof-constr;NeuralNetworkLayer"/>
		<rdfs:label xml:lang="en-US">convolutional layer</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">neural network layer that applies learnable filters to its input and outputs feature maps that capture spatial hierarchies and patterns</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ConvolutionalNeuralNetwork">
		<rdfs:subClassOf rdf:resource="&iof-constr;ArtificialNeuralNetwork"/>
		<rdfs:label xml:lang="en-US">convolutional neural network</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;ArtificialNeuralNetwork">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;ModelInputRequirementSpecification">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;hasDimensionNumberValue"/>
										<owl:someValuesFrom>
											<rdfs:Datatype>
												<owl:onDatatype rdf:resource="&xsd;int"/>
												<owl:withRestrictions rdf:parseType="Collection">
													<rdf:Description>
														<xsd:minInclusive rdf:datatype="&xsd;int">2</xsd:minInclusive>
													</rdf:Description>
												</owl:withRestrictions>
											</rdfs:Datatype>
										</owl:someValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ConvolutionalLayer"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">artificial neural network that is composed primarily of convolutional layers and that requires inputs that have dimensions of at least two</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataCleaningAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingAlgorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;DataCleaningOperation"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">data cleaning algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">Multiple Imputation by Chained Equations algorithm used to impute the missing values</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data processing algorithm that prescribes how the missing or corrupted entries in a dataset should be corrected</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataCleaningObjective">
		<rdfs:subClassOf rdf:resource="&iof-constr;ObjectiveSpecification"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isAchievedByAtSomeTime"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;DataCleaningOperation">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-constr;DataCleaningPipeline">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">data cleaning objective</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">objective specification that prescribes the outcome of a data cleaning operation or pipeline</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataCleaningOperation">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingOperation"/>
		<rdfs:label xml:lang="en-US">data cleaning operation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;DataProcessingOperation">
					</rdf:Description>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000059"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;DataCleaningObjective"/>
							</owl:Restriction>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;executed"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;EncodedDataCleaningAlgorithm"/>
							</owl:Restriction>
						</owl:unionOf>
					</owl:Class>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data processing operation that detects and corrects a set of corrupt, missing or inaccurate records from a dataset</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataCleaningPipeline">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingPipeline"/>
		<rdfs:label xml:lang="en-US">data cleaning pipeline</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;DataProcessingPipeline">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DataCleaningOperation"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
						<owl:someValuesFrom rdf:resource="&bfo;IAO_0000100"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;PreProcessedDataSet"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process that consists of a number of data cleaning operations through which the input dataset is processed to impute missing and/or remove corrupted values</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataDescriptionObjective">
		<rdfs:subClassOf rdf:resource="&iof-constr;ModelExecutionObjective"/>
		<rdfs:label xml:lang="en-US">data description objective</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">use of PCA to identify which tumor types share a similar RNA expression pattern</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">model execution objective to describe some underlying characteristic of the input data items</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataImputationAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataCleaningAlgorithm"/>
		<rdfs:label xml:lang="en-US">data imputation algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data cleaning algorithm that prescribes how missing values within some dataset should be replaced</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataImputationOperation">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataCleaningOperation"/>
		<rdfs:label xml:lang="en-US">data imputation operation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;DataCleaningOperation">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;executed"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;EncodedDataCleaningAlgorithm">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;DataImputationAlgorithm"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">computing process in which missing values are replaced by some encoded data imputation algorithm</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataItemCharacteristic">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntityCharacteristic"/>
		<rdfs:label xml:lang="en-US">data item characteristic</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;informationContentEntityCharacteristicOf"/>
				<owl:someValuesFrom rdf:resource="&bfo;IAO_0000027"/>
			</owl:Restriction>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity characteristic of a data item</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataProcessingAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;Algorithm"/>
		<rdfs:label xml:lang="en-US">data processing algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">algorithm that prescribes how to transform or modify pieces of data</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataProcessingOperation">
		<rdfs:subClassOf rdf:resource="&iof-constr;ComputingProcess"/>
		<rdfs:subClassOf>
			<owl:Class>
				<owl:complementOf>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000118"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DataProcessingOperation"/>
					</owl:Restriction>
				</owl:complementOf>
			</owl:Class>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
				<owl:someValuesFrom rdf:resource="&bfo;IAO_0000027"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
				<owl:someValuesFrom rdf:resource="&bfo;IAO_0000027"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">data processing operation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">computing process that transforms or modifies input data</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataProcessingPipeline">
		<rdfs:subClassOf rdf:resource="&iof-constr;ComputingProcess"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;DataProcessingOperation"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
				<owl:someValuesFrom rdf:resource="&bfo;IAO_0000100"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
				<owl:someValuesFrom rdf:resource="&bfo;IAO_0000100"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">data processing pipeline</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">computing process that consists of an ordered set of data processing operations through which an input dataset is transformed</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataQualityAssesment">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000059"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;DataQualityMetric"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
				<owl:someValuesFrom rdf:resource="&bfo;IAO_0000100"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">data quality assessment</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which the data quality of a dataset is assessed with respect to one or more quality metrics</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataQualityMetric">
		<rdfs:subClassOf rdf:resource="&iof-constr;MathematicalFunction"/>
		<rdfs:label xml:lang="en-US">data quality metric</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">1) data quality metrics include metrics for accuracy, data completeness, consistency, and timeliness
2) data quality metrics can be qualitative, quantitative and semi-quantitative</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">mathematical function that prescribes how to assess the suitability of a dataset for a particular application</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataQualityMonitoring">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:subClassOf>
			<owl:Class>
				<owl:unionOf rdf:parseType="Collection">
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000132"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DeployedMachineLearningModelState"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;occursSimultaneouslyWith"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DeployedMachineLearningModelState"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;temporallyFinishes"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DeployedMachineLearningModelState"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;temporallyStarts"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DeployedMachineLearningModelState"/>
					</owl:Restriction>
				</owl:unionOf>
			</owl:Class>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;DataQualityAssesment"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">data quality monitoring</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">prior to utilization, the dataset in this context includes either raw or pre-processed datasets</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process during which data quality is assessed for datasets prior to being utilized for a deployed machine learning model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataReshapingOperation">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingOperation"/>
		<rdfs:label xml:lang="en-US">data reshaping operation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data processing operation that changes the dimensions of one or more datasets or data items</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataSetCharacteristic">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntityCharacteristic"/>
		<rdfs:label xml:lang="en-US">data set characteristic</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;informationContentEntityCharacteristicOf"/>
				<owl:someValuesFrom rdf:resource="&bfo;IAO_0000100"/>
			</owl:Restriction>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data item characteristic of a dataset</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DataSetOrderingScheme">
		<rdfs:label xml:lang="en-US">data set ordering scheme</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;InformationContentEntityOrderingScheme">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isAbout"/>
						<owl:someValuesFrom rdf:resource="&bfo;IAO_0000100"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;Index"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity ordering scheme that prescribes the ordering of data items within a dataset</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DateTimeFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;Feature"/>
		<rdfs:label xml:lang="en-US">date-time feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;Feature">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isValueExpressionOfAtSomeTime"/>
						<owl:someValuesFrom rdf:resource="&bfo;BFO_0000008"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature whose values are dates or times</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DecisionTreeAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTrainingAlgorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;DecisionTreeModel"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">decision tree algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">ID3, M5, Stump</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning algorithm that prescribes how a decision tree model is generated</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DecisionTreeModel">
		<rdfs:subClassOf rdf:resource="&iof-constr;NonParametricModel"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;RegressionObjective"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">decision tree model</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">non-parametric model that is a tree-like graph where each branching present is dependent on a value of some feature present in the training set that was used to train the model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DefaultSetting">
		<rdfs:subClassOf rdf:resource="&iof-constr;ConfigurationSetting"/>
		<rdfs:label xml:lang="en-US">default setting</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isDefaultSettingOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;ConfigurationVariable"/>
			</owl:Restriction>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">5 neighbors is the default setting for sklearn KNN training algorithm implementation</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">configuration variable setting that specifies the default value (value that is used if user does not provide a value) of a configuration variable</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DeployedMachineLearningModelState">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000015"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000057"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningParameterSettingSet"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000167"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;EngineeredSystem"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000167"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;meets"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModelDeploymentProcess"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">deployed machine learning model state</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">process during which a machine learning model is deployed on a particular engineered system</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DerivedFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;Feature"/>
		<rdfs:label xml:lang="en-US">derived feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;Feature">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;dataOutputOf"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;FeatureEngineeringOperation">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-constr;FeatureEngineeringPipeline">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature that was created by a set of feature engineering operations</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DerivedFeatureColumn">
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
				<owl:allValuesFrom rdf:resource="&iof-constr;DerivedFeature"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">derived feature column</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;FeatureColumn">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DerivedFeature"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature column that has only derived features as parts</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DigitalImage">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000027"/>
		<rdfs:label xml:lang="en-US">digital image</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data item that is a rectangular or cuboid grid of elements (pixels or voxels respectively), whose values are finite, discrete quantities derived from measurements of some quality of a number of entities repeated at regular intervals across a spatial range</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DimensionalityReductionAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTrainingAlgorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&bfo;BFO_0000057"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;DimensionalityReductionModel"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">dimensionality reduction algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">randomized SVD solver used to generate a principal component model</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning algorithm that prescribes how a dimensionality reduction model is trained</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DimensionalityReductionModel">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningModel"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;DataDescriptionObjective"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">dimensionality reduction model</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning model that prescribes how to map datasets to a space of lower dimension</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DirectiveInformationContentEntity">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DiscreteNumericFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;NumericalFeature"/>
		<rdfs:label xml:lang="en-US">discrete numeric feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">discrete numerical values are values from a set that consists of a countable number of equally spaced values between a certain range of numbers (e.g Integers)</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">numeric feature that has discrete numerical values</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;DistanceMetric">
		<rdfs:subClassOf rdf:resource="&iof-constr;MathematicalFunction"/>
		<rdfs:label xml:lang="en-US">distance metric</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">the euclidean distance between two samples in a dataset</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">mathematical function that prescribes how a distance between each pair of point elements of a set is calculated</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EncodedAlgorithm">
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isEncodedIn"/>
				<owl:someValuesFrom rdf:resource="&bfo;IAO_0000025"/>
			</owl:Restriction>
		</rdfs:subClassOf>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EncodedAlgorithmCharacteristic">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntityCharacteristic"/>
		<rdfs:label xml:lang="en-US">encoded algorithm characteristic</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;informationContentEntityCharacteristicOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;EncodedAlgorithm"/>
			</owl:Restriction>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity characteristic that is the distinguishing quality or property of an encoded algorithm</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EncodedDataCleaningAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;EncodedAlgorithm"/>
		<rdfs:label xml:lang="en-US">encoded data cleaning algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DataCleaningAlgorithm"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">encoded algorithm that is the implementation of a data cleaning algorithm</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EncodedFeatureEngineeringAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;EncodedAlgorithm"/>
		<rdfs:label xml:lang="en-US">encoded feature engineering algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;FeatureEngineeringAlgorithm"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">encoded algorithm that is the implementation of a feature engineering algorithm</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EncodedInitializationAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;EncodedAlgorithm"/>
		<rdfs:label xml:lang="en-US">encoded initialization algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;InitializationAlgorithm"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">encoded algorithm that is the implementation of an initialization algorithm</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EncodedMachineLearningTrainingAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;EncodedAlgorithm"/>
		<rdfs:label xml:lang="en-US">encoded machine learning training algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningTrainingAlgorithm"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:explanatoryNote xml:lang="en-US">typically an encoded machine learning algorithm is a part of a larger machine learning framework</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">encoded algorithm that is the implementation of a machine learning training algorithm</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EncodedOptimizationAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;EncodedAlgorithm"/>
		<rdfs:label xml:lang="en-US">encoded optimization algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;OptimizationAlgorithm"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">encoded algorithm that is the implementation of an optimization algorithm</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EncodedRegularizationMethod">
		<rdfs:subClassOf rdf:resource="&iof-constr;EncodedAlgorithm"/>
		<rdfs:label xml:lang="en-US">encoded regularization method</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;RegularizationMethod"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">encoded algorithm that is the implementation of a regularization method</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EngineeredSystem">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EnsembleAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTrainingAlgorithm"/>
		<rdfs:label xml:lang="en-US">ensemble algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning algorithm that prescribes how to combine elements of multiple machine learning models trained on the same task in order to achieve better performance</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Epoch">
		<rdfs:subClassOf rdf:resource="&bfo;BFO_0000202"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000139"/>
				<owl:someValuesFrom>
					<owl:Restriction>
						<owl:onProperty>
							<rdf:Description>
								<owl:inverseOf rdf:resource="&bfo;BFO_0000199"/>
							</rdf:Description>
						</owl:onProperty>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningTraining"/>
					</owl:Restriction>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">epoch</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">time interval during which a whole machine learning input dataset is processed in a machine learning training</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;EpochNumber">
		<rdfs:subClassOf rdf:resource="&iof-constr;Hyperparameter"/>
		<rdfs:label xml:lang="en-US">epoch number</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">hyperparameter that specifies the number of epochs a machine learning model will be trained for</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ExploratoryDataAnalysis">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
				<owl:someValuesFrom rdf:resource="&bfo;IAO_0000100"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;DataItemCharacteristic">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-constr;DataSetCharacteristic">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">exploratory data analysis</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">determining the correlation between feature vectors, determining the skewness of the distribution of a particular feature</skos:example>
		<iof-av:explanatoryNote xml:lang="en-US">typically precedes machine learning data preparation</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which one or more characteristics of a dataset or its parts are determined</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Feature">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000027"/>
		<rdfs:label xml:lang="en-US">feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;IAO_0000027">
					</rdf:Description>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000177"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningDataSet"/>
							</owl:Restriction>
							<owl:Restriction>
								<owl:onProperty>
									<rdf:Description>
										<owl:inverseOf rdf:resource="&iof-constr;informationContentEntityDerivedFrom"/>
									</rdf:Description>
								</owl:onProperty>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&bfo;IAO_0000027">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&bfo;BFO_0000177"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningDataSet"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:unionOf>
					</owl:Class>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">petal width value of an iris flower; digital image of a number</skos:example>
		<iof-av:explanatoryNote xml:lang="en-US">1. the data item considered as feature can be used directly in machine learning training or can first undergo a series of machine learning data preparation operations (e.g., feature engineering or data cleaning)

2. association here can be interpreted as the feature being about some aspect or characteristic of the entity

3. Feature can also in some cases be interpreted as a single item (entry) within a machine learning dataset</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data item associated with an entity and intended to be used as input to a machine learning model execution or machine learning training</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureCharacteristic">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataItemCharacteristic"/>
		<rdfs:label xml:lang="en-US">feature characteristic</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;informationContentEntityCharacteristicOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;Feature"/>
			</owl:Restriction>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data item characteristic of a feature</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureColumn">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000100"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
				<owl:allValuesFrom rdf:resource="&iof-constr;Feature"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;Feature"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">feature column</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">petal length value of 50 different iris flowers</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">dataset that is composed of a number of features of the same type that are associated with different entities</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureDecomposition">
		<rdfs:subClassOf rdf:resource="&iof-constr;FeatureEngineeringOperation"/>
		<rdfs:label xml:lang="en-US">feature decomposition</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature engineering operation that creates multiple features from one feature</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureEngineeringAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingAlgorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;FeatureEngineeringOperation"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">feature engineering algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">min-max normalization algorithm that scales all the features to a specific range</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data processing algorithm that prescribes how to generate a feature of a particular type from a set of inputs</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureEngineeringOperation">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingOperation"/>
		<rdfs:label xml:lang="en-US">feature engineering operation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;DataProcessingOperation">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;executed"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;EncodedFeatureEngineeringAlgorithm"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">min-max normalization of a numerical feature vector; bagging transformation of a textual feature</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which one or more input features are used to create derived features</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureEngineeringPipeline">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingPipeline"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;FeatureEngineeringOperation"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;IAO_0000100">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;DerivedFeatureColumn"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">feature engineering pipeline</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process that consists of a number of feature engineering operations and that outputs a dataset that has at least one derived feature column as part</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureEngineeringTransformation">
		<rdfs:subClassOf rdf:resource="&iof-constr;FeatureEngineeringOperation"/>
		<rdfs:label xml:lang="en-US">feature engineering transformation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature engineering operation that changes the representation or value of a feature</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureGeneration">
		<rdfs:subClassOf rdf:resource="&iof-constr;FeatureEngineeringOperation"/>
		<rdfs:label xml:lang="en-US">feature generation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature engineering operation that generates one or more features by combining multiple features</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureScalingAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;FeatureEngineeringAlgorithm"/>
		<rdfs:label xml:lang="en-US">feature scaling algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature engineering algorithm that prescribes how to scale a feature vector or feature to be within a particular value range</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureScalingOperation">
		<rdfs:subClassOf rdf:resource="&iof-constr;FeatureEngineeringTransformation"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;ScaledFeature">
							</rdf:Description>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;DerivedFeatureColumn">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;ScaledFeature"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:unionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">feature scaling operation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature engineering transformation that produced scaled features as its output</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureSelection">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningTraining"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;ModelEvaluation"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningDataSet"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningDataSet"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">feature selection</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which a subset of initial features is selected such that the associated machine learning model has a more optimal performance</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureVector">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000100"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
				<owl:allValuesFrom rdf:resource="&iof-constr;Feature"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;describes"/>
				<owl:onClass rdf:resource="&bfo;BFO_0000001"/>
				<owl:qualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">1</owl:qualifiedCardinality>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;Feature"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">feature vector</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">petal length value, petal width value, sepal length value and sepal width value associated with a single iris flower</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">dataset composed of a set of features that belong to a single entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FeatureVectorCharacteristic">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataSetCharacteristic"/>
		<rdfs:label xml:lang="en-US">feature vector characteristic</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;informationContentEntityCharacteristicOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;FeatureVector"/>
			</owl:Restriction>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">dataset characteristic of a feature vector</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FlatteningLayer">
		<rdfs:subClassOf rdf:resource="&iof-constr;NeuralNetworkLayer"/>
		<rdfs:label xml:lang="en-US">flattening layer</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">neural network layer that transforms multidimensional input data into a one-dimensional array to prepare the data for input to fully connected layers</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;FullyConnectedLayer">
		<rdfs:subClassOf rdf:resource="&iof-constr;NeuralNetworkLayer"/>
		<rdfs:label xml:lang="en-US">fully connected layer</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">in case the FC layer is the input layer, then each node directly takes as inputs all the entries of an individual feature vector</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">neural network layer in which each node connects directly to all nodes from a previous layer</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;GaussianNoise">
		<rdfs:subClassOf rdf:resource="&iof-constr;Noise"/>
		<rdfs:label xml:lang="en-US">gaussian noise</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">noise whose values follow a gaussian distribution</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;GaussianProcessRegression">
		<rdfs:subClassOf rdf:resource="&iof-constr;NonParametricModel"/>
		<rdfs:label xml:lang="en-US">gaussian process regression</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">gaussian process regression is trained by a bayesian algorithm in a supervised learning process where a gaussian process prior is used as input</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">non-parametric model which is a gaussian process distribution over possible functions that model the underlying data</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Graph">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:subClassOf>
			<owl:Class>
				<owl:unionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;IAO_0000027">
					</rdf:Description>
					<rdf:Description rdf:about="&bfo;IAO_0000100">
					</rdf:Description>
				</owl:unionOf>
			</owl:Class>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">graph</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data item or dataset that consists of a set of nodes that are connected with edges</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;GraphFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;Feature"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;describes"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;Graph"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">graph feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature of a graph</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;GroupOfMachineLearningModels">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">group of machine learning models</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">collection of machine learning models</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;HammingLoss">
		<rdfs:subClassOf rdf:resource="&iof-constr;PerformanceMetric"/>
		<rdfs:label xml:lang="en-US">hamming loss</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">performance metric that prescribes how to quantify the fraction of incorrect labels assigned to a set of machine learning inputs</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Hyperparameter">
		<rdfs:subClassOf rdf:resource="&iof-constr;ConfigurationVariable"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;configurationVariableOf"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedMachineLearningTrainingAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty>
									<rdf:Description>
										<owl:inverseOf rdf:resource="&iof-constr;isComposedOf"/>
									</rdf:Description>
								</owl:onProperty>
								<owl:someValuesFrom rdf:resource="&iof-constr;EncodedMachineLearningTrainingAlgorithm"/>
							</owl:Restriction>
						</owl:unionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">hyperparameter</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:disjointWith rdf:resource="&iof-constr;MachineLearningParameter"/>
		<skos:example xml:lang="en-US">number of epochs for training a neural network model</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">configuration variable of an encoded machine learning algorithm whose value is not influenced directly by data during machine learning training</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;HyperparameterSet">
		<rdfs:subClassOf rdf:resource="&iof-constr;ConfigurationVariableSet"/>
		<rdfs:label xml:lang="en-US">hyperparameter set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">collection of hyperparameters that belong to a particular machine learning training implementation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;HyperparameterTuning">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:label xml:lang="en-US">hyperparameter tuning</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;PlannedProcess">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ModelValidation"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;ConfigurationVariableSettingSet">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;isConfigurationSettingSetOfAtSomeTime"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;HyperparameterSet"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which an optimal hyperparameter value set is found by a set of model validations, whereby machine learning training in each model validation has different hyperparameter values as inputs</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Identifier">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ImageFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;Feature"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;describes"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;DigitalImage"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">image feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature of a digital image</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Index">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">index</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity that is the position of an information content entity within another information content entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;InformationContentEntity">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;InformationContentEntityCharacteristic">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">information content entity characteristic</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;informationContentEntityCharacteristicOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;InformationContentEntity"/>
			</owl:Restriction>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">skewness in the distribution of a feature, collinearity between different feature vectors, capability of a model to handle non-linear data, depth of a machine learning model, class entropy of a categorical dataset</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">distinguishing quality or property of an information content entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;InformationContentEntityOrderingScheme">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">information content entity ordering scheme</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity that prescribes the ordering between elements of which an information content entity is composed of</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;InitialMachineLearningParameterSetting">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningParameterSetting"/>
		<rdfs:label xml:lang="en-US">initial machine learning parameter setting</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningParameterSetting">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isInputOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningTraining"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">value of a neuron weight that is the output of machine learning parameter initialization and the input of training of the neural network the neuron is a part of</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning parameter setting at the beginning of some machine learning training</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;InitialMachineLearningParameterSettingSet">
		<rdfs:label xml:lang="en-US">initial machine learning parameter setting set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningParameterSettingSet">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isInputOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningTraining"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning parameter setting set that contains all the values of a machine learning parameter set at the beginning of machine learning training</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;InitializationAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;Algorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningParameterInitialization"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">initialization algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">Xe initialization used to initialize weights of neurons in an ANN</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">algorithm that prescribes how machine learning parameter values will be set at the beginning of machine learning training</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;InstanceBasedAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTrainingAlgorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;InstanceBasedModel"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">instance-based algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">coordinate descent algorithm that creates a support vector machine model</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning algorithm that prescribes how to generate an instance-based model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;InstanceBasedModel">
		<rdfs:subClassOf rdf:resource="&iof-constr;NonParametricModel"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;FeatureVector">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000177"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;TrainingDataSet"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">instance-based model</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">k-nearest neighbours</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">non-parametric model that consists of a subset of feature vectors present in the training dataset that was used to train the model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Keras">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningFramework"/>
		<rdfs:label xml:lang="en-US">keras</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:directSource>https://keras.io/</iof-av:directSource>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning framework that provides an interface for defining, training, and executing machine learning models</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;LinearModel">
		<rdfs:subClassOf rdf:resource="&iof-constr;PolynomialModel"/>
		<rdfs:label xml:lang="en-US">linear model</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">polynomial model in which the polynomial function is a linear function</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;LogisticRegression">
		<rdfs:subClassOf rdf:resource="&iof-constr;PolynomialModel"/>
		<rdfs:label xml:lang="en-US">logistic regression</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">polynomial model that is based on the logistic function and is used to classify inputs into two or more categories</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;LossFunction">
		<rdfs:subClassOf rdf:resource="&iof-constr;MathematicalFunction"/>
		<rdfs:label xml:lang="en-US">loss function</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">Mean absolute error that is used as part of an optimization procedure to measure the absolute difference between the prediction value of the model and the absolute value.</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">mathematical function that prescribes how the difference between a target variable and the output of a machine learning model is calculated</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningDataPreparationPipeline">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingPipeline"/>
		<rdfs:label xml:lang="en-US">machine learning data preparation pipeline</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;DataProcessingPipeline">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;RawDataSet"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningDataSet"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process that consists of a set of data processing operations and/or data cleaning operations through which a raw dataset is converted into a machine learning dataset</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningDataSet">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000100"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;FeatureVector"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;dataInputOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;MachineLearningDataSetPartitioning">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-constr;ModelExecution">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">machine learning data set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">dataset that consists of patient PET images used as input into cGAN execution; cNIST dataset used for input in an ANN classification; dataset that consists of values of several CPPs measured over a certain period of time that is used as input for a deep learning model that predicts a particular CQA</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">dataset that consists of a number of feature vectors and is intended to be input to machine learning model execution or machine learning training</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningDataSetPartitioning">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:label xml:lang="en-US">machine learning data set partitioning</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;PlannedProcess">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
						<owl:someValuesFrom rdf:resource="&bfo;IAO_0000100"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;TrainingDataSet"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;TestDataSet">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-constr;ValidationDataSet">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process that splits the input dataset into subsets for machine learning training and model evaluation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningFramework">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;EncodedMachineLearningTrainingAlgorithm"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">machine learning framework</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">collection of a number of encoded algorithms necessary for machine learning training, model assessment and model execution encoded in some programming language</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningModel">
		<rdfs:subClassOf rdf:resource="&iof-constr;EncodedAlgorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;ModelExecutionObjective"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">machine learning model</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">a convolutional neural network, a decision tree</skos:example>
		<iof-av:explanatoryNote xml:lang="en-US">the internal parameters of a machine learning model are determined by some machine learning training</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">encoded algorithm that is executed to find patterns, make decisions, or make predictions from a previously unseen dataset</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningModelAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;Algorithm"/>
		<rdfs:label xml:lang="en-US">machine learning model algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">the structure of a neural network that is implementation independent</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">algorithm that prescribes a machine learning model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningModelComponent">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">machine learning model component</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;InformationContentEntity">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty>
							<rdf:Description>
								<owl:inverseOf rdf:resource="&iof-constr;isComposedOf"/>
							</rdf:Description>
						</owl:onProperty>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;MachineLearningModel">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-constr;MachineLearningModelAlgorithm">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">support vector within a SVM, neuron within a neural network, cluster within a clustering model</skos:example>
		<iof-av:explanatoryNote xml:lang="en-US">since machine learning model components can either be algorithmic in nature (e.g., neural network layer) or a data item (e.g., a cluster) this class was put directly under ICE</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity that is a proper part of a machine learning model or machine learning model algorithm</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningModelDeploymentProcess">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000057"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;EngineeredSystem"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasInput"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasOutput"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;MachineLearningModel">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000084"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;EngineeredSystem"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">machine learning model deployment process</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which a machine learning model is deployed in an engineered system</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningModelDevelopmentPipeline">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:label xml:lang="en-US">machine learning model development pipeline</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;PlannedProcess">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000062"/>
										<owl:someValuesFrom>
											<owl:Class>
												<owl:unionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="&iof-constr;ExploratoryDataAnalysis">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-constr;MachineLearningDataPreparationPipeline">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-constr;MachineLearningDataSetPartitioning">
													</rdf:Description>
												</owl:unionOf>
											</owl:Class>
										</owl:someValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;ModelEvaluation">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000062"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningTraining"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;ExploratoryDataAnalysis">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-constr;MachineLearningDataPreparationPipeline">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-constr;MachineLearningDataSetPartitioning">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process that consists of a set of processes that are required to develop a machine learning model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningModelUpdate">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTraining"/>
		<rdfs:label xml:lang="en-US">machine learning model update</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000057"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasInput"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;MachineLearningParameterSettingSet">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;isOutputOf"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningTraining"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningParameterSettingSet"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which the machine learning parameters of a previously trained model are updated</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningParameter">
		<rdfs:subClassOf rdf:resource="&iof-constr;ConfigurationVariable"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;configurationVariableOf"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;MachineLearningModel">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-constr;MachineLearningModelComponent">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">machine learning parameter</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">coefficients in a regression model; weights of a neuron</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">configuration variable internal to a machine learning model whose value is influenced by (updated on the basis of) input data during machine learning training</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningParameterInitialization">
		<rdfs:subClassOf rdf:resource="&iof-constr;ComputingProcess"/>
		<rdfs:label xml:lang="en-US">machine learning parameter initialization</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;ComputingProcess">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000063"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningTraining"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;executed"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;EncodedInitializationAlgorithm"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasInput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningParameterSet"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasOutput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;InitialMachineLearningParameterSettingSet"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">computing process that executes an encoded initialization algorithm to create initial machine learning parameter setting set</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningParameterSet">
		<rdfs:subClassOf rdf:resource="&iof-constr;ConfigurationVariableSet"/>
		<rdfs:label xml:lang="en-US">machine learning parameter set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">collection of machine learning parameters that belong to a particular machine learning model or model component</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningParameterSetting">
		<rdfs:subClassOf rdf:resource="&iof-constr;ConfigurationSetting"/>
		<rdfs:label xml:lang="en-US">machine learning parameter setting</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;ConfigurationSetting">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isConfigurationSettingOfAtSomeTime"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningParameter"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">value of a machine learning parameter after machine learning training</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">configuration variable setting of a machine learning parameter</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningParameterSettingSet">
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;MachineLearningParameterSetting">
							</rdf:Description>
							<rdf:Description rdf:about="&iof-constr;MachineLearningParameterSettingSet">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">machine learning parameter setting set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;ConfigurationVariableSettingSet">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isConfigurationSettingSetOfAtSomeTime"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningParameterSet"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">configuration variable setting set that contains all the values of a machine learning parameter set</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningSampleIdentifier">
		<rdfs:label xml:lang="en-US">feature vector identifier</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;Identifier">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;designates"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;FeatureVector"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">identifier that identifies a feature vector within a dataset</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningTraining">
		<rdfs:subClassOf rdf:resource="&iof-constr;ComputingProcess"/>
		<rdfs:label xml:lang="en-US">machine learning training</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;ComputingProcess">
					</rdf:Description>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<owl:Restriction>
												<owl:onProperty rdf:resource="&iof-constr;hasInput"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;InitialMachineLearningParameterSettingSet"/>
											</owl:Restriction>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&iof-constr;hasOutput"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningParameterSettingSet"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&bfo;BFO_0000057"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
							</owl:Restriction>
						</owl:unionOf>
					</owl:Class>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;executed"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;EncodedMachineLearningTrainingAlgorithm"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;TrainingDataSet"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:explanatoryNote xml:lang="en-US">Learning is defined in this case as progressively improving performance of the underlying model on a predefined task.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">computing process in which an encoded machine learning algorithm is executed to generate or update a machine learning model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MachineLearningTrainingAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;Algorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningTraining"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">machine learning training algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">backpropagation algorithm used to train a neural network; M5 algorithm used to generate a decision tree model</skos:example>
		<iof-av:explanatoryNote xml:lang="en-US">machine learning training algorithms determine how the patterns and rules from the input machine learning dataset will be stored in and used to create or update a machine learning model</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">algorithm that prescribes how a machine learning model will be updated or generated</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MathematicalFunction">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">mathematical function</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">y=x+2, any polynomial, y=sin(x)</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">an expression, rule, or law that defines a relationship between one or more variables (the independent variables) and another set of variables (the dependent variables)</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MeanAbsoluteError">
		<rdfs:subClassOf rdf:resource="&iof-constr;PerformanceMetric"/>
		<rdfs:label xml:lang="en-US">mean absolute error</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">performance metric which prescribes how to determine the average of the absolute differences between predicted values and observed values</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MeasuredValueExpression">
		<owl:disjointWith rdf:resource="&iof-constr;SimulatedValueExpression"/>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelAssumptions">
		<rdfs:subClassOf rdf:resource="&iof-constr;ModelInputRequirementSpecification"/>
		<rdfs:label xml:lang="en-US">model assumptions</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">These conditions are typically checkable.</iof-av:explanatoryNote>
		<iof-av:explanatoryNote xml:lang="en-US">to be a valid input in this context means that it is an input of a computing process which executes an encoding of the model or algorithm</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">model input requirement specification that specifies the data item characteristics that features, feature vectors, or feature vector sets must have</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelCharacteristic">
		<rdfs:subClassOf rdf:resource="&iof-constr;EncodedAlgorithmCharacteristic"/>
		<rdfs:label xml:lang="en-US">model characteristic</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;informationContentEntityCharacteristicOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
			</owl:Restriction>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">encoded algorithm characteristic of a machine learning model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelEvaluation">
		<rdfs:subClassOf rdf:resource="&iof-constr;ModelPerformanceAssessment"/>
		<rdfs:label xml:lang="en-US">model evaluation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;ModelPerformanceAssessment">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;ModelOutputDataSet">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;informationContentEntityDerivedFrom"/>
										<owl:someValuesFrom>
											<owl:Class>
												<owl:unionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="&iof-constr;TestDataSet">
													</rdf:Description>
													<rdf:Description rdf:about="&iof-constr;ValidationDataSet">
													</rdf:Description>
												</owl:unionOf>
											</owl:Class>
										</owl:someValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:explanatoryNote xml:lang="en-US">an independent dataset means that the dataset has not been used for model training</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">model performance assessment that evaluates the quality of a model output that was derived from an independent dataset</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelExecution">
		<rdfs:subClassOf rdf:resource="&iof-constr;ComputingProcess"/>
		<rdfs:label xml:lang="en-US">model execution</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;ComputingProcess">
					</rdf:Description>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;FeatureVector"/>
									</owl:Restriction>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;ModelOutput"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningDataSet"/>
									</owl:Restriction>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;hasDataOutput"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;ModelOutputDataSet"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:unionOf>
					</owl:Class>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000059"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningParameterSettingSet"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;executed"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which some machine learning model is executed on a machine learning dataset or on a feature vector</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelExecutionObjective">
		<rdfs:subClassOf rdf:resource="&iof-constr;ObjectiveSpecification"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isAchievedByAtSomeTime"/>
				<owl:allValuesFrom rdf:resource="&iof-constr;ModelExecution"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">model execution objective</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">predicting a patient therapy dose based on pre-therapy images, predicting a CQA based parameter inputs, detecting common patterns of gene expression within a pancreatic cancer patient cohort</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">objective specification that prescribes what the outcome of a model execution should be</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelInputRequirementSpecification">
		<rdfs:subClassOf rdf:resource="&iof-constr;RequirementSpecification"/>
		<rdfs:label xml:lang="en-US">model input requirements</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">requirement specification that specifies the conditions to which an input to machine learning training or execution must conform to for a particular machine learning model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelOutput">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000027"/>
		<rdfs:label xml:lang="en-US">model output</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;IAO_0000027">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;dataOutputOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ModelExecution"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;informationContentEntityDerivedFrom"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;FeatureVector"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data item that is created as an output of a model execution that corresponds to a single feature vector</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelOutputDataSet">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000100"/>
		<rdfs:label xml:lang="en-US">model output data set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:disjointWith rdf:resource="&iof-constr;PreProcessedDataSet"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;IAO_0000100">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;dataOutputOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ModelExecution"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ModelOutput"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">dataset that consists of model outputs</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelOutputTransformationAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;Algorithm"/>
		<rdfs:label xml:lang="en-US">model output transformation algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">algorithm that prescribes how to transform model output data into a specific representation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelOutputTransformationOperation">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingOperation"/>
		<rdfs:label xml:lang="en-US">model output transformation operation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;DataProcessingOperation">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;executed"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
										<owl:someValuesFrom rdf:resource="&iof-constr;ModelOutputTransformationAlgorithm"/>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasInput"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;ModelOutput">
									</rdf:Description>
									<rdf:Description rdf:about="&iof-constr;ModelOutputDataSet">
									</rdf:Description>
								</owl:unionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data processing operation which transforms the model output to a particular representation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelPerformanceAssessment">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:label xml:lang="en-US">model performance assessment</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;PlannedProcess">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000059"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;PerformanceMetric"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ModelOutputDataSet"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ModelPerformanceResult"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">estimating the performance of a CNN on an image classification task</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which the quality of a model output is assessed with respect to some performance metric</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelPerformanceMonitoring">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:subClassOf>
			<owl:Class>
				<owl:unionOf rdf:parseType="Collection">
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000132"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DeployedMachineLearningModelState"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;occursSimultaneouslyWith"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DeployedMachineLearningModelState"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;temporallyFinishes"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DeployedMachineLearningModelState"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;temporallyStarts"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;DeployedMachineLearningModelState"/>
					</owl:Restriction>
				</owl:unionOf>
			</owl:Class>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;ModelPerformanceAssessment"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">model performance monitoring</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process during which model performance of a deployed model is assessed</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelPerformanceResult">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">model performance result</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;InformationContentEntity">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;describes"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isAbout"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ModelOutputDataSet"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isSpecifiedOutputOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ModelPerformanceAssessment"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">the result of determining the mean absolute error between predictions and the target variable on a particular dataset</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity that is the result of assessing the performance of a machine learning model with a particular dataset</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelSelection">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:label xml:lang="en-US">model selection</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;PlannedProcess">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ModelEvaluation"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasInput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;GroupOfMachineLearningModels"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningModel"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which model that has the best performance is selected among a number of machine learning models</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ModelValidation">
		<rdfs:subClassOf rdf:resource="&iof-constr;PlannedProcess"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;ModelEvaluation"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;MachineLearningDataSetPartitioning">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000063"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningTraining"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000117"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000063"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;ModelEvaluation"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">model validation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">Leave one out cross validation</skos:example>
		<iof-av:explanatoryNote xml:lang="en-US">iterations are typically performed until each feature vector is used for model evaluation</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">planned process in which a machine learning model is evaluated through successive iterations of dataset partitioning, machine learning training and model evaluation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;MultiLayerPerceptron">
		<rdfs:subClassOf rdf:resource="&iof-constr;ArtificialNeuralNetwork"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
				<owl:allValuesFrom rdf:resource="&iof-constr;FullyConnectedLayer"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">multi layer perceptron</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">artificial neural network composed of only fully connected layers</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;NeuralNetworkLayer">
		<rdfs:label xml:lang="en-US">neural network layer</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningModelComponent">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000137"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;ArtificialNeuralNetwork"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;Neuron"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning model component that consists of neurons operating together at a specific depth within a neural network</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;NeuralNetworkLayerBias">
		<rdfs:subClassOf rdf:resource="&iof-constr;NeuralNetworkParameter"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;configurationVariableOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;NeuralNetworkLayer"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">neural network layer bias</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">neural network parameter of a neural network layer that is added to the product of the layer input and neural network layer weights</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;NeuralNetworkParameter">
		<rdfs:label xml:lang="en-US">neural network parameter</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningParameter">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;configurationVariableOf"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:unionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;ArtificialNeuralNetwork">
									</rdf:Description>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-constr;MachineLearningModelComponent">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&bfo;BFO_0000137"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;ArtificialNeuralNetwork"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:unionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning parameter of a neural network model or its component</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Neuron">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningModelComponent"/>
		<rdfs:label xml:lang="en-US">neuron</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">input in the definition is here serving as a shorthand for the execution of a neuron and the input to the &quot;part of the process&quot; during which the execution of the neuron occurs</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning model component that is a part of a neural network layer and that has a set of scalar values which modify the input through multiplication</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;NeuronWeight">
		<rdfs:subClassOf rdf:resource="&iof-constr;NeuralNetworkParameter"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;configurationVariableOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;Neuron"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">neuron weight</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">neural network parameter of a neuron</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Noise">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntity"/>
		<rdfs:label xml:lang="en-US">noise</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">random or unpredictable fluctuations in data that disrupt the ability to identify target patterns or relationships</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;NominalClassificationScheme">
		<rdfs:subClassOf rdf:resource="&iof-constr;ClassificationScheme"/>
		<rdfs:label xml:lang="en-US">nominal classification scheme</rdfs:label>
		<dcterms:description>classification scheme that prescribes values which do not have any implicit ordering relation between them</dcterms:description>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">classification scheme whose categories do not have an intrinsic order</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;NominalFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;CategoricalFeature"/>
		<rdfs:label xml:lang="en-US">nominal feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;CategoricalFeature">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;NominalClassificationScheme"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">categorical feature whose possible values have no implicit ordering</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;NonParametricModel">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningModel"/>
		<rdfs:label xml:lang="en-US">non-parametric model</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:adaptedFrom>https://www.kaggle.com/discussions/general/324532</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning model that does not have a fixed pre-determined number of parameters</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;NumericalFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;Feature"/>
		<rdfs:label xml:lang="en-US">numerical feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature that has quantitative numeric values</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ObjectiveSpecification">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;OneHotEncoding">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingOperation"/>
		<rdfs:subClassOf>
			<owl:Class>
				<owl:unionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;FeatureEngineeringTransformation">
					</rdf:Description>
					<rdf:Description rdf:about="&iof-constr;ModelOutputTransformationOperation">
					</rdf:Description>
				</owl:unionOf>
			</owl:Class>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">one hot encoding</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:explanatoryNote xml:lang="en-US">the length of the vector depends on the number of categorical variables specified in the classification scheme</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature engineering transformation or model output transformation operation where a categorical input is transformed into a vector of binary values</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;OptimizationAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;Algorithm"/>
		<rdfs:label xml:lang="en-US">optimization algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">adam optimizer, stochastic gradient descent</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">algorithm that prescribes how to find the minimum or maximum of an objective function</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;OrdinalClassificationScheme">
		<rdfs:subClassOf rdf:resource="&iof-constr;ClassificationScheme"/>
		<rdfs:label xml:lang="en-US">ordinal classification scheme</rdfs:label>
		<dcterms:description>classification scheme that prescribes values which have an implicit ordering relation between them</dcterms:description>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">classification scheme whose categories have an intrinsic order</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;OrdinalFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;CategoricalFeature"/>
		<rdfs:label xml:lang="en-US">ordinal feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;CategoricalFeature">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;OrdinalClassificationScheme"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">categorical feature whose possible values have an implicit ordering</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PerformanceMetric">
		<rdfs:subClassOf rdf:resource="&iof-constr;MathematicalFunction"/>
		<rdfs:label xml:lang="en-US">performance metric</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">classification accuracy used to estimate the performance of a CNN on image classification task</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">function that prescribes how to assess the performance of a machine learning model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PlanSpecification">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PlannedProcess">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PoissonNoise">
		<rdfs:subClassOf rdf:resource="&iof-constr;Noise"/>
		<rdfs:label xml:lang="en-US">poisson noise</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">noise whose values follow a poisson distribution</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PolynomialFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;DerivedFeature"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;informationContentEntityDerivedFrom"/>
				<owl:allValuesFrom rdf:resource="&iof-constr;NumericalFeature"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">polynomial feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">derived feature that was created by raising a numerical feature by some exponent</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PolynomialFunction">
		<rdfs:subClassOf rdf:resource="&iof-constr;MathematicalFunction"/>
		<rdfs:label xml:lang="en-US">polynomial function</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">mathematical function that consists of coefficients, variables, constants, operators, and non-negative integers as exponents</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PolynomialModel">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningModel"/>
		<rdfs:label xml:lang="en-US">polynomial model</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningModel">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;RegressionObjective"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasComplexValueExpressionAtAllTimes"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;PolynomialFunction"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning model that is an explicitly parameterized polynomial function</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PolynomialModelTrainingAlgorithm">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTrainingAlgorithm"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;prescribes"/>
				<owl:allValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;EncodedAlgorithm">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;isExecutedIn"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&bfo;BFO_0000057"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;PolynomialModel"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:allValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">polynomial model training algorithm</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">ordinary least squares</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning algorithm that prescribes the training of a regression model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PoolingLayer">
		<rdfs:subClassOf rdf:resource="&iof-constr;NeuralNetworkLayer"/>
		<rdfs:label xml:lang="en-US">pooling layer</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">neural network layer that reduces the spatial dimensions of input data by applying a downsampling operation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PreProcessedDataSet">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000100"/>
		<rdfs:label xml:lang="en-US">preprocessed data set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:disjointWith rdf:resource="&iof-constr;RawDataSet"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">dataset that is the result of a data cleaning pipeline</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;PredictionObjective">
		<rdfs:subClassOf rdf:resource="&iof-constr;ModelExecutionObjective"/>
		<rdfs:label xml:lang="en-US">prediction objective</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:disjointUnionOf rdf:parseType="Collection">
			<rdf:Description rdf:about="&iof-constr;ClassificationObjective">
			</rdf:Description>
			<rdf:Description rdf:about="&iof-constr;RegressionObjective">
			</rdf:Description>
		</owl:disjointUnionOf>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">model execution objective to predict some classification or a numeric value of an entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ProductionMachineLearningDataSet">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningDataSet"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;dataInputOf"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;ModelExecution">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&iof-constr;executed"/>
								<owl:someValuesFrom>
									<owl:Class>
										<owl:intersectionOf rdf:parseType="Collection">
											<rdf:Description rdf:about="&iof-constr;MachineLearningModel">
											</rdf:Description>
											<owl:Restriction>
												<owl:onProperty rdf:resource="&bfo;BFO_0000166"/>
												<owl:someValuesFrom rdf:resource="&iof-constr;DeployedMachineLearningModelState"/>
											</owl:Restriction>
										</owl:intersectionOf>
									</owl:Class>
								</owl:someValuesFrom>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">production machine learning data set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning dataset that is used as input to the execution of a deployed model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;RSquared">
		<rdfs:subClassOf rdf:resource="&iof-constr;PerformanceMetric"/>
		<rdfs:label xml:lang="en-US">r squared</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">performance metric utilized for regression model assessment which prescribes how to determine the portion of variance in the observed values that is predictable by the model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;RawDataSet">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000100"/>
		<rdfs:label xml:lang="en-US">raw data set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">dataset that consists of unprocessed outputs from a series of measurement processes</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">dataset collected from a domain of interest, that has not undergone any data processing</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;RectifiedLinearUnit">
		<rdfs:subClassOf rdf:resource="&iof-constr;ActivationFunction"/>
		<rdfs:label xml:lang="en-US">rectified linear unit</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:abbreviation>ReLU</iof-av:abbreviation>
		<iof-av:adaptedFrom>https://www.kaggle.com/code/dansbecker/rectified-linear-units-relu-in-deep-learning</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">activation function that sets all negative output values to 0 and does not modify non-negative output values</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;RegressionCoefficient">
		<rdfs:subClassOf rdf:resource="&iof-constr;RegressionParameter"/>
		<rdfs:label xml:lang="en-US">regression coefficient</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">regression parameter that has a scalar value which modifies a particular input feature by multiplying it</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;RegressionIntercept">
		<rdfs:subClassOf rdf:resource="&iof-constr;RegressionParameter"/>
		<rdfs:label xml:lang="en-US">regression intercept</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">regression parameter whose value is the mean of the target variables used to train the regression model and that is added to the output of regression model execution</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;RegressionObjective">
		<rdfs:subClassOf rdf:resource="&iof-constr;PredictionObjective"/>
		<rdfs:label xml:lang="en-US">regression objective</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">A GAN model has the objective to predict the post-therapy dose value in each voxel based on the pre-therapy scans of a patient</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">prediction objective to output a numeric prediction of an attribute of an entity</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;RegressionParameter">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningParameter"/>
		<rdfs:label xml:lang="en-US">regression parameter</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningParameter">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;configurationVariableOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;PolynomialModel"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning parameter of a regression model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;RegularizationMethod">
		<rdfs:subClassOf rdf:resource="&iof-constr;Algorithm"/>
		<rdfs:label xml:lang="en-US">regularization method</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<skos:example xml:lang="en-US">L1 regularization, L2 regularization, dropout regularization</skos:example>
		<iof-av:explanatoryNote xml:lang="en-US">Regularization is typically introduced to avoid model overfitting</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">algorithm that prescribes how to constrain the set of possible machine learning parameter values during machine learning training</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ReinforcementLearning">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTraining"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasSpecifiedOutput"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;MachineLearningModel">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;ActionSelectionObjective"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">reinforcement learning</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning training used for learning an action selection model and that is based on a feedback interaction with an environment</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;RequirementSpecification">
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;RootMeanSquaredError">
		<rdfs:subClassOf rdf:resource="&iof-constr;PerformanceMetric"/>
		<rdfs:label xml:lang="en-US">root mean squared error</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">performance metric which prescribes how to determine the root of the average of the squared differences between predicted values and observed values</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ScaledFeature">
		<rdfs:label xml:lang="en-US">scaled feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;DerivedFeature">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;dataOutputOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;FeatureScalingOperation"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">derived feature that is a result of a feature scaling operation</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;SemiSupervisedLearning">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTraining"/>
		<rdfs:label xml:lang="en-US">semi supervised learning</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningTraining">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;TargetVariableVector"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;MachineLearningDataSet">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
										<owl:someValuesFrom>
											<owl:Class>
												<owl:intersectionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="&iof-constr;FeatureVector">
													</rdf:Description>
													<owl:Class>
														<owl:complementOf>
															<owl:Restriction>
																<owl:onProperty rdf:resource="&iof-constr;hasTargetVariable"/>
																<owl:someValuesFrom rdf:resource="&iof-constr;TargetVariable"/>
															</owl:Restriction>
														</owl:complementOf>
													</owl:Class>
												</owl:intersectionOf>
											</owl:Class>
										</owl:someValuesFrom>
									</owl:Restriction>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
										<owl:someValuesFrom>
											<owl:Class>
												<owl:intersectionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="&iof-constr;FeatureVector">
													</rdf:Description>
													<owl:Restriction>
														<owl:onProperty rdf:resource="&iof-constr;hasTargetVariable"/>
														<owl:someValuesFrom rdf:resource="&iof-constr;TargetVariable"/>
													</owl:Restriction>
												</owl:intersectionOf>
											</owl:Class>
										</owl:someValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:explanatoryNote xml:lang="en-US">semi supervised learning is typically used when only a subset of the training samples have a target variable available.</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning training procedure based on a combination of supervised and unsupervised learning</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;SequentialFeature">
		<rdfs:label xml:lang="en-US">sequential feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;Feature">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
						<owl:someValuesFrom rdf:resource="&bfo;IAO_0000027"/>
					</owl:Restriction>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;prescribedBy"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;SequentialFeatureOrderingScheme"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">time series, textual features</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature that consists of data items that have an explicit ordering along one dimension</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;SequentialFeatureOrderingScheme">
		<rdfs:subClassOf rdf:resource="&iof-constr;InformationContentEntityOrderingScheme"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;informationContentEntityDerivedFrom"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:unionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&bfo;IAO_0000027">
							</rdf:Description>
							<rdf:Description rdf:about="&bfo;IAO_0000100">
							</rdf:Description>
						</owl:unionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isAbout"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;SequentialFeature"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">sequential feature ordering scheme</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">information content entity ordering scheme that dictates the ordering of a sequential feature</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;SimulatedValueExpression">
		<rdfs:subClassOf rdf:resource="&iof-constr;ValueExpression"/>
		<rdfs:label xml:lang="en-US">simulated value expression</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">value expression that was generated by a predictive model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Softmax">
		<rdfs:subClassOf rdf:resource="&iof-constr;ActivationFunction"/>
		<rdfs:label xml:lang="en-US">softmax</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:adaptedFrom>https://en.wikipedia.org/wiki/Softmax_function</iof-av:adaptedFrom>
		<iof-av:explanatoryNote xml:lang="en-US">the exponential function has been applied to all output values prior to the sum</iof-av:explanatoryNote>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">activation function that transforms all output values to probability values by applying a standard exponential function to each individual output value and then normalizing each value by dividing it by the sum of all the exponentials</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;SpecifiedValueExpression">
		<rdfs:subClassOf rdf:resource="&iof-constr;ValueExpression"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000177"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;DirectiveInformationContentEntity"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">specified value expression</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">value expression that is part of a specification and that prescribes the value that the attribute should have</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;StatisticalSignificanceCriteria">
		<rdfs:subClassOf rdf:resource="&iof-constr;RequirementSpecification"/>
		<rdfs:label xml:lang="en-US">statistical significance criteria</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">requirement specification that prescribes the range of values that the result of a statistical hypothesis test should have to be statistically significant</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;StatisticallySignificantParameter">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningParameter"/>
		<rdfs:label xml:lang="en-US">statistically significant parameter</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;MachineLearningParameter">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;satisfiesRequirement"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;StatisticalSignificanceCriteria"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">a regression coefficient that has a p value less than the required significance level</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning parameter that has been estimated as statistically significant by some statistical significance criteria</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;SuccessRate">
		<rdfs:subClassOf rdf:resource="&iof-constr;PerformanceMetric"/>
		<rdfs:label xml:lang="en-US">success rate</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">performance metric that prescribes how to assess the percentage of correctly predicted output values within some specified margin of error</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;SupervisedLearning">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTraining"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;TargetVariableVector"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">supervised learning</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:disjointWith rdf:resource="&iof-constr;UnsupervisedLearning"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning training based on comparing the model outputs to known target variables, which are available for each sample in the training set</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;SupportVectorMachine">
		<rdfs:subClassOf rdf:resource="&iof-constr;InstanceBasedModel"/>
		<rdfs:label xml:lang="en-US">support vector machine</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:adaptedFrom>https://www.iso.org/obp/ui/#iso:std:iso-iec:22989:ed-1:v1:en:term:3.3.13</iof-av:adaptedFrom>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">instance-based model that consists of a hyperplane (decision boundary) with maximal margins from the selected group of feature vectors (support vectors)</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;TargetVariable">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000027"/>
		<rdfs:label xml:lang="en-US">target variable</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&bfo;IAO_0000027">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;targetVariableOf"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;FeatureVector"/>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<skos:example xml:lang="en-US">the measured value of the intended prediction of a ML model execution (e.g., dose prediction, CQA prediction)</skos:example>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data item that a machine learning model execution should output if given a particular feature vector as input</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;TargetVariableVector">
		<rdfs:subClassOf rdf:resource="&bfo;IAO_0000100"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;TargetVariable"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">target variable vector</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">dataset that is composed of target variables for different samples</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;Tensorflow">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningFramework"/>
		<rdfs:label xml:lang="en-US">tensorflow</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:directSource>https://www.tensorflow.org/</iof-av:directSource>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning framework that provides software libraries for defining, training, and executing machine learning models</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;TestDataSet">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningDataSet"/>
		<rdfs:label xml:lang="en-US">test data set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning dataset that is used as input for machine learning model evaluation of a final model</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;TextualFeature">
		<rdfs:subClassOf rdf:resource="&iof-constr;SequentialFeature"/>
		<rdfs:label xml:lang="en-US">textual feature</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature that consists of a sequence of words whose order conveys a meaning</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;TimeSeries">
		<rdfs:subClassOf rdf:resource="&iof-constr;SequentialFeature"/>
		<rdfs:label xml:lang="en-US">time series</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<owl:equivalentClass>
			<owl:Class>
				<owl:intersectionOf rdf:parseType="Collection">
					<rdf:Description rdf:about="&iof-constr;SequentialFeature">
					</rdf:Description>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;isSubjectOf"/>
						<owl:someValuesFrom>
							<owl:Class>
								<owl:intersectionOf rdf:parseType="Collection">
									<rdf:Description rdf:about="&iof-constr;SequentialFeatureOrderingScheme">
									</rdf:Description>
									<owl:Restriction>
										<owl:onProperty rdf:resource="&iof-constr;informationContentEntityDerivedFrom"/>
										<owl:someValuesFrom>
											<owl:Class>
												<owl:intersectionOf rdf:parseType="Collection">
													<rdf:Description rdf:about="&bfo;IAO_0000100">
													</rdf:Description>
													<owl:Restriction>
														<owl:onProperty rdf:resource="&iof-constr;isComposedOf"/>
														<owl:someValuesFrom>
															<owl:Restriction>
																<owl:onProperty rdf:resource="&iof-constr;isValueExpressionOfAtSomeTime"/>
																<owl:someValuesFrom rdf:resource="&bfo;BFO_0000008"/>
															</owl:Restriction>
														</owl:someValuesFrom>
													</owl:Restriction>
												</owl:intersectionOf>
											</owl:Class>
										</owl:someValuesFrom>
									</owl:Restriction>
								</owl:intersectionOf>
							</owl:Class>
						</owl:someValuesFrom>
					</owl:Restriction>
				</owl:intersectionOf>
			</owl:Class>
		</owl:equivalentClass>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">feature that consists of a sequence of observations taken sequentially in time</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;TrainingDataSet">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningDataSet"/>
		<rdfs:label xml:lang="en-US">training data set</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning dataset that is used as input to machine learning training</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;TypeCastingOperation">
		<rdfs:subClassOf rdf:resource="&iof-constr;DataProcessingOperation"/>
		<rdfs:label xml:lang="en-US">type casting operation</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">data processing operation that casts the values of all the inputs to a particular data type</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;UnsupervisedLearning">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningTraining"/>
		<rdfs:subClassOf>
			<owl:Class>
				<owl:complementOf>
					<owl:Restriction>
						<owl:onProperty rdf:resource="&iof-constr;hasDataInput"/>
						<owl:someValuesFrom rdf:resource="&iof-constr;TargetVariable"/>
					</owl:Restriction>
				</owl:complementOf>
			</owl:Class>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&bfo;BFO_0000057"/>
				<owl:someValuesFrom>
					<owl:Class>
						<owl:intersectionOf rdf:parseType="Collection">
							<rdf:Description rdf:about="&iof-constr;MachineLearningModel">
							</rdf:Description>
							<owl:Restriction>
								<owl:onProperty rdf:resource="&bfo;BFO_0000110"/>
								<owl:someValuesFrom rdf:resource="&iof-constr;DataDescriptionObjective"/>
							</owl:Restriction>
						</owl:intersectionOf>
					</owl:Class>
				</owl:someValuesFrom>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">unsupervised learning</rdfs:label>
		<rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/machinelearninglifecycle/MachineLearningLifecycle/"/>
		<iof-av:naturalLanguageDefinition xml:lang="en-US">machine learning training that is independent from any target variables</iof-av:naturalLanguageDefinition>
	</owl:Class>
	
	<owl:Class rdf:about="&iof-constr;ValidationDataSet">
		<rdfs:subClassOf rdf:resource="&iof-constr;MachineLearningDataSet"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&iof-constr;dataOutputOf"/>
				<owl:someValuesFrom rdf:resource="&iof-constr;MachineLearningDataSetPartitioning"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label xml:lang="en-US">validation data set</rdfs:label>
