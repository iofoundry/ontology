<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE rdf:RDF [
	<!ENTITY dcterms "http://purl.org/dc/terms/">
	<!ENTITY iof-av "https://spec.industrialontologies.org/ontology/annotation/">
  <!ENTITY iof-ind "https://spec.industrialontologies.org/ontology/individual/">
	<!ENTITY owl "http://www.w3.org/2002/07/owl#">
	<!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#">
	<!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#">
	<!ENTITY skos "http://www.w3.org/2004/02/skos/core#">
	<!ENTITY xsd "http://www.w3.org/2001/XMLSchema#">
]>
<rdf:RDF xml:base="https://spec.industrialontologies.org/ontology/AboutIOFDev/"
	xmlns:dcterms="http://purl.org/dc/terms/"
	xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
  xmlns:iof-ind="https://spec.industrialontologies.org/ontology/individual/"
	xmlns:owl="http://www.w3.org/2002/07/owl#"
	xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
	xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
	xmlns:skos="http://www.w3.org/2004/02/skos/core#"
	xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
	
	<owl:Ontology rdf:about="https://spec.industrialontologies.org/ontology/AboutIOFDev/">
		<rdfs:label xml:lang="en-US">About IOF Development</rdfs:label>
		<dcterms:abstract>This ontology defines the scope of development maturity level IOF ontologies.</dcterms:abstract>
		<dcterms:license rdf:datatype="&xsd;anyURI">http://opensource.org/licenses/MIT</dcterms:license>
		<dcterms:title>Industrial Ontology Foundry (IOF) Ontology - Development</dcterms:title>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/cache/CMNS/AnnotationVocabulary.rdf"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/cache/CMNS/Collections.rdf"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/cache/CMNS/Designators.rdf"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/cache/CMNS/Identifiers.rdf"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/cache/CMNS/TextDatatype.rdf"/>

		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/cache/bfo/2020/bfo.rdf"/>

		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/core/Core/"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/supplychain/SupplyChain/"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/maintenance/Maintenance/"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/core/meta/AnnotationVocabulary/"/>

		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/core/commonstocoremapping/MappingCommonsToIOF/"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/core/commonstocoremapping/meta/MappingAnnotationVocabularyToCommons/"/>

		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/productionplanning/ProductionPlanning/"/>
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/productservicesystem/ProductServiceSystem/"/>    
		<owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/certification/Certification/"/>

    <!-- Biopharma Ontologies -->
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/core/Core/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/biopharma/Parameter/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/biopharma/MaterialProcurementAndStorage/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/biopharma/Material/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/biopharma/Recipe/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/biopharma/Agent/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/biopharma/Physical/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/biopharma/Equipment/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/biopharma/ManufacturingExecution/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/biopharma/MonitoringAndControl/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202601/biopharma/ReferenceOntologyCandidates/"/>


		<owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202601/AboutIOFDev/"/>
		<iof-av:copyright>Copyright (c) 2022, 2023, 2024, 2025, 2026 Open Applications Group</iof-av:copyright>
		<iof-av:maturity rdf:resource="&iof-ind;Provisional"/>
	</owl:Ontology>

</rdf:RDF>
