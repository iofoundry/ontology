    <!-- https://spec.industrialontologies.org/ontology/construct/Sensor -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/Sensor">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialProduct"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasRole"/>
                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/SensorRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:description>2 - a device which detects or measures a physical property and records, indicates, or otherwise responds to it</terms:description>
        <terms:description>material entity that senses some quality that inheres in some independent continuant</terms:description>
    </owl:Class>
    


