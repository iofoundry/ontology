<?xml version="1.0"?>
<rdf:RDF xmlns="https://spec.industrialontologies.org/ontology/productservicesystem/ProductServiceSystem/Sensor#"
     xml:base="https://spec.industrialontologies.org/ontology/productservicesystem/ProductServiceSystem/Sensor"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:bfo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:iof-ind="https://spec.industrialontologies.org/ontology/individual/"
     xmlns:iof-const="https://spec.industrialontologies.org/ontology/construct/"
     xmlns:CommonCoreOntologies="http://www.ontologyrepository.com/CommonCoreOntologies/">
    <owl:Ontology rdf:about="https://spec.industrialontologies.org/ontology/productservicesystem/ProductServiceSystem/Sensor">
        <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202502/productservicesystem/ProductServiceSystem/Sensor"/>
        <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/"/>
        <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/supplychain/SupplyChain/"/>
        <dcterms:abstract>This module contains terms and relations necessary for representing basic sensor entities.</dcterms:abstract>
        <dcterms:contributor>Ana Teresa Correia, Institut fuer angewandte Systemtechnik Bremen GmbH (ATB-Bremen)</dcterms:contributor>
        <dcterms:contributor>Dragan Stokic, Institut fuer angewandte Systemtechnik Bremen GmbH (ATB-Bremen)</dcterms:contributor>
        <dcterms:contributor>Dusan Sormaz, Ohio University</dcterms:contributor>
        <dcterms:contributor>Gabriela Henning, CONICET</dcterms:contributor>
        <dcterms:contributor>Marcela Vegetti, University of Santa Fe</dcterms:contributor>
        <dcterms:contributor>Mark Schubert, Parson Europe</dcterms:contributor>
        <dcterms:contributor>Roberto Sala, University of Bergamo</dcterms:contributor>
        <dcterms:contributor>Todd Schneider, Engineering Semantics</dcterms:contributor>
        <dcterms:creator xml:lang="en-us">Product Service System (PSS) working group</dcterms:creator>
        <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
        <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
        <dcterms:title>Product Service System (PSS) Reference Ontology</dcterms:title>
        <rdfs:label xml:lang="en-us">Sensor Ontology</rdfs:label>
        <iof-av:copyright>Copyright (c) 2025 Open Applications Group</iof-av:copyright>
        <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2002/07/owl#minQualifiedCardinality -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#minQualifiedCardinality"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://spec.industrialontologies.org/ontology/construct/owns -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/owns">
        <skos:example>PSSProvider owns a PSS (inverse to PSS belongsTo PSSProvider)</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://www.omg.org/spec/Commons/Collections/isPartOf -->

    <owl:ObjectProperty rdf:about="https://www.omg.org/spec/Commons/Collections/isPartOf">
        <rdfs:label xml:lang="en-us">is part of</rdfs:label>
        <iof-av:naturalLanguageDefinition>relates something to another thing that it is some component or portion of, regardless of how that whole-part relationship is manifested</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">relates something to another thing that it is some component or portion of, regardless of how that whole-part relationship is manifested</iof-av:naturalLanguageDefinition>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://www.omg.org/spec/Commons/Collections/isPartOf"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition"/>
        <owl:annotatedTarget>relates something to another thing that it is some component or portion of, regardless of how that whole-part relationship is manifested</owl:annotatedTarget>
        <rdfs:comment>Stanford Encyclopedia of Philosophy at http://plato.stanford.edu/entries/mereology/</rdfs:comment>
    </owl:Axiom>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://spec.industrialontologies.org/ontology/construct/Accuracy -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/Accuracy">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en-us">accuracy</rdfs:label>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">quality that is the closeness of agreement between the value of an observation and the true value of the observed quality</iof-av:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/construct/Accuracy"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition"/>
        <owl:annotatedTarget xml:lang="en-us">quality that is the closeness of agreement between the value of an observation and the true value of the observed quality</owl:annotatedTarget>
        <iof-av:adaptedFrom>https://www.w3.org/2005/Incubator/ssn/wiki/SSN.html#Accuracy</iof-av:adaptedFrom>
    </owl:Axiom>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/Facility -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/Facility"/>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/Precision -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/Precision">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en-us">precision</rdfs:label>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">quality that is the closeness of agreement between replicate observations on an unchanged or similar quality value: i.e., a measure of a sensor&apos;s ability to consitently reproduce an observation.</iof-av:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/construct/Precision"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition"/>
        <owl:annotatedTarget xml:lang="en-us">quality that is the closeness of agreement between replicate observations on an unchanged or similar quality value: i.e., a measure of a sensor&apos;s ability to consitently reproduce an observation.</owl:annotatedTarget>
        <iof-av:adaptedFrom>https://www.w3.org/2005/Incubator/ssn/wiki/SSN.html#Precision</iof-av:adaptedFrom>
    </owl:Axiom>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/Resolution -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/Resolution">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en-us">resolution</rdfs:label>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">quality that is the smallest difference in the value of a quality being observed that would result in perceptably different values of observation results</iof-av:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/construct/Resolution"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition"/>
        <owl:annotatedTarget xml:lang="en-us">quality that is the smallest difference in the value of a quality being observed that would result in perceptably different values of observation results</owl:annotatedTarget>
        <iof-av:adaptedFrom>https://www.w3.org/2005/Incubator/ssn/wiki/SSN.html#Resolution</iof-av:adaptedFrom>
    </owl:Axiom>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/SensingCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/SensingCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Capability"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/capabilityOf"/>
                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/Sensor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en-us">sensing capability</rdfs:label>
        <iof-av:naturalLanguageDefinition>capability that a sensor has to acquire(?) a quality value</iof-av:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/construct/SensingCapability"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition"/>
        <owl:annotatedTarget>capability that a sensor has to acquire(?) a quality value</owl:annotatedTarget>
        <iof-av:adaptedFrom>https://www.w3.org/2005/Incubator/ssn/wiki/SSN.html#Sensing</iof-av:adaptedFrom>
    </owl:Axiom>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/Sensor -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/Sensor">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasRole"/>
                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/SensorRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/prescribedBy"/>
                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/SensorSpecification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Does a sensor has qualities like:
&apos;has quality&apos; some (accuracy and precision and resolution)
?</rdfs:comment>
        <rdfs:comment>From SSN: A sensor can do (implements) sensing: that is, a sensor is any entity that can follow a sensing method and thus observe some Property of a  FeatureOfInterest. Sensors may be physical devices, computational 
methods, a laboratory setup with a person following a method, or any other thing that can follow a Sensing Method to observe a Property.
https://www.w3.org/2005/Incubator/ssn/wiki/SSN.html#Sensor</rdfs:comment>
        <rdfs:comment>I would think that a sensor could be either sensing (the output is the electrical signal) or measuring (the output is a value like e.g. 14 degrees centigrades) then we could add such an axiom:

(&apos;has capability&apos; some &apos;measurement capability&apos;) or (&apos;has capability&apos; some &apos;sensing capability&apos;)

Does this make sense?</rdfs:comment>
        <rdfs:comment>provides physical property?</rdfs:comment>
        <rdfs:label xml:lang="en-us">sensor</rdfs:label>
        <iof-av:explanatoryNote>We are thinking here about physical sensor not virtual sensors/soft sensor</iof-av:explanatoryNote>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">material entity that senses/detects some quality that inheres in some independent continuant</iof-av:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/SensorMeasurementProcess -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/SensorMeasurementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
        <rdfs:label xml:lang="en-us">sensor measurement process</rdfs:label>
        <iof-av:naturalLanguageDefinition>measurement of the value of an attribute of a sensor</iof-av:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/SensorRole -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/SensorRole">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/roleOf"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en-us">sensor role</rdfs:label>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/SensorSpecification -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/construct/SensorSpecification">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/prescribes"/>
                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/Sensor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en-us">specification of a sensor - are ranges and accuracy defined here as properties?</rdfs:comment>
        <rdfs:label xml:lang="en-us">sensor specification</rdfs:label>
        <iof-av:naturalLanguageDefinition></iof-av:naturalLanguageDefinition>
    </owl:Class>
    <rdf:Description>
        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
    </rdf:Description>
</rdf:RDF>



