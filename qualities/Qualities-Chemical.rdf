<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:iof-av="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="de">Chemische Qualität</rdfs:label>
    <rdfs:label xml:lang="en">chemical quality</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Chemical quality is a quality pertaining to properties or characteristics related to chemical condition or categorization, such as electron negativity or molar mass</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'chemical quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000019'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalProcessCharacteristic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/ProcessCharacteristic"/>
    <rdfs:label xml:lang="en">chemical process characteristic</rdfs:label>
    <rdfs:label xml:lang="de">chemische Prozesscharakteristik</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Chemical process characteristic defines attributes of a process concretizing a chemical interaction over time</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'chemical process characteristic' have not yet been formalized. The term is defined as a specific subtype of 'ProcessCharacteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Hydrophobic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuantity"/>
    <rdfs:label xml:lang="de">Hydrophob</rdfs:label>
    <rdfs:label xml:lang="en">hydrophobic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001885"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">hydrophobic quality inheres in a bearer due to lacking affinity for water, causing repulsion and resistance to dissolution</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'hydrophobic' have not yet been formalized. The term is defined as a specific subtype of 'chemical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001885.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202507/qualities/Qualities-Chemical/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <dcterms:abstract xml:lang="en-us">The IOF Qualities-Chemical Ontology aims to represent Qualities relevant to chemicals and chemical processes</dcterms:abstract>
    <dcterms:contributor xml:lang="en-us">Thomas Hanke, Fraunhofer IWM</dcterms:contributor>
    <dcterms:creator xml:lang="en-us">IOF Materials Working Group</dcterms:creator>
    <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
    <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
    <dcterms:references rdf:resource="http://spec.org/dc/terms/"/>
    <dcterms:references rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    <dcterms:title xml:lang="en-us">Industrial Ontology Foundry (IOF) Chemical Qualities Ontology</dcterms:title>
    <rdfs:label xml:lang="en-us">Chemical Qualities Ontology</rdfs:label>
    <iof-av:copyright xml:lang="en">Industrial Ontology Foundry (IOF)</iof-av:copyright>
    <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuantity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
    <rdfs:label xml:lang="de">Chemische Relationale Qualität</rdfs:label>
    <rdfs:label xml:lang="en">chemical relational quality</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Chemical relational quality is a relational quality related to the properties or characteristics of an entity that connect to other entities, relying on the existence of the second entity, including aspects like solubility or affinity</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'chemical relational quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000145'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/MolecularQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalQuality"/>
    <rdfs:label xml:lang="de">Molekulare Qualität</rdfs:label>
    <rdfs:label xml:lang="en">molecular quality</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">molecular quality is inherent in a molecular entity such as a single molecule, atom, ion, or radical</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'molecular quality' have not yet been formalized. The term is defined as a specific subtype of 'chemical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000116">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">Editor Note</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nec5715b065ae40599a641ca12eada8d2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000057"/>
    <owl:someValuesFrom rdf:nodeID="N074920851e0946f2b0eead43f14abafa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalAction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="Nf99d44a96ba4485a8dff9182fcb0df0d"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Action"/>
    <rdfs:label xml:lang="en">chemical action</rdfs:label>
    <rdfs:label xml:lang="de">chemische Aktion</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Chemical action represents a stimulus enacting a chemical interaction with an object</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en">ChemicalAction(x) ↔ (∃b ((obo:BFO_0000040(b) ∧ ∃c (ChemicalRelationalQuality(c) ∧ hasQuality(b, c))) ∧ obo:BFO_0000057(x, b)) ∨ ∃d (ChemicalProcessCharacteristic(d) ∧ hasProcessCharacteristic(x, d)))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en">every instance of 'chemical action' is defined as exactly an instance of 'that 'obo:BFO_0000057' some an instance of 'BFO_0000040' and that 'hasQuality' some 'chemical relational quality'' or 'that 'hasProcessCharacteristic' some 'chemical process characteristic''</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb4390e139bb54e0f96229d2ff2005ff4">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Hydrophilicity"/>
    <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/explanatoryNote"/>
    <owl:annotatedTarget>Hydrophilic molecule or portion of a molecule is one whose interactions with water and other polar substances are more thermodynamically favorable than their interactions with oil or other hydrophobic solvents. Typically charge-polarized and capable of hydrogen bonding, making them soluble not only in water but also in other polar solvents

Hydrophilic molecules (and portions of molecules) contrast with hydrophobic molecules (and portions of molecules). In some cases, both hydrophilic and hydrophobic properties occur in a single molecule. An example is the lipids that comprise the cell membrane. Another example is soap, which has a hydrophilic head and a hydrophobic tail, allowing it to dissolve in both water and oil

Hydrophilic and hydrophobic molecules are also known as polar molecules and nonpolar molecules, respectively. Some hydrophilic substances do not dissolve; this type of mixture is called a colloid</owl:annotatedTarget>
    <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Hydrophile</iof-av:directSource>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalReaction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="Nbe44effbb6eb4e9d940c142c65443169"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Reaction"/>
    <rdfs:label xml:lang="en">chemical reaction</rdfs:label>
    <rdfs:label xml:lang="de">chemische Antwort</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Chemical reaction characterizes a process where a biologcal capability of entity X is realized in response to a chemical action involving X or more material entities</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en">ChemicalReaction(x) ↔ ∃b (ChemicalCapability(b) ∧ obo:BFO_0000055(x, b))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en">every instance of 'chemical reaction' is defined as exactly that 'obo:BFO_0000055' some 'chemical capability'</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Lipophilicity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalCapability"/>
    <rdfs:label xml:lang="de">Lipophilidität</rdfs:label>
    <rdfs:label xml:lang="en">lipophilicity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Lipophilicity"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">lipophilicity is an ability of chemical compounds to dissolve in fats, oils, lipids, and non-polar solvents, described as "fat-loving" due to composition</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'lipophilicity' have not yet been formalized. The term is defined as a specific subtype of 'chemical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Lipophilicity.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N714a77b6ce7247f2acf9dab9d9c27ff6">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasQuality"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuality"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Lypophobic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuantity"/>
    <rdfs:label xml:lang="de">fettabweisend</rdfs:label>
    <rdfs:label xml:lang="en">lipophobic</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">lipophobic quality inheres in a bearer due to lack of affinity for fats, oils, lipids, and non-polar solvents, resisting and repelling these substances</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'lipophobic' have not yet been formalized. The term is defined as a specific subtype of 'chemical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N73df4ffcb3444d45b33b6541c7b7e18d">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasProcessCharacteristic"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalProcessCharacteristic"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
    <rdfs:label xml:lang="de">Chemische Fähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">chemical capability</rdfs:label>
    <rdfs:label xml:lang="de">chemische Fähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Chemical capability is a capability realized through an entity governed by chemical interaction in the interest of an agent</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'chemical capability' have not yet been formalized. The term is defined as a specific subtype of 'Capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Hydrophilic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuantity"/>
    <rdfs:label xml:lang="de">Hydrophil</rdfs:label>
    <rdfs:label xml:lang="en">hydrophilic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001887"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">hydrophilic quality inheres in a bearer due to the bearer's disposition to affinity for water, promoting dissolution, mixing, or wetting by water</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'hydrophilic' have not yet been formalized. The term is defined as a specific subtype of 'chemical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001887.</iof-av:primitiveRationale>
  </rdf:Description>
