<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="de">Chemische Qualität</rdfs:label>
    <rdfs:label xml:lang="en-US">chemical quality</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Chemical quality is a quality pertaining to properties or characteristics related to chemical condition or categorization, such as electron negativity or molar mass</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Chemische Qualität ist eine Qualität, die sich auf Eigenschaften oder Merkmale im Zusammenhang mit dem chemischen Zustand oder der Kategorisierung bezieht, wie z. B. Elektronennegativität oder Molmasse</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'chemical quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000019'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000019(x) ← ChemicalQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;chemical quality&apos; then x is a &apos;b f o_0000019&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the molar mass of sodium chloride (58.44 g/mol) is a chemical quality of that compound</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalProcessCharacteristic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/ProcessCharacteristic"/>
    <rdfs:label xml:lang="en-US">chemical process characteristic</rdfs:label>
    <rdfs:label xml:lang="de">chemische Prozesscharakteristik</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Chemical process characteristic defines attributes of a process concretizing a chemical interaction over time</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Charakteristik eines chemischen Prozesses definiert Attribute eines Prozesses, die eine chemische Wechselwirkung im Laufe der Zeit konkretisieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'chemical process characteristic' have not yet been formalized. The term is defined as a specific subtype of 'ProcessCharacteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ProcessCharacteristic(x) ← ChemicalProcessCharacteristic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;chemical process characteristic&apos; then x is a &apos;process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the reaction rate constant of acid hydrolysis at 25°C is a chemical process characteristic</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Hydrophobic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuality"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000169"/>
        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_15377"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:label xml:lang="de">Hydrophob</rdfs:label>
    <rdfs:label xml:lang="en-US">hydrophobic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001885"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">hydrophobic quality inheres in a bearer due to lacking affinity for water, causing repulsion and resistance to dissolution</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Aufgrund der fehlenden Affinität zu Wasser ist einem Träger eine hydrophobe Eigenschaft inhärent, die zu Abstoßung und Auflösungswiderstand führt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hydrophobic' have not yet been formalized. The term is defined as a specific subtype of 'chemical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001885.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalRelationalQuality(x) ← Hydrophobic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hydrophobic&apos; then x is a &apos;chemical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">polytetrafluoroethylene (PTFE) exhibits a hydrophobic quality, causing water droplets to bead on its surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202507/qualities/Qualities-Chemical/"/>
    <owl:versionInfo>202507</owl:versionInfo>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <dcterms:abstract xml:lang="en-us">The IOF Qualities-Chemical Ontology aims to represent Qualities relevant to chemicals and chemical processes</dcterms:abstract>
    <dcterms:contributor xml:lang="en-us">Thomas Hanke, Fraunhofer IWM</dcterms:contributor>
    <dcterms:creator xml:lang="en-us">IOF Materials Working Group</dcterms:creator>
    <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
    <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
    <dcterms:references rdf:resource="http://spec.org/dc/terms/"/>
    <dcterms:references rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    <dcterms:title xml:lang="en-us">Industrial Ontology Foundry (IOF) Chemical Qualities Ontology</dcterms:title>
    <rdfs:label xml:lang="en-us">Chemical Qualities Ontology</rdfs:label>
    <iof-av:copyright xml:lang="en-US">Industrial Ontology Foundry (IOF)</iof-av:copyright>
    <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/MolecularQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalQuality"/>
    <rdfs:label xml:lang="de">Molekulare Qualität</rdfs:label>
    <rdfs:label xml:lang="en-US">molecular quality</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">molecular quality is inherent in a molecular entity such as a single molecule, atom, ion, or radical</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die molekulare Qualität ist einer molekularen Einheit wie einem einzelnen Molekül, Atom, Ion oder Radikal inhärent</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'molecular quality' have not yet been formalized. The term is defined as a specific subtype of 'chemical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalQuality(x) ← MolecularQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;molecular quality&apos; then x is a &apos;chemical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the electronegativity of a fluorine atom is a molecular quality of that atom</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000116">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en-US">Editor Note</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nec5715b065ae40599a641ca12eada8d2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000057"/>
    <owl:someValuesFrom rdf:nodeID="N074920851e0946f2b0eead43f14abafa"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalAction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <owl:equivalentClass rdf:nodeID="Nf99d44a96ba4485a8dff9182fcb0df0d"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Action"/>
    <rdfs:label xml:lang="en-US">chemical action</rdfs:label>
    <rdfs:label xml:lang="de">chemische Aktion</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Chemical action represents a stimulus enacting a chemical interaction with an object</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine chemische Aktion stellt einen Reiz dar, der eine chemische Wechselwirkung mit einem Objekt auslöst</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en-US">ChemicalAction(x) ↔ (∃b ((obo:BFO_0000040(b) ∧ ∃c (ChemicalRelationalQuality(c) ∧ hasQuality(b, c))) ∧ obo:BFO_0000057(x, b)) ∨ ∃d (ChemicalProcessCharacteristic(d) ∧ hasProcessCharacteristic(x, d)))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-US">every instance of 'chemical action' is defined as exactly an instance of 'that 'obo:BFO_0000057' some an instance of 'BFO_0000040' and that 'hasQuality' some 'chemical relational quality'' or 'that 'hasProcessCharacteristic' some 'chemical process characteristic''</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb4390e139bb54e0f96229d2ff2005ff4">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Hydrophilicity"/>
    <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/explanatoryNote"/>
    <owl:annotatedTarget>Hydrophilic molecule or portion of a molecule is one whose interactions with water and other polar substances are more thermodynamically favorable than their interactions with oil or other hydrophobic solvents. Typically charge-polarized and capable of hydrogen bonding, making them soluble not only in water but also in other polar solvents

Hydrophilic molecules (and portions of molecules) contrast with hydrophobic molecules (and portions of molecules). In some cases, both hydrophilic and hydrophobic properties occur in a single molecule. An example is the lipids that comprise the cell membrane. Another example is soap, which has a hydrophilic head and a hydrophobic tail, allowing it to dissolve in both water and oil

Hydrophilic and hydrophobic molecules are also known as polar molecules and nonpolar molecules, respectively. Some hydrophilic substances do not dissolve; this type of mixture is called a colloid</owl:annotatedTarget>
    <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Hydrophile</iof-av:directSource>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalReaction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <owl:equivalentClass rdf:nodeID="Nbe44effbb6eb4e9d940c142c65443169"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Reaction"/>
    <rdfs:label xml:lang="en-US">chemical reaction</rdfs:label>
    <rdfs:label xml:lang="de">chemische Antwort</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Chemical reaction characterizes a process where a biologcal capability of entity X is realized in response to a chemical action involving X or more material entities</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine chemische Reaktion charakterisiert einen Prozess, bei dem eine biologische Fähigkeit von Entität X als Reaktion auf eine chemische Aktion realisiert wird, an der X oder mehr materielle Entitäten beteiligt sind</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en-US">ChemicalReaction(x) ↔ ∃b (ChemicalCapability(b) ∧ obo:BFO_0000055(x, b))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-US">every instance of 'chemical reaction' is defined as exactly that 'obo:BFO_0000055' some 'chemical capability'</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Lipophilicity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalCapability"/>
    <rdfs:label xml:lang="de">Lipophilidität</rdfs:label>
    <rdfs:label xml:lang="en-US">lipophilicity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Lipophilicity"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">lipophilicity is an ability of chemical compounds to dissolve in fats, oils, lipids, and non-polar solvents, described as "fat-loving" due to composition</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Lipophilie versteht man die Fähigkeit chemischer Verbindungen, sich in Fetten, Ölen, Lipiden und unpolaren Lösungsmitteln aufzulösen, die aufgrund ihrer Zusammensetzung als „fettliebend“ bezeichnet werden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lipophilicity' have not yet been formalized. The term is defined as a specific subtype of 'chemical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Lipophilicity.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalCapability(x) ← Lipophilicity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lipophilicity&apos; then x is a &apos;chemical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the high lipophilicity of benzene enables it to readily dissolve in hexane but not in water</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N714a77b6ce7247f2acf9dab9d9c27ff6">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasQuality"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuality"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Lypophobic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuality"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000169"/>
        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_18059"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:label xml:lang="de">fettabweisend</rdfs:label>
    <rdfs:label xml:lang="en-US">lipophobic</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">lipophobic quality inheres in a bearer due to lack of affinity for fats, oils, lipids, and non-polar solvents, resisting and repelling these substances</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Aufgrund der fehlenden Affinität zu Fetten, Ölen, Lipiden und unpolaren Lösungsmitteln ist einem Träger eine lipophobe Eigenschaft inhärent, die diesen Substanzen widersteht und sie abstößt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lipophobic' have not yet been formalized. The term is defined as a specific subtype of 'chemical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalRelationalQuality(x) ← Lypophobic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lipophobic&apos; then x is a &apos;chemical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">sucrose exhibits a lipophobic quality, resisting dissolution in nonpolar solvents such as diethyl ether</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N73df4ffcb3444d45b33b6541c7b7e18d">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasProcessCharacteristic"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalProcessCharacteristic"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
    <rdfs:label xml:lang="en-US">chemical capability</rdfs:label>
    <rdfs:label xml:lang="de">chemische Fähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Chemical capability is a capability realized through an entity governed by chemical interaction in the interest of an agent</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Chemische Fähigkeit ist eine Fähigkeit, die durch eine Einheit realisiert wird, die durch chemische Wechselwirkung im Interesse eines Agenten gesteuert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'chemical capability' have not yet been formalized. The term is defined as a specific subtype of 'Capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Capability(x) ← ChemicalCapability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;chemical capability&apos; then x is a &apos;capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the capability of zinc to reduce copper ions in solution is a chemical capability</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalResistance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalCapability"/>
    <rdfs:label xml:lang="en-US">chemical resistance</rdfs:label>
    <rdfs:label xml:lang="de">Chemikalienbeständigkeit</rdfs:label>
    <skos:altLabel xml:lang="en-US">chemical inertness</skos:altLabel>
    <skos:altLabel xml:lang="de">chemische Inertheit</skos:altLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Chemical resistance is a chemical capability of a material to withstand exposure to chemicals without significant deterioration of its mechanical, physical, or chemical properties</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Chemikalienbeständigkeit ist eine chemische Fähigkeit eines Materials, der Einwirkung von Chemikalien standzuhalten, ohne wesentliche Verschlechterung seiner mechanischen, physikalischen oder chemischen Eigenschaften</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for &apos;chemical resistance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;chemical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalCapability(x) ← ChemicalResistance(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;chemical resistance&apos; then x is a &apos;chemical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the chemical resistance of HDPE to concentrated sulfuric acid keeps its tensile strength largely unchanged after 24 hours immersion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/CorrosionResistant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalResistance"/>
    <rdfs:label xml:lang="en-US">corrosion resistant</rdfs:label>
    <rdfs:label xml:lang="de">korrosionsbeständig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010000"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Corrosion resistant is a chemical capability of a material to withstand corrosive attack to a certain extent without significant degradation of its properties</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Korrosionsbeständigkeit ist die chemische Fähigkeit eines Materials, einem Korrosionsangriff bis zu einem gewissen Grad standzuhalten, ohne dass sich seine Eigenschaften wesentlich verschlechtern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'corrosion resistant' have not yet been formalized. The term is defined as a specific subtype of 'chemical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010000.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalResistance(x) ← CorrosionResistant(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;corrosion resistant&apos; then x is a &apos;chemical resistance&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">stainless steel 316L is corrosion resistant in chloride-rich marine environments due to its chromium and molybdenum content</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/OxidationResistance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalResistance"/>
    <rdfs:label xml:lang="en-US">oxidation resistance</rdfs:label>
    <rdfs:label xml:lang="de">Oxidationsbeständigkeit</rdfs:label>
    <skos:altLabel xml:lang="en-US">oxidation stability</skos:altLabel>
    <skos:altLabel xml:lang="de">Oxidationsstabilität</skos:altLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Oxidation resistance is a chemical capability of a material to withstand chemical degradation through oxidation reactions, maintaining structural and functional integrity under oxidizing conditions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Oxidationsbeständigkeit ist eine chemische Fähigkeit eines Materials, chemischem Abbau durch Oxidationsreaktionen zu widerstehen und strukturelle sowie funktionelle Integrität unter oxidierenden Bedingungen aufrechtzuerhalten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for &apos;oxidation resistance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;chemical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalResistance(x) ← OxidationResistance(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;oxidation resistance&apos; then x is a &apos;chemical resistance&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the oxidation resistance of alumina-forming nickel superalloys allows turbine blade service at 1000°C in air</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Hydrophilic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuality"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000169"/>
        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_15377"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:label xml:lang="de">Hydrophil</rdfs:label>
    <rdfs:label xml:lang="en-US">hydrophilic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001887"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">hydrophilic quality inheres in a bearer due to the bearer's disposition to affinity for water, promoting dissolution, mixing, or wetting by water</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die hydrophile Qualität ist einem Träger aufgrund seiner Affinität zu Wasser inhärent und fördert die Auflösung, Vermischung oder Benetzung durch Wasser</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hydrophilic' have not yet been formalized. The term is defined as a specific subtype of 'chemical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001887.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalRelationalQuality(x) ← Hydrophilic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hydrophilic&apos; then x is a &apos;chemical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">cellulose is hydrophilic, readily absorbing water and swelling due to hydroxyl groups forming hydrogen bonds</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/pH">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuality"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000169"/>
        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_15377"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:label xml:lang="en-US">pH</rdfs:label>
    <rdfs:label xml:lang="de">pH-Wert</rdfs:label>
    <skos:altLabel xml:lang="en-US">hydrogen ion concentration</skos:altLabel>
    <skos:altLabel xml:lang="de">Wasserstoffionenkonzentration</skos:altLabel>
    <iof-av:symbol xml:lang="en-US">pH</iof-av:symbol>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">pH is a chemical relational quality of an aqueous solution that specifies the negative logarithm of the hydrogen ion activity, indicating the acidity or alkalinity of the solution</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">pH-Wert ist eine chemische relationale Qualität einer wässrigen Lösung, die den negativen Logarithmus der Wasserstoffionenaktivität angibt und die Acidität oder Alkalinität der Lösung beschreibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for &apos;pH&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;chemical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalRelationalQuality(x) ← pH(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pH&apos; then x is a &apos;chemical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the pH of a 0.1 mol/L hydrochloric acid solution is approximately 1</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Solubility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuality"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000169"/>
        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_46787"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:label xml:lang="en-US">solubility</rdfs:label>
    <rdfs:label xml:lang="de">Löslichkeit</rdfs:label>
    <iof-av:symbol xml:lang="en-US">S</iof-av:symbol>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Solubility is a chemical relational quality of a substance that quantifies the maximum amount of that substance which can dissolve in a given quantity of a specified solvent at defined temperature and pressure conditions to form a homogeneous solution</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Löslichkeit ist eine chemische relationale Qualität eines Stoffes, die die maximale Menge angibt, die sich unter definierten Temperatur- und Druckbedingungen in einer gegebenen Menge eines bestimmten Lösungsmittels lösen kann, um eine homogene Lösung zu bilden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for &apos;solubility&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;chemical relational quality&apos; that specifically depends on a solvent entity. The value is solvent-specific and cannot be defined without reference to the solvent.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalRelationalQuality(x) ∧ ∃s(CHEBI_46787(s) ∧ specificallyDependsOn(x,s)) ← Solubility(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;solubility&apos; then x is a &apos;chemical relational quality&apos; and x specifically depends on some solvent</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the solubility of sodium chloride in water at 20°C is approximately 360 g/L</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N94edd5f30b0c4257b41b60c04fb46aeb">
    <rdf:first rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
    <rdf:rest rdf:nodeID="N7e600270eb2c485d8971d9e1441b7288"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
    <rdfs:label xml:lang="en-US">chemical relational quality</rdfs:label>
    <rdfs:label xml:lang="de">chemisch relative Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Chemical relational quality pertains to properties or characteristics of an entity dependent on its relation to other entities</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die chemische Beziehungsqualität bezieht sich auf Eigenschaften oder Merkmale einer Entität, die von ihrer Beziehung zu anderen Entitäten abhängig sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'chemical relational quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000145'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000145(x) ← ChemicalRelationalQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;chemical relational quality&apos; then x is a &apos;b f o_0000145&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the solubility of aspirin in ethanol is a chemical relational quality dependent on both solute and solvent</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Bond">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalRelationalQuality"/>
    <rdfs:label xml:lang="en-US">bond</rdfs:label>
    <rdfs:label xml:lang="de">Bindung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0050000"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Bond is a chemical relational quality that inheres between atoms and describes the force interaction holding them together</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bindung ist eine chemische Beziehungsqualität, die zwischen Atomen innewohnt und die Kraftwechselwirkung beschreibt, die sie zusammenhält</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bond' have not yet been formalized. The term is defined as a specific subtype of 'chemical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0050000.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ChemicalRelationalQuality(x) ← Bond(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bond&apos; then x is a &apos;chemical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the bond between two hydrogen atoms in H2 determines the molecule's stability and bond length of 74 pm</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/CovalentBond">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Bond"/>
    <rdfs:label xml:lang="en-US">covalent bond</rdfs:label>
    <rdfs:label xml:lang="de">kovalente Bindung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0050001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Covalent bond is a bond that inheres between nonmetal atoms sharing electrons to achieve a stable electron configuration</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine kovalente Bindung ist eine Bindung zwischen Nichtmetallatomen, die sich Elektronen teilen, um eine stabile Elektronenkonfiguration zu erreichen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'covalent bond' have not yet been formalized. The term is defined as a specific subtype of 'bond'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0050001.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Bond(x) ← CovalentBond(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;covalent bond&apos; then x is a &apos;bond&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the C-H covalent bond in methane results from carbon and hydrogen sharing two electrons</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/MetallicBond">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Bond"/>
    <rdfs:label xml:lang="en-US">metallic bond</rdfs:label>
    <rdfs:label xml:lang="de">metallische Bindung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0050002"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Metallic bond is a bond that inheres between metal atoms, where electrons are delocalized and shared in a sea of electrons moving freely around the metal ions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine Metallbindung ist eine Bindung zwischen Metallatomen, bei der Elektronen delokalisiert und in einem Meer von Elektronen geteilt werden, die sich frei um die Metallionen bewegen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'metallic bond' have not yet been formalized. The term is defined as a specific subtype of 'bond'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0050002.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Bond(x) ← MetallicBond(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;metallic bond&apos; then x is a &apos;bond&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the metallic bond in copper allows free electron movement, giving it high electrical conductivity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/IonicBond">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Bond"/>
    <rdfs:label xml:lang="en-US">ionic bond</rdfs:label>
    <rdfs:label xml:lang="de">ionische Bindung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0050003"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ionic bond is a bond that inheres between oppositely charged ions formed when one atom donates an electron to another atom</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine Ionenbindung ist eine Bindung zwischen entgegengesetzt geladenen Ionen, die entsteht, wenn ein Atom ein Elektron an ein anderes Atom abgibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ionic bond' have not yet been formalized. The term is defined as a specific subtype of 'bond'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0050003.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Bond(x) ← IonicBond(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ionic bond&apos; then x is a &apos;bond&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the ionic bond in sodium chloride forms when sodium donates an electron to chlorine, creating Na+ and Cl- ions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/HydrogenBond">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/Bond"/>
    <rdfs:label xml:lang="en-US">hydrogen bond</rdfs:label>
    <rdfs:label xml:lang="de">Wasserstoffbrückenbindung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020024"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Hydrogen bond is a bond that inheres between a hydrogen atom of one molecule and an electronegative atom of another molecule</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine Wasserstoffbindung ist eine Bindung, die zwischen einem Wasserstoffatom eines Moleküls und einem elektronegativen Atom eines anderen Moleküls besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hydrogen bond' have not yet been formalized. The term is defined as a specific subtype of 'bond'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020024.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Bond(x) ← HydrogenBond(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hydrogen bond&apos; then x is a &apos;bond&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the hydrogen bond between water molecules (O-H···O) is responsible for water's unusually high boiling point</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nbe44effbb6eb4e9d940c142c65443169">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Chemical/ChemicalCapability"/>
  </rdf:Description>
