  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ProtogynousHermaphroditism">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Protogynous"/>
    <rdfs:label xml:lang="de">protogyner Hermaphroditismus</rdfs:label>
    <rdfs:label xml:lang="en">protogynous hermaphroditism</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040054"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Protogynous hermaphroditism occurs when organisms start life as females and become hermaphroditic during later stages</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'protogynous hermaphroditism' have not yet been formalized. The term is defined as a specific subtype of 'protogynous'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040054.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000412">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">Imported From</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/title">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Circling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MovementBehavioralQuality"/>
    <rdfs:label xml:lang="en">circling</rdfs:label>
    <rdfs:label xml:lang="de">kreisen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001911"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Circling denotes repetitive movement in a circular course exhibited by the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'circling' have not yet been formalized. The term is defined as a specific subtype of 'movement behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001911.</iof-av:primitiveRationale>
  </rdf:Description>
