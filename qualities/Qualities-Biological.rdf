    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleFertility"/>
    <rdfs:label xml:lang="en">female fertile</rdfs:label>
    <rdfs:label xml:lang="de">weibliche Fruchtbarkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000888"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Female fertile quality indicates a female's disposition to initiate, sustain, or support reproduction</iof-av:naturalLanguageDefinition>
