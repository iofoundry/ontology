  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ProtogynousHermaphroditism">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Protogynous"/>
    <rdfs:label xml:lang="de">protogyner Hermaphroditismus</rdfs:label>
    <rdfs:label xml:lang="en-US">protogynous hermaphroditism</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040054"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Protogynous hermaphroditism occurs when organisms start life as females and become hermaphroditic during later stages</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'protogynous hermaphroditism' have not yet been formalized. The term is defined as a specific subtype of 'protogynous'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040054.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Protogynous(x) ← ProtogynousHermaphroditism(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;protogynous hermaphroditism&apos; then x is a &apos;protogynous&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;protogynous hermaphroditism&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000412">
