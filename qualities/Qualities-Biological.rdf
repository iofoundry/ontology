  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemalePseudohermaphrodite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pseudohermaphrodite"/>
    <rdfs:label xml:lang="en">female pseudohermaphrodite</rdfs:label>
    <rdfs:label xml:lang="de">weiblicher Pseudohermaphrodit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001829"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Female pseudohermaphrodite involves internal female reproductive organs and external male sexual characteristics</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'female pseudohermaphrodite' have not yet been formalized. The term is defined as a specific subtype of 'pseudohermaphrodite'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001829.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pentaploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="en">pentaploid</rdfs:label>
    <rdfs:label xml:lang="de">pentaploidie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001383"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Pentaploid quality indicates the presence of five homologous sets of chromosomes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'pentaploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001383.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Endopolyploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="de">endopolyploid</rdfs:label>
    <rdfs:label xml:lang="en">endopolyploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001392"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Endopolyploid is a quality indicating increased chromosome count due to endomitosis, proportionate to endomitosis occurrence</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'endopolyploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001392.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Receptivity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Empfänglichkeit</rdfs:label>
    <rdfs:label xml:lang="en">receptivity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001719"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Receptivity quality signifies the ability to receive a stimulus or entity effectively</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'receptivity' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001719.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Migratory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="en">migratory</rdfs:label>
    <rdfs:label xml:lang="de">migrierend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095008"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Migratory quality signifies adaptations facilitating long-distance, typically seasonal, movement within conspecifics</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'migratory' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095008.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Paralysed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MovementBehavioralQuality"/>
    <rdfs:label xml:lang="de">gelähmt</rdfs:label>
    <rdfs:label xml:lang="en">paralysed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000763"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Paralysed quality indicates the loss or impairment of the ability to move certain body parts</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'paralysed' have not yet been formalized. The term is defined as a specific subtype of 'movement behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000763.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Undifferentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="en">undifferentiated</rdfs:label>
    <rdfs:label xml:lang="de">undifferenziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002100"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Undifferentiated quality reflects the state of having not yet acquired specialized structure or function</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'undifferentiated' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002100.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Haploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Euploid"/>
    <rdfs:label xml:lang="de">Haploidy</rdfs:label>
    <rdfs:label xml:lang="en">haploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001375"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Haploid quality reflects the presence of a single set of homologous chromosomes within the cell</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'haploid' have not yet been formalized. The term is defined as a specific subtype of 'euploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001375.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GrandMultiparous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multiparous"/>
    <rdfs:label xml:lang="en">grand multiparous</rdfs:label>
    <rdfs:label xml:lang="de">großmultipar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002372"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Grand multiparous quality defines a viviparous organism that has given birth five or more times</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'grand multiparous' have not yet been formalized. The term is defined as a specific subtype of 'multiparous'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002372.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Larval">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="de">Larvenstadium</rdfs:label>
    <rdfs:label xml:lang="en">larval</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001185"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Larval maturity quality characterizes an organism undergoing indirect development with metamorphosis stages</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'larval' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001185.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000114">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">Has Curation Status</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/RightHandedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Handedness"/>
    <rdfs:label xml:lang="de">Rechtshändigkeit</rdfs:label>
    <rdfs:label xml:lang="en">right handedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002203"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Right handedness attributes preferential use of the right hand or foot for tasks demanding dominance</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'right handedness' have not yet been formalized. The term is defined as a specific subtype of 'handedness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002203.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleFertile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleFertility"/>
    <rdfs:label xml:lang="en">male fertile</rdfs:label>
    <rdfs:label xml:lang="de">männliche Fruchtbarkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000891"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Male fertile quality embodies a male's ability to initiate, sustain, or support reproductive processes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'male fertile' have not yet been formalized. The term is defined as a specific subtype of 'male fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000891.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multiparous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parity"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parous"/>
    <rdfs:label xml:lang="de">mehrfachträchtig</rdfs:label>
    <rdfs:label xml:lang="en">multiparous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002369"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Multiparous quality defines a viviparous organism experiencing two or more successful birth cycles</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'multiparous' have not yet been formalized. The term is defined as a specific subtype of 'parity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002369.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleFertility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertility"/>
    <rdfs:label xml:lang="en">female fertility</rdfs:label>
    <rdfs:label xml:lang="de">weibliche Fruchtbarkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000277"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Female fertility quality encompasses the ability to initiate, sustain, or support reproduction from the female aspect</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'female fertility' have not yet been formalized. The term is defined as a specific subtype of 'fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000277.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multipotent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="de">mehrfachdifferenzierungsfähig</rdfs:label>
    <rdfs:label xml:lang="en">multipotent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001402"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Multipotent quality involves the capability to develop into multiple differentiated cell types</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'multipotent' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001402.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
    <rdfs:label xml:lang="en">biological capability</rdfs:label>
    <rdfs:label xml:lang="de">biologische Fähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Biological capability describes a capability realized through an entity in a Biological interaction, fulfilling an agent's interest</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'biological capability' have not yet been formalized. The term is defined as a specific subtype of 'Capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioactive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="en">bioactive</rdfs:label>
    <rdfs:label xml:lang="de">bioaktiv</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010023"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Bioactive is a biological capability of a material entity that is realized as a specific interaction with one or more biological systems, producing a measurable biological effect such as a therapeutic, toxic, or signaling outcome</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'bioactive' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010023.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Biocompatible">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioactive"/>
    <rdfs:label xml:lang="en">biocompatible</rdfs:label>
    <rdfs:label xml:lang="de">biokompatibel</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020251"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Biocompatible is a biological capability of a material entity that is realized as a bioactive interaction without causing harmful or unacceptable biological responses such as toxicity, inflammation, or immune reaction</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'biocompatible' have not yet been formalized. The term is defined as a specific subtype of 'bioactive'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020251.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioresorbable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Biocompatible"/>
    <rdfs:label xml:lang="en">bioresorbable</rdfs:label>
    <rdfs:label xml:lang="de">bioresorbierbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010025"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Bioresorbable is a biological capability of a material entity that is realized as gradual degradation and resorption by the body over time while performing its intended function</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'bioresorbable' have not yet been formalized. The term is defined as a specific subtype of 'biocompatible'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010025.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioinert">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="en">bioinert</rdfs:label>
    <rdfs:label xml:lang="de">bioinert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010024"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Bioinert is a biological capability of a material entity that is realized as minimal or no biological response when in contact with tissue, being non-toxic and non-immunogenic</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'bioinert' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010024.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Biodegradability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="en">biodegradability</rdfs:label>
    <rdfs:label xml:lang="de">Biologische Abbaubarkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0200001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Biodegradability is a biological capability of a material that is realized as full microbial conversion of its organic constituents into inorganic end products within an environmentally non-harmful timescale</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'biodegradability' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0200001.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Indiscriminate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Discrimination"/>
    <rdfs:label xml:lang="en">indiscriminate</rdfs:label>
    <rdfs:label xml:lang="de">unterscheidungslos</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001318"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Indiscriminate quality pertains to incapability in perceiving differences between stimuli</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'indiscriminate' have not yet been formalized. The term is defined as a specific subtype of 'discrimination'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001318.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MatingCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="de">Paarungsfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">mating capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Capablity of an organism to be able to mate with another individuum for the purpose of reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mating capability' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MosaicTrisomy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Trisomy"/>
    <rdfs:label xml:lang="de">Mosaik Trisomie</rdfs:label>
    <rdfs:label xml:lang="en">mosaic trisomy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001391"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mosaic trisomy quality refers to the presence of extra chromosomal material in only some cells of the organism</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mosaic trisomy' have not yet been formalized. The term is defined as a specific subtype of 'trisomy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001391.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductiveQuality"/>
    <rdfs:label xml:lang="en">parous</rdfs:label>
    <rdfs:label xml:lang="de">parös</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040028"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Parous quality denotes having successfully reproduced at least once</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'parous' have not yet been formalized. The term is defined as a specific subtype of 'reproductive quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040028.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/IntactFemale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Female"/>
    <rdfs:label xml:lang="en">intact female</rdfs:label>
    <rdfs:label xml:lang="de">unversehrt weibliche</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002365"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Intact female defines possessing complete, unaltered reproductive organs</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'intact female' have not yet been formalized. The term is defined as a specific subtype of 'female'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002365.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Handedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Händigkeit</rdfs:label>
    <rdfs:label xml:lang="en">handedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002201"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Handedness refers to the unequal distribution of fine motor skills between the left and right hands or feet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'handedness' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002201.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleGenotypicSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GenotypicSex"/>
    <rdfs:label xml:lang="en">male genotypic sex</rdfs:label>
    <rdfs:label xml:lang="de">männlicher Geschlechtsgenotyp</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0020001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Male genotypic sex quality is determined by genetic composition, enabling male gonad differentiation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'male genotypic sex' have not yet been formalized. The term is defined as a specific subtype of 'genotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0020001.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleGenotypicSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GenotypicSex"/>
    <rdfs:label xml:lang="en">female genotypic sex</rdfs:label>
    <rdfs:label xml:lang="de">genotypischer weiblicher Geschlecht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0020002"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Female genotypic sex quality is determined by genotypic composition conferring capacity for female gonad differentiation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'female genotypic sex' have not yet been formalized. The term is defined as a specific subtype of 'genotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0020002.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalQuality"/>
    <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000428"/>
    <rdfs:label xml:lang="en">cellular quality</rdfs:label>
    <rdfs:label xml:lang="de">zelluläre Qualität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001396"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Cellular quality encompasses traits or characteristics that exist within the cellular level of organization</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'cellular quality' have not yet been formalized. The term is defined as a specific subtype of 'biological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001396.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Virulence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Virulenz</rdfs:label>
    <rdfs:label xml:lang="en">virulence</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002146"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Virulence quality pertains to the severity of an infectious disease caused by the organism in a target host</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'virulence' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002146.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/LeftHandedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Handedness"/>
    <rdfs:label xml:lang="de">Linkshändigkeit</rdfs:label>
    <rdfs:label xml:lang="en">left handedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002202"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Left handedness reflects a preference for utilizing the left hand or foot in tasks requiring singular motor dominance</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'left handedness' have not yet been formalized. The term is defined as a specific subtype of 'handedness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002202.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalQuality"/>
    <rdfs:label xml:lang="en">organismal quality</rdfs:label>
    <rdfs:label xml:lang="de">organismen Qualität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001995"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Organismal quality encompasses biological attributes inherent in an entire organism or its parts</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'organismal quality' have not yet been formalized. The term is defined as a specific subtype of 'biological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001995.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/HMinus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SchizosaccharomycesPombeMatingType"/>
    <rdfs:label xml:lang="de">h Minus</rdfs:label>
    <rdfs:label xml:lang="en">h minus</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001345"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">H Minus refers to a Schizosaccharomyces pombe mating type determined by specific gene configurations at the mat1 locus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'h minus' have not yet been formalized. The term is defined as a specific subtype of 'schizosaccharomyces pombe mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001345.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Cursorial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">cursorial</rdfs:label>
    <rdfs:label xml:lang="en">cursorial</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095002"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Cursorial is a quality denoting morphological and physiological adaptations for running in the organism</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'cursorial' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095002.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="en">biological sex</rdfs:label>
    <rdfs:label xml:lang="de">biologisches Geschlecht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000047"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Biological sex defines an organismal quality enabling differentiation during reproductive processes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'biological sex' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000047.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Monandrous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex"/>
    <rdfs:label xml:lang="de">monandrisch</rdfs:label>
    <rdfs:label xml:lang="en">monandrous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040051"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Monandrous quality signifies flowers having only one stamen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'monandrous' have not yet been formalized. The term is defined as a specific subtype of 'phenotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040051.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/AlphaMatingTypeYeast">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SaccharomycesCerevisiaeMatingType"/>
    <rdfs:label xml:lang="de">Alpha Paarungstyp Hefe</rdfs:label>
    <rdfs:label xml:lang="en">alpha mating type (yeast)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001344"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Alpha mating type (yeast) indicates yeast cells that secrete pheromones to stimulate alpha haploid yeast cells toward mating</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'alpha mating type (yeast)' have not yet been formalized. The term is defined as a specific subtype of 'saccharomyces cerevisiae mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001344.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Differentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="en">differentiated</rdfs:label>
    <rdfs:label xml:lang="de">differenziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002099"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Differentiated is a quality signifying stable specialization into a specific cell type</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'differentiated' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002099.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="en">cellular potency</rdfs:label>
    <rdfs:label xml:lang="de">zelluläre Potenz</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001397"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Cellular potency is a quality embodying a cell's potential for differentiation into various mature cell types</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'cellular potency' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001397.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/LethalSensuGenetics">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en">lethal (sensu genetics)</rdfs:label>
    <rdfs:label xml:lang="de">tödlich (sensu genetisch)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000718"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Lethal quality (sensu genetics) is defined by long-term survival inability in a population</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'lethal (sensu genetics)' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000718.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleSemiSterile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleFertility"/>
    <rdfs:label xml:lang="en">male semi-sterile</rdfs:label>
    <rdfs:label xml:lang="de">männlich steril</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001762"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Male semi-sterile quality suggests incomplete or impaired reproductive capability in males</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'male semi-sterile' have not yet been formalized. The term is defined as a specific subtype of 'male fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001762.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Triploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="de">triploid</rdfs:label>
    <rdfs:label xml:lang="en">triploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001381"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Triploid quality pertains to having three homologous sets of chromosomes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'triploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001381.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/NonDeciduousAnyBodyPart">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Shedability"/>
    <rdfs:label xml:lang="de">nicht laubabwerfend (alle teile)</rdfs:label>
    <rdfs:label xml:lang="en">non-deciduous (any body part)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001732"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Non-deciduous quality defines the absence of shedding any body part by the organism</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'non-deciduous (any body part)' have not yet been formalized. The term is defined as a specific subtype of 'shedability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001732.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fecundity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductiveQuality"/>
    <rdfs:label xml:lang="de">Fruchtbarkeit</rdfs:label>
    <rdfs:label xml:lang="en">fecundity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000273"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Fecundity quality represents potential reproductive capacity measured by the number of gametes produced</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'fecundity' have not yet been formalized. The term is defined as a specific subtype of 'reproductive quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000273.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/WellDifferentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Differentiated"/>
    <rdfs:label xml:lang="de">gut differenziert</rdfs:label>
    <rdfs:label xml:lang="en">well differentiated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002110"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Well differentiated quality reflects possessing most cellular characteristics of the tissue of origin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'well differentiated' have not yet been formalized. The term is defined as a specific subtype of 'differentiated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002110.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MovementBehavioralQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Bewegungsverhaltensqualität</rdfs:label>
    <rdfs:label xml:lang="en">movement behavioral quality</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002076"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Movement behavioral quality refers to the attribute arising from the bearer’s movement capability</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'movement behavioral quality' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002076.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000116">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">Editor Note</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SchizosaccharomycesPombeMatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/YeastMatingType"/>
    <rdfs:label xml:lang="de">Schizosaccharomyces Pombe Paarungstyp</rdfs:label>
    <rdfs:label xml:lang="en">schizosaccharomyces pombe mating type</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001343"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Schizosaccharomyces pombe mating type is defined by gene configuration on the mat1 locus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'schizosaccharomyces pombe mating type' have not yet been formalized. The term is defined as a specific subtype of 'yeast mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001343.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SelfRenewal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Proliferative"/>
    <rdfs:label xml:lang="de">Selbst Erneuerung</rdfs:label>
    <rdfs:label xml:lang="en">self-renewal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001398"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Self-renewal quality entails a cell's ability to undergo multiple cycles of division while maintaining its undifferentiated state</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'self-renewal' have not yet been formalized. The term is defined as a specific subtype of 'proliferative'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001398.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/bibliographicCitation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SexuallyDimorphic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">geschlechtsdimorph</rdfs:label>
    <rdfs:label xml:lang="en">sexually dimorphic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002451"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Sexually dimorphic quality indicates phenotypic differences between males and females of the same species</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'sexually dimorphic' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002451.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Ploidy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="de">Ploidie</rdfs:label>
    <rdfs:label xml:lang="en">ploidy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001374"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Ploidy quality concerns the number of homologous sets of chromosomes in a cell's nucleus or primary chromosome-containing compartment</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'ploidy' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001374.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fossorial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">fossorial</rdfs:label>
    <rdfs:label xml:lang="en">fossorial</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095003"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Fossorial quality is characterized by adaptations for digging and subterranean living</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'fossorial' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095003.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductionCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="de">Reproduktionsfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">reproduction capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Capablity of an organism to be able to reproduce</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'reproduction capability' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleSpecific">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SexSpecific"/>
    <rdfs:label xml:lang="en">female-specific</rdfs:label>
    <rdfs:label xml:lang="de">weiblich-spezifisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0060003"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Female-specific quality pertains to features present exclusively in females and absent in males within the same species</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'female-specific' have not yet been formalized. The term is defined as a specific subtype of 'sex-specific'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0060003.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Heterophilic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularAdhesivity"/>
    <rdfs:label xml:lang="de">heterophil</rdfs:label>
    <rdfs:label xml:lang="en">heterophilic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001441"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Heterophilic quality describes intercellular adherence wherein molecules attach to nonidentical molecules in adjacent cells</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'heterophilic' have not yet been formalized. The term is defined as a specific subtype of 'cellular adhesivity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001441.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BroodViability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en">brood viability</rdfs:label>
    <rdfs:label xml:lang="de">Überlebensfähigkeit des Nachwuchses</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001497"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Brood viability indicates the disposition of offspring to survive and develop normally</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'brood viability' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001497.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SexSpecific">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SexuallyDimorphic"/>
    <rdfs:label xml:lang="de">geschlechtsspezifisch</rdfs:label>
    <rdfs:label xml:lang="en">sex-specific</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0060001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Sex-specific quality refers to characteristics present in one sex but absent in the other within the same species</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'sex-specific' have not yet been formalized. The term is defined as a specific subtype of 'sexually dimorphic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0060001.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PartiallyParalysed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MovementBehavioralQuality"/>
    <rdfs:label xml:lang="en">partially paralysed</rdfs:label>
    <rdfs:label xml:lang="de">teilweise gelähmt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001858"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Partial paralysis quality reflects incomplete loss of movement in a part or parts of the body</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'partially paralysed' have not yet been formalized. The term is defined as a specific subtype of 'movement behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001858.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nd2e38bfbacdd47c397197fb4b1d4cbfc">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
