<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
   xmlns:obo="http://purl.obolibrary.org/obo/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Homeostatic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="en-US">homeostatic</rdfs:label>
    <rdfs:label xml:lang="de">homöostatisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002541"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Homeostatic quality pertains to maintaining internal equilibrium through physiological adjustments</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die homöostatische Qualität bezieht sich auf die Aufrechterhaltung des inneren Gleichgewichts durch physiologische Anpassungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'homeostatic' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002541.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Homeostatic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;homeostatic&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">human body temperature regulation around 37 degrees Celsius exemplifies homeostatic quality in mammals</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleSpecific">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SexSpecific"/>
    <rdfs:label xml:lang="en-US">male-specific</rdfs:label>
    <rdfs:label xml:lang="de">männlich-spezifisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0060002"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male-specific quality refers to features present exclusively in males and absent in females within the same species</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Männchenspezifische Qualität bezieht sich auf Merkmale, die ausschließlich bei Männchen vorhanden sind und bei Weibchen derselben Art fehlen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male-specific' have not yet been formalized. The term is defined as a specific subtype of 'sex-specific'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0060002.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SexSpecific(x) ← MaleSpecific(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male-specific&apos; then x is a &apos;sex specific&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">antler growth in male deer is a male-specific quality absent in females of the same species</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Nulliparous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parity"/>
    <rdfs:label xml:lang="de">nullipar</rdfs:label>
    <rdfs:label xml:lang="en-US">nulliparous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002368"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Nulliparous quality characterizes a viviparous organism which has not undergone childbirth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die nullipare Qualität kennzeichnet einen lebendgebärenden Organismus, der keine Geburt erlebt hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'nulliparous' have not yet been formalized. The term is defined as a specific subtype of 'parity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002368.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Parity(x) ← Nulliparous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;nulliparous&apos; then x is a &apos;parity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a laboratory mouse that has never given birth is classified as nulliparous before any breeding experiment</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductiveQuality"/>
    <rdfs:label xml:lang="de">Geburtenzahl</rdfs:label>
    <rdfs:label xml:lang="en-US">parity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002370"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Parity quality represents the number of times a viviparous organism has experienced childbirth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Paritätsqualität gibt an, wie oft ein lebendgebärender Organismus eine Geburt erlebt hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'parity' have not yet been formalized. The term is defined as a specific subtype of 'reproductive quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002370.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ReproductiveQuality(x) ← Parity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;parity&apos; then x is a &apos;reproductive quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a cow that has calved three times has a parity of three as recorded in livestock health databases</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductiveQuality"/>
    <rdfs:label xml:lang="de">Fruchtbarkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">fertility</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000274"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Fertility quality describes the ability to initiate, sustain, or support new life production</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Fruchtbarkeitsqualität beschreibt die Fähigkeit, die Produktion neuen Lebens einzuleiten, aufrechtzuerhalten oder zu unterstützen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fertility' have not yet been formalized. The term is defined as a specific subtype of 'reproductive quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000274.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ReproductiveQuality(x) ← Fertility(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fertility&apos; then x is a &apos;reproductive quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">high fertility in Drosophila melanogaster females is measured by egg-laying rate under controlled laboratory conditions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Dead">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en-US">dead</rdfs:label>
    <rdfs:label xml:lang="de">tot</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001422"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Dead is a viability quality signifying the cessation of life processes in the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">„Tot“ ist eine Lebensfähigkeitseigenschaft, die das Aufhören von Lebensprozessen im Träger bedeutet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dead' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001422.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← Dead(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dead&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a culture plate showing no colony growth after 72 hours indicates that all bacterial cells are dead</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Hermaphrodite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex"/>
    <rdfs:label xml:lang="de">Hermaphrodit</rdfs:label>
    <rdfs:label xml:lang="en-US">hermaphrodite</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001340"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Hermaphrodite quality refers to organisms possessing both male and female reproductive organs within the same individual</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Hermaphrodit-Qualität bezieht sich auf Organismen, die sowohl männliche als auch weibliche Fortpflanzungsorgane innerhalb desselben Individuums besitzen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hermaphrodite' have not yet been formalized. The term is defined as a specific subtype of 'phenotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001340.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhenotypicSex(x) ← Hermaphrodite(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hermaphrodite&apos; then x is a &apos;phenotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the garden snail Helix aspersa is a hermaphrodite possessing both ovotestes producing sperm and eggs</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleSemiSterile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleFertility"/>
    <rdfs:label xml:lang="en-US">female semi-sterile</rdfs:label>
    <rdfs:label xml:lang="de">weiblich halbsteril</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001763"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female semi-sterile quality signifies partial incapacity for initiating, sustaining, or supporting reproduction in females</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die semisterile Qualität einer Frau bedeutet, dass sie teilweise nicht in der Lage ist, die Fortpflanzung bei Frauen einzuleiten, aufrechtzuerhalten oder zu unterstützen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female semi-sterile' have not yet been formalized. The term is defined as a specific subtype of 'female fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001763.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">FemaleFertility(x) ← FemaleSemiSterile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female semi-sterile&apos; then x is a &apos;female fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a female mouse producing fewer than half the normal number of pups per litter is classified as female semi-sterile</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SpayedFemale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Female"/>
    <rdfs:label xml:lang="en-US">spayed female</rdfs:label>
    <rdfs:label xml:lang="de">weiblich sterilisiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040020"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spayed female quality indicates inability to reproduce due to the functional loss of ovaries and/or uterus from surgical removal</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität einer kastrierten Frau weist auf die Unfähigkeit zur Fortpflanzung aufgrund des Funktionsverlusts der Eierstöcke und/oder der Gebärmutter durch die chirurgische Entfernung hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spayed female' have not yet been formalized. The term is defined as a specific subtype of 'female'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040020.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Female(x) ← SpayedFemale(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spayed female&apos; then x is a &apos;female&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a spayed female cat can no longer reproduce after bilateral ovariohysterectomy performed at six months of age</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Mating">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalAction"/>
    <rdfs:label xml:lang="de">Paarung</rdfs:label>
    <rdfs:label xml:lang="en-US">mating</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Process of two organisms to realizes their mating capabilities, generaly for the purpose of reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Prozess zweier Organismen zur Verwirklichung ihrer Paarungsfähigkeiten, im Allgemeinen zum Zwecke der Fortpflanzung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mating' have not yet been formalized. The term is defined as a specific subtype of 'biological action'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalAction(x) ← Mating(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mating&apos; then x is a &apos;biological action&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">mating between male and female Caenorhabditis elegans worms results in cross-progeny used for genetic studies</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Mature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="en-US">mature</rdfs:label>
    <rdfs:label xml:lang="de">reif</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001701"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mature quality is characterized by complete growth, differentiation, or development within the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Reife Qualität zeichnet sich durch vollständiges Wachstum, Differenzierung oder Entwicklung innerhalb des Trägers aus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mature' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001701.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Mature(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mature&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a mature Arabidopsis thaliana plant has completed vegetative development and entered the reproductive phase</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BacterialMatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MatingType"/>
    <rdfs:label xml:lang="en-US">bacterial mating type</rdfs:label>
    <rdfs:label xml:lang="de">bakterieller Paarungstyp</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001335"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Bacterial mating type is a quality that indicates whether the F plasmid has integrated into the bacterial chromosome</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der bakterielle Paarungstyp ist eine Eigenschaft, die anzeigt, ob sich das F-Plasmid in das Bakterienchromosom integriert hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bacterial mating type' have not yet been formalized. The term is defined as a specific subtype of 'mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001335.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MatingType(x) ← BacterialMatingType(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bacterial mating type&apos; then x is a &apos;mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an Hfr strain of Escherichia coli has a bacterial mating type defined by chromosomally integrated F plasmid</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Coordinated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Coordination"/>
    <rdfs:label xml:lang="en-US">coordinated</rdfs:label>
    <rdfs:label xml:lang="de">koordiniert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000769"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Coordinated is a quality characterized by skilled and effective interaction in movement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Koordiniert ist eine Qualität, die sich durch geschicktes und effektives Zusammenspiel in der Bewegung auszeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'coordinated' have not yet been formalized. The term is defined as a specific subtype of 'coordination'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000769.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Coordination(x) ← Coordinated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;coordinated&apos; then x is a &apos;coordination&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a coordinated mouse navigates the rotarod apparatus without falling for 120 seconds during a motor function test</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Male">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex"/>
    <rdfs:label xml:lang="en-US">male</rdfs:label>
    <rdfs:label xml:lang="de">männlich</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000384"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male quality is characterized by having sex organs that produce only male gametes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Männliche Qualität zeichnet sich dadurch aus, dass Geschlechtsorgane vorhanden sind, die ausschließlich männliche Gameten produzieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male' have not yet been formalized. The term is defined as a specific subtype of 'phenotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000384.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhenotypicSex(x) ← Male(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male&apos; then x is a &apos;phenotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a XY Mus musculus individual bearing testes that produce spermatozoa is classified as male</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehaviouralActivity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Verhaltensaktivität</rdfs:label>
    <rdfs:label xml:lang="en-US">behavioural activity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002265"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Behavioural activity is a quality signifying the disposition to exhibit pronounced activity during processes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verhaltensaktivität ist eine Eigenschaft, die die Bereitschaft zu ausgeprägter Aktivität während Prozessen bezeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'behavioural activity' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002265.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← BehaviouralActivity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;behavioural activity&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">high behavioural activity in zebrafish larvae is quantified by total swim distance over a 10-minute tracking period</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Organism">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdfs:subClassOf rdf:nodeID="Nf7080facfcd24701b712c1211d16d0cd"/>
    <rdfs:label xml:lang="de">Organismus</rdfs:label>
    <rdfs:label xml:lang="en-US">organism</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Organism"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Organism is any living thing that functions as an individual</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ein Organismus ist jedes Lebewesen, das als Individuum funktioniert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'organism' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000030'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Organism.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000030(x) ← Organism(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;organism&apos; then x is a &apos;b f o_0000030&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Escherichia coli strain K-12 is a single-celled organism widely used as a model system in molecular biology</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Passive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">passiv</rdfs:label>
    <rdfs:label xml:lang="en-US">passive</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000764"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Passive quality refers to receiving an action without response or initiation of reciprocal action</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Passive Qualität bezieht sich auf das Empfangen einer Aktion ohne Reaktion oder Einleitung einer Gegenaktion</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'passive' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000764.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← Passive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;passive&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a passive prey fish in an escape test does not initiate movement when a predator model is presented</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/HighFrequencyRecombinant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FMinusMatingType"/>
    <rdfs:label xml:lang="en-US">high frequency recombinant</rdfs:label>
    <rdfs:label xml:lang="de">hochfrequenzrekombinant</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001349"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">High frequency recombinant type indicates the integration of the F plasmid into the bacterial chromosome</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der hochfrequente rekombinante Typ zeigt die Integration des F-Plasmids in das Bakterienchromosom an</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'high frequency recombinant' have not yet been formalized. The term is defined as a specific subtype of 'f minus mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001349.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">FMinusMatingType(x) ← HighFrequencyRecombinant(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;high frequency recombinant&apos; then x is a &apos;f minus mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an Hfr Escherichia coli donor transfers chromosomal genes to F-minus recipients at high frequency</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/NucleateQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="en-US">nucleate quality</rdfs:label>
    <rdfs:label xml:lang="de">nukleäre Qualität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001404"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Nucleate quality represents a cellular attribute concerned with nuclear number within the cell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Zellkernqualität stellt ein zelluläres Attribut dar, das sich auf die Kernzahl innerhalb der Zelle bezieht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'nucleate quality' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001404.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularQuality(x) ← NucleateQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;nucleate quality&apos; then x is a &apos;cellular quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">erythrocytes lose their nucleate quality during maturation, becoming anucleate in the final differentiation stage</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Coordination">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Koordination</rdfs:label>
    <rdfs:label xml:lang="en-US">coordination</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000188"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Coordination is a quality referring to the ability to execute highly skillful and effective interactions or movements</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Koordination ist eine Eigenschaft, die sich auf die Fähigkeit bezieht, äußerst geschickte und effektive Interaktionen oder Bewegungen auszuführen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'coordination' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000188.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← Coordination(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;coordination&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">coordination in a rat is assessed by measuring paw placement accuracy on a balance beam test</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Prepubescent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="en-US">prepubescent</rdfs:label>
    <rdfs:label xml:lang="de">vorpubertär</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001186"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Prepubescent quality reflects the period immediately preceding the onset of puberty</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die präpubertäre Qualität spiegelt den Zeitraum unmittelbar vor Beginn der Pubertät wider</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'prepubescent' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001186.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Prepubescent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;prepubescent&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a prepubescent female mouse at day 18 post-birth has not yet experienced vaginal opening</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multinucleate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Nucleated"/>
    <rdfs:label xml:lang="de">mehrkernig</rdfs:label>
    <rdfs:label xml:lang="en-US">multinucleate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001908"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multinucleate quality signifies possessing multiple nuclei within the cellular structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrkernige Qualität bedeutet, dass innerhalb der Zellstruktur mehrere Kerne vorhanden sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multinucleate' have not yet been formalized. The term is defined as a specific subtype of 'nucleated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001908.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Nucleated(x) ← Multinucleate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multinucleate&apos; then x is a &apos;nucleated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Aspergillus fumigatus hyphae are multinucleate, containing several nuclei within each hyphal compartment</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SemiLethalSensuGenetics">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="de">semi tödlich sensu genetics</rdfs:label>
    <rdfs:label xml:lang="en-US">semi-lethal (sensu genetics)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001768"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Semi-lethal (sensu genetics) quality describes the inability to survive to reproductive maturity in some population members</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Halbletale (sensu-genetische) Qualität beschreibt die Unfähigkeit einiger Populationsmitglieder, bis zur Fortpflanzungsreife zu überleben</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'semi-lethal (sensu genetics)' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001768.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← SemiLethalSensuGenetics(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;semi-lethal (sensu genetics)&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a semi-lethal Drosophila mutation reduces eclosion rates to approximately 50 percent in homozygous populations</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Nuclear/CytoplasmicRatio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="en-US">nuclear/cytoplasmic ratio</rdfs:label>
    <rdfs:label xml:lang="de">nukleär-zytoplasmatisches Verhältnis</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040071"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Nuclear/cytoplasmic ratio quality relates to the proportion between the nucleus's volume and the cytoplasm's volume in a cell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität des Kern-/Zytoplasma-Verhältnisses bezieht sich auf das Verhältnis zwischen dem Kernvolumen und dem Zytoplasmavolumen in einer Zelle</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'nuclear/cytoplasmic ratio' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040071.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularQuality(x) ← CytoplasmicRatio(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;nuclear/cytoplasmic ratio&apos; then x is a &apos;cellular quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a high nuclear/cytoplasmic ratio in a lymphocyte nucleus occupying most of the cell volume is characteristic of blast cells</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Euploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Ploidy"/>
    <rdfs:label xml:lang="en-US">euploid</rdfs:label>
    <rdfs:label xml:lang="de">euploidie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001393"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Euploid is a quality indicating an integral multiple of the monoploid number within the cellular structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Euploid ist eine Eigenschaft, die ein ganzzahliges Vielfaches der monoploiden Zahl innerhalb der Zellstruktur angibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'euploid' have not yet been formalized. The term is defined as a specific subtype of 'ploidy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001393.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Ploidy(x) ← Euploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;euploid&apos; then x is a &apos;ploidy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a normal human somatic cell with 46 chromosomes arranged as 23 pairs is classified as euploid</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nae06ee5764c54ea0807a5c6e4b19a860">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasQuality"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalRelationalQuality"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pseudohermaphrodite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex"/>
    <rdfs:label xml:lang="de">Pseudohermaphrodit</rdfs:label>
    <rdfs:label xml:lang="en-US">pseudohermaphrodite</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001827"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pseudohermaphrodite quality involves internal organs from one sex and external characteristics from the other sex</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bei der pseudohermaphroditischen Qualität handelt es sich um innere Organe des einen Geschlechts und äußere Merkmale des anderen Geschlechts</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pseudohermaphrodite' have not yet been formalized. The term is defined as a specific subtype of 'phenotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001827.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhenotypicSex(x) ← Pseudohermaphrodite(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pseudohermaphrodite&apos; then x is a &apos;phenotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a genetic male lizard with ovotestes and external female genitalia is classified as a pseudohermaphrodite</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Unipotent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="de">unipotent</rdfs:label>
    <rdfs:label xml:lang="en-US">unipotent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001400"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unipotent quality involves the capacity to produce only one differentiated cell type</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unipotente Qualität beinhaltet die Fähigkeit, nur einen differenzierten Zelltyp zu produzieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unipotent' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001400.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Unipotent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unipotent&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">adult spermatogonial stem cells are unipotent, capable of producing only spermatozoa upon differentiation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Cellularity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Zellularität</rdfs:label>
    <rdfs:label xml:lang="en-US">cellularity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001992"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cellularity describes the characteristic of being composed of one or more cells</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zellularität beschreibt die Eigenschaft, aus einer oder mehreren Zellen zusammengesetzt zu sein</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cellularity' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001992.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Cellularity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cellularity&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">high cellularity of bone marrow biopsy sections indicates an active hematopoietic compartment in a young rat</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Compatibility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Kompatibilität</rdfs:label>
    <rdfs:label xml:lang="en-US">compatibility</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000021"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Compatibility quality encapsulates a harmonious coexistence disposition</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kompatibilitätsqualität fasst ein harmonisches Zusammenleben zusammen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'compatibility' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000021.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← Compatibility(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;compatibility&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">compatibility between donor and host tissues was confirmed by the absence of rejection after skin grafting in mice</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Monoploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Euploid"/>
    <rdfs:label xml:lang="de">monoploid</rdfs:label>
    <rdfs:label xml:lang="en-US">monoploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001376"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Monoploid quality involves a single set of unique homologous chromosomes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bei der monoploiden Qualität handelt es sich um einen einzigen Satz einzigartiger homologer Chromosomen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'monoploid' have not yet been formalized. The term is defined as a specific subtype of 'euploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001376.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Euploid(x) ← Monoploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;monoploid&apos; then x is a &apos;euploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a monoploid barley plant derived from anther culture carries a single set of seven chromosomes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/DeciduousGeneric">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Shedability"/>
    <rdfs:label xml:lang="en-US">deciduous (generic)</rdfs:label>
    <rdfs:label xml:lang="de">laubabwerfend (generisch)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001730"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Deciduous (generic) is a quality indicating a disposition to shed body parts periodically</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Laubabwerfend (generisch) ist eine Eigenschaft, die auf die Neigung hinweist, regelmäßig Körperteile abzuwerfen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'deciduous (generic)' have not yet been formalized. The term is defined as a specific subtype of 'shedability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001730.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shedability(x) ← DeciduousGeneric(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;deciduous (generic)&apos; then x is a &apos;shedability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">deer exhibit deciduous antler quality, shedding and regrowing their antlers each year</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Protandrous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SequentialHermaphrodite"/>
    <rdfs:label xml:lang="de">protandrisch</rdfs:label>
    <rdfs:label xml:lang="en-US">protandrous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040053"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Protandrous quality occurs when organisms begin life as males and transition to females at a later stage</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Protandrische Qualität tritt auf, wenn Organismen ihr Leben als Männchen beginnen und zu einem späteren Zeitpunkt in Weibchen übergehen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'protandrous' have not yet been formalized. The term is defined as a specific subtype of 'sequential hermaphrodite'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040053.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SequentialHermaphrodite(x) ← Protandrous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;protandrous&apos; then x is a &apos;sequential hermaphrodite&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the clownfish Amphiprion percula is protandrous, maturing first as male before transitioning to female</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/TrophicQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="en-US">trophic quality</rdfs:label>
    <rdfs:label xml:lang="de">trophische Qualität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000056"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Trophic quality encompasses an organism's disposition for synthesizing essential organic compounds for growth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die trophische Qualität umfasst die Bereitschaft eines Organismus, essentielle organische Verbindungen für das Wachstum zu synthetisieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'trophic quality' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000056.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← TrophicQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;trophic quality&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">autotrophic quality of Chlamydomonas reinhardtii enables photosynthetic carbon fixation without external organic carbon</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Unicellular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Cellularity"/>
    <rdfs:label xml:lang="de">einzellig</rdfs:label>
    <rdfs:label xml:lang="en-US">unicellular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001994"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unicellular quality describes the state of consisting of exactly one cell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Einzellerqualität beschreibt den Zustand, aus genau einer Zelle zu bestehen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unicellular' have not yet been formalized. The term is defined as a specific subtype of 'cellularity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001994.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cellularity(x) ← Unicellular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unicellular&apos; then x is a &apos;cellularity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Saccharomyces cerevisiae grown under standard liquid culture conditions is a unicellular organism</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehaviouralInactive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehaviouralActivity"/>
    <rdfs:label xml:lang="en-US">behavioural inactive</rdfs:label>
    <rdfs:label xml:lang="de">verhaltensinaktiv</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001706"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Behavioural inactive is a quality representing the disposition to lack activity, indicating dormancy or passivity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Inaktives Verhalten ist eine Eigenschaft, die die Neigung zu mangelnder Aktivität darstellt und auf Ruhe oder Passivität hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'behavioural inactive' have not yet been formalized. The term is defined as a specific subtype of 'behavioural activity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001706.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehaviouralActivity(x) ← BehaviouralInactive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;behavioural inactive&apos; then x is a &apos;behavioural activity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a behavioural inactive ground squirrel during winter hibernation shows minimal locomotor and metabolic activity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Lebensfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">viability</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000169"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Viability quality describes the capability to survive and develop normally, or represents the number of surviving individuals within a population</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Lebensfähigkeitsqualität beschreibt die Fähigkeit, normal zu überleben und sich zu entwickeln, oder stellt die Anzahl der überlebenden Individuen innerhalb einer Population dar</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'viability' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000169.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Viability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;viability&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">viability of stored seed lots is assessed by germination rate after three years of cold storage</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Ciliatedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="de">Zilienigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">ciliatedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001408"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ciliatedness is a quality manifests as thin, tail-like projections extending from the cell body</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bewimperung ist eine Eigenschaft, die sich als dünne, schwanzartige Vorsprünge manifestiert, die vom Zellkörper ausgehen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ciliatedness' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001408.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularQuality(x) ← Ciliatedness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ciliatedness&apos; then x is a &apos;cellular quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Paramecium caudatum exhibits ciliatedness with thousands of cilia covering the cell surface for motility and feeding</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Haplodiploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Diploid"/>
    <rdfs:label xml:lang="de">Haplodiploidie</rdfs:label>
    <rdfs:label xml:lang="en-US">haplodiploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001395"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Haplodiploid quality identifies species in which one sex has haploid cells and the other has diploid cells</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die haplodiploide Qualität identifiziert Arten, bei denen ein Geschlecht haploide Zellen und das andere diploide Zellen hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'haplodiploid' have not yet been formalized. The term is defined as a specific subtype of 'diploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001395.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Diploid(x) ← Haplodiploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;haplodiploid&apos; then x is a &apos;diploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">in the honeybee Apis mellifera, females are diploid and males are haploid, defining its haplodiploid system</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en-US">viable</rdfs:label>
    <rdfs:label xml:lang="de">überlebensfähig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000719"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Viable quality indicates an organism’s ability for long-term survival or enduring survival in a population</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die lebensfähige Qualität gibt die Fähigkeit eines Organismus zum langfristigen Überleben oder dauerhaften Überleben in einer Population an</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'viable' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000719.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← Viable(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;viable&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">viable embryos at the blastocyst stage are selected for transfer based on morphology and cell number</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Balance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">ausbalanciert</rdfs:label>
    <rdfs:label xml:lang="en-US">balance</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000185"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Balance is a behavioral quality reflecting the physical steadiness of an organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gleichgewicht ist eine Verhaltensqualität, die die körperliche Stabilität eines Organismus widerspiegelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'balance' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000185.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← Balance(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;balance&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">balance in a rat is measured by the latency to fall from an elevated narrow beam test</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularAdhesivity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="en-US">cellular adhesivity</rdfs:label>
    <rdfs:label xml:lang="de">zelluläre Adhäsivität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001531"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cellular adhesivity is a quality pertaining to a cell's disposition to adhere to adjacent cells or extracellular molecules</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zelladhäsivität ist eine Eigenschaft, die sich auf die Neigung einer Zelle bezieht, an benachbarte Zellen oder extrazelluläre Moleküle zu haften</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cellular adhesivity' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001531.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularQuality(x) ← CellularAdhesivity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cellular adhesivity&apos; then x is a &apos;cellular quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">high cellular adhesivity in metastatic breast cancer cells promotes attachment to endothelial layers during extravasation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Incompatible">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Compatibility"/>
    <rdfs:label xml:lang="en-US">incompatible</rdfs:label>
    <rdfs:label xml:lang="de">nicht kompatibel</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000345"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Incompatible quality represents an incapability for harmonious coexistence</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Inkompatible Qualität stellt eine Unfähigkeit für ein harmonisches Zusammenleben dar</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'incompatible' have not yet been formalized. The term is defined as a specific subtype of 'compatibility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000345.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Compatibility(x) ← Incompatible(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;incompatible&apos; then x is a &apos;compatibility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">ABO blood group incompatible transfusion triggers complement-mediated hemolysis within minutes of infusion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Juvenile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="de">jugendlich</rdfs:label>
    <rdfs:label xml:lang="en-US">juvenile</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001190"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Juvenile maturity quality is identified by the bearer’s state of being not fully grown or developed</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Jugendreife wird dadurch identifiziert, dass der Träger noch nicht vollständig ausgewachsen oder entwickelt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'juvenile' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001190.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Juvenile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;juvenile&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a juvenile zebrafish at 14 days post-fertilization displays adult pigmentation but has not yet reached sexual maturity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Anucleate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/NucleateQuality"/>
    <rdfs:label xml:lang="en-US">anucleate</rdfs:label>
    <rdfs:label xml:lang="de">anukleat</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001405"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Anucleate is a quality describing a cell lacking a nucleus, manifesting as a subtype of nucleate deficiency</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Anukleat ist eine Eigenschaft, die eine Zelle ohne Zellkern beschreibt und sich als Subtyp des Zellkernmangels manifestiert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'anucleate' have not yet been formalized. The term is defined as a specific subtype of 'nucleate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001405.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">NucleateQuality(x) ← Anucleate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;anucleate&apos; then x is a &apos;nucleate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">mature mammalian red blood cells are anucleate, having expelled their nuclei during terminal erythropoiesis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Verhaltensqualität</rdfs:label>
    <rdfs:label xml:lang="en-US">behavioral quality</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000186"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Behavioral quality denotes the aggregate of responses, reactions, or movements exhibited in a specific context</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verhaltensqualität bezeichnet die Gesamtheit der Reaktionen, Reaktionen oder Bewegungen, die in einem bestimmten Kontext gezeigt werden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'behavioral quality' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000186.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← BehavioralQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;behavioral quality&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">increased grooming frequency as a behavioral quality in mice can indicate anxiety or skin irritation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleReceptivity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Receptivity"/>
    <rdfs:label xml:lang="en-US">female receptivity</rdfs:label>
    <rdfs:label xml:lang="de">weibliche Empfänglichkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001720"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female receptivity reflects the extent of a female's responsiveness to male advances</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die weibliche Empfänglichkeit spiegelt das Ausmaß der Reaktionsfähigkeit einer Frau auf männliche Annäherungsversuche wider</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female receptivity' have not yet been formalized. The term is defined as a specific subtype of 'receptivity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001720.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Receptivity(x) ← FemaleReceptivity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female receptivity&apos; then x is a &apos;receptivity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">female receptivity in Drosophila melanogaster is quantified by copulation latency with courting males</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SemiFertile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertility"/>
    <rdfs:label xml:lang="de">halbfruchtbar</rdfs:label>
    <rdfs:label xml:lang="en-US">semi-fertile</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001767"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Semi-fertile quality reflects partial fertility</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Halbfruchtbarkeit spiegelt die Teilfruchtbarkeit wider</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'semi-fertile' have not yet been formalized. The term is defined as a specific subtype of 'fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001767.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fertility(x) ← SemiFertile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;semi-fertile&apos; then x is a &apos;fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a semi-fertile Arabidopsis mutant produces approximately half the normal seed count per silique</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/IntactMale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Male"/>
    <rdfs:label xml:lang="en-US">intact male</rdfs:label>
    <rdfs:label xml:lang="de">intakter Mann</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002366"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Intact male quality indicates possessing complete, unaltered reproductive organs</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Intakte männliche Eigenschaften weisen auf den Besitz vollständiger, unveränderter Fortpflanzungsorgane hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'intact male' have not yet been formalized. The term is defined as a specific subtype of 'male'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002366.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Male(x) ← IntactMale(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;intact male&apos; then x is a &apos;male&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an intact male rat retains both testes and shows normal testosterone-driven territorial behavior</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Prepupal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="de">Vorpuppe</rdfs:label>
    <rdfs:label xml:lang="en-US">prepupal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001188"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Prepupal quality describes being in an inactive development stage between larval and pupal phases</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Präpuppenqualität beschreibt den Zustand einer inaktiven Entwicklungsphase zwischen der Larven- und der Puppenphase</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'prepupal' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001188.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Prepupal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;prepupal&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Drosophila larvae enter the prepupal stage when they cease feeding and form the white prepupa before pupariation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Neonatal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="de">neonatal</rdfs:label>
    <rdfs:label xml:lang="en-US">neonatal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002206"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Neonatal maturity quality signifies the period surrounding birth, immediately before or after</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Neugeborenenreife bezeichnet den Zeitraum rund um die Geburt, unmittelbar davor oder danach</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'neonatal' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002206.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Neonatal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;neonatal&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">neonatal mice in the first 24 hours after birth are assessed for reflex development and body weight</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Diandrous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex"/>
    <rdfs:label xml:lang="en-US">diandrous</rdfs:label>
    <rdfs:label xml:lang="de">zweidamig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040050"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Diandrous is a quality defines a plant structure in which flowers contain two stamens</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Diandrous ist eine Eigenschaft, die eine Pflanzenstruktur definiert, bei der Blüten zwei Staubblätter enthalten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'diandrous' have not yet been formalized. The term is defined as a specific subtype of 'phenotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040050.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhenotypicSex(x) ← Diandrous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;diandrous&apos; then x is a &apos;phenotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Veronica officinalis is a diandrous plant with flowers containing exactly two functional stamens</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleSemiFertile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SemiFertile"/>
    <rdfs:label xml:lang="en-US">male semi-fertile</rdfs:label>
    <rdfs:label xml:lang="de">männlich halbfruchtbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001761"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male semi-fertile quality indicates a male’s partial capability for reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der männlichen Halbfruchtbarkeit weist auf die teilweise Fortpflanzungsfähigkeit eines Mannes hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male semi-fertile' have not yet been formalized. The term is defined as a specific subtype of 'semi-fertile'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001761.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SemiFertile(x) ← MaleSemiFertile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male semi-fertile&apos; then x is a &apos;semi fertile&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a male Drosophila producing spermatids but failing to fully mature them shows male semi-fertile quality</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ProtandrousHermaphroditism">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Protandrous"/>
    <rdfs:label xml:lang="de">protandrischer Hermaphroditismus</rdfs:label>
    <rdfs:label xml:lang="en-US">protandrous hermaphroditism</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040055"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Protandrous hermaphroditism involves organisms starting as male and becoming hermaphroditic over time</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beim protandrischen Hermaphroditismus beginnen Organismen als Männer und entwickeln sich mit der Zeit zu Hermaphroditen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'protandrous hermaphroditism' have not yet been formalized. The term is defined as a specific subtype of 'protandrous'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040055.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Protandrous(x) ← ProtandrousHermaphroditism(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;protandrous hermaphroditism&apos; then x is a &apos;protandrous&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the slipper limpet Crepidula fornicata exhibits protandrous hermaphroditism, starting as male then becoming hermaphroditic</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductiveQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="en-US">reproductive quality</rdfs:label>
    <rdfs:label xml:lang="de">reproduktive Qualität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001434"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Reproductive quality encapsulates the ability to produce offspring or new life forms</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Reproduktionsqualität umfasst die Fähigkeit, Nachkommen oder neue Lebensformen hervorzubringen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'reproductive quality' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001434.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← ReproductiveQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;reproductive quality&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">elevated reproductive quality in farmed salmon is measured by egg number and fertilization success per spawning</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleWithDsd">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex"/>
    <rdfs:label xml:lang="en-US">male with dsd</rdfs:label>
    <rdfs:label xml:lang="de">männlich mit dsd</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040049"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male with dsd quality pertains to males having ambiguous or atypical congenital development of reproductive systems</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Männer mit DSD-Qualität beziehen sich auf Männer mit einer unklaren oder atypischen angeborenen Entwicklung des Fortpflanzungssystems</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male with dsd' have not yet been formalized. The term is defined as a specific subtype of 'phenotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040049.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhenotypicSex(x) ← MaleWithDsd(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male with dsd&apos; then x is a &apos;phenotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a 46,XX individual with congenital adrenal hyperplasia may be recorded as male with dsd in clinical databases</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Arboreal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="en-US">arboreal</rdfs:label>
    <rdfs:label xml:lang="de">baumlebend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095004"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Arboreal is a quality characterizes organisms adapted for life within trees through specific morphological and physiological traits</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Baumart ist eine Eigenschaft, die Organismen charakterisiert, die durch spezifische morphologische und physiologische Merkmale an das Leben in Bäumen angepasst sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'arboreal' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095004.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Arboreal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;arboreal&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the red-eyed tree frog Agalychnis callidryas has arboreal quality, with adhesive toe pads for canopy locomotion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BroodSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BroodQuality"/>
    <rdfs:label xml:lang="de">Brutgröße</rdfs:label>
    <rdfs:label xml:lang="en-US">brood size</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000276"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Brood size describes the reproductive quality relating to the number of offspring cared for at one time</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Brutgröße beschreibt die Fortpflanzungsqualität bezogen auf die Anzahl der gleichzeitig betreuten Nachkommen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'brood size' have not yet been formalized. The term is defined as a specific subtype of 'brood quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000276.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BroodQuality(x) ← BroodSize(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;brood size&apos; then x is a &apos;brood quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the average brood size of a C57BL/6 mouse litter is 6 to 8 pups under standard housing conditions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertility"/>
    <rdfs:label xml:lang="en-US">fertile</rdfs:label>
    <rdfs:label xml:lang="de">fruchtbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000955"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Fertile quality represents the capability to initiate, sustain, or support reproduction in the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Fruchtbare Qualität stellt die Fähigkeit dar, die Fortpflanzung des Trägers zu initiieren, aufrechtzuerhalten oder zu unterstützen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fertile' have not yet been formalized. The term is defined as a specific subtype of 'fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000955.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fertility(x) ← Fertile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fertile&apos; then x is a &apos;fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a fertile male zebrafish produces viable sperm capable of fertilizing oocytes in in vitro fertilization assays</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleReceptivity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Receptivity"/>
    <rdfs:label xml:lang="en-US">male receptivity</rdfs:label>
    <rdfs:label xml:lang="de">männliche Empfänglichkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001721"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male receptivity reflects the extent to which a male is susceptible to female advances</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die männliche Empfänglichkeit spiegelt das Ausmaß wider, in dem ein Mann für weibliche Annäherungsversuche empfänglich ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male receptivity' have not yet been formalized. The term is defined as a specific subtype of 'receptivity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001721.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Receptivity(x) ← MaleReceptivity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male receptivity&apos; then x is a &apos;receptivity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">male receptivity in Drosophila is measured as the proportion of males that copulate when presented with receptive females</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Trisomy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Aneuploid"/>
    <rdfs:label xml:lang="de">Trisomie</rdfs:label>
    <rdfs:label xml:lang="en-US">trisomy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001389"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Trisomy quality signifies the possession of three chromosomes of a particular numbered type instead of two</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Trisomie-Qualität versteht man den Besitz von drei statt zwei Chromosomen eines bestimmten nummerierten Typs</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'trisomy' have not yet been formalized. The term is defined as a specific subtype of 'aneuploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001389.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Aneuploid(x) ← Trisomy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;trisomy&apos; then x is a &apos;aneuploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">trisomy 21 in Homo sapiens results in three copies of chromosome 21 and causes Down syndrome</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BangSensitive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="en-US">bang sensitive</rdfs:label>
    <rdfs:label xml:lang="de">knallempfindlich</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000759"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Bang sensitive is a quality describing the bearer’s proclivity for experiencing paralysis in response to mechanical shock</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Knallempfindlichkeit ist eine Eigenschaft, die die Neigung des Trägers beschreibt, als Reaktion auf einen mechanischen Schock eine Lähmung zu erleiden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bang sensitive' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000759.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← BangSensitive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bang sensitive&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">bang sensitive Drosophila mutants fall into paralysis when the culture vial is struck sharply against a surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Disomy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Aneuploid"/>
    <rdfs:label xml:lang="de">Disomie</rdfs:label>
    <rdfs:label xml:lang="en-US">disomy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001387"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Disomy is a quality reflecting having two chromosomes from a pair in a cell's nucleus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Disomie ist eine Eigenschaft, die darauf hinweist, dass sich im Zellkern zwei Chromosomen eines Paares befinden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'disomy' have not yet been formalized. The term is defined as a specific subtype of 'aneuploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001387.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Aneuploid(x) ← Disomy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;disomy&apos; then x is a &apos;aneuploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">normal somatic cells of Homo sapiens exhibit disomy for autosomes, carrying two copies of each chromosome</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FMinusMatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BacterialMatingType"/>
    <rdfs:label xml:lang="de">f Minus Paarungstyp</rdfs:label>
    <rdfs:label xml:lang="en-US">f minus mating type</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001348"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">F Minus mating type indicates the absence of the F plasmid in a bacterial cell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der F-Minus-Paarungstyp zeigt das Fehlen des F-Plasmids in einer Bakterienzelle an</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'f minus mating type' have not yet been formalized. The term is defined as a specific subtype of 'bacterial mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001348.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BacterialMatingType(x) ← FMinusMatingType(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;f minus mating type&apos; then x is a &apos;bacterial mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an F minus Escherichia coli cell lacks the F plasmid and acts as recipient in conjugation experiments</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MatingTypeYeast">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SaccharomycesCerevisiaeMatingType"/>
    <rdfs:label xml:lang="en-US">a mating type (yeast)</rdfs:label>
    <rdfs:label xml:lang="de">hefeartige Paarung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001341"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mating type 'a' in yeast involves cells that secrete pheromones to facilitate mating processes with alpha haploid cells</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beim Paarungstyp „a“ in Hefe handelt es sich um Zellen, die Pheromone absondern, um Paarungsprozesse mit alpha-haploiden Zellen zu erleichtern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'a mating type (yeast)' have not yet been formalized. The term is defined as a specific subtype of 'saccharomyces cerevisiae mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001341.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SaccharomycesCerevisiaeMatingType(x) ← MatingTypeYeast(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;a mating type (yeast)&apos; then x is a &apos;saccharomyces cerevisiae mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Saccharomyces cerevisiae a mating type cells secrete a-factor pheromone to attract alpha mating type partners</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Anecic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Anecic</rdfs:label>
    <rdfs:label xml:lang="en-US">anecic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095009"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Anecic is an organismal quality represents the capability to create deep soil burrows and maintain stable vertical tunnels beyond 20 cm</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Anecic ist eine Organismenqualität, die die Fähigkeit verkörpert, tiefe Erdhöhlen zu schaffen und stabile vertikale Tunnel über 20 cm aufrechtzuerhalten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'anecic' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095009.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Anecic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;anecic&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the earthworm Lumbricus terrestris is anecic, constructing permanent vertical burrows deeper than 20 cm in agricultural soil</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Reife</rdfs:label>
    <rdfs:label xml:lang="en-US">maturity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000261"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Maturity quality represents a growth, differentiation, or developmental state exhibited by the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Reifequalität stellt einen Wachstums-, Differenzierungs- oder Entwicklungszustand dar, den der Träger zeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'maturity' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000261.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Maturity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;maturity&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">full maturity of Atlantic salmon is signaled by gonadal development and readiness to spawn in freshwater</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Metaplastic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="en-US">metaplastic</rdfs:label>
    <rdfs:label xml:lang="de">metaplastisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002101"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Metaplastic quality involves a shift from one fully differentiated cell state to another</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bei der metaplastischen Qualität handelt es sich um einen Übergang von einem vollständig differenzierten Zellzustand zu einem anderen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'metaplastic' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002101.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Metaplastic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;metaplastic&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">metaplastic transformation of esophageal squamous epithelium into columnar epithelium defines Barrett esophagus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/LackOfFertilityInOffspring">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertility"/>
    <rdfs:label xml:lang="de">Unfruchtbarkeit des Nachwuchses</rdfs:label>
    <rdfs:label xml:lang="en-US">lack of fertility in offspring</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001862"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Lack of fertility in offspring quality reflects the disposition leading to sterility in the offspring produced</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mangelnde Fruchtbarkeit in der Qualität der Nachkommen spiegelt die Veranlagung wider, die zur Unfruchtbarkeit der Nachkommen führt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lack of fertility in offspring' have not yet been formalized. The term is defined as a specific subtype of 'fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001862.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fertility(x) ← LackOfFertilityInOffspring(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lack of fertility in offspring&apos; then x is a &apos;fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a hybrid mule exhibits lack of fertility in offspring quality due to chromosomal incompatibility between horse and donkey</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Allopolyploidy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="de">Allopolyploidie</rdfs:label>
    <rdfs:label xml:lang="en-US">allopolyploidy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001379"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Allopolyploidy is a feature characterizing a polyploid organism possessing chromosomes from multiple distinct species</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Allopolyploidie ist ein Merkmal, das einen polyploiden Organismus charakterisiert, der Chromosomen mehrerer verschiedener Arten besitzt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'allopolyploidy' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001379.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Allopolyploidy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;allopolyploidy&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">bread wheat Triticum aestivum is allopolyploid, combining genomes from three ancestral diploid species</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Oligopotent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="de">oligopotent</rdfs:label>
    <rdfs:label xml:lang="en-US">oligopotent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001401"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Oligopotent quality refers to cellular capacity to differentiate into multiple cell types of a specific lineage, lacking self-renewing ability</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter oligopotenter Qualität versteht man die zelluläre Fähigkeit, sich in mehrere Zelltypen einer bestimmten Abstammungslinie zu differenzieren, wobei die Fähigkeit zur Selbsterneuerung fehlt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'oligopotent' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001401.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Oligopotent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;oligopotent&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a myeloid progenitor cell is oligopotent, producing only granulocytes, monocytes, and related lineages</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FMatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BacterialMatingType"/>
    <rdfs:label xml:lang="de">f Paarungstyp</rdfs:label>
    <rdfs:label xml:lang="en-US">f mating type</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001347"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">F mating type denotes the presence of the F plasmid within a bacterial cell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der F-Paarungstyp bezeichnet das Vorhandensein des F-Plasmids in einer Bakterienzelle</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'f mating type' have not yet been formalized. The term is defined as a specific subtype of 'bacterial mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001347.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BacterialMatingType(x) ← FMatingType(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;f mating type&apos; then x is a &apos;bacterial mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an F+ Escherichia coli cell carries the F plasmid and can donate genetic material to F minus cells during conjugation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Aversion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Preference"/>
    <rdfs:label xml:lang="de">Abneigung</rdfs:label>
    <rdfs:label xml:lang="en-US">aversion</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000771"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Aversion is a preference quality characterized by a conscious disliking of a perceived stimulus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Aversion ist eine Präferenzqualität, die durch eine bewusste Abneigung gegen einen wahrgenommenen Reiz gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'aversion' have not yet been formalized. The term is defined as a specific subtype of 'preference'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000771.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Preference(x) ← Aversion(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;aversion&apos; then x is a &apos;preference&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">mice show aversion to open brightly lit areas in the open field test, preferring peripheral zones</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BroodQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductiveQuality"/>
    <rdfs:label xml:lang="de">Brutqualität</rdfs:label>
    <rdfs:label xml:lang="en-US">brood quality</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001496"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Brood quality denotes a reproductive trait characterized by the level of care provided to offspring</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Brutqualität versteht man ein Fortpflanzungsmerkmal, das durch den Grad der Fürsorge für die Nachkommen gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'brood quality' have not yet been formalized. The term is defined as a specific subtype of 'reproductive quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001496.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ReproductiveQuality(x) ← BroodQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;brood quality&apos; then x is a &apos;reproductive quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">high brood quality in honeybee colonies is reflected by uniform capping and absence of sunken cell caps</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/EvergreenPlant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Shedability"/>
    <rdfs:label xml:lang="en-US">evergreen (plant)</rdfs:label>
    <rdfs:label xml:lang="de">immergrüne Pflanze</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001733"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Evergreen (plant) is a quality denoting the disposition to retain foliage year-round</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Immergrün (Pflanze) ist eine Eigenschaft, die die Neigung bezeichnet, das Laub das ganze Jahr über zu behalten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'evergreen (plant)' have not yet been formalized. The term is defined as a specific subtype of 'shedability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001733.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shedability(x) ← EvergreenPlant(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;evergreen (plant)&apos; then x is a &apos;shedability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Pinus sylvestris displays evergreen quality, retaining needle-like leaves throughout the year</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N54d65823b2904b1cab3d945c7a633070">
    <rdf:first rdf:nodeID="Nce09b7152458430094339b138901b986"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GenotypicSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalSex"/>
    <rdfs:label xml:lang="en-US">genotypic sex</rdfs:label>
    <rdfs:label xml:lang="de">genotypisches Geschlecht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0020000"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Genotypic sex quality describes the genetic composition of sex chromosomes that determine an organism's sex</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die genotypische Geschlechtsqualität beschreibt die genetische Zusammensetzung der Geschlechtschromosomen, die das Geschlecht eines Organismus bestimmen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'genotypic sex' have not yet been formalized. The term is defined as a specific subtype of 'biological sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0020000.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalSex(x) ← GenotypicSex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;genotypic sex&apos; then x is a &apos;biological sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">XX genotypic sex in mice is determined by the absence of the Sry gene on the Y chromosome</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SaccharomycesCerevisiaeMatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/YeastMatingType"/>
    <rdfs:label xml:lang="de">Saccharomyces Cerevisiae Paarungstyp</rdfs:label>
    <rdfs:label xml:lang="en-US">saccharomyces cerevisiae mating type</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001342"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saccharomyces cerevisiae mating type identifies specific reproductive cell types in yeast</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Paarungstyp von Saccharomyces cerevisiae identifiziert bestimmte reproduktive Zelltypen in Hefe</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saccharomyces cerevisiae mating type' have not yet been formalized. The term is defined as a specific subtype of 'yeast mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001342.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">YeastMatingType(x) ← SaccharomycesCerevisiaeMatingType(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saccharomyces cerevisiae mating type&apos; then x is a &apos;yeast mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Saccharomyces cerevisiae MATa and MATalpha strains are distinguished by their saccharomyces cerevisiae mating type loci</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Mononucleate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Nucleated"/>
    <rdfs:label xml:lang="en-US">mononucleate</rdfs:label>
    <rdfs:label xml:lang="de">mononukleär</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001407"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mononucleate quality is characterized by having a singular nucleus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die einkernige Qualität zeichnet sich durch einen singulären Kern aus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mononucleate' have not yet been formalized. The term is defined as a specific subtype of 'nucleated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001407.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Nucleated(x) ← Mononucleate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mononucleate&apos; then x is a &apos;nucleated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">mature hepatocytes in young rodents are predominantly mononucleate, each containing a single nucleus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OvariectomizedFemale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleSterile"/>
    <rdfs:label xml:lang="en-US">ovariectomized female</rdfs:label>
    <rdfs:label xml:lang="de">ovariektomierte Frau</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002380"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ovariectomized female quality describes infertility due to surgical removal of ovaries</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der ovarektomierten Frau beschreibt Unfruchtbarkeit aufgrund der chirurgischen Entfernung der Eierstöcke</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ovariectomized female' have not yet been formalized. The term is defined as a specific subtype of 'female sterile'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002380.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">FemaleSterile(x) ← OvariectomizedFemale(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ovariectomized female&apos; then x is a &apos;female sterile&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an ovariectomized female rat lacks circulating estrogens and serves as a postmenopausal model in pharmacology studies</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ModeratelyWellDifferentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Differentiated"/>
    <rdfs:label xml:lang="en-US">moderately well differentiated</rdfs:label>
    <rdfs:label xml:lang="de">mäßig gut differenziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002111"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Moderately well differentiated denotes cells lacking few of the cellular characteristics necessary for full differentiation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mäßig gut differenziert bezeichnet Zellen, denen einige der für eine vollständige Differenzierung erforderlichen Zellmerkmale fehlen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'moderately well differentiated' have not yet been formalized. The term is defined as a specific subtype of 'differentiated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002111.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Differentiated(x) ← ModeratelyWellDifferentiated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;moderately well differentiated&apos; then x is a &apos;differentiated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a moderately well differentiated colorectal adenocarcinoma retains partial glandular architecture visible under light microscopy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Sterile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertility"/>
    <rdfs:label xml:lang="en-US">sterile</rdfs:label>
    <rdfs:label xml:lang="de">unfruchtbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000956"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sterile quality reflects inability to initiate, sustain, or support reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Sterilität spiegelt die Unfähigkeit wider, die Fortpflanzung einzuleiten, aufrechtzuerhalten oder zu unterstützen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sterile' have not yet been formalized. The term is defined as a specific subtype of 'fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000956.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fertility(x) ← Sterile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sterile&apos; then x is a &apos;fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a sterile worker honeybee never produces eggs under normal colony conditions due to reproductive suppression by the queen</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Euploid"/>
    <rdfs:label xml:lang="en-US">polyploid</rdfs:label>
    <rdfs:label xml:lang="de">polyploidie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001377"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Polyploid quality involves possessing more than two homologous sets of chromosomes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Polyploide Qualität bedeutet, dass mehr als zwei homologe Chromosomensätze vorhanden sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'polyploid' have not yet been formalized. The term is defined as a specific subtype of 'euploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001377.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Euploid(x) ← Polyploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;polyploid&apos; then x is a &apos;euploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Xenopus laevis is a polyploid frog with four sets of chromosomes arising from ancient genome duplication</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb0c0f019f708479a800fa1e5e212e852">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="N8710a39c0392454db98f55505d6322ac"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehaviouralActive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehaviouralActivity"/>
    <rdfs:label xml:lang="en-US">behavioural active</rdfs:label>
    <rdfs:label xml:lang="de">verhaltensaktiv</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001707"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Behavioural active is a quality manifested through significant activity demonstrated by the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verhaltensaktiv ist eine Eigenschaft, die sich durch erhebliche Aktivität des Trägers manifestiert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'behavioural active' have not yet been formalized. The term is defined as a specific subtype of 'behavioural activity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001707.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehaviouralActivity(x) ← BehaviouralActive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;behavioural active&apos; then x is a &apos;behavioural activity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a behavioural active Drosophila line shows significantly more spontaneous locomotion than wild-type controls in open arena tests</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202507/qualities/Qualities-Biological/"/>
    <owl:versionInfo>202507</owl:versionInfo>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <dcterms:abstract xml:lang="en-us">The IOF Biological Qualities Ontology aims to represent the generic constructs (including classes and properties) related to biological qualities.</dcterms:abstract>
    <dcterms:contributor xml:lang="en-us">Thomas Hanke, Fraunhofer IWM</dcterms:contributor>
    <dcterms:creator xml:lang="en-us">IOF Materials Working Group</dcterms:creator>
    <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
    <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
    <dcterms:references rdf:resource="http://spec.org/dc/terms/"/>
    <dcterms:references rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    <dcterms:title xml:lang="en-us">Industrial Ontology Foundry (IOF) Biological Qualities Ontology</dcterms:title>
    <rdfs:label xml:lang="en-us">Biological Qualities Ontology</rdfs:label>
    <iof-av:copyright>Industrial Ontology Foundry (IOF)</iof-av:copyright>
    <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalSex"/>
    <rdfs:label xml:lang="de">Geschlechtstypen</rdfs:label>
    <rdfs:label xml:lang="en-US">mating type</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001895"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mating type quality characterizes the sexual reproduction potential in an individual or a population</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität des Paarungstyps charakterisiert das sexuelle Fortpflanzungspotenzial eines Individuums oder einer Population</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mating type' have not yet been formalized. The term is defined as a specific subtype of 'biological sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001895.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalSex(x) ← MatingType(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mating type&apos; then x is a &apos;biological sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">conjugation between opposite mating types of Tetrahymena thermophila requires recognition of cell surface glycoproteins</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Protogynous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SequentialHermaphrodite"/>
    <rdfs:label xml:lang="de">protogynisch</rdfs:label>
    <rdfs:label xml:lang="en-US">protogynous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040052"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Protogynous quality identifies organisms that start life as females and transition to males</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die protogyne Qualität identifiziert Organismen, die ihr Leben als Weibchen beginnen und zu Männchen übergehen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'protogynous' have not yet been formalized. The term is defined as a specific subtype of 'sequential hermaphrodite'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040052.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SequentialHermaphrodite(x) ← Protogynous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;protogynous&apos; then x is a &apos;sequential hermaphrodite&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the blueheaded wrasse Thalassoma bifasciatum is protogynous, beginning reproductive life as female before becoming male</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Alive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en-US">alive</rdfs:label>
    <rdfs:label xml:lang="de">lebendig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001421"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Alive is a viability status reflecting a viability quality wherein the bearer is conditionally existent prior to the cessation of life</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Lebendig ist ein Lebensfähigkeitsstatus, der eine Lebensfähigkeitsqualität widerspiegelt, bei der der Träger vor dem Ende des Lebens bedingt existiert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'alive' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001421.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← Alive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;alive&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an alive Caenorhabditis elegans worm at 72 hours post-hatching moves spontaneously and responds to touch stimuli</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N909ae554adf94737bdaf7ac73a9e8618">
    <rdf:first rdf:nodeID="Nae06ee5764c54ea0807a5c6e4b19a860"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Immortal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en-US">immortal</rdfs:label>
    <rdfs:label xml:lang="de">unsterblich</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001991"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Immortal quality involves the disposition to possess indefinite growth and division capabilities</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zur unsterblichen Qualität gehört die Bereitschaft, über unbegrenzte Wachstums- und Teilungsfähigkeiten zu verfügen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'immortal' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001991.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← Immortal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;immortal&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">HeLa cells exhibit immortal quality, having undergone continuous division in laboratory culture since 1951</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalAction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <owl:equivalentClass rdf:nodeID="Nb0c0f019f708479a800fa1e5e212e852"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Action"/>
    <rdfs:label xml:lang="en-US">biological action</rdfs:label>
    <rdfs:label xml:lang="de">biologische Aktion</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biological action represents a stimulus enacting a biological interaction with an object</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine biologische Aktion stellt einen Reiz dar, der eine biologische Interaktion mit einem Objekt auslöst</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en-US">BiologicalAction(x) ↔ (∃b ((obo:BFO_0000040(b) ∧ ∃c (BiologicalRelationalQuality(c) ∧ hasQuality(b, c))) ∧ obo:BFO_0000057(x, b)) ∨ ∃d (BiologicProcessCharacteristic(d) ∧ hasProcessCharacteristic(x, d)))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-US">every instance of 'biological action' is defined as exactly an instance of 'that 'obo:BFO_0000057' some an instance of 'BFO_0000040' and that 'hasQuality' some 'biological relational quality'' or 'that 'hasProcessCharacteristic' some 'biologic process characteristic''</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Discrimination">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Diskriminierung</rdfs:label>
    <rdfs:label xml:lang="en-US">discrimination</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000189"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Discrimination is a quality referring to the ability to discern between different stimuli</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Diskriminierung versteht man die Fähigkeit, zwischen verschiedenen Reizen zu unterscheiden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'discrimination' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000189.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← Discrimination(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;discrimination&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">rats show discrimination quality by choosing a novel object over a familiar one in the novel object recognition test</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Herbaceous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Shedability"/>
    <rdfs:label xml:lang="en-US">herbaceous</rdfs:label>
    <rdfs:label xml:lang="de">krautartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002352"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Herbaceous quality describes the dieback of plant upper parts to the rootstock at the conclusion of the growing season</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter krautiger Qualität versteht man das Absterben der Pflanzenoberteile bis zum Wurzelstock am Ende der Vegetationsperiode</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'herbaceous' have not yet been formalized. The term is defined as a specific subtype of 'shedability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002352.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shedability(x) ← Herbaceous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;herbaceous&apos; then x is a &apos;shedability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Arabidopsis thaliana has herbaceous quality, with above-ground parts dying back to the rootstock after seed set</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PoorlyDifferentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Differentiated"/>
    <rdfs:label xml:lang="en-US">poorly differentiated</rdfs:label>
    <rdfs:label xml:lang="de">schlecht differenziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002106"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Poorly differentiated quality reflects lacking most cellular characteristics necessary for full differentiation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine schlecht differenzierte Qualität spiegelt das Fehlen der meisten Zellmerkmale wider, die für eine vollständige Differenzierung erforderlich sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'poorly differentiated' have not yet been formalized. The term is defined as a specific subtype of 'differentiated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002106.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Differentiated(x) ← PoorlyDifferentiated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;poorly differentiated&apos; then x is a &apos;differentiated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a poorly differentiated pancreatic adenocarcinoma lacks recognizable acinar or ductal structures in histological sections</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/YeastMatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MatingType"/>
    <rdfs:label xml:lang="de">hefeartige Befruchtung</rdfs:label>
    <rdfs:label xml:lang="en-US">yeast mating type</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001337"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Yeast mating type describes distinctions among the reproductive cell types in yeast</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Hefepaarungstyp beschreibt die Unterschiede zwischen den reproduktiven Zelltypen in Hefen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'yeast mating type' have not yet been formalized. The term is defined as a specific subtype of 'mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001337.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MatingType(x) ← YeastMatingType(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;yeast mating type&apos; then x is a &apos;mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">yeast mating type in Saccharomyces cerevisiae is determined by the allele present at the MAT locus on chromosome III</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleSemiFertile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SemiFertile"/>
    <rdfs:label xml:lang="en-US">female semi-fertile</rdfs:label>
    <rdfs:label xml:lang="de">weiblich halbfruchtbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001760"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female semi-fertile quality indicates partial ability for reproduction in females</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der weiblichen Halbfruchtbarkeit weist auf eine teilweise Fortpflanzungsfähigkeit der Weibchen hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female semi-fertile' have not yet been formalized. The term is defined as a specific subtype of 'semi-fertile'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001760.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SemiFertile(x) ← FemaleSemiFertile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female semi-fertile&apos; then x is a &apos;semi fertile&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a female Drosophila mutant laying only 30 percent of wild-type egg numbers is classified as female semi-fertile</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Na1210685e26a423d9fdec2bc24e86e27">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000057"/>
    <owl:someValuesFrom rdf:nodeID="N06e296eb4cd4410cb8e6484531f762ce"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Decayed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en-US">decayed</rdfs:label>
    <rdfs:label xml:lang="de">verfallen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001432"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Decayed is a quality reflecting decomposition where the bearer breaks down into component parts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verfallen ist eine Eigenschaft, die Zersetzung widerspiegelt, bei der der Träger in Einzelteile zerfällt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'decayed' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001432.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← Decayed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;decayed&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a decayed whale carcass on the ocean floor supports a succession of scavenger and decomposer organisms</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleWithDsd">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex"/>
    <rdfs:label xml:lang="en-US">female with dsd</rdfs:label>
    <rdfs:label xml:lang="de">weiblich mit dsd</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040056"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female with dsd quality refers to ambiguous or atypical congenital development of reproductive systems in otherwise female individuals</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Weiblich mit DSD-Qualität bezieht sich auf eine mehrdeutige oder atypische angeborene Entwicklung des Fortpflanzungssystems bei ansonsten weiblichen Individuen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female with dsd' have not yet been formalized. The term is defined as a specific subtype of 'phenotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040056.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhenotypicSex(x) ← FemaleWithDsd(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female with dsd&apos; then x is a &apos;phenotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a 46,XY individual with complete androgen insensitivity syndrome may be recorded as female with dsd in clinical records</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pregnancy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalReaction"/>
    <rdfs:subClassOf rdf:nodeID="N074a53d01a2848e09af37ab4c5c2a6a8"/>
    <rdfs:label xml:lang="de">Schwangerschaft</rdfs:label>
    <rdfs:label xml:lang="en-US">pregnancy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Pregnancy"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pregnancy is a process during which one or more offspring develops (gestates) inside a woman's uterus (womb)</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine Schwangerschaft ist ein Prozess, bei dem sich ein oder mehrere Nachkommen in der Gebärmutter einer Frau entwickeln (Gebärmutter).</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pregnancy' have not yet been formalized. The term is defined as a specific subtype of 'biologic reaction'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Pregnancy.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalReaction(x) ← Pregnancy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pregnancy&apos; then x is a &apos;biological reaction&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a pregnancy in Mus musculus lasts approximately 19 to 21 days and can be confirmed by palpation or ultrasound</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Binucleate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multinucleate"/>
    <rdfs:label xml:lang="en-US">binucleate</rdfs:label>
    <rdfs:label xml:lang="de">zweinukleatig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001406"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Binucleate is a quality denoting the presence of two distinct nuclei within the cellular structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zweikernig ist eine Eigenschaft, die das Vorhandensein von zwei unterschiedlichen Kernen innerhalb der Zellstruktur bezeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'binucleate' have not yet been formalized. The term is defined as a specific subtype of 'multinucleate'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001406.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Multinucleate(x) ← Binucleate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;binucleate&apos; then x is a &apos;multinucleate&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">cardiac muscle cells in adult mammals are frequently binucleate, containing two nuclei per cardiomyocyte</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalAreaToMassRatio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">organismal Fläche-Masse-Verhältnis</rdfs:label>
    <rdfs:label xml:lang="en-US">organismal area to mass ratio</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Organismal area to mass ratio quality is defined by the quotient of surface area divided by organism mass</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität des Verhältnisses von Organismenfläche zu Masse wird durch den Quotienten aus Oberfläche geteilt durch die Masse des Organismus definiert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'organismal area to mass ratio' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095001.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← OrganismalAreaToMassRatio(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;organismal area to mass ratio&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">small insects have a high organismal area to mass ratio facilitating rapid heat exchange with the environment</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Adolescent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="de">Adoleszent</rdfs:label>
    <rdfs:label xml:lang="en-US">adolescent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001189"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Adolescent is a maturity quality inhering in the bearer by virtue of being between the onset of puberty and adulthood</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Pubertät ist eine Reifequalität, die dem Träger innewohnt, da er sich zwischen dem Beginn der Pubertät und dem Erwachsenenalter befindet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'adolescent' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001189.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Adolescent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;adolescent&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an adolescent human is between 10 and 19 years of age and undergoing pubertal hormonal changes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Tetraploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="de">tetraploid</rdfs:label>
    <rdfs:label xml:lang="en-US">tetraploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001382"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tetraploid quality signifies the presence of four homologous chromosome sets</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Tetraploide Qualität bedeutet das Vorhandensein von vier homologen Chromosomensätzen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tetraploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001382.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Tetraploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tetraploid&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the African clawed frog Xenopus laevis is tetraploid, carrying four homologous sets of chromosomes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MalePseudohermaphrodite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pseudohermaphrodite"/>
    <rdfs:label xml:lang="en-US">male pseudohermaphrodite</rdfs:label>
    <rdfs:label xml:lang="de">männlicher Pseudohermaphrodit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001828"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male pseudohermaphrodite quality involves internal male organs and external female characteristics</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die männliche Pseudohermaphroditqualität umfasst innere männliche Organe und äußere weibliche Merkmale</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male pseudohermaphrodite' have not yet been formalized. The term is defined as a specific subtype of 'pseudohermaphrodite'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001828.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pseudohermaphrodite(x) ← MalePseudohermaphrodite(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male pseudohermaphrodite&apos; then x is a &apos;pseudohermaphrodite&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a 46,XY individual with 5-alpha reductase deficiency is classified as a male pseudohermaphrodite with female external genitalia</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Compatible">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Compatibility"/>
    <rdfs:label xml:lang="en-US">compatible</rdfs:label>
    <rdfs:label xml:lang="de">kompatibel</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000344"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Compatible is a quality reflecting an aptitude for harmonious coexistence with other entities</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kompatibilität ist eine Eigenschaft, die die Fähigkeit zum harmonischen Zusammenleben mit anderen Wesen widerspiegelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'compatible' have not yet been formalized. The term is defined as a specific subtype of 'compatibility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000344.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Compatibility(x) ← Compatible(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;compatible&apos; then x is a &apos;compatibility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">compatible blood group matching between donor and recipient ensures safe platelet transfusion in clinical settings</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CastratedMale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Male"/>
    <rdfs:label xml:lang="en-US">castrated male</rdfs:label>
    <rdfs:label xml:lang="de">männlich kastriert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002367"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Castrated male is a quality describing a male devoid of reproductive capabilities due to testicular loss, surgical or chemical</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Als kastrierter Mann bezeichnet man einen Mann, dem die Fortpflanzungsfähigkeit aufgrund eines Hodenverlusts, sei es durch chirurgische Eingriffe oder chemische Eingriffe, fehlt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'castrated male' have not yet been formalized. The term is defined as a specific subtype of 'male'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002367.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Male(x) ← CastratedMale(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;castrated male&apos; then x is a &apos;male&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a castrated male rat shows reduced aggression and territorial marking compared to intact male controls</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Auxotrophic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/TrophicQuality"/>
    <rdfs:label xml:lang="de">auxotroph</rdfs:label>
    <rdfs:label xml:lang="en-US">auxotrophic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000422"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Auxotrophic is a quality referring to an organism's inability to synthesize certain vital organic compounds necessary for growth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Auxotroph ist eine Eigenschaft, die sich auf die Unfähigkeit eines Organismus bezieht, bestimmte lebenswichtige organische Verbindungen, die für das Wachstum notwendig sind, zu synthetisieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'auxotrophic' have not yet been formalized. The term is defined as a specific subtype of 'trophic quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000422.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">TrophicQuality(x) ← Auxotrophic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;auxotrophic&apos; then x is a &apos;trophic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an auxotrophic E. coli strain unable to synthesize leucine requires leucine supplementation in minimal medium</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Diploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Euploid"/>
    <rdfs:label xml:lang="de">diploid</rdfs:label>
    <rdfs:label xml:lang="en-US">diploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001394"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Diploid is a quality referring to having two homologous sets of chromosomes, typically inherited one from each parent</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Diploid ist eine Eigenschaft, die sich auf das Vorhandensein zweier homologer Chromosomensätze bezieht, die typischerweise von jedem Elternteil geerbt werden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'diploid' have not yet been formalized. The term is defined as a specific subtype of 'euploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001394.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Euploid(x) ← Diploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;diploid&apos; then x is a &apos;euploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a somatic cell of Homo sapiens is diploid, containing 46 chromosomes organized as 23 homologous pairs</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Paleopolyploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="en-US">paleopolyploid</rdfs:label>
    <rdfs:label xml:lang="de">paläopolyploidie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001380"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Paleopolyploid quality identifies organisms with ancient polyploid ancestors</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die paläopolyploide Qualität identifiziert Organismen mit alten polyploiden Vorfahren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'paleopolyploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001380.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Paleopolyploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;paleopolyploid&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Arabidopsis thaliana is considered paleopolyploid following ancient genome duplication events in the mustard family lineage</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pluripotent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="de">pluripotent</rdfs:label>
    <rdfs:label xml:lang="en-US">pluripotent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001403"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pluripotent quality denotes the capacity to produce differentiated cell types from all three primary germ layers, excluding extraembryonic types</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Pluripotente Qualität bezeichnet die Fähigkeit, differenzierte Zelltypen aus allen drei primären Keimschichten zu produzieren, mit Ausnahme extraembryonaler Typen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pluripotent' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001403.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Pluripotent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pluripotent&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">induced pluripotent stem cells derived from mouse fibroblasts can differentiate into all three primary germ layers</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Prototrophic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/TrophicQuality"/>
    <rdfs:label xml:lang="en-US">prototrophic</rdfs:label>
    <rdfs:label xml:lang="de">prototrophisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000423"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Prototrophic quality denotes a nutritional capability allowing synthesis of essential organic compounds for growth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Prototrophe Qualität bezeichnet eine Ernährungsfähigkeit, die die Synthese essentieller organischer Verbindungen für das Wachstum ermöglicht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'prototrophic' have not yet been formalized. The term is defined as a specific subtype of 'trophic quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000423.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">TrophicQuality(x) ← Prototrophic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;prototrophic&apos; then x is a &apos;trophic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a prototrophic Saccharomyces cerevisiae strain grows on minimal medium without amino acid supplementation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000119">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en-US">Definition Source</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SemiDeciduousPlant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Shedability"/>
    <rdfs:label xml:lang="de">halbimmergrün</rdfs:label>
    <rdfs:label xml:lang="en-US">semi-deciduous (plant)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001734"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Semi-deciduous plant quality describes a state between evergreen and deciduous</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Halblaubpflanze beschreibt einen Zustand zwischen immergrün und laubabwerfend</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'semi-deciduous (plant)' have not yet been formalized. The term is defined as a specific subtype of 'shedability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001734.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shedability(x) ← SemiDeciduousPlant(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;semi-deciduous (plant)&apos; then x is a &apos;shedability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Ficus benjamina exhibits semi-deciduous quality, retaining some leaves year-round while shedding others seasonally</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalReaction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <owl:equivalentClass rdf:nodeID="Nd2e38bfbacdd47c397197fb4b1d4cbfc"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Reaction"/>
    <rdfs:label xml:lang="en-US">biologic reaction</rdfs:label>
    <rdfs:label xml:lang="de">biologische Antwort</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biological reaction characterizes a process where a biological capability of entity X is realized in response to a biological action involving X or more material entities</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Biologische Reaktion charakterisiert einen Prozess, bei dem eine biologische Fähigkeit von Entität X als Reaktion auf eine biologische Aktion realisiert wird, an der X oder mehr materielle Entitäten beteiligt sind</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en-US">BiologicReaction(x) ↔ ∃b (BiologicalCapability(b) ∧ obo:BFO_0000055(x, b))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-US">every instance of 'biologic reaction' is defined as exactly that 'obo:BFO_0000055' some 'biological capability'</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Balanced">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Balance"/>
    <rdfs:label xml:lang="en-US">balanced</rdfs:label>
    <rdfs:label xml:lang="de">balanziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000757"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Balanced is a quality characterized by the bearer having equilibrium</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ausgeglichen ist eine Eigenschaft, die dadurch gekennzeichnet ist, dass der Träger im Gleichgewicht ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'balanced' have not yet been formalized. The term is defined as a specific subtype of 'balance'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000757.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Balance(x) ← Balanced(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;balanced&apos; then x is a &apos;balance&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a balanced mouse on the balance beam test crosses the full length without stepping off within 60 seconds</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nf7080facfcd24701b712c1211d16d0cd">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasCapability"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductionCapability"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pathogenicity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Krankheitserregung</rdfs:label>
    <rdfs:label xml:lang="en-US">pathogenicity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040003"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pathogenicity quality represents the ability to cause infectious disease or disorder in other organisms</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Pathogenitätsqualität stellt die Fähigkeit dar, infektiöse Krankheiten oder Störungen bei anderen Organismen hervorzurufen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pathogenicity' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040003.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Pathogenicity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pathogenicity&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Mycobacterium tuberculosis displays high pathogenicity by establishing chronic pulmonary infection in immunocompetent hosts</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/UniparentalDisomy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Disomy"/>
    <rdfs:label xml:lang="de">einzelnnukleäre Disomie</rdfs:label>
    <rdfs:label xml:lang="en-US">uniparental disomy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001388"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Uniparental disomy quality indicates possessing two copies of a chromosome from one parent, with none from the other</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität einer uniparentalen Disomie weist darauf hin, dass ein Elternteil zwei Kopien eines Chromosoms besitzt, der andere jedoch keine</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'uniparental disomy' have not yet been formalized. The term is defined as a specific subtype of 'disomy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001388.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Disomy(x) ← UniparentalDisomy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;uniparental disomy&apos; then x is a &apos;disomy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">uniparental disomy of chromosome 15 from the paternal side causes Angelman syndrome in human patients</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleSterile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Sterile"/>
    <rdfs:label xml:lang="en-US">female sterile</rdfs:label>
    <rdfs:label xml:lang="de">unfruchtbar weiblich</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000892"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female sterile quality reflects the complete incapability of a female to reproduce or support reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die weibliche Sterilität spiegelt die völlige Unfähigkeit einer Frau wider, sich fortzupflanzen oder die Fortpflanzung zu unterstützen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female sterile' have not yet been formalized. The term is defined as a specific subtype of 'sterile'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000892.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Sterile(x) ← FemaleSterile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female sterile&apos; then x is a &apos;sterile&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a female sterile Drosophila mutant produces no viable eggs despite normal mating behavior</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Hexaploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="en-US">hexaploid</rdfs:label>
    <rdfs:label xml:lang="de">hexaploidie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001384"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Hexaploid quality indicates the possession of six homologous chromosome sets</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Hexaploide Qualität weist auf den Besitz von sechs homologen Chromosomensätzen hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hexaploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001384.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Hexaploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hexaploid&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">bread wheat Triticum aestivum is hexaploid with six sets of chromosomes derived from three ancestral diploid progenitors</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Totipotent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="de">totipotent</rdfs:label>
    <rdfs:label xml:lang="en-US">totipotent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001399"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Totipotent quality denotes the capacity to produce differentiated cell types from all primary germ layers and extraembryonic types</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter totipotenter Qualität versteht man die Fähigkeit, aus allen primären Keimschichten und extraembryonalen Typen differenzierte Zelltypen zu produzieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'totipotent' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001399.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Totipotent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;totipotent&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a single blastomere from a 2-cell stage mouse embryo is totipotent and can develop into a complete organism</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/DoubledHaploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Euploid"/>
    <rdfs:label xml:lang="de">doppelhaploid</rdfs:label>
    <rdfs:label xml:lang="en-US">doubled haploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040027"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Doubled haploid is a quality reflecting haploid cells undergoing chromosome doubling</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verdoppelt haploid ist eine Eigenschaft, die haploide Zellen widerspiegelt, die einer Chromosomenverdoppelung unterliegen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'doubled haploid' have not yet been formalized. The term is defined as a specific subtype of 'euploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040027.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Euploid(x) ← DoubledHaploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;doubled haploid&apos; then x is a &apos;euploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">doubled haploid barley plants obtained by anther culture have restored full fertility after chromosome doubling with colchicine</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Homophilic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularAdhesivity"/>
    <rdfs:label xml:lang="de">homophil</rdfs:label>
    <rdfs:label xml:lang="en-US">homophilic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001440"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Homophilic quality is characterized by adhesion between identical molecules on adjacent cells</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Homophile Qualität ist durch die Adhäsion zwischen identischen Molekülen auf benachbarten Zellen gekennzeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'homophilic' have not yet been formalized. The term is defined as a specific subtype of 'cellular adhesivity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001440.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularAdhesivity(x) ← Homophilic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;homophilic&apos; then x is a &apos;cellular adhesivity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">E-cadherin mediates homophilic adhesion between identical E-cadherin molecules on adjacent epithelial cells</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Indifference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Preference"/>
    <rdfs:label xml:lang="en-US">indifference</rdfs:label>
    <rdfs:label xml:lang="de">indifferent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000772"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Indifference is characterized by a lack of preference towards a perceived stimulus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gleichgültigkeit ist durch mangelnde Präferenz gegenüber einem wahrgenommenen Reiz gekennzeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'indifference' have not yet been formalized. The term is defined as a specific subtype of 'preference'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000772.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Preference(x) ← Indifference(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;indifference&apos; then x is a &apos;preference&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a rat in a sucrose preference test exhibiting equal consumption of sucrose and water shows indifference to sweet stimuli</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Discriminate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Discrimination"/>
    <rdfs:label xml:lang="en-US">discriminate</rdfs:label>
    <rdfs:label xml:lang="de">unterscheidend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001319"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Discriminate is a quality involving the capability to perceive differences between multiple stimuli</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Diskriminierung versteht man die Fähigkeit, Unterschiede zwischen mehreren Reizen wahrzunehmen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'discriminate' have not yet been formalized. The term is defined as a specific subtype of 'discrimination'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001319.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Discrimination(x) ← Discriminate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;discriminate&apos; then x is a &apos;discrimination&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a trained honeybee can discriminate between two floral odors after differential conditioning in a proboscis extension reflex assay</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Unbalanced">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Balance"/>
    <rdfs:label xml:lang="en-US">unbalanced</rdfs:label>
    <rdfs:label xml:lang="de">ungleichgewichtig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000758"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unbalanced quality describes lacking equilibrium</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unausgeglichene Qualität beschreibt mangelndes Gleichgewicht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unbalanced' have not yet been formalized. The term is defined as a specific subtype of 'balance'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000758.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Balance(x) ← Unbalanced(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unbalanced&apos; then x is a &apos;balance&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an unbalanced mouse after vestibular lesion falls repeatedly from the balance beam during motor testing</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multicellular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Cellularity"/>
    <rdfs:label xml:lang="de">mehrzellig</rdfs:label>
    <rdfs:label xml:lang="en-US">multicellular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001993"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multicellular quality denotes an organismal state consisting of more than one cell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter multizellularer Qualität versteht man einen Organismuszustand, der aus mehr als einer Zelle besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multicellular' have not yet been formalized. The term is defined as a specific subtype of 'cellularity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001993.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cellularity(x) ← Multicellular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multicellular&apos; then x is a &apos;cellularity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Caenorhabditis elegans is a multicellular organism composed of exactly 959 somatic cells in the adult hermaphrodite</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReducedVirulence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Virulence"/>
    <rdfs:label xml:lang="en-US">reduced virulence</rdfs:label>
    <rdfs:label xml:lang="de">reduzierte Virulenz</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002147"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Reduced virulence quality represents a lower-than-normal severity of infectious disease potential</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine verringerte Virulenzqualität bedeutet eine geringere Schwere des Infektionskrankheitspotenzials als normal</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'reduced virulence' have not yet been formalized. The term is defined as a specific subtype of 'virulence'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002147.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Virulence(x) ← ReducedVirulence(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;reduced virulence&apos; then x is a &apos;virulence&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a Staphylococcus aureus mutant lacking the agr locus shows reduced virulence in a murine abscess model</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Primiparous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parity"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parous"/>
    <rdfs:label xml:lang="de">einmalig Gebärend</rdfs:label>
    <rdfs:label xml:lang="en-US">primiparous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002371"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Primiparous quality designates a viviparous organism that has experienced childbirth exactly once</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Erstgebärende Qualität bezeichnet einen lebendgebärenden Organismus, der genau einmal eine Geburt erlebt hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'primiparous' have not yet been formalized. The term is defined as a specific subtype of 'parity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002371.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Parity(x) ← Primiparous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;primiparous&apos; then x is a &apos;parity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a primiparous ewe giving birth for the first time often requires closer veterinary monitoring during parturition</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Aneuploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Ploidy"/>
    <rdfs:label xml:lang="de">Aneuploidie</rdfs:label>
    <rdfs:label xml:lang="en-US">aneuploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001385"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Aneuploid is a condition referring to a ploidy anomaly, exhibiting deviation from integral multiples of the monoploid number due to missing or additional chromosomes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Aneuploid ist ein Zustand, der sich auf eine Ploidieanomalie bezieht und eine Abweichung von ganzzahligen Vielfachen der monoploiden Zahl aufgrund fehlender oder zusätzlicher Chromosomen aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'aneuploid' have not yet been formalized. The term is defined as a specific subtype of 'ploidy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001385.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Ploidy(x) ← Aneuploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;aneuploid&apos; then x is a &apos;ploidy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">trisomy 21 in human prenatal diagnosis represents an aneuploid condition detected by karyotyping amniocytes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularMotility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="en-US">cellular motility</rdfs:label>
    <rdfs:label xml:lang="de">zelluläre Motilität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001488"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cellular motility is a quality reflecting a cell's inherent ability to move autonomously and spontaneously</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zellmotilität ist eine Qualität, die die inhärente Fähigkeit einer Zelle widerspiegelt, sich autonom und spontan zu bewegen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cellular motility' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001488.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularQuality(x) ← CellularMotility(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cellular motility&apos; then x is a &apos;cellular quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">neutrophils show rapid cellular motility by migrating up a chemoattractant gradient in a Boyden chamber assay</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Shedability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Verlierensneigung</rdfs:label>
    <rdfs:label xml:lang="en-US">shedability</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001729"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shedability quality refers to an organism's disposition to lose body parts or entities through natural processes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Abscheidbarkeit bezieht sich auf die Neigung eines Organismus, Körperteile oder -einheiten durch natürliche Prozesse zu verlieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shedability' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001729.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Shedability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shedability&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">dogs exhibit shedability by losing large amounts of fur during seasonal coat transitions in spring and autumn</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Lethargic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehaviouralActivity"/>
    <rdfs:label xml:lang="en-US">lethargic</rdfs:label>
    <rdfs:label xml:lang="de">träge</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001418"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Lethargic represents a behavioral quality of deficient alertness or activity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Lethargisch stellt eine Verhaltensqualität mangelnder Aufmerksamkeit oder Aktivität dar</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lethargic' have not yet been formalized. The term is defined as a specific subtype of 'behavioural activity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001418.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehaviouralActivity(x) ← Lethargic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lethargic&apos; then x is a &apos;behavioural activity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a lethargic Drosophila mutant displays reduced spontaneous movement and slow responses to tactile stimulation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Trinucleate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multinucleate"/>
    <rdfs:label xml:lang="de">dreinukleär</rdfs:label>
    <rdfs:label xml:lang="en-US">trinucleate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001909"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Trinucleate quality indicates possessing three nuclei within the cell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die dreikernige Qualität weist darauf hin, dass die Zelle drei Kerne besitzt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'trinucleate' have not yet been formalized. The term is defined as a specific subtype of 'multinucleate'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001909.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Multinucleate(x) ← Trinucleate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;trinucleate&apos; then x is a &apos;multinucleate&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">mature pollen grains of angiosperms are trinucleate at the time of pollen tube germination, containing three nuclei</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalRelationalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
    <rdfs:label xml:lang="en-US">biological relational quality</rdfs:label>
    <rdfs:label xml:lang="de">biologisch relative Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biological relational quality pertains to properties or characteristics of an entity dependent on its relation to other entities</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die biologische Beziehungsqualität bezieht sich auf Eigenschaften oder Merkmale einer Entität, die von ihrer Beziehung zu anderen Entitäten abhängig sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biological relational quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000145'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000145(x) ← BiologicalRelationalQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biological relational quality&apos; then x is a &apos;b f o_0000145&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the symbiotic quality of nitrogen-fixing bacteria in root nodules is a biological relational quality dependent on the host legume</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SemiViable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="de">semi lebensfähig</rdfs:label>
    <rdfs:label xml:lang="en-US">semi-viable</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001770"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Semi-viable quality defines the survival capability in only a portion of a given population</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die semiviable Qualität definiert die Überlebensfähigkeit nur eines Teils einer bestimmten Population</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'semi-viable' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001770.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← SemiViable(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;semi-viable&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a semi-viable mouse genotype shows 50 percent survival to weaning compared to wild-type littermates</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Proliferative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="en-US">proliferative</rdfs:label>
    <rdfs:label xml:lang="de">proliferierende Zelle</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002102"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Proliferative quality is characterized by the ability to grow and increase in number through cell division</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die proliferative Qualität zeichnet sich durch die Fähigkeit aus, durch Zellteilung zu wachsen und sich zu vermehren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'proliferative' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002102.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularQuality(x) ← Proliferative(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;proliferative&apos; then x is a &apos;cellular quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">proliferative basal keratinocytes in skin tissue continuously divide to replenish the stratified squamous epithelium</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pubescent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="de">Pubeszenz</rdfs:label>
    <rdfs:label xml:lang="en-US">pubescent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000455"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pubescent quality pertains to individuals who have reached the onset of puberty, where sex glands become functional, but not yet maturity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Pubertätsqualität bezieht sich auf Personen, die den Beginn der Pubertät erreicht haben, wo die Geschlechtsdrüsen funktionsfähig, aber noch nicht reif sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pubescent' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000455.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Pubescent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pubescent&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a pubescent human female between ages 8 and 13 shows early breast development as the first sign of puberty</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nce09b7152458430094339b138901b986">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasProcessCharacteristic"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalProcessCharacteristic"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OvariohysterectomizedFemale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleSterile"/>
    <rdfs:label xml:lang="en-US">ovariohysterectomized female</rdfs:label>
    <rdfs:label xml:lang="de">ovariohysterektomierte weibliche</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002379"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ovariohysterectomized female quality signifies infertility due to surgical removal of ovaries and uterus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ovariohysterektomierte weibliche Qualität bedeutet Unfruchtbarkeit aufgrund der chirurgischen Entfernung von Eierstöcken und Gebärmutter</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ovariohysterectomized female' have not yet been formalized. The term is defined as a specific subtype of 'female sterile'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002379.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">FemaleSterile(x) ← OvariohysterectomizedFemale(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ovariohysterectomized female&apos; then x is a &apos;female sterile&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an ovariohysterectomized female dog cannot reproduce after surgical removal of both ovaries and the uterus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Mosaicism">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Mosaikismus</rdfs:label>
    <rdfs:label xml:lang="en-US">mosaicism</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002048"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mosaicism quality characterizes having two or more distinct cell populations differing in genetic makeup, affecting any cell type including blood cells, gametes, and skin</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität des Mosaizismus zeichnet sich dadurch aus, dass zwei oder mehr unterschiedliche Zellpopulationen vorhanden sind, die sich in der genetischen Ausstattung unterscheiden und jeden Zelltyp betreffen, einschließlich Blutzellen, Gameten und Haut</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mosaicism' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002048.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Mosaicism(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mosaicism&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a child with mosaic Down syndrome has trisomy 21 in only some somatic cells due to post-zygotic nondisjunction</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/HPlus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SchizosaccharomycesPombeMatingType"/>
    <rdfs:label xml:lang="de">h Plus</rdfs:label>
    <rdfs:label xml:lang="en-US">h plus</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001346"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">H Plus identifies a S. pombe mating type, based on specific gene configurations at the mat1 locus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">H Plus identifiziert einen S. pombe-Paarungstyp basierend auf spezifischen Genkonfigurationen am mat1-Locus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'h plus' have not yet been formalized. The term is defined as a specific subtype of 'schizosaccharomyces pombe mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001346.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SchizosaccharomycesPombeMatingType(x) ← HPlus(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;h plus&apos; then x is a &apos;schizosaccharomyces pombe mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">S. pombe h plus cells mate with h minus cells to form diploid zygotes in fission yeast crossing experiments</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Nucleated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/NucleateQuality"/>
    <rdfs:label xml:lang="en-US">nucleated</rdfs:label>
    <rdfs:label xml:lang="de">nukleiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002505"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Nucleated quality signifies a cell having one or more nuclei</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die kernhaltige Qualität bezeichnet eine Zelle mit einem oder mehreren Kernen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'nucleated' have not yet been formalized. The term is defined as a specific subtype of 'nucleate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002505.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">NucleateQuality(x) ← Nucleated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;nucleated&apos; then x is a &apos;nucleate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">nucleated red blood cells circulating in a chicken blood smear can be distinguished from mammalian anucleate erythrocytes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Autopolyploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="en-US">autopolyploid</rdfs:label>
    <rdfs:label xml:lang="de">autopolyploidie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001378"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Autopolyploid is a quality indicating polyploid condition with chromosome sets derived from a single species</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Autopolyploid ist eine Qualität, die auf einen polyploiden Zustand mit Chromosomensätzen hinweist, die von einer einzelnen Art stammen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'autopolyploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001378.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Autopolyploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;autopolyploid&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">autopolyploid Solanum tuberosum cultivars carry four chromosome sets all derived from diploid potato ancestors</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalProcessCharacteristic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/ProcessCharacteristic"/>
    <rdfs:label xml:lang="en-US">biologic process characteristic</rdfs:label>
    <rdfs:label xml:lang="de">biologische Prozesscharakteristik</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biological process characteristic defines attributes of a process concretizing a biological interaction over time</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Biologische Prozesseigenschaften definieren Attribute eines Prozesses, die eine biologische Interaktion im Zeitverlauf konkretisieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biologic process characteristic' have not yet been formalized. The term is defined as a specific subtype of 'ProcessCharacteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ProcessCharacteristic(x) ← BiologicalProcessCharacteristic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biologic process characteristic&apos; then x is a &apos;process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">oxidative phosphorylation efficiency is a biologic process characteristic measured in isolated mitochondria from liver tissue</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/AmbidextrousHandedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Handedness"/>
    <rdfs:label xml:lang="de">Beidhändigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">ambidextrous handedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002204"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ambidextrous handedness is a handedness characterized by equal proficiency in using both right and left hands or feet without preference</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beidhändige Händigkeit ist eine Händigkeit, die durch die gleiche Fähigkeit gekennzeichnet ist, sowohl die rechte als auch die linke Hand oder den linken Fuß ohne Präferenz zu verwenden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ambidextrous handedness' have not yet been formalized. The term is defined as a specific subtype of 'handedness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002204.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Handedness(x) ← AmbidextrousHandedness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ambidextrous handedness&apos; then x is a &apos;handedness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an ambidextrous capuchin monkey uses left and right hands with equal frequency during tool-use tasks</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Immature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="en-US">immature</rdfs:label>
    <rdfs:label xml:lang="de">unreif</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001501"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Immature quality reflects lacking complete growth, differentiation, or development</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unreife Qualität spiegelt das Fehlen von vollständigem Wachstum, Differenzierung oder Entwicklung wider</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'immature' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001501.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Immature(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;immature&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an immature follicle in the ovarian cortex has not yet completed its growth phase and lacks a full antrum</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Uncoordinated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Coordination"/>
    <rdfs:label xml:lang="en-US">uncoordinated</rdfs:label>
    <rdfs:label xml:lang="de">unkoordiniert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000770"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Uncoordinated quality signifies lacking skillful and effective interaction in movement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unkoordinierte Qualität bedeutet mangelndes geschicktes und effektives Zusammenspiel in der Bewegung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'uncoordinated' have not yet been formalized. The term is defined as a specific subtype of 'coordination'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000770.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Coordination(x) ← Uncoordinated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;uncoordinated&apos; then x is a &apos;coordination&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an uncoordinated unc-22 Caenorhabditis elegans mutant shows a characteristic body twitching phenotype under a dissecting microscope</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="en-US">biological quality</rdfs:label>
    <rdfs:label xml:lang="de">biologische Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biological quality refers to attributes or traits inherent in an entity that relate to biologic interactions or factors</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Biologische Qualität bezieht sich auf Attribute oder Merkmale, die einer Entität innewohnen und sich auf biologische Wechselwirkungen oder Faktoren beziehen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biological quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000019'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000019(x) ← BiologicalQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biological quality&apos; then x is a &apos;b f o_0000019&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the photosynthetic pigmentation of Chlorella vulgaris is a biological quality measured by chlorophyll content per cell</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalSex"/>
    <rdfs:label xml:lang="en-US">phenotypic sex</rdfs:label>
    <rdfs:label xml:lang="de">phänotypisches Geschlecht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001894"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Phenotypic sex quality pertains to the physical expression of sexual characteristics</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die phänotypische Geschlechtsqualität bezieht sich auf den physischen Ausdruck sexueller Merkmale</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'phenotypic sex' have not yet been formalized. The term is defined as a specific subtype of 'biological sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001894.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalSex(x) ← PhenotypicSex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;phenotypic sex&apos; then x is a &apos;biological sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a chicken with ZZ chromosomes exhibits male phenotypic sex, including wattle, comb, and spur development</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Preference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Discrimination"/>
    <obo:IAO_000_0412 rdf:resource="http://purl.obolibrary.org/obo/PATO_0000773"/>
    <rdfs:label xml:lang="de">Präferenz</rdfs:label>
    <rdfs:label xml:lang="en-US">preference</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Preference quality involves a liking or inclination toward a perceived stimulus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bei der Präferenzqualität handelt es sich um eine Vorliebe oder Neigung zu einem wahrgenommenen Reiz</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'preference' have not yet been formalized. The term is defined as a specific subtype of 'discrimination'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Discrimination(x) ← Preference(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;preference&apos; then x is a &apos;discrimination&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">mice show preference for the more novel compartment in a conditioned place preference assay after drug exposure</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pupal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="de">pupal</rdfs:label>
    <rdfs:label xml:lang="en-US">pupal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001187"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pupal maturity quality identifies insects in the chrysalis (cocoon) or post-larval stage</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Puppenreife identifiziert Insekten im Puppenstadium (Kokon) oder im Postlarvenstadium</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pupal' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001187.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Pupal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pupal&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Drosophila melanogaster spends approximately 4 days in the pupal stage enclosed within the cuticle of the puparium</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PartialTrisomy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Trisomy"/>
    <rdfs:label xml:lang="en-US">partial trisomy</rdfs:label>
    <rdfs:label xml:lang="de">teilweise Trisomie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001390"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Partial trisomy quality refers to the condition where an organism has a partial or extra copy of one or more chromosome segments</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter partieller Trisomiequalität versteht man den Zustand, bei dem ein Organismus eine teilweise oder zusätzliche Kopie eines oder mehrerer Chromosomensegmente besitzt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'partial trisomy' have not yet been formalized. The term is defined as a specific subtype of 'trisomy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001390.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Trisomy(x) ← PartialTrisomy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;partial trisomy&apos; then x is a &apos;trisomy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">partial trisomy 13q in a child results from translocation and causes only a subset of full trisomy 13 features</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleSterile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Sterile"/>
    <rdfs:label xml:lang="en-US">male sterile</rdfs:label>
    <rdfs:label xml:lang="de">männlich steril</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000890"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male sterile quality indicates the inability of males to initiate, sustain, or support reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Männliche Sterilität weist darauf hin, dass Männchen nicht in der Lage sind, die Fortpflanzung einzuleiten, aufrechtzuerhalten oder zu unterstützen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male sterile' have not yet been formalized. The term is defined as a specific subtype of 'sterile'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000890.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Sterile(x) ← MaleSterile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male sterile&apos; then x is a &apos;sterile&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a male sterile Arabidopsis thaliana mutant produces non-functional anthers and cannot self-pollinate</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/DeciduousPlant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Shedability"/>
    <rdfs:label xml:lang="en-US">deciduous (plant)</rdfs:label>
    <rdfs:label xml:lang="de">laubabwerfende Pflanze</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001731"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Deciduous (plant) is a quality signifying a tendency to shed foliage seasonally</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Laubabwerfend (Pflanze) ist eine Eigenschaft, die darauf hindeutet, dass die Pflanze dazu neigt, saisonal Laub abzuwerfen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'deciduous (plant)' have not yet been formalized. The term is defined as a specific subtype of 'shedability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001731.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shedability(x) ← DeciduousPlant(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;deciduous (plant)&apos; then x is a &apos;shedability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Fagus sylvatica has deciduous plant quality, dropping all leaves in autumn before winter dormancy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Monosomy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Aneuploid"/>
    <rdfs:label xml:lang="de">monosomie</rdfs:label>
    <rdfs:label xml:lang="en-US">monosomy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001386"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Monosomy quality is characterized by the presence of only a single chromosome from a pair within a cell's nucleus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Monosomiequalität ist dadurch gekennzeichnet, dass im Zellkern nur ein einziges Chromosom eines Paares vorhanden ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'monosomy' have not yet been formalized. The term is defined as a specific subtype of 'aneuploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001386.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Aneuploid(x) ← Monosomy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;monosomy&apos; then x is a &apos;aneuploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">monosomy X in humans causes Turner syndrome, characterized by a single X chromosome in all somatic cells</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Female">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex"/>
    <rdfs:label xml:lang="en-US">female</rdfs:label>
    <rdfs:label xml:lang="de">weiblich</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000383"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female quality is expressed as the production of gametes capable of being fertilized by male gametes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die weibliche Qualität wird als die Produktion von Gameten ausgedrückt, die von männlichen Gameten befruchtet werden können</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female' have not yet been formalized. The term is defined as a specific subtype of 'phenotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000383.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhenotypicSex(x) ← Female(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female&apos; then x is a &apos;phenotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a female Drosophila melanogaster carries two X chromosomes and produces oocytes in its paired ovaries</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/HighNuclear/CytoplasmicRatio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="en-US">high nuclear/cytoplasmic ratio</rdfs:label>
    <rdfs:label xml:lang="de">hohes nukleär-zytoplasmatisches Verhältnis</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040072"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">High nuclear/cytoplasmic ratio quality defines cells where the nucleus takes up a disproportionate volume compared to the cytoplasm</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine hohe Qualität des Kern-/Zytoplasma-Verhältnisses definiert Zellen, bei denen der Kern im Vergleich zum Zytoplasma ein unverhältnismäßiges Volumen einnimmt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'high nuclear/cytoplasmic ratio' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040072.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularQuality(x) ← CytoplasmicRatio(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;high nuclear/cytoplasmic ratio&apos; then x is a &apos;cellular quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a lymphoblast with high nuclear/cytoplasmic ratio is identified in peripheral blood smears of patients with acute lymphocytic leukemia</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleFertility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertility"/>
    <rdfs:label xml:lang="en-US">male fertility</rdfs:label>
    <rdfs:label xml:lang="de">männliche Fruchtbarkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000279"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male fertility quality refers to the male's disposition to initiate, sustain, or support reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter männlicher Fruchtbarkeitsqualität versteht man die Bereitschaft des Mannes, die Fortpflanzung einzuleiten, aufrechtzuerhalten oder zu unterstützen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male fertility' have not yet been formalized. The term is defined as a specific subtype of 'fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000279.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fertility(x) ← MaleFertility(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male fertility&apos; then x is a &apos;fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">male fertility in bulls is routinely assessed by semen analysis including motility, morphology, and concentration</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleFertile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleFertility"/>
    <rdfs:label xml:lang="en-US">female fertile</rdfs:label>
    <rdfs:label xml:lang="de">weiblich fruchtbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000888"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female fertile quality indicates a female's disposition to initiate, sustain, or support reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die weibliche Fruchtbarkeit gibt die Bereitschaft einer Frau an, die Fortpflanzung einzuleiten, aufrechtzuerhalten oder zu unterstützen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female fertile' have not yet been formalized. The term is defined as a specific subtype of 'female fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000888.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">FemaleFertility(x) ← FemaleFertile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female fertile&apos; then x is a &apos;female fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a female fertile C. elegans hermaphrodite at day 1 of adulthood lays over 250 self-fertilized progeny</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N8710a39c0392454db98f55505d6322ac">
    <rdf:first rdf:nodeID="Na1210685e26a423d9fdec2bc24e86e27"/>
    <rdf:rest rdf:nodeID="N54d65823b2904b1cab3d945c7a633070"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemalePseudohermaphrodite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pseudohermaphrodite"/>
    <rdfs:label xml:lang="en-US">female pseudohermaphrodite</rdfs:label>
    <rdfs:label xml:lang="de">weiblicher Pseudohermaphrodit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001829"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female pseudohermaphrodite involves internal female reproductive organs and external male sexual characteristics</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der weibliche Pseudohermaphrodit betrifft die inneren weiblichen Fortpflanzungsorgane und die äußeren männlichen Geschlechtsmerkmale</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female pseudohermaphrodite' have not yet been formalized. The term is defined as a specific subtype of 'pseudohermaphrodite'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001829.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pseudohermaphrodite(x) ← FemalePseudohermaphrodite(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female pseudohermaphrodite&apos; then x is a &apos;pseudohermaphrodite&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a 46,XX individual with congenital adrenal hyperplasia may be classified as a female pseudohermaphrodite due to virilized genitalia</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pentaploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="en-US">pentaploid</rdfs:label>
    <rdfs:label xml:lang="de">pentaploidie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001383"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pentaploid quality indicates the presence of five homologous sets of chromosomes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die pentaploide Qualität weist auf das Vorhandensein von fünf homologen Chromosomensätzen hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pentaploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001383.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Pentaploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pentaploid&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">some natural hybrid roses are pentaploid, containing five sets of chromosomes from multiple progenitor species</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Endopolyploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="de">endopolyploid</rdfs:label>
    <rdfs:label xml:lang="en-US">endopolyploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001392"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Endopolyploid is a quality indicating increased chromosome count due to endomitosis, proportionate to endomitosis occurrence</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Endopolyploid ist eine Eigenschaft, die auf eine erhöhte Chromosomenzahl aufgrund einer Endomitose hinweist, die proportional zum Auftreten einer Endomitose ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'endopolyploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001392.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Endopolyploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;endopolyploid&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">endopolyploid cells in Drosophila salivary glands contain up to 1024n DNA content due to repeated endomitosis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Receptivity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Empfänglichkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">receptivity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001719"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Receptivity quality signifies the ability to receive a stimulus or entity effectively</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Rezeptionsqualität versteht man die Fähigkeit, einen Reiz oder eine Entität effektiv zu empfangen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'receptivity' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001719.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← Receptivity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;receptivity&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">uterine receptivity in mice peaks at 3.5 days post-coitus, when the endometrium permits blastocyst implantation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Migratory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="en-US">migratory</rdfs:label>
    <rdfs:label xml:lang="de">migrierend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095008"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Migratory quality signifies adaptations facilitating long-distance, typically seasonal, movement within conspecifics</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Migrationsqualität versteht man Anpassungen, die die Bewegung von Artgenossen über weite Distanzen, typischerweise saisonal, ermöglichen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'migratory' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095008.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Migratory(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;migratory&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the migratory quality of Arctic terns enables a seasonal round trip of more than 70000 km between poles</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Paralysed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MovementBehavioralQuality"/>
    <rdfs:label xml:lang="de">gelähmt</rdfs:label>
    <rdfs:label xml:lang="en-US">paralysed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000763"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Paralysed quality indicates the loss or impairment of the ability to move certain body parts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Eigenschaft einer Lähmung weist auf den Verlust oder die Beeinträchtigung der Fähigkeit hin, bestimmte Körperteile zu bewegen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'paralysed' have not yet been formalized. The term is defined as a specific subtype of 'movement behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000763.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MovementBehavioralQuality(x) ← Paralysed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;paralysed&apos; then x is a &apos;movement behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a paralysed C. elegans unc-54 mutant lacking functional myosin heavy chain cannot move its body wall muscles</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Undifferentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="en-US">undifferentiated</rdfs:label>
    <rdfs:label xml:lang="de">undifferenziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002100"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Undifferentiated quality reflects the state of having not yet acquired specialized structure or function</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Undifferenzierte Qualität spiegelt den Zustand wider, dass noch keine spezielle Struktur oder Funktion erworben wurde</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'undifferentiated' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002100.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Undifferentiated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;undifferentiated&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an undifferentiated embryonic stem cell expresses Oct4 and Nanog and has not yet committed to any lineage</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Haploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Euploid"/>
    <rdfs:label xml:lang="de">Haploidy</rdfs:label>
    <rdfs:label xml:lang="en-US">haploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001375"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Haploid quality reflects the presence of a single set of homologous chromosomes within the cell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die haploide Qualität spiegelt das Vorhandensein eines einzelnen Satzes homologer Chromosomen in der Zelle wider</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'haploid' have not yet been formalized. The term is defined as a specific subtype of 'euploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001375.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Euploid(x) ← Haploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;haploid&apos; then x is a &apos;euploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a pollen grain of Lilium longiflorum is haploid, carrying a single set of 12 chromosomes after meiosis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GrandMultiparous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multiparous"/>
    <rdfs:label xml:lang="en-US">grand multiparous</rdfs:label>
    <rdfs:label xml:lang="de">großmultipar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002372"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Grand multiparous quality defines a viviparous organism that has given birth five or more times</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität „Grand Multiparous“ definiert einen lebendgebärenden Organismus, der fünfmal oder öfter Kinder zur Welt gebracht hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'grand multiparous' have not yet been formalized. The term is defined as a specific subtype of 'multiparous'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002372.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Multiparous(x) ← GrandMultiparous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;grand multiparous&apos; then x is a &apos;multiparous&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a grand multiparous sow that has farrowed seven litters is monitored for reduced productivity in later parities</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Larval">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="de">Larvenstadium</rdfs:label>
    <rdfs:label xml:lang="en-US">larval</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001185"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Larval maturity quality characterizes an organism undergoing indirect development with metamorphosis stages</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Larvenreife charakterisiert einen Organismus, der eine indirekte Entwicklung mit Metamorphosestadien durchläuft</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'larval' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001185.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Larval(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;larval&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a larval zebrafish at 5 days post-fertilization begins free swimming and independent feeding behavior</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000114">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en-US">Has Curation Status</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/RightHandedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Handedness"/>
    <rdfs:label xml:lang="de">Rechtshändigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">right handedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002203"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Right handedness attributes preferential use of the right hand or foot for tasks demanding dominance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rechtshändigkeit bedeutet, dass bei Aufgaben, die Dominanz erfordern, bevorzugt die rechte Hand oder der rechte Fuß eingesetzt wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'right handedness' have not yet been formalized. The term is defined as a specific subtype of 'handedness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002203.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Handedness(x) ← RightHandedness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;right handedness&apos; then x is a &apos;handedness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a chimpanzee consistently using the right hand for precision grip tasks shows right handedness in tool use studies</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleFertile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleFertility"/>
    <rdfs:label xml:lang="en-US">male fertile</rdfs:label>
    <rdfs:label xml:lang="de">männlich fruchtbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000891"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male fertile quality embodies a male's ability to initiate, sustain, or support reproductive processes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die männliche Fruchtbarkeitsqualität verkörpert die Fähigkeit eines Mannes, Fortpflanzungsprozesse einzuleiten, aufrechtzuerhalten oder zu unterstützen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male fertile' have not yet been formalized. The term is defined as a specific subtype of 'male fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000891.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaleFertility(x) ← MaleFertile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male fertile&apos; then x is a &apos;male fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a male fertile Zea mays plant sheds viable pollen from its anthers and successfully pollinates neighboring plants</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multiparous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parity"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parous"/>
    <rdfs:label xml:lang="de">mehrfachträchtig</rdfs:label>
    <rdfs:label xml:lang="en-US">multiparous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002369"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multiparous quality defines a viviparous organism experiencing two or more successful birth cycles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Multiparitätsqualität definiert einen lebendgebärenden Organismus, der zwei oder mehr erfolgreiche Geburtszyklen durchläuft</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multiparous' have not yet been formalized. The term is defined as a specific subtype of 'parity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002369.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Parity(x) ← Multiparous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multiparous&apos; then x is a &apos;parity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a multiparous female rat on its third pregnancy is used as a breeding colony founder in neuroscience research</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleFertility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertility"/>
    <rdfs:label xml:lang="en-US">female fertility</rdfs:label>
    <rdfs:label xml:lang="de">weibliche Fruchtbarkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000277"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female fertility quality encompasses the ability to initiate, sustain, or support reproduction from the female aspect</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der weiblichen Fruchtbarkeit umfasst die Fähigkeit, die Fortpflanzung von der weiblichen Seite aus zu initiieren, aufrechtzuerhalten oder zu unterstützen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female fertility' have not yet been formalized. The term is defined as a specific subtype of 'fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000277.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fertility(x) ← FemaleFertility(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female fertility&apos; then x is a &apos;fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">female fertility in cows is routinely evaluated by conception rate and interval to first service after calving</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multipotent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="de">mehrfachdifferenzierungsfähig</rdfs:label>
    <rdfs:label xml:lang="en-US">multipotent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001402"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multipotent quality involves the capability to develop into multiple differentiated cell types</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Multipotente Qualität beinhaltet die Fähigkeit, sich zu mehreren differenzierten Zelltypen zu entwickeln</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multipotent' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001402.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Multipotent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multipotent&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">bone marrow mesenchymal stromal cells are multipotent, differentiating into osteoblasts, adipocytes, and chondrocytes in vitro</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
    <rdfs:label xml:lang="en-US">biological capability</rdfs:label>
    <rdfs:label xml:lang="de">biologische Fähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biological capability describes a capability realized through an entity in a Biological interaction, fulfilling an agent's interest</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Biologische Fähigkeiten beschreiben eine Fähigkeit, die durch eine Entität in einer biologischen Interaktion realisiert wird und die Interessen eines Agenten erfüllt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biological capability' have not yet been formalized. The term is defined as a specific subtype of 'Capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Capability(x) ← BiologicalCapability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biological capability&apos; then x is a &apos;capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the nitrogen-fixing biological capability of Rhizobium leguminosarum is realized within root nodules of leguminous plants</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioactive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="en-US">bioactive</rdfs:label>
    <rdfs:label xml:lang="de">bioaktiv</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010023"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Bioactive is a biological capability of a material entity that is realized as a specific interaction with one or more biological systems, producing a measurable biological effect such as a therapeutic, toxic, or signaling outcome</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bioaktiv ist eine biologische Fähigkeit einer materiellen Einheit, die als spezifische Interaktion mit einem oder mehreren biologischen Systemen realisiert wird und eine messbare biologische Wirkung hervorruft, beispielsweise eine therapeutische, toxische oder signalisierende Wirkung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bioactive' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010023.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalCapability(x) ← Bioactive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bioactive&apos; then x is a &apos;biological capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">hydroxyapatite is bioactive, stimulating direct bone bonding at the implant-tissue interface in orthopedic applications</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Biocompatible">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioactive"/>
    <rdfs:label xml:lang="en-US">biocompatible</rdfs:label>
    <rdfs:label xml:lang="de">biokompatibel</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020251"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biocompatible is a biological capability of a material entity that is realized as a bioactive interaction without causing harmful or unacceptable biological responses such as toxicity, inflammation, or immune reaction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Biokompatibilität ist die biologische Fähigkeit einer materiellen Einheit, die als bioaktive Interaktion realisiert wird, ohne schädliche oder inakzeptable biologische Reaktionen wie Toxizität, Entzündung oder Immunreaktion hervorzurufen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biocompatible' have not yet been formalized. The term is defined as a specific subtype of 'bioactive'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020251.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Bioactive(x) ← Biocompatible(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biocompatible&apos; then x is a &apos;bioactive&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">titanium alloys used in dental implants are biocompatible, eliciting no significant immune or inflammatory response in jaw bone</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioresorbable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Biocompatible"/>
    <rdfs:label xml:lang="en-US">bioresorbable</rdfs:label>
    <rdfs:label xml:lang="de">bioresorbierbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010025"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Bioresorbable is a biological capability of a material entity that is realized as gradual degradation and resorption by the body over time while performing its intended function</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bioresorbierbar ist die biologische Fähigkeit einer materiellen Einheit, die sich als allmählicher Abbau und Resorption durch den Körper im Laufe der Zeit bei der Erfüllung seiner beabsichtigten Funktion verwirklicht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bioresorbable' have not yet been formalized. The term is defined as a specific subtype of 'biocompatible'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010025.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Biocompatible(x) ← Bioresorbable(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bioresorbable&apos; then x is a &apos;biocompatible&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">poly-lactic acid sutures are bioresorbable, degrading by hydrolysis and being absorbed by tissue over 60 to 90 days</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioinert">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="en-US">bioinert</rdfs:label>
    <rdfs:label xml:lang="de">bioinert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010024"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Bioinert is a biological capability of a material entity that is realized as minimal or no biological response when in contact with tissue, being non-toxic and non-immunogenic</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bioinert ist die biologische Fähigkeit einer materiellen Einheit, die sich bei Kontakt mit Gewebe als minimale oder keine biologische Reaktion zeigt und ungiftig und nicht immunogen ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bioinert' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010024.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalCapability(x) ← Bioinert(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bioinert&apos; then x is a &apos;biological capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">alumina ceramic hip implant components are bioinert, remaining chemically stable with no measurable tissue response over decades</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Biodegradability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="en-US">biodegradability</rdfs:label>
    <rdfs:label xml:lang="de">Biologische Abbaubarkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0200001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biodegradability is a biological capability of a material that is realized as full microbial conversion of its organic constituents into inorganic end products within an environmentally non-harmful timescale</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter biologischer Abbaubarkeit versteht man die biologische Fähigkeit eines Materials, die durch die vollständige mikrobielle Umwandlung seiner organischen Bestandteile in anorganische Endprodukte innerhalb eines für die Umwelt ungefährlichen Zeitrahmens realisiert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biodegradability' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0200001.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalCapability(x) ← Biodegradability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biodegradability&apos; then x is a &apos;biological capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">polylactic acid mulch film exhibits biodegradability, being fully mineralized to CO2 and water by soil microbes within one growing season</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Indiscriminate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Discrimination"/>
    <rdfs:label xml:lang="en-US">indiscriminate</rdfs:label>
    <rdfs:label xml:lang="de">unterscheidungslos</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001318"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Indiscriminate quality pertains to incapability in perceiving differences between stimuli</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter wahlloser Qualität versteht man die Unfähigkeit, Unterschiede zwischen Reizen wahrzunehmen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'indiscriminate' have not yet been formalized. The term is defined as a specific subtype of 'discrimination'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001318.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Discrimination(x) ← Indiscriminate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;indiscriminate&apos; then x is a &apos;discrimination&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an indiscriminate predator such as the introduced brown tree snake consumes birds, lizards, and small mammals without selectivity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MatingCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="de">Paarungsfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">mating capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Capablity of an organism to be able to mate with another individuum for the purpose of reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Fähigkeit eines Organismus, sich zum Zwecke der Fortpflanzung mit einem anderen Individuum zu paaren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mating capability' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalCapability(x) ← MatingCapability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mating capability&apos; then x is a &apos;biological capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the mating capability of C. elegans males is assessed by the proportion that successfully inseminate hermaphrodites in crossing assays</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MosaicTrisomy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Trisomy"/>
    <rdfs:label xml:lang="de">Mosaik Trisomie</rdfs:label>
    <rdfs:label xml:lang="en-US">mosaic trisomy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001391"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mosaic trisomy quality refers to the presence of extra chromosomal material in only some cells of the organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Mosaik-Trisomiequalität versteht man das Vorhandensein von zusätzlichem Chromosomenmaterial nur in einigen Zellen des Organismus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mosaic trisomy' have not yet been formalized. The term is defined as a specific subtype of 'trisomy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001391.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Trisomy(x) ← MosaicTrisomy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mosaic trisomy&apos; then x is a &apos;trisomy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">mosaic trisomy 8 in humans involves three copies of chromosome 8 in only a subset of analyzed lymphocytes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductiveQuality"/>
    <rdfs:label xml:lang="en-US">parous</rdfs:label>
    <rdfs:label xml:lang="de">parös</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040028"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Parous quality denotes having successfully reproduced at least once</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Paröse Qualität bedeutet, dass man sich mindestens einmal erfolgreich reproduziert hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'parous' have not yet been formalized. The term is defined as a specific subtype of 'reproductive quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040028.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ReproductiveQuality(x) ← Parous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;parous&apos; then x is a &apos;reproductive quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a parous rabbit that has previously delivered at least one litter is selected as dam in pharmacological safety studies</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/IntactFemale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Female"/>
    <rdfs:label xml:lang="en-US">intact female</rdfs:label>
    <rdfs:label xml:lang="de">unversehrt weibliche</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002365"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Intact female defines possessing complete, unaltered reproductive organs</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine intakte Frau bedeutet, dass sie über vollständige, unveränderte Fortpflanzungsorgane verfügt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'intact female' have not yet been formalized. The term is defined as a specific subtype of 'female'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002365.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Female(x) ← IntactFemale(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;intact female&apos; then x is a &apos;female&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an intact female mouse retains both ovaries and the uterus, producing regular estrous cycles measurable by vaginal cytology</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Handedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Händigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">handedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002201"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Handedness refers to the unequal distribution of fine motor skills between the left and right hands or feet</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Händigkeit versteht man die ungleiche Verteilung der Feinmotorik zwischen der linken und rechten Hand bzw. dem rechten Fuß</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'handedness' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002201.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← Handedness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;handedness&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">handedness in non-human primates is quantified by the hand preference index during a tube-reaching task</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleGenotypicSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GenotypicSex"/>
    <rdfs:label xml:lang="en-US">male genotypic sex</rdfs:label>
    <rdfs:label xml:lang="de">männlicher Geschlechtsgenotyp</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0020001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male genotypic sex quality is determined by genetic composition, enabling male gonad differentiation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die genotypische Geschlechtsqualität des Mannes wird durch die genetische Zusammensetzung bestimmt und ermöglicht die Differenzierung der männlichen Keimdrüsen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male genotypic sex' have not yet been formalized. The term is defined as a specific subtype of 'genotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0020001.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">GenotypicSex(x) ← MaleGenotypicSex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male genotypic sex&apos; then x is a &apos;genotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an XY mouse embryo has male genotypic sex, with Sry expression initiating testicular differentiation in the gonadal ridge</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleGenotypicSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GenotypicSex"/>
    <rdfs:label xml:lang="en-US">female genotypic sex</rdfs:label>
    <rdfs:label xml:lang="de">genotypischer weiblicher Geschlecht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0020002"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female genotypic sex quality is determined by genotypic composition conferring capacity for female gonad differentiation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die genotypische Geschlechtsqualität einer Frau wird durch die genotypische Zusammensetzung bestimmt, die die Fähigkeit zur Differenzierung der weiblichen Keimdrüsen verleiht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female genotypic sex' have not yet been formalized. The term is defined as a specific subtype of 'genotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0020002.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">GenotypicSex(x) ← FemaleGenotypicSex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female genotypic sex&apos; then x is a &apos;genotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">an XX mouse embryo has female genotypic sex, developing ovaries in the absence of Sry expression</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalQuality"/>
    <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000428"/>
    <rdfs:label xml:lang="en-US">cellular quality</rdfs:label>
    <rdfs:label xml:lang="de">zelluläre Qualität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001396"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cellular quality encompasses traits or characteristics that exist within the cellular level of organization</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zellqualität umfasst Merkmale oder Merkmale, die innerhalb der zellulären Organisationsebene vorhanden sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cellular quality' have not yet been formalized. The term is defined as a specific subtype of 'biological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001396.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalQuality(x) ← CellularQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cellular quality&apos; then x is a &apos;biological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the secretory cellular quality of pancreatic acinar cells is reflected by their abundant zymogen granules</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Virulence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Virulenz</rdfs:label>
    <rdfs:label xml:lang="en-US">virulence</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002146"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Virulence quality pertains to the severity of an infectious disease caused by the organism in a target host</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Virulenzqualität bezieht sich auf die Schwere einer Infektionskrankheit, die durch den Organismus in einem Zielwirt verursacht wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'virulence' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002146.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Virulence(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;virulence&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the high virulence of Yersinia pestis in a rodent model results in systemic infection and mortality within 5 days</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/LeftHandedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Handedness"/>
    <rdfs:label xml:lang="de">Linkshändigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">left handedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002202"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Left handedness reflects a preference for utilizing the left hand or foot in tasks requiring singular motor dominance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Linkshändigkeit spiegelt die Vorliebe wider, die linke Hand oder den linken Fuß bei Aufgaben zu verwenden, die eine einzigartige motorische Dominanz erfordern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'left handedness' have not yet been formalized. The term is defined as a specific subtype of 'handedness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002202.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Handedness(x) ← LeftHandedness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;left handedness&apos; then x is a &apos;handedness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a gorilla consistently using the left hand for nut-cracking tasks shows left handedness in behavioral field observations</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalQuality"/>
    <rdfs:label xml:lang="en-US">organismal quality</rdfs:label>
    <rdfs:label xml:lang="de">organismen Qualität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001995"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Organismal quality encompasses biological attributes inherent in an entire organism or its parts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität eines Organismus umfasst biologische Eigenschaften, die einem gesamten Organismus oder seinen Teilen innewohnen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'organismal quality' have not yet been formalized. The term is defined as a specific subtype of 'biological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001995.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalQuality(x) ← OrganismalQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;organismal quality&apos; then x is a &apos;biological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the bioluminescent organismal quality of Photobacterium phosphoreum is measured by light emission intensity in marine environments</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/HMinus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SchizosaccharomycesPombeMatingType"/>
    <rdfs:label xml:lang="de">h Minus</rdfs:label>
    <rdfs:label xml:lang="en-US">h minus</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001345"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">H Minus refers to a Schizosaccharomyces pombe mating type determined by specific gene configurations at the mat1 locus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">H Minus bezieht sich auf einen Schizosaccharomyces pombe-Paarungstyp, der durch spezifische Genkonfigurationen am mat1-Locus bestimmt wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'h minus' have not yet been formalized. The term is defined as a specific subtype of 'schizosaccharomyces pombe mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001345.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SchizosaccharomycesPombeMatingType(x) ← HMinus(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;h minus&apos; then x is a &apos;schizosaccharomyces pombe mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">S. pombe h minus cells mate with h plus cells to form stable diploids in crosses used for genetic analysis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Cursorial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">cursorial</rdfs:label>
    <rdfs:label xml:lang="en-US">cursorial</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095002"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cursorial is a quality denoting morphological and physiological adaptations for running in the organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Cursorial ist eine Qualität, die morphologische und physiologische Anpassungen für das Laufen im Organismus bezeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cursorial' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095002.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Cursorial(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cursorial&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the cheetah Acinonyx jubatus exhibits cursorial quality with long limbs and a flexible spine enabling speeds of 110 km/h</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="en-US">biological sex</rdfs:label>
    <rdfs:label xml:lang="de">biologisches Geschlecht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000047"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biological sex defines an organismal quality enabling differentiation during reproductive processes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Biologisches Geschlecht definiert eine Eigenschaft des Organismus, die eine Differenzierung während der Fortpflanzungsverfahren ermöglicht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biological sex' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000047.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← BiologicalSex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biological sex&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">biological sex in Drosophila melanogaster is determined by the X to autosome ratio rather than the presence of a Y chromosome</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Monandrous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex"/>
    <rdfs:label xml:lang="de">monandrisch</rdfs:label>
    <rdfs:label xml:lang="en-US">monandrous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040051"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Monandrous quality signifies flowers having only one stamen</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Monandrische Qualität bedeutet, dass Blumen nur ein Staubblatt haben</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'monandrous' have not yet been formalized. The term is defined as a specific subtype of 'phenotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040051.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhenotypicSex(x) ← Monandrous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;monandrous&apos; then x is a &apos;phenotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Veronica chamaedrys has monandrous flowers containing a single functional stamen per individual bloom</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/AlphaMatingTypeYeast">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SaccharomycesCerevisiaeMatingType"/>
    <rdfs:label xml:lang="de">Alpha Paarungstyp Hefe</rdfs:label>
    <rdfs:label xml:lang="en-US">alpha mating type (yeast)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001344"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Alpha mating type (yeast) indicates yeast cells that secrete pheromones to stimulate alpha haploid yeast cells toward mating</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Alpha-Paarungstyp (Hefe) bezeichnet Hefezellen, die Pheromone absondern, um alpha-haploide Hefezellen zur Paarung anzuregen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'alpha mating type (yeast)' have not yet been formalized. The term is defined as a specific subtype of 'saccharomyces cerevisiae mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001344.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SaccharomycesCerevisiaeMatingType(x) ← AlphaMatingTypeYeast(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;alpha mating type (yeast)&apos; then x is a &apos;saccharomyces cerevisiae mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Saccharomyces cerevisiae alpha mating type cells secrete alpha-factor pheromone to arrest a mating type cells in G1 phase</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Differentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="en-US">differentiated</rdfs:label>
    <rdfs:label xml:lang="de">differenziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002099"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Differentiated is a quality signifying stable specialization into a specific cell type</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Differenziert ist eine Eigenschaft, die eine stabile Spezialisierung auf einen bestimmten Zelltyp bedeutet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'differentiated' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002099.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Differentiated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;differentiated&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a differentiated neuron expresses neurofilament proteins and long axons and no longer divides under normal conditions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="en-US">cellular potency</rdfs:label>
    <rdfs:label xml:lang="de">zelluläre Potenz</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001397"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cellular potency is a quality embodying a cell's potential for differentiation into various mature cell types</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zellwirksamkeit ist eine Eigenschaft, die das Potenzial einer Zelle zur Differenzierung in verschiedene reife Zelltypen verkörpert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cellular potency' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001397.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularQuality(x) ← CellularPotency(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cellular potency&apos; then x is a &apos;cellular quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">embryonic stem cells have maximal cellular potency, contributing to all somatic and germ cell lineages when injected into blastocysts</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/LethalSensuGenetics">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en-US">lethal (sensu genetics)</rdfs:label>
    <rdfs:label xml:lang="de">tödlich (sensu genetisch)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000718"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Lethal quality (sensu genetics) is defined by long-term survival inability in a population</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Letale Qualität (Sensu-Genetik) wird durch die langfristige Überlebensunfähigkeit einer Population definiert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lethal (sensu genetics)' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000718.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← LethalSensuGenetics(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lethal (sensu genetics)&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a lethal recessive mutation in Drosophila causes 100 percent mortality in homozygous individuals before reaching adulthood</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleSemiSterile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleFertility"/>
    <rdfs:label xml:lang="en-US">male semi-sterile</rdfs:label>
    <rdfs:label xml:lang="de">männlich halbsteril</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001762"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male semi-sterile quality suggests incomplete or impaired reproductive capability in males</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die semisterile Qualität des Mannes weist auf eine unvollständige oder beeinträchtigte Fortpflanzungsfähigkeit des Mannes hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male semi-sterile' have not yet been formalized. The term is defined as a specific subtype of 'male fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001762.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaleFertility(x) ← MaleSemiSterile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male semi-sterile&apos; then x is a &apos;male fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a male semi-sterile mouse produces sperm at reduced density, resulting in fewer than normal offspring per litter</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Triploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="de">triploid</rdfs:label>
    <rdfs:label xml:lang="en-US">triploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001381"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Triploid quality pertains to having three homologous sets of chromosomes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die triploide Qualität bezieht sich auf das Vorhandensein von drei homologen Chromosomensätzen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'triploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001381.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Triploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;triploid&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">triploid salmon produced by pressure treatment are commercially valued because they do not divert energy to reproduction</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/NonDeciduousAnyBodyPart">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Shedability"/>
    <rdfs:label xml:lang="de">nicht laubabwerfend (alle teile)</rdfs:label>
    <rdfs:label xml:lang="en-US">non-deciduous (any body part)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001732"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Non-deciduous quality defines the absence of shedding any body part by the organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Nicht-Laub-Qualität definiert das Fehlen der Abstoßung eines Körperteils durch den Organismus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'non-deciduous (any body part)' have not yet been formalized. The term is defined as a specific subtype of 'shedability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001732.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shedability(x) ← NonDeciduousAnyBodyPart(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;non-deciduous (any body part)&apos; then x is a &apos;shedability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">rhinoceros horns show non-deciduous quality, growing continuously without being shed throughout the animal's life</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fecundity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductiveQuality"/>
    <rdfs:label xml:lang="de">Fekundität</rdfs:label>
    <rdfs:label xml:lang="en-US">fecundity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000273"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Fecundity quality represents potential reproductive capacity measured by the number of gametes produced</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Fruchtbarkeitsqualität stellt die potenzielle Reproduktionskapazität dar, gemessen an der Anzahl der produzierten Gameten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fecundity' have not yet been formalized. The term is defined as a specific subtype of 'reproductive quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000273.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ReproductiveQuality(x) ← Fecundity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fecundity&apos; then x is a &apos;reproductive quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">fecundity of a Drosophila female is quantified by counting total eggs deposited over a 10-day oviposition period</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/WellDifferentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Differentiated"/>
    <rdfs:label xml:lang="de">gut differenziert</rdfs:label>
    <rdfs:label xml:lang="en-US">well differentiated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002110"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Well differentiated quality reflects possessing most cellular characteristics of the tissue of origin</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine gut differenzierte Qualität spiegelt die meisten zellulären Eigenschaften des Ursprungsgewebes wider</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'well differentiated' have not yet been formalized. The term is defined as a specific subtype of 'differentiated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002110.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Differentiated(x) ← WellDifferentiated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;well differentiated&apos; then x is a &apos;differentiated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a well differentiated thyroid papillary carcinoma retains thyroglobulin expression and follicular architecture in histological sections</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MovementBehavioralQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Bewegungsverhaltensqualität</rdfs:label>
    <rdfs:label xml:lang="en-US">movement behavioral quality</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002076"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Movement behavioral quality refers to the attribute arising from the bearer’s movement capability</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Bewegungsverhaltensqualität versteht man die Eigenschaft, die sich aus der Bewegungsfähigkeit des Trägers ergibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'movement behavioral quality' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002076.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← MovementBehavioralQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;movement behavioral quality&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the stereotyped movement behavioral quality of a Parkinson mouse model is quantified by stride length analysis on footprint tests</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000116">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en-US">Editor Note</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SchizosaccharomycesPombeMatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/YeastMatingType"/>
    <rdfs:label xml:lang="de">Schizosaccharomyces Pombe Paarungstyp</rdfs:label>
    <rdfs:label xml:lang="en-US">schizosaccharomyces pombe mating type</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001343"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Schizosaccharomyces pombe mating type is defined by gene configuration on the mat1 locus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Paarungstyp von Schizosaccharomyces pombe wird durch die Genkonfiguration am mat1-Locus definiert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'schizosaccharomyces pombe mating type' have not yet been formalized. The term is defined as a specific subtype of 'yeast mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001343.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">YeastMatingType(x) ← SchizosaccharomycesPombeMatingType(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;schizosaccharomyces pombe mating type&apos; then x is a &apos;yeast mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">schizosaccharomyces pombe mating type is determined by the mat1 locus allele, either h plus or h minus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SelfRenewal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Proliferative"/>
    <rdfs:label xml:lang="de">Selbst Erneuerung</rdfs:label>
    <rdfs:label xml:lang="en-US">self-renewal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001398"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Self-renewal quality entails a cell's ability to undergo multiple cycles of division while maintaining its undifferentiated state</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Selbsterneuerung beinhaltet die Fähigkeit einer Zelle, mehrere Teilungszyklen zu durchlaufen und dabei ihren undifferenzierten Zustand beizubehalten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'self-renewal' have not yet been formalized. The term is defined as a specific subtype of 'proliferative'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001398.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Proliferative(x) ← SelfRenewal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;self-renewal&apos; then x is a &apos;proliferative&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">hematopoietic stem cells maintain self-renewal quality by dividing asymmetrically to produce one stem cell and one progenitor</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/bibliographicCitation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SexuallyDimorphic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">geschlechtsdimorph</rdfs:label>
    <rdfs:label xml:lang="en-US">sexually dimorphic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002451"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sexually dimorphic quality indicates phenotypic differences between males and females of the same species</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die sexuell dimorphe Qualität weist auf phänotypische Unterschiede zwischen Männchen und Weibchen derselben Art hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sexually dimorphic' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002451.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← SexuallyDimorphic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sexually dimorphic&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">sexually dimorphic body size in elephant seals is extreme, with males weighing up to four times more than females</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Ploidy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="de">Ploidie</rdfs:label>
    <rdfs:label xml:lang="en-US">ploidy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001374"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ploidy quality concerns the number of homologous sets of chromosomes in a cell's nucleus or primary chromosome-containing compartment</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Ploidiequalität betrifft die Anzahl homologer Chromosomensätze im Zellkern oder im primären Chromosomen enthaltenden Kompartiment</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ploidy' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001374.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularQuality(x) ← Ploidy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ploidy&apos; then x is a &apos;cellular quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">ploidy of wheat varieties ranges from diploid in einkorn to hexaploid in common bread wheat</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fossorial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">fossorial</rdfs:label>
    <rdfs:label xml:lang="en-US">fossorial</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095003"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Fossorial quality is characterized by adaptations for digging and subterranean living</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Fossilien zeichnet sich durch Anpassungen an das Graben und das Leben im Untergrund aus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fossorial' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095003.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Fossorial(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fossorial&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the mole Talpa europaea has fossorial quality with shovel-like forelimbs adapted for excavating underground tunnels</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductionCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="de">Reproduktionsfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">reproduction capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Capablity of an organism to be able to reproduce</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Fähigkeit eines Organismus, sich fortpflanzen zu können</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'reproduction capability' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalCapability(x) ← ReproductionCapability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;reproduction capability&apos; then x is a &apos;biological capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the reproduction capability of a honeybee queen is assessed by her daily egg-laying rate of up to 2000 eggs</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleSpecific">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SexSpecific"/>
    <rdfs:label xml:lang="en-US">female-specific</rdfs:label>
    <rdfs:label xml:lang="de">weiblich-spezifisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0060003"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female-specific quality pertains to features present exclusively in females and absent in males within the same species</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Weibchenspezifische Qualität bezieht sich auf Merkmale, die ausschließlich bei Weibchen vorhanden sind und bei Männchen derselben Art fehlen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female-specific' have not yet been formalized. The term is defined as a specific subtype of 'sex-specific'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0060003.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SexSpecific(x) ← FemaleSpecific(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female-specific&apos; then x is a &apos;sex specific&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">lactation is a female-specific quality in mammals, occurring only in individuals that have given birth and possess mammary glands</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Heterophilic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularAdhesivity"/>
    <rdfs:label xml:lang="de">heterophil</rdfs:label>
    <rdfs:label xml:lang="en-US">heterophilic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001441"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Heterophilic quality describes intercellular adherence wherein molecules attach to nonidentical molecules in adjacent cells</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die heterophile Qualität beschreibt die interzelluläre Adhärenz, bei der sich Moleküle an nichtidentische Moleküle in benachbarten Zellen anlagern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'heterophilic' have not yet been formalized. The term is defined as a specific subtype of 'cellular adhesivity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001441.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularAdhesivity(x) ← Heterophilic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;heterophilic&apos; then x is a &apos;cellular adhesivity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">CD8 T cells use heterophilic adhesion through CD2 binding to LFA-3 on antigen-presenting cells during immune recognition</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BroodViability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en-US">brood viability</rdfs:label>
    <rdfs:label xml:lang="de">Überlebensfähigkeit des Nachwuchses</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001497"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Brood viability indicates the disposition of offspring to survive and develop normally</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Lebensfähigkeit der Brut gibt die Bereitschaft der Nachkommen an, zu überleben und sich normal zu entwickeln</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'brood viability' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001497.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← BroodViability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;brood viability&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">brood viability in zebrafish clutches is expressed as the percentage of fertilized eggs reaching the pharyngula stage</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SexSpecific">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SexuallyDimorphic"/>
    <rdfs:label xml:lang="de">geschlechtsspezifisch</rdfs:label>
    <rdfs:label xml:lang="en-US">sex-specific</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0060001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sex-specific quality refers to characteristics present in one sex but absent in the other within the same species</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter geschlechtsspezifischer Qualität versteht man Merkmale, die bei einem Geschlecht innerhalb derselben Art vorhanden sind, beim anderen jedoch fehlen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sex-specific' have not yet been formalized. The term is defined as a specific subtype of 'sexually dimorphic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0060001.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SexuallyDimorphic(x) ← SexSpecific(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sex-specific&apos; then x is a &apos;sexually dimorphic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the ruff Philomachus pugnax displays sex-specific ornamental plumage in males that is entirely absent in females</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PartiallyParalysed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MovementBehavioralQuality"/>
    <rdfs:label xml:lang="en-US">partially paralysed</rdfs:label>
    <rdfs:label xml:lang="de">teilweise gelähmt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001858"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Partial paralysis quality reflects incomplete loss of movement in a part or parts of the body</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität einer partiellen Lähmung spiegelt den unvollständigen Bewegungsverlust eines oder mehrerer Körperteile wider</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'partially paralysed' have not yet been formalized. The term is defined as a specific subtype of 'movement behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001858.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MovementBehavioralQuality(x) ← PartiallyParalysed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;partially paralysed&apos; then x is a &apos;movement behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a partially paralysed mouse with a hemisected spinal cord retains some hindlimb movement in the open-field test</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nd2e38bfbacdd47c397197fb4b1d4cbfc">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SequentialHermaphrodite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Hermaphrodite"/>
    <rdfs:label xml:lang="en-US">sequential hermaphrodite</rdfs:label>
    <rdfs:label xml:lang="de">sequenzieller Hermaphrodit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0070000"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sequential hermaphrodite quality is characterized by sex changes at different life stages within the organism or species</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die sequentielle hermaphroditische Qualität ist durch Geschlechtsveränderungen in verschiedenen Lebensstadien innerhalb des Organismus oder der Art gekennzeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sequential hermaphrodite' have not yet been formalized. The term is defined as a specific subtype of 'hermaphrodite'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0070000.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hermaphrodite(x) ← SequentialHermaphrodite(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sequential hermaphrodite&apos; then x is a &apos;hermaphrodite&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the clownfish Amphiprion ocellaris is a sequential hermaphrodite, transitioning from male to female when the dominant female dies</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N06e296eb4cd4410cb8e6484531f762ce">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="Nf48ffc296bde48f881cb3817d2def6e5"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nf48ffc296bde48f881cb3817d2def6e5">
    <rdf:first rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
    <rdf:rest rdf:nodeID="N909ae554adf94737bdaf7ac73a9e8618"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ProtogynousHermaphroditism">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Protogynous"/>
    <rdfs:label xml:lang="de">protogyner Hermaphroditismus</rdfs:label>
    <rdfs:label xml:lang="en-US">protogynous hermaphroditism</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040054"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Protogynous hermaphroditism occurs when organisms start life as females and become hermaphroditic during later stages</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Protogyner Hermaphroditismus tritt auf, wenn Organismen ihr Leben als Weibchen beginnen und in späteren Stadien zum Hermaphroditen werden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'protogynous hermaphroditism' have not yet been formalized. The term is defined as a specific subtype of 'protogynous'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040054.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Protogynous(x) ← ProtogynousHermaphroditism(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;protogynous hermaphroditism&apos; then x is a &apos;protogynous&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the grouper Epinephelus striatus exhibits protogynous hermaphroditism, maturing first as female before transforming to male</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000412">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en-US">Imported From</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/title">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Circling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MovementBehavioralQuality"/>
    <rdfs:label xml:lang="en-US">circling</rdfs:label>
    <rdfs:label xml:lang="de">kreisen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001911"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Circling denotes repetitive movement in a circular course exhibited by the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unter Kreisen versteht man die wiederholte Bewegung des Trägers in einem kreisförmigen Kurs</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'circling' have not yet been formalized. The term is defined as a specific subtype of 'movement behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001911.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MovementBehavioralQuality(x) ← Circling(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;circling&apos; then x is a &apos;movement behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a mouse with unilateral vestibular lesion shows circling behavior, rotating consistently toward the lesioned side</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N074a53d01a2848e09af37ab4c5c2a6a8">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
