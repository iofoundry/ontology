  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemalePseudohermaphrodite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pseudohermaphrodite"/>
    <rdfs:label xml:lang="en-US">female pseudohermaphrodite</rdfs:label>
    <rdfs:label xml:lang="de">weiblicher Pseudohermaphrodit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001829"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female pseudohermaphrodite involves internal female reproductive organs and external male sexual characteristics</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female pseudohermaphrodite' have not yet been formalized. The term is defined as a specific subtype of 'pseudohermaphrodite'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001829.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pseudohermaphrodite(x) ← FemalePseudohermaphrodite(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female pseudohermaphrodite&apos; then x is a &apos;pseudohermaphrodite&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;female pseudohermaphrodite&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Pentaploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="en-US">pentaploid</rdfs:label>
    <rdfs:label xml:lang="de">pentaploidie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001383"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pentaploid quality indicates the presence of five homologous sets of chromosomes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pentaploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001383.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Pentaploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pentaploid&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;pentaploid&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Endopolyploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="de">endopolyploid</rdfs:label>
    <rdfs:label xml:lang="en-US">endopolyploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001392"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Endopolyploid is a quality indicating increased chromosome count due to endomitosis, proportionate to endomitosis occurrence</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'endopolyploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001392.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Endopolyploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;endopolyploid&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;endopolyploid&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Receptivity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Empfänglichkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">receptivity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001719"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Receptivity quality signifies the ability to receive a stimulus or entity effectively</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'receptivity' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001719.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← Receptivity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;receptivity&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;receptivity&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Migratory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="en-US">migratory</rdfs:label>
    <rdfs:label xml:lang="de">migrierend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095008"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Migratory quality signifies adaptations facilitating long-distance, typically seasonal, movement within conspecifics</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'migratory' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095008.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Migratory(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;migratory&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;migratory&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Paralysed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MovementBehavioralQuality"/>
    <rdfs:label xml:lang="de">gelähmt</rdfs:label>
    <rdfs:label xml:lang="en-US">paralysed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000763"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Paralysed quality indicates the loss or impairment of the ability to move certain body parts</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'paralysed' have not yet been formalized. The term is defined as a specific subtype of 'movement behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000763.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MovementBehavioralQuality(x) ← Paralysed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;paralysed&apos; then x is a &apos;movement behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;paralysed&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Undifferentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="en-US">undifferentiated</rdfs:label>
    <rdfs:label xml:lang="de">undifferenziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002100"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Undifferentiated quality reflects the state of having not yet acquired specialized structure or function</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'undifferentiated' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002100.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Undifferentiated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;undifferentiated&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;undifferentiated&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Haploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Euploid"/>
    <rdfs:label xml:lang="de">Haploidy</rdfs:label>
    <rdfs:label xml:lang="en-US">haploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001375"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Haploid quality reflects the presence of a single set of homologous chromosomes within the cell</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'haploid' have not yet been formalized. The term is defined as a specific subtype of 'euploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001375.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Euploid(x) ← Haploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;haploid&apos; then x is a &apos;euploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;haploid&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GrandMultiparous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multiparous"/>
    <rdfs:label xml:lang="en-US">grand multiparous</rdfs:label>
    <rdfs:label xml:lang="de">großmultipar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002372"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Grand multiparous quality defines a viviparous organism that has given birth five or more times</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'grand multiparous' have not yet been formalized. The term is defined as a specific subtype of 'multiparous'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002372.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Multiparous(x) ← GrandMultiparous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;grand multiparous&apos; then x is a &apos;multiparous&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;grand multiparous&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Larval">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Maturity"/>
    <rdfs:label xml:lang="de">Larvenstadium</rdfs:label>
    <rdfs:label xml:lang="en-US">larval</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001185"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Larval maturity quality characterizes an organism undergoing indirect development with metamorphosis stages</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'larval' have not yet been formalized. The term is defined as a specific subtype of 'maturity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001185.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Maturity(x) ← Larval(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;larval&apos; then x is a &apos;maturity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;larval&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000114">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en-US">Has Curation Status</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/RightHandedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Handedness"/>
    <rdfs:label xml:lang="de">Rechtshändigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">right handedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002203"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Right handedness attributes preferential use of the right hand or foot for tasks demanding dominance</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'right handedness' have not yet been formalized. The term is defined as a specific subtype of 'handedness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002203.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Handedness(x) ← RightHandedness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;right handedness&apos; then x is a &apos;handedness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;right handedness&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleFertile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleFertility"/>
    <rdfs:label xml:lang="en-US">male fertile</rdfs:label>
    <rdfs:label xml:lang="de">männlich fruchtbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000891"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male fertile quality embodies a male's ability to initiate, sustain, or support reproductive processes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male fertile' have not yet been formalized. The term is defined as a specific subtype of 'male fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000891.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaleFertility(x) ← MaleFertile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male fertile&apos; then x is a &apos;male fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;male fertile&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multiparous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parity"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parous"/>
    <rdfs:label xml:lang="de">mehrfachträchtig</rdfs:label>
    <rdfs:label xml:lang="en-US">multiparous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002369"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multiparous quality defines a viviparous organism experiencing two or more successful birth cycles</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multiparous' have not yet been formalized. The term is defined as a specific subtype of 'parity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002369.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Parity(x) ← Multiparous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multiparous&apos; then x is a &apos;parity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;multiparous&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleFertility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertility"/>
    <rdfs:label xml:lang="en-US">female fertility</rdfs:label>
    <rdfs:label xml:lang="de">weibliche Fruchtbarkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000277"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female fertility quality encompasses the ability to initiate, sustain, or support reproduction from the female aspect</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female fertility' have not yet been formalized. The term is defined as a specific subtype of 'fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000277.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fertility(x) ← FemaleFertility(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female fertility&apos; then x is a &apos;fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;female fertility&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Multipotent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="de">mehrfachdifferenzierungsfähig</rdfs:label>
    <rdfs:label xml:lang="en-US">multipotent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001402"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multipotent quality involves the capability to develop into multiple differentiated cell types</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multipotent' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001402.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Multipotent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multipotent&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;multipotent&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
    <rdfs:label xml:lang="en-US">biological capability</rdfs:label>
    <rdfs:label xml:lang="de">biologische Fähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biological capability describes a capability realized through an entity in a Biological interaction, fulfilling an agent's interest</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biological capability' have not yet been formalized. The term is defined as a specific subtype of 'Capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Capability(x) ← BiologicalCapability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biological capability&apos; then x is a &apos;capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;biological capability&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioactive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="en-US">bioactive</rdfs:label>
    <rdfs:label xml:lang="de">bioaktiv</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010023"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Bioactive is a biological capability of a material entity that is realized as a specific interaction with one or more biological systems, producing a measurable biological effect such as a therapeutic, toxic, or signaling outcome</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bioactive' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010023.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalCapability(x) ← Bioactive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bioactive&apos; then x is a &apos;biological capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;bioactive&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Biocompatible">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioactive"/>
    <rdfs:label xml:lang="en-US">biocompatible</rdfs:label>
    <rdfs:label xml:lang="de">biokompatibel</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020251"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biocompatible is a biological capability of a material entity that is realized as a bioactive interaction without causing harmful or unacceptable biological responses such as toxicity, inflammation, or immune reaction</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biocompatible' have not yet been formalized. The term is defined as a specific subtype of 'bioactive'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020251.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Bioactive(x) ← Biocompatible(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biocompatible&apos; then x is a &apos;bioactive&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;biocompatible&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioresorbable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Biocompatible"/>
    <rdfs:label xml:lang="en-US">bioresorbable</rdfs:label>
    <rdfs:label xml:lang="de">bioresorbierbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010025"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Bioresorbable is a biological capability of a material entity that is realized as gradual degradation and resorption by the body over time while performing its intended function</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bioresorbable' have not yet been formalized. The term is defined as a specific subtype of 'biocompatible'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010025.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Biocompatible(x) ← Bioresorbable(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bioresorbable&apos; then x is a &apos;biocompatible&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;bioresorbable&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Bioinert">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="en-US">bioinert</rdfs:label>
    <rdfs:label xml:lang="de">bioinert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010024"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Bioinert is a biological capability of a material entity that is realized as minimal or no biological response when in contact with tissue, being non-toxic and non-immunogenic</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bioinert' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010024.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalCapability(x) ← Bioinert(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bioinert&apos; then x is a &apos;biological capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;bioinert&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Biodegradability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="en-US">biodegradability</rdfs:label>
    <rdfs:label xml:lang="de">Biologische Abbaubarkeit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0200001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biodegradability is a biological capability of a material that is realized as full microbial conversion of its organic constituents into inorganic end products within an environmentally non-harmful timescale</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biodegradability' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0200001.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalCapability(x) ← Biodegradability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biodegradability&apos; then x is a &apos;biological capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;biodegradability&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Indiscriminate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Discrimination"/>
    <rdfs:label xml:lang="en-US">indiscriminate</rdfs:label>
    <rdfs:label xml:lang="de">unterscheidungslos</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001318"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Indiscriminate quality pertains to incapability in perceiving differences between stimuli</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'indiscriminate' have not yet been formalized. The term is defined as a specific subtype of 'discrimination'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001318.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Discrimination(x) ← Indiscriminate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;indiscriminate&apos; then x is a &apos;discrimination&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;indiscriminate&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MatingCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalCapability"/>
    <rdfs:label xml:lang="de">Paarungsfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">mating capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Capablity of an organism to be able to mate with another individuum for the purpose of reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mating capability' have not yet been formalized. The term is defined as a specific subtype of 'biological capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalCapability(x) ← MatingCapability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mating capability&apos; then x is a &apos;biological capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;mating capability&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MosaicTrisomy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Trisomy"/>
    <rdfs:label xml:lang="de">Mosaik Trisomie</rdfs:label>
    <rdfs:label xml:lang="en-US">mosaic trisomy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001391"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mosaic trisomy quality refers to the presence of extra chromosomal material in only some cells of the organism</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mosaic trisomy' have not yet been formalized. The term is defined as a specific subtype of 'trisomy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001391.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Trisomy(x) ← MosaicTrisomy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mosaic trisomy&apos; then x is a &apos;trisomy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;mosaic trisomy&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Parous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductiveQuality"/>
    <rdfs:label xml:lang="en-US">parous</rdfs:label>
    <rdfs:label xml:lang="de">parös</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040028"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Parous quality denotes having successfully reproduced at least once</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'parous' have not yet been formalized. The term is defined as a specific subtype of 'reproductive quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040028.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ReproductiveQuality(x) ← Parous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;parous&apos; then x is a &apos;reproductive quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;parous&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/IntactFemale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Female"/>
    <rdfs:label xml:lang="en-US">intact female</rdfs:label>
    <rdfs:label xml:lang="de">unversehrt weibliche</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002365"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Intact female defines possessing complete, unaltered reproductive organs</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'intact female' have not yet been formalized. The term is defined as a specific subtype of 'female'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002365.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Female(x) ← IntactFemale(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;intact female&apos; then x is a &apos;female&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;intact female&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Handedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Händigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">handedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002201"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Handedness refers to the unequal distribution of fine motor skills between the left and right hands or feet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'handedness' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002201.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← Handedness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;handedness&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;handedness&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleGenotypicSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GenotypicSex"/>
    <rdfs:label xml:lang="en-US">male genotypic sex</rdfs:label>
    <rdfs:label xml:lang="de">männlicher Geschlechtsgenotyp</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0020001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male genotypic sex quality is determined by genetic composition, enabling male gonad differentiation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male genotypic sex' have not yet been formalized. The term is defined as a specific subtype of 'genotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0020001.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">GenotypicSex(x) ← MaleGenotypicSex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male genotypic sex&apos; then x is a &apos;genotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;male genotypic sex&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleGenotypicSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GenotypicSex"/>
    <rdfs:label xml:lang="en-US">female genotypic sex</rdfs:label>
    <rdfs:label xml:lang="de">genotypischer weiblicher Geschlecht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0020002"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Female genotypic sex quality is determined by genotypic composition conferring capacity for female gonad differentiation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'female genotypic sex' have not yet been formalized. The term is defined as a specific subtype of 'genotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0020002.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">GenotypicSex(x) ← FemaleGenotypicSex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;female genotypic sex&apos; then x is a &apos;genotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;female genotypic sex&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalQuality"/>
    <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000428"/>
    <rdfs:label xml:lang="en-US">cellular quality</rdfs:label>
    <rdfs:label xml:lang="de">zelluläre Qualität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001396"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cellular quality encompasses traits or characteristics that exist within the cellular level of organization</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cellular quality' have not yet been formalized. The term is defined as a specific subtype of 'biological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001396.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalQuality(x) ← CellularQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cellular quality&apos; then x is a &apos;biological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;cellular quality&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Virulence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">Virulenz</rdfs:label>
    <rdfs:label xml:lang="en-US">virulence</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002146"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Virulence quality pertains to the severity of an infectious disease caused by the organism in a target host</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'virulence' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002146.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Virulence(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;virulence&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;virulence&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/LeftHandedness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Handedness"/>
    <rdfs:label xml:lang="de">Linkshändigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">left handedness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002202"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Left handedness reflects a preference for utilizing the left hand or foot in tasks requiring singular motor dominance</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'left handedness' have not yet been formalized. The term is defined as a specific subtype of 'handedness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002202.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Handedness(x) ← LeftHandedness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;left handedness&apos; then x is a &apos;handedness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;left handedness&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalQuality"/>
    <rdfs:label xml:lang="en-US">organismal quality</rdfs:label>
    <rdfs:label xml:lang="de">organismen Qualität</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001995"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Organismal quality encompasses biological attributes inherent in an entire organism or its parts</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'organismal quality' have not yet been formalized. The term is defined as a specific subtype of 'biological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001995.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalQuality(x) ← OrganismalQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;organismal quality&apos; then x is a &apos;biological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;organismal quality&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/HMinus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SchizosaccharomycesPombeMatingType"/>
    <rdfs:label xml:lang="de">h Minus</rdfs:label>
    <rdfs:label xml:lang="en-US">h minus</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001345"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">H Minus refers to a Schizosaccharomyces pombe mating type determined by specific gene configurations at the mat1 locus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'h minus' have not yet been formalized. The term is defined as a specific subtype of 'schizosaccharomyces pombe mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001345.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SchizosaccharomycesPombeMatingType(x) ← HMinus(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;h minus&apos; then x is a &apos;schizosaccharomyces pombe mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;h minus&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Cursorial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="de">cursorial</rdfs:label>
    <rdfs:label xml:lang="en-US">cursorial</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0095002"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cursorial is a quality denoting morphological and physiological adaptations for running in the organism</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cursorial' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0095002.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← Cursorial(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cursorial&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;cursorial&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OrganismalQuality"/>
    <rdfs:label xml:lang="en-US">biological sex</rdfs:label>
    <rdfs:label xml:lang="de">biologisches Geschlecht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000047"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biological sex defines an organismal quality enabling differentiation during reproductive processes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biological sex' have not yet been formalized. The term is defined as a specific subtype of 'organismal quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000047.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganismalQuality(x) ← BiologicalSex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biological sex&apos; then x is a &apos;organismal quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;biological sex&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Monandrous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PhenotypicSex"/>
    <rdfs:label xml:lang="de">monandrisch</rdfs:label>
    <rdfs:label xml:lang="en-US">monandrous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040051"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Monandrous quality signifies flowers having only one stamen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'monandrous' have not yet been formalized. The term is defined as a specific subtype of 'phenotypic sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040051.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhenotypicSex(x) ← Monandrous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;monandrous&apos; then x is a &apos;phenotypic sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;monandrous&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/AlphaMatingTypeYeast">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SaccharomycesCerevisiaeMatingType"/>
    <rdfs:label xml:lang="de">Alpha Paarungstyp Hefe</rdfs:label>
    <rdfs:label xml:lang="en-US">alpha mating type (yeast)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001344"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Alpha mating type (yeast) indicates yeast cells that secrete pheromones to stimulate alpha haploid yeast cells toward mating</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'alpha mating type (yeast)' have not yet been formalized. The term is defined as a specific subtype of 'saccharomyces cerevisiae mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001344.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SaccharomycesCerevisiaeMatingType(x) ← AlphaMatingTypeYeast(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;alpha mating type (yeast)&apos; then x is a &apos;saccharomyces cerevisiae mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;alpha mating type (yeast)&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Differentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency"/>
    <rdfs:label xml:lang="en-US">differentiated</rdfs:label>
    <rdfs:label xml:lang="de">differenziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002099"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Differentiated is a quality signifying stable specialization into a specific cell type</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'differentiated' have not yet been formalized. The term is defined as a specific subtype of 'cellular potency'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002099.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularPotency(x) ← Differentiated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;differentiated&apos; then x is a &apos;cellular potency&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;differentiated&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularPotency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/CellularQuality"/>
    <rdfs:label xml:lang="en-US">cellular potency</rdfs:label>
    <rdfs:label xml:lang="de">zelluläre Potenz</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001397"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cellular potency is a quality embodying a cell's potential for differentiation into various mature cell types</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cellular potency' have not yet been formalized. The term is defined as a specific subtype of 'cellular quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001397.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CellularQuality(x) ← CellularPotency(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cellular potency&apos; then x is a &apos;cellular quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;cellular potency&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/LethalSensuGenetics">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en-US">lethal (sensu genetics)</rdfs:label>
    <rdfs:label xml:lang="de">tödlich (sensu genetisch)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000718"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Lethal quality (sensu genetics) is defined by long-term survival inability in a population</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lethal (sensu genetics)' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000718.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← LethalSensuGenetics(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lethal (sensu genetics)&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;lethal (sensu genetics)&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleSemiSterile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MaleFertility"/>
    <rdfs:label xml:lang="en-US">male semi-sterile</rdfs:label>
    <rdfs:label xml:lang="de">männlich halbsteril</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001762"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Male semi-sterile quality suggests incomplete or impaired reproductive capability in males</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'male semi-sterile' have not yet been formalized. The term is defined as a specific subtype of 'male fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001762.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaleFertility(x) ← MaleSemiSterile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;male semi-sterile&apos; then x is a &apos;male fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;male semi-sterile&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Triploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid"/>
    <rdfs:label xml:lang="de">triploid</rdfs:label>
    <rdfs:label xml:lang="en-US">triploid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001381"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Triploid quality pertains to having three homologous sets of chromosomes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'triploid' have not yet been formalized. The term is defined as a specific subtype of 'polyploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001381.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Polyploid(x) ← Triploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;triploid&apos; then x is a &apos;polyploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;triploid&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/NonDeciduousAnyBodyPart">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Shedability"/>
    <rdfs:label xml:lang="de">nicht laubabwerfend (alle teile)</rdfs:label>
    <rdfs:label xml:lang="en-US">non-deciduous (any body part)</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001732"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Non-deciduous quality defines the absence of shedding any body part by the organism</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'non-deciduous (any body part)' have not yet been formalized. The term is defined as a specific subtype of 'shedability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001732.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shedability(x) ← NonDeciduousAnyBodyPart(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;non-deciduous (any body part)&apos; then x is a &apos;shedability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;non-deciduous (any body part)&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fecundity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ReproductiveQuality"/>
    <rdfs:label xml:lang="de">Fekundität</rdfs:label>
    <rdfs:label xml:lang="en-US">fecundity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000273"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Fecundity quality represents potential reproductive capacity measured by the number of gametes produced</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fecundity' have not yet been formalized. The term is defined as a specific subtype of 'reproductive quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000273.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ReproductiveQuality(x) ← Fecundity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fecundity&apos; then x is a &apos;reproductive quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;fecundity&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/WellDifferentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Differentiated"/>
    <rdfs:label xml:lang="de">gut differenziert</rdfs:label>
    <rdfs:label xml:lang="en-US">well differentiated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002110"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Well differentiated quality reflects possessing most cellular characteristics of the tissue of origin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'well differentiated' have not yet been formalized. The term is defined as a specific subtype of 'differentiated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002110.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Differentiated(x) ← WellDifferentiated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;well differentiated&apos; then x is a &apos;differentiated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;well differentiated&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MovementBehavioralQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Bewegungsverhaltensqualität</rdfs:label>
    <rdfs:label xml:lang="en-US">movement behavioral quality</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002076"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Movement behavioral quality refers to the attribute arising from the bearer’s movement capability</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'movement behavioral quality' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002076.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← MovementBehavioralQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;movement behavioral quality&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;movement behavioral quality&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000116">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
