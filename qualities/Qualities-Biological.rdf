  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/GenotypicSex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalSex"/>
    <rdfs:label xml:lang="en-US">genotypic sex</rdfs:label>
    <rdfs:label xml:lang="de">genotypisches Geschlecht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0020000"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Genotypic sex quality describes the genetic composition of sex chromosomes that determine an organism's sex</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'genotypic sex' have not yet been formalized. The term is defined as a specific subtype of 'biological sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0020000.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalSex(x) ← GenotypicSex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;genotypic sex&apos; then x is a &apos;biological sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;genotypic sex&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SaccharomycesCerevisiaeMatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/YeastMatingType"/>
    <rdfs:label xml:lang="de">Saccharomyces Cerevisiae Paarungstyp</rdfs:label>
    <rdfs:label xml:lang="en-US">saccharomyces cerevisiae mating type</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001342"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saccharomyces cerevisiae mating type identifies specific reproductive cell types in yeast</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saccharomyces cerevisiae mating type' have not yet been formalized. The term is defined as a specific subtype of 'yeast mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001342.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">YeastMatingType(x) ← SaccharomycesCerevisiaeMatingType(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saccharomyces cerevisiae mating type&apos; then x is a &apos;yeast mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;saccharomyces cerevisiae mating type&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Mononucleate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Nucleated"/>
    <rdfs:label xml:lang="en-US">mononucleate</rdfs:label>
    <rdfs:label xml:lang="de">mononukleär</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001407"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mononucleate quality is characterized by having a singular nucleus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mononucleate' have not yet been formalized. The term is defined as a specific subtype of 'nucleated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001407.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Nucleated(x) ← Mononucleate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mononucleate&apos; then x is a &apos;nucleated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;mononucleate&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/OvariectomizedFemale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleSterile"/>
    <rdfs:label xml:lang="en-US">ovariectomized female</rdfs:label>
    <rdfs:label xml:lang="de">ovariektomierte Frau</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002380"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ovariectomized female quality describes infertility due to surgical removal of ovaries</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ovariectomized female' have not yet been formalized. The term is defined as a specific subtype of 'female sterile'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002380.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">FemaleSterile(x) ← OvariectomizedFemale(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ovariectomized female&apos; then x is a &apos;female sterile&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;ovariectomized female&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/ModeratelyWellDifferentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Differentiated"/>
    <rdfs:label xml:lang="en-US">moderately well differentiated</rdfs:label>
    <rdfs:label xml:lang="de">mäßig gut differenziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002111"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Moderately well differentiated denotes cells lacking few of the cellular characteristics necessary for full differentiation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'moderately well differentiated' have not yet been formalized. The term is defined as a specific subtype of 'differentiated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002111.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Differentiated(x) ← ModeratelyWellDifferentiated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;moderately well differentiated&apos; then x is a &apos;differentiated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;moderately well differentiated&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Sterile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Fertility"/>
    <rdfs:label xml:lang="en-US">sterile</rdfs:label>
    <rdfs:label xml:lang="de">unfruchtbar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000956"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sterile quality reflects inability to initiate, sustain, or support reproduction</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sterile' have not yet been formalized. The term is defined as a specific subtype of 'fertility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000956.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fertility(x) ← Sterile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sterile&apos; then x is a &apos;fertility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;sterile&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Polyploid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Euploid"/>
    <rdfs:label xml:lang="en-US">polyploid</rdfs:label>
    <rdfs:label xml:lang="de">polyploidie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001377"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Polyploid quality involves possessing more than two homologous sets of chromosomes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'polyploid' have not yet been formalized. The term is defined as a specific subtype of 'euploid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001377.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Euploid(x) ← Polyploid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;polyploid&apos; then x is a &apos;euploid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;polyploid&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb0c0f019f708479a800fa1e5e212e852">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="N8710a39c0392454db98f55505d6322ac"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehaviouralActive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehaviouralActivity"/>
    <rdfs:label xml:lang="en-US">behavioural active</rdfs:label>
    <rdfs:label xml:lang="de">verhaltensaktiv</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001707"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Behavioural active is a quality manifested through significant activity demonstrated by the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'behavioural active' have not yet been formalized. The term is defined as a specific subtype of 'behavioural activity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001707.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehaviouralActivity(x) ← BehaviouralActive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;behavioural active&apos; then x is a &apos;behavioural activity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;behavioural active&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202507/qualities/Qualities-Biological/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <dcterms:abstract xml:lang="en-us">The IOF Biological Qualities Ontology aims to represent the generic constructs (including classes and properties) related to biological qualities.</dcterms:abstract>
    <dcterms:contributor xml:lang="en-us">Thomas Hanke, Fraunhofer IWM</dcterms:contributor>
    <dcterms:creator xml:lang="en-us">IOF Materials Working Group</dcterms:creator>
    <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
    <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
    <dcterms:references rdf:resource="http://spec.org/dc/terms/"/>
    <dcterms:references rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    <dcterms:title xml:lang="en-us">Industrial Ontology Foundry (IOF) Biological Qualities Ontology</dcterms:title>
    <rdfs:label xml:lang="en-us">Biological Qualities Ontology</rdfs:label>
    <iof-av:copyright>Industrial Ontology Foundry (IOF)</iof-av:copyright>
    <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalSex"/>
    <rdfs:label xml:lang="de">Geschlechtstypen</rdfs:label>
    <rdfs:label xml:lang="en-US">mating type</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001895"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mating type quality characterizes the sexual reproduction potential in an individual or a population</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mating type' have not yet been formalized. The term is defined as a specific subtype of 'biological sex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001895.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BiologicalSex(x) ← MatingType(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mating type&apos; then x is a &apos;biological sex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;mating type&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Protogynous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SequentialHermaphrodite"/>
    <rdfs:label xml:lang="de">protogynisch</rdfs:label>
    <rdfs:label xml:lang="en-US">protogynous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040052"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Protogynous quality identifies organisms that start life as females and transition to males</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'protogynous' have not yet been formalized. The term is defined as a specific subtype of 'sequential hermaphrodite'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040052.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SequentialHermaphrodite(x) ← Protogynous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;protogynous&apos; then x is a &apos;sequential hermaphrodite&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;protogynous&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Alive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en-US">alive</rdfs:label>
    <rdfs:label xml:lang="de">lebendig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001421"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Alive is a viability status reflecting a viability quality wherein the bearer is conditionally existent prior to the cessation of life</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'alive' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001421.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← Alive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;alive&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;alive&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N909ae554adf94737bdaf7ac73a9e8618">
    <rdf:first rdf:nodeID="Nae06ee5764c54ea0807a5c6e4b19a860"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Immortal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Viability"/>
    <rdfs:label xml:lang="en-US">immortal</rdfs:label>
    <rdfs:label xml:lang="de">unsterblich</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001991"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Immortal quality involves the disposition to possess indefinite growth and division capabilities</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'immortal' have not yet been formalized. The term is defined as a specific subtype of 'viability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001991.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Viability(x) ← Immortal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;immortal&apos; then x is a &apos;viability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;immortal&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BiologicalAction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <owl:equivalentClass rdf:nodeID="Nb0c0f019f708479a800fa1e5e212e852"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Action"/>
    <rdfs:label xml:lang="en-US">biological action</rdfs:label>
    <rdfs:label xml:lang="de">biologische Aktion</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Biological action represents a stimulus enacting a biological interaction with an object</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en-US">BiologicalAction(x) ↔ (∃b ((obo:BFO_0000040(b) ∧ ∃c (BiologicalRelationalQuality(c) ∧ hasQuality(b, c))) ∧ obo:BFO_0000057(x, b)) ∨ ∃d (BiologicProcessCharacteristic(d) ∧ hasProcessCharacteristic(x, d)))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-US">every instance of 'biological action' is defined as exactly an instance of 'that 'obo:BFO_0000057' some an instance of 'BFO_0000040' and that 'hasQuality' some 'biological relational quality'' or 'that 'hasProcessCharacteristic' some 'biologic process characteristic''</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Discrimination">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/BehavioralQuality"/>
    <rdfs:label xml:lang="de">Diskriminierung</rdfs:label>
    <rdfs:label xml:lang="en-US">discrimination</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000189"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Discrimination is a quality referring to the ability to discern between different stimuli</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'discrimination' have not yet been formalized. The term is defined as a specific subtype of 'behavioral quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000189.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BehavioralQuality(x) ← Discrimination(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;discrimination&apos; then x is a &apos;behavioral quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;discrimination&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Herbaceous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Shedability"/>
    <rdfs:label xml:lang="en-US">herbaceous</rdfs:label>
    <rdfs:label xml:lang="de">krautartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002352"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Herbaceous quality describes the dieback of plant upper parts to the rootstock at the conclusion of the growing season</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'herbaceous' have not yet been formalized. The term is defined as a specific subtype of 'shedability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002352.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shedability(x) ← Herbaceous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;herbaceous&apos; then x is a &apos;shedability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;herbaceous&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/PoorlyDifferentiated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Differentiated"/>
    <rdfs:label xml:lang="en-US">poorly differentiated</rdfs:label>
    <rdfs:label xml:lang="de">schlecht differenziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002106"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Poorly differentiated quality reflects lacking most cellular characteristics necessary for full differentiation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'poorly differentiated' have not yet been formalized. The term is defined as a specific subtype of 'differentiated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002106.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Differentiated(x) ← PoorlyDifferentiated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;poorly differentiated&apos; then x is a &apos;differentiated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;poorly differentiated&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/YeastMatingType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/MatingType"/>
    <rdfs:label xml:lang="de">hefeartige Befruchtung</rdfs:label>
    <rdfs:label xml:lang="en-US">yeast mating type</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001337"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Yeast mating type describes distinctions among the reproductive cell types in yeast</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'yeast mating type' have not yet been formalized. The term is defined as a specific subtype of 'mating type'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001337.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MatingType(x) ← YeastMatingType(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;yeast mating type&apos; then x is a &apos;mating type&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;yeast mating type&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/FemaleSemiFertile">
