  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/SequentialHermaphrodite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Biological/Hermaphrodite"/>
    <rdfs:label xml:lang="en">sequential hermaphrodite</rdfs:label>
    <rdfs:label xml:lang="de">sequenzieller Hermaphrodit</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0070000"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Sequential hermaphrodite quality is characterized by sex changes at different life stages within the organism or species</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'sequential hermaphrodite' have not yet been formalized. The term is defined as a specific subtype of 'hermaphrodite'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0070000.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N06e296eb4cd4410cb8e6484531f762ce">
