    <rdfs:label xml:lang="de">Verhaltensqualität</rdfs:label>
    <rdfs:label xml:lang="en">behavioral quality</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000186"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Behavioral quality denotes the aggregate of responses, reactions, or movements exhibited in a specific context</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
