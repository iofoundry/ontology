    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002370"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Branching pattern characterized by loops formed between adjacent secondary veins</iof-av:naturalLanguageDefinition>
