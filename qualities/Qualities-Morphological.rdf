    <rdfs:label xml:lang="de">verstopft</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001836"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Structural quality characterized by overcrowded or overloaded elements</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
