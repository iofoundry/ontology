    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000377"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Twisted characteristic oriented towards the tongue or inside oral cavity</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
