    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;reinforced&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;reinforced&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Retrorse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
