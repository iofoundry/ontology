    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0005003"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Quality inhering in a bearer by virtue of resembling the form of a paddle</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
