    <rdfs:label xml:lang="de">expandiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002452"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Structural quality depicting expansion or loosening after being condensed</iof-av:naturalLanguageDefinition>
