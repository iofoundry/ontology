<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
   xmlns:obo="http://purl.obolibrary.org/obo/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fibrillary">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">fibrillary</rdfs:label>
    <rdfs:label xml:lang="de">fibrillär</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002134"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation indicating the presence of fibril formations or very fine fibers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Beobachtung der Zusammensetzung weist auf das Vorhandensein von Fibrillenformationen oder sehr feinen Fasern hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fibrillary' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002134.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Fibrillary(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fibrillary&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Muscle tissue in cardiac myopathy shows fibrillary architecture with fragmented fine-fiber bundles visible under microscopy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cut">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">cut</rdfs:label>
    <rdfs:label xml:lang="de">geschnitten</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001978"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape quality characterized by an incision or division in a material</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formqualität, gekennzeichnet durch einen Einschnitt oder eine Teilung in einem Material</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cut' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001978.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Cut(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cut&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A surgical incision in human skin exhibits a cut quality, leaving a clean linear division through the dermis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sloped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">geneigt</rdfs:label>
    <rdfs:label xml:lang="en-US">sloped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001481"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sloped is a shape quality inhering in a bearer by virtue of having an oblique or slanted direction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schräg ist eine Formeigenschaft, die einem Träger aufgrund seiner schrägen oder schrägen Richtung innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sloped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001481.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Sloped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sloped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sloped surface of a whale fluke transitions at an oblique angle from the dorsal midline to the tip</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Grey">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">grau</rdfs:label>
    <rdfs:label xml:lang="en-US">grey</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000950"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue with equal values of black and white, lacking chromatic color</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit gleichen Anteilen von Schwarz und Weiß, ohne chromatische Farbe</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'grey' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000950.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Grey(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;grey&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The grey pelage of a timber wolf reflects the neutral coloration typical of boreal forest mammals</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SplitLaterally">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Split"/>
    <rdfs:label xml:lang="de">längsgespalten</rdfs:label>
    <rdfs:label xml:lang="en-US">split laterally</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002170"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Split laterally is a shape quality inhering in a bearer due to being split asymmetrically on one side</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Seitlich gespalten ist eine Formeigenschaft, die einem Träger innewohnt, da er auf einer Seite asymmetrisch gespalten ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'split laterally' have not yet been formalized. The term is defined as a specific subtype of 'split'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002170.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Split(x) ← SplitLaterally(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;split laterally&apos; then x is a &apos;split&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The labellum of the orchid Ophrys apifera is split laterally, creating an asymmetric lobe on one side</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape3D"/>
    <rdfs:label xml:lang="en-US">concave 3-d shape</rdfs:label>
    <rdfs:label xml:lang="de">konkave 3-d form</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002008"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">3D shape characterized by an inward curve on its surface, forming a hollow</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">3D-Form, gekennzeichnet durch eine nach innen gerichtete Krümmung der Oberfläche, die eine Mulde bildet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'concave 3-d shape' have not yet been formalized. The term is defined as a specific subtype of 'shape3 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002008.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape3D(x) ← Concave3DShape(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;concave 3-d shape&apos; then x is a &apos;shape3 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The acetabulum of the human pelvis presents a concave 3-D shape that articulates with the femoral head</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Arachnose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy"/>
    <rdfs:label xml:lang="en-US">arachnose</rdfs:label>
    <rdfs:label xml:lang="de">spinnwebenartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002344"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Hairy quality resembling spider webs</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Behaarte Qualität, die an Spinnennetze erinnert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'arachnose' have not yet been formalized. The term is defined as a specific subtype of 'hairy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002344.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hairy(x) ← Arachnose(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;arachnose&apos; then x is a &apos;hairy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cap surface of Amanita muscaria displays arachnose texture from fine web-like fibers across the cuticle</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Disconnected">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">disconnected</rdfs:label>
    <rdfs:label xml:lang="de">getrennt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0010001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality indicating separation or lack of continuity between components</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, die auf eine Trennung oder mangelnde Kontinuität zwischen Komponenten hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'disconnected' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0010001.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Disconnected(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;disconnected&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">In a fractured vertebra, the bony fragments appear disconnected with visible separation between cortical pieces</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pilosity"/>
    <rdfs:label xml:lang="de">haarig</rdfs:label>
    <rdfs:label xml:lang="en-US">hairy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000454"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pilosity quality marked by the presence of hair or hair-like structures on a surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Behaarungsqualität, gekennzeichnet durch das Vorhandensein von Haaren oder haarähnlichen Strukturen auf einer Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hairy' have not yet been formalized. The term is defined as a specific subtype of 'pilosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000454.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pilosity(x) ← Hairy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hairy&apos; then x is a &apos;pilosity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stem of Urtica dioica is hairy, densely covered with stinging trichomes along its entire length</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RadialSymmetry">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Symmetry"/>
    <rdfs:label xml:lang="en-US">radial symmetry</rdfs:label>
    <rdfs:label xml:lang="de">radialsymmetrie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001325"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Symmetry characterized by identical parts arranged around a central axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Symmetrie, gekennzeichnet durch identische Teile, die um eine Mittelachse angeordnet sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'radial symmetry' have not yet been formalized. The term is defined as a specific subtype of 'symmetry'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001325.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Symmetry(x) ← RadialSymmetry(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;radial symmetry&apos; then x is a &apos;symmetry&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The body plan of Asterias rubens exhibits radial symmetry with five equivalent arms radiating from a central disc</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spherical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spheroid"/>
    <rdfs:label xml:lang="de">kugelig</rdfs:label>
    <rdfs:label xml:lang="en-US">spherical</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001499"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Resembling a ball with equal equatorial and polar diameters</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ähnelt einer Kugel mit gleichen äquatorialen und polaren Durchmessern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spherical' have not yet been formalized. The term is defined as a specific subtype of 'spheroid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001499.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spheroid(x) ← Spherical(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spherical&apos; then x is a &apos;spheroid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pollen grain of Lilium candidum is spherical, with equal dimensions along all axes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rounded">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">gerundet</rdfs:label>
    <rdfs:label xml:lang="en-US">rounded</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001065"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by curves or circular borders with smooth transitions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, gekennzeichnet durch Kurven oder kreisförmige Ränder mit sanften Übergängen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rounded' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001065.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Rounded(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rounded&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tips of mammalian fingernails are rounded, lacking any sharp angular termination</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Vacant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavitated"/>
    <rdfs:label xml:lang="de">leer</rdfs:label>
    <rdfs:label xml:lang="en-US">vacant</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000264"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cavity quality characterized by consistency lacking material or content</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Hohlraumqualität, gekennzeichnet durch Konsistenz ohne Material oder Inhalt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'vacant' have not yet been formalized. The term is defined as a specific subtype of 'cavitated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000264.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavitated(x) ← Vacant(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;vacant&apos; then x is a &apos;cavitated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bone marrow cavity of a long bone is vacant in aplastic anemia, devoid of normal hematopoietic cells</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shaggy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy"/>
    <rdfs:label xml:lang="en-US">shaggy</rdfs:label>
    <rdfs:label xml:lang="de">zottelig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001871"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Hairy quality marked by long, unkempt hair or fibers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Haarige Qualität, gekennzeichnet durch lange, ungepflegte Haare oder Fasern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shaggy' have not yet been formalized. The term is defined as a specific subtype of 'hairy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001871.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hairy(x) ← Shaggy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shaggy&apos; then x is a &apos;hairy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mane of Panthera leo is shaggy, composed of long unkempt hairs surrounding the head and neck</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/FluidFilled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavitated"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities"/>
    <rdfs:label xml:lang="en-US">fluid filled</rdfs:label>
    <rdfs:label xml:lang="de">flüssigkeitsgefüllt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002409"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cavity quality characterized by being filled with liquid substances</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Hohlraumqualität, die sich durch die Füllung mit flüssigen Stoffen auszeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fluid filled' have not yet been formalized. The term is defined as a specific subtype of 'cavitated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002409.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavitated(x) ← FluidFilled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fluid filled&apos; then x is a &apos;cavitated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">An ovarian follicle is fluid filled, containing antral fluid within the follicular chamber</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Bronze">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brown"/>
    <rdfs:label xml:lang="de">bronze</rdfs:label>
    <rdfs:label xml:lang="en-US">bronze</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002363"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color consisting of brown hue with a metallic sheen</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbe bestehend aus einem braunen Farbton mit metallischem Glanz</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bronze' have not yet been formalized. The term is defined as a specific subtype of 'brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002363.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Brown(x) ← Bronze(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bronze&apos; then x is a &apos;brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The elytra of the beetle Chalcophora mariana display a bronze coloration with metallic brown-gold sheen</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Coiled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Coiling"/>
    <rdfs:label xml:lang="en-US">coiled</rdfs:label>
    <rdfs:label xml:lang="de">gewunden</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000404"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Coiling quality involving a spiral or cylindrical twisting arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Wickelqualität mit spiralförmiger oder zylindrischer Verdrillung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'coiled' have not yet been formalized. The term is defined as a specific subtype of 'coiling'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000404.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Coiling(x) ← Coiled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;coiled&apos; then x is a &apos;coiling&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The shell of Nautilus pompilius is coiled in a tight logarithmic spiral around a central axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Quadrangular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="de">viereckig</rdfs:label>
    <rdfs:label xml:lang="en-US">quadrangular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001988"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Quadrangular is a shape quality inhering in a bearer by virtue of having four angles and four sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Viereckig ist eine Formeigenschaft, die einem Träger innewohnt, weil er vier Winkel und vier Seiten hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'quadrangular' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001988.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← Quadrangular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;quadrangular&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cross-section of the human femur midshaft appears quadrangular with four recognizable sides and corners</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Laminar">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">laminar</rdfs:label>
    <rdfs:label xml:lang="en-US">laminar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002124"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality indicating arrangement into thin, flat layers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, die die Anordnung in dünnen, flachen Schichten anzeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'laminar' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002124.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Laminar(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;laminar&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The laminar bone tissue of large dinosaur femora shows parallel layers of compact bone arranged in flat sheets</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Collagenous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">collagenous</rdfs:label>
    <rdfs:label xml:lang="de">kollagenartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002462"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation indicating the presence of collagen fibers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beobachtung der Zusammensetzung, die auf das Vorhandensein von Kollagenfasern hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'collagenous' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002462.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Collagenous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;collagenous&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dermis of mammalian skin is collagenous, with dense interwoven collagen fiber bundles conferring tensile strength</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nd8a3b2d3b87c4dd582a295aba650e1e6">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000057"/>
    <owl:someValuesFrom rdf:nodeID="N8f5052841bf4431d9d0c9ac85882f126"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Caseous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">caseous</rdfs:label>
    <rdfs:label xml:lang="de">käsig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002109"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure quality exhibiting a cheese-like appearance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität mit käseähnlichem Aussehen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'caseous' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002109.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Caseous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;caseous&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Tuberculous lymph nodes develop a caseous center, appearing cheese-like with soft crumbling white material</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cicatricial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">cicatricial</rdfs:label>
    <rdfs:label xml:lang="de">vernarbt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002421"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape quality marked by scar tissue development, exhibiting irregular texture and appearance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Formqualität ist durch die Entwicklung von Narbengewebe gekennzeichnet und weist eine unregelmäßige Textur und ein unregelmäßiges Erscheinungsbild auf</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cicatricial' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002421.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Cicatricial(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cicatricial&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Healed burn tissue in human skin shows a cicatricial quality with irregular fibrous replacement of normal dermis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Colorless">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ColorPattern"/>
    <rdfs:label xml:lang="en-US">colorless</rdfs:label>
    <rdfs:label xml:lang="de">farblos</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000337"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color pattern lacking perceivable hues</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbmuster ohne wahrnehmbare Farbtöne</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'colorless' have not yet been formalized. The term is defined as a specific subtype of 'color pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000337.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ColorPattern(x) ← Colorless(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;colorless&apos; then x is a &apos;color pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The glass sponge Euplectella aspergillum produces colorless siliceous spicules that transmit light without pigmentation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SplayedVentral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Splayed"/>
    <rdfs:label xml:lang="en-US">splayed ventral</rdfs:label>
    <rdfs:label xml:lang="de">ventral gespreizte</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002154"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Splayed ventral is a curvature quality inhering in a bearer by virtue of being curved outwards towards the abdomen of an organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die gespreizte ventrale Form ist eine Krümmungseigenschaft, die einem Träger dadurch innewohnt, dass er nach außen zum Bauch eines Organismus hin gebogen ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'splayed ventral' have not yet been formalized. The term is defined as a specific subtype of 'splayed'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002154.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Splayed(x) ← SplayedVentral(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;splayed ventral&apos; then x is a &apos;splayed&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The costal cartilages of the ribcage exhibit splayed ventral curvature, bending outward toward the abdomen</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brookhidodromous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branched"/>
    <rdfs:label xml:lang="de">brochidodrom</rdfs:label>
    <rdfs:label xml:lang="en-US">brookhidodromous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002370"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Branching pattern characterized by loops formed between adjacent secondary veins</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verzweigungsmuster, gekennzeichnet durch Schleifen, die zwischen benachbarten sekundären Adern gebildet werden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'brookhidodromous' have not yet been formalized. The term is defined as a specific subtype of 'branched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002370.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branched(x) ← Brookhidodromous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;brookhidodromous&apos; then x is a &apos;branched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Leaf venation in Alnus glutinosa is brookhidodromous, with loops connecting adjacent secondary veins near the margin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spatulate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Oblong"/>
    <rdfs:label xml:lang="de">spatelatartig</rdfs:label>
    <rdfs:label xml:lang="en-US">spatulate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001937"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatulate is a shape quality inhering in a bearer by virtue of being oblong, with the lower end very much attenuated</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Spatel ist eine Formeigenschaft, die einem Träger innewohnt, weil er länglich ist, wobei das untere Ende sehr stark abgeschwächt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spatulate' have not yet been formalized. The term is defined as a specific subtype of 'oblong'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001937.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Oblong(x) ← Spatulate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spatulate&apos; then x is a &apos;oblong&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spatulate leaves of Plantago major broaden distally into a wide blade attached by a narrow petiole</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000428"/>
    <rdfs:label xml:lang="de">Struktur</rdfs:label>
    <rdfs:label xml:lang="en-US">structure</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000141"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure is a morphology quality inhering in a bearer by virtue of how it is perceived by humans in aspects like overall composition, wholeness, or functionality</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Struktur ist eine morphologische Qualität, die einem Träger dadurch innewohnt, dass sie vom Menschen in Aspekten wie Gesamtzusammensetzung, Ganzheit oder Funktionalität wahrgenommen wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'structure' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000141.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← Structure(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;structure&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The trabecular structure of cancellous bone provides a lightweight scaffolding observable in cross-section</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/WedgeShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Triangular"/>
    <rdfs:label xml:lang="de">keilförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">wedge shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002423"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Triangular shape resembling a wedge, broad at one end and tapering to a point at the other</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Dreieckige Form, die einem Keil ähnelt, an einem Ende breit und am anderen Ende spitz zulaufend</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'wedge shaped' have not yet been formalized. The term is defined as a specific subtype of 'triangular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002423.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Triangular(x) ← WedgeShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;wedge shaped&apos; then x is a &apos;triangular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cuneate bone of the human foot is wedge shaped, broader proximally and narrowing distally</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PalePurple">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Purple"/>
    <rdfs:label xml:lang="de">blass violett</rdfs:label>
    <rdfs:label xml:lang="en-US">pale purple</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002013"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Purple hue reduced in brightness or intensity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Helligkeit oder Intensität des violetten Farbtons wird reduziert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale purple' have not yet been formalized. The term is defined as a specific subtype of 'purple'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002013.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Purple(x) ← PalePurple(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale purple&apos; then x is a &apos;purple&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The flowers of Lavandula angustifolia show pale purple petals reduced in color intensity compared to deep lavender</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DesaturatedPurple">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Purple"/>
    <rdfs:label xml:lang="en-US">desaturated purple</rdfs:label>
    <rdfs:label xml:lang="de">entsättigtes Lila</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001282"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue where purple tones are blended with white or grey, decreasing vibrancy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, bei dem violette Töne mit Weiß oder Grau gemischt werden, wodurch die Lebendigkeit verringert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'desaturated purple' have not yet been formalized. The term is defined as a specific subtype of 'purple'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001282.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Purple(x) ← DesaturatedPurple(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;desaturated purple&apos; then x is a &apos;purple&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The aging bruise on human skin fades to a desaturated purple as hemoglobin breakdown reduces color vibrancy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rhomboidal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rhomboid"/>
    <rdfs:label xml:lang="de">rautenähnlich</rdfs:label>
    <rdfs:label xml:lang="en-US">rhomboidal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000406"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rhomboid quality resembling or related to a rhombus, having similar features</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rhomboidqualität, die einer Raute ähnelt oder mit ihr verwandt ist und ähnliche Merkmale aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rhomboidal' have not yet been formalized. The term is defined as a specific subtype of 'rhomboid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000406.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rhomboid(x) ← Rhomboidal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rhomboidal&apos; then x is a &apos;rhomboid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The scale outline of the gar fish Lepisosteus osseus is rhomboidal, resembling a tilted square</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Bent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">bent</rdfs:label>
    <rdfs:label xml:lang="de">gebogen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000617"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape exhibiting a curvature or angle</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die eine Krümmung oder einen Winkel aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bent' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000617.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Bent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bent&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bent coracoid process of a bird skeleton curves anteriorly at a visible angle from the scapula</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkOrange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Orange"/>
    <rdfs:label xml:lang="en-US">dark orange</rdfs:label>
    <rdfs:label xml:lang="de">dunkelorange</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001256"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue exhibiting deep orange tones with a lower brightness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit tiefen Orangetönen und geringerer Helligkeit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark orange' have not yet been formalized. The term is defined as a specific subtype of 'orange'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001256.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Orange(x) ← DarkOrange(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark orange&apos; then x is a &apos;orange&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bill of Fratercula arctica is dark orange at the base with deep concentrated orange pigmentation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Permanent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">dauerhaft</rdfs:label>
    <rdfs:label xml:lang="en-US">permanent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002293"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Permanent is a structural quality inhering in a bearer due to its structure not changing over time</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Permanent ist eine strukturelle Eigenschaft, die einem Träger innewohnt, da sich seine Struktur im Laufe der Zeit nicht verändert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'permanent' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002293.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Permanent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;permanent&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fused sutures of a mature human skull represent a permanent structural configuration that does not remodel</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Matted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tangled"/>
    <rdfs:label xml:lang="en-US">matted</rdfs:label>
    <rdfs:label xml:lang="de">verfilzt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001607"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tangled quality inhering in a bearer by virtue of the bearer's being not possible to unravel</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine verworrene Qualität, die einem Träger innewohnt, weil es nicht möglich ist, den Träger zu entwirren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'matted' have not yet been formalized. The term is defined as a specific subtype of 'tangled'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001607.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Tangled(x) ← Matted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;matted&apos; then x is a &apos;tangled&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fur of a neglected domestic cat becomes matted when tangled fibers compress into impenetrable felt-like masses</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Oblanceolate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Linear"/>
    <rdfs:label xml:lang="en-US">oblanceolate</rdfs:label>
    <rdfs:label xml:lang="de">oblanzförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002330"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Quality characterized by an elongated form resembling a reversed lance-point with a tapering point attached to the leafstalk</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Qualität, gekennzeichnet durch eine längliche Form, die einer umgekehrten Lanzenspitze ähnelt, mit einer am Blattstiel befestigten, sich verjüngenden Spitze</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'oblanceolate' have not yet been formalized. The term is defined as a specific subtype of 'linear'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002330.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Linear(x) ← Oblanceolate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;oblanceolate&apos; then x is a &apos;linear&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaves of Oenothera biennis are oblanceolate, tapering at the base and widest near the rounded apex</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Dentated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Serrated"/>
    <rdfs:label xml:lang="en-US">dentated</rdfs:label>
    <rdfs:label xml:lang="de">gezähnt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001205"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Serrated quality featuring tooth-like projections along the margin</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gezahnte Qualität mit zahnartigen Vorsprüngen am Rand</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dentated' have not yet been formalized. The term is defined as a specific subtype of 'serrated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001205.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Serrated(x) ← Dentated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dentated&apos; then x is a &apos;serrated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf margin of Urtica dioica is dentated, bearing prominent coarse tooth-like projections</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spheroid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape3D"/>
    <rdfs:label xml:lang="de">kugelförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">spheroid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001865"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">3D shape resembling a sphere or ellipsoid</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">3D-Form, die einer Kugel oder einem Ellipsoid ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spheroid' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001865.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← Spheroid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spheroid&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The egg of Gallus domesticus is a spheroid, slightly elongated along the polar axis relative to the equatorial diameter</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fibrinopurulent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">fibrinopurulent</rdfs:label>
    <rdfs:label xml:lang="de">fibrinpurulent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002116"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation describing a mixture of fibrin and pus, often indicating infection</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zusammensetzungsbeobachtung, die eine Mischung aus Fibrin und Eiter beschreibt und oft auf eine Infektion hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fibrinopurulent' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002116.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Fibrinopurulent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fibrinopurulent&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pleural exudate in bacterial pleuritis is fibrinopurulent, containing mixed fibrin strands and neutrophilic pus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Craspedodromous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branched"/>
    <rdfs:label xml:lang="en-US">craspedodromous</rdfs:label>
    <rdfs:label xml:lang="de">kraspedodrom</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001969"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Branching pattern characterized by secondary veins running straight towards the leaf edge</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verzweigungsmuster, gekennzeichnet durch sekundäre Adern, die direkt zum Blattrand verlaufen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'craspedodromous' have not yet been formalized. The term is defined as a specific subtype of 'branched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001969.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branched(x) ← Craspedodromous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;craspedodromous&apos; then x is a &apos;branched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Leaf venation in Fagus sylvatica is craspedodromous, with secondary veins running straight to the serrated margin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sharp">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sharpness"/>
    <rdfs:label xml:lang="de">scharf</rdfs:label>
    <rdfs:label xml:lang="en-US">sharp</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001419"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sharp is a shape quality inhering in a bearer by virtue of terminating in a point or edge</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Scharf ist eine Formqualität, die einem Träger innewohnt, weil sie in einem Punkt oder einer Kante endet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sharp' have not yet been formalized. The term is defined as a specific subtype of 'sharpness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001419.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Sharpness(x) ← Sharp(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sharp&apos; then x is a &apos;sharpness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The talon of Falco peregrinus terminates in a sharp recurved point adapted for gripping prey</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Actinomorphic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RadialSymmetry"/>
    <rdfs:label xml:lang="en-US">actinomorphic</rdfs:label>
    <rdfs:label xml:lang="de">aktinomorph</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001328"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Radial symmetry creating identical features around the axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Radiale Symmetrie erzeugt identische Merkmale um die Achse</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'actinomorphic' have not yet been formalized. The term is defined as a specific subtype of 'radial symmetry'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001328.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RadialSymmetry(x) ← Actinomorphic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;actinomorphic&apos; then x is a &apos;radial symmetry&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The flower of Ranunculus acris is actinomorphic, with petals arranged symmetrically around the central axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Polymeric">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">polymere Struktur</rdfs:label>
    <rdfs:label xml:lang="en-US">polymeric</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015006"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Polymeric is a quality inhering in a structure due to consisting of repeated, similar or identical subunits arranged orderly</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Polymer ist eine Eigenschaft, die einer Struktur innewohnt, weil sie aus wiederholten, ähnlichen oder identischen, geordnet angeordneten Untereinheiten besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'polymeric' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015006.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Polymeric(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;polymeric&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cellulose cell wall of plant cells is polymeric, built from repeated glucose subunits in ordered chains</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Circular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Elliptic"/>
    <rdfs:label xml:lang="en-US">circular</rdfs:label>
    <rdfs:label xml:lang="de">rund</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000411"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Elliptic quality representing a perfect circle</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Elliptische Qualität, die einen perfekten Kreis darstellt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'circular' have not yet been formalized. The term is defined as a specific subtype of 'elliptic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000411.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Elliptic(x) ← Circular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;circular&apos; then x is a &apos;elliptic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cross-section of a roundworm body is circular, with equal diameter in all directions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Decondensed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">decondensed</rdfs:label>
    <rdfs:label xml:lang="de">expandiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002452"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality depicting expansion or loosening after being condensed</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, die die Ausdehnung oder Lockerung nach der Verdichtung darstellt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'decondensed' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002452.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Decondensed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;decondensed&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">During interphase, the chromatin of a human cell nucleus is decondensed into loosely arranged fibrous threads</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Distensible">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Distensibility"/>
    <rdfs:label xml:lang="de">dehnbar</rdfs:label>
    <rdfs:label xml:lang="en-US">distensible</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002468"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural indicating the capability to expand or be stretched</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturell, was die Fähigkeit angibt, sich auszudehnen oder zu dehnen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'distensible' have not yet been formalized. The term is defined as a specific subtype of 'distensibility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002468.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Distensibility(x) ← Distensible(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;distensible&apos; then x is a &apos;distensibility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The urinary bladder wall is distensible, capable of expanding greatly as it fills with urine</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branchiness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">Verästelung</rdfs:label>
    <rdfs:label xml:lang="en-US">branchiness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002009"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by the presence of branches or divisions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, gekennzeichnet durch das Vorhandensein von Zweigen oder Unterteilungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'branchiness' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002009.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Branchiness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;branchiness&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The branchiness of Quercus robur is evident from its numerous bifurcating limbs forming a broad crown</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Suppurative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">eiternd</rdfs:label>
    <rdfs:label xml:lang="en-US">suppurative</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002120"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Suppurative is a quality inhering in a bearer by virtue of having the ability to produce pus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eitriger ist eine Eigenschaft, die einem Träger aufgrund der Fähigkeit, Eiter zu produzieren, innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'suppurative' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002120.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Suppurative(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;suppurative&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">An infected hair follicle becomes suppurative, producing visible pus within the follicular canal</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tangled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">tangled</rdfs:label>
    <rdfs:label xml:lang="de">verschlungen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001846"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tangled is a structural quality inhering in a bearer by virtue of being entwined and difficult to unravel</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">„Verheddert“ ist eine strukturelle Eigenschaft, die einem Träger innewohnt, weil er verschlungen und schwer zu entwirren ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tangled' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001846.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Tangled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tangled&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The nerve fibers in a traumatic neuroma are tangled, forming disorganized bundles difficult to trace individually</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Condensed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">condensed</rdfs:label>
    <rdfs:label xml:lang="de">verdichtet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001485"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality marked by compression or densification</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Durch Kompression oder Verdichtung gekennzeichnete Strukturqualität</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'condensed' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001485.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Condensed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;condensed&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Metaphase chromosomes appear condensed, compacted into dense rod-like structures visible under light microscopy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/StriateAngular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Striated"/>
    <rdfs:label xml:lang="de">streifenförmig eckig</rdfs:label>
    <rdfs:label xml:lang="en-US">striate angular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002385"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Striate-angular is a shape quality inhering in a bearer by virtue of being marked by narrow lines, usually parallel, with at least one salient angle on the margin</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Streifig-eckig ist eine Formeigenschaft, die einem Träger dadurch innewohnt, dass sie durch schmale, normalerweise parallele Linien mit mindestens einem hervorstehenden Winkel am Rand gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'striate angular' have not yet been formalized. The term is defined as a specific subtype of 'striated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002385.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Striated(x) ← StriateAngular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;striate angular&apos; then x is a &apos;striated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stem of Carum carvi is striate angular, showing parallel longitudinal ridges along its angled surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Delaminated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">delaminated</rdfs:label>
    <rdfs:label xml:lang="de">delaminiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001514"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality characterized by separation of layered material into distinct layers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, gekennzeichnet durch die Aufteilung des Schichtmaterials in verschiedene Schichten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'delaminated' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001514.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Delaminated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;delaminated&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The articular cartilage of an osteoarthritic knee joint becomes delaminated, with surface layers separating from the bulk</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Folded">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="en-US">folded</rdfs:label>
    <rdfs:label xml:lang="de">gefaltet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001910"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Surface feature shape characterized by layers that have been bent and creased</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form einer Oberflächenstruktur, die durch gebogene und gefaltete Schichten gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'folded' have not yet been formalized. The term is defined as a specific subtype of 'surface feature shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001910.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SurfaceFeatureShape(x) ← Folded(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;folded&apos; then x is a &apos;surface feature shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cerebral cortex of humans is folded into gyri and sulci, greatly increasing its total surface area</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Swooping">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="de">schwingend</rdfs:label>
    <rdfs:label xml:lang="en-US">swooping</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002435"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curved form marked by smooth and descending arcs, typically creating a sweeping trajectory</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gebogene Form, gekennzeichnet durch glatte und absteigende Bögen, die typischerweise eine geschwungene Flugbahn erzeugen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'swooping' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002435.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← Swooping(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;swooping&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The neck vertebrae of Brachiosaurus altithorax follow a swooping trajectory, arching gracefully upward from the torso</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IsoscelesTriangular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Triangular"/>
    <rdfs:label xml:lang="de">gleichschenklig dreieckig</rdfs:label>
    <rdfs:label xml:lang="en-US">isosceles triangular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002307"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Triangular shape characterized by equal-length sides and angles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Dreieckige Form, gekennzeichnet durch gleich lange Seiten und Winkel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'isosceles triangular' have not yet been formalized. The term is defined as a specific subtype of 'triangular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002307.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Triangular(x) ← IsoscelesTriangular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;isosceles triangular&apos; then x is a &apos;triangular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal fin of some shark species is isosceles triangular, with two equal lateral sides meeting at the apex</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curvature"/>
    <rdfs:label xml:lang="en-US">curved</rdfs:label>
    <rdfs:label xml:lang="de">geschwungen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000406"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature characterized by deviation from straightness, forming arcs or bends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung, gekennzeichnet durch eine Abweichung von der Geradheit, die Bildung von Bögen oder Biegungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'curved' have not yet been formalized. The term is defined as a specific subtype of 'curvature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000406.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curvature(x) ← Curved(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;curved&apos; then x is a &apos;curvature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ribs of the human thorax are curved, bending from the vertebral column to the sternum</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Petaloid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">blütenblattartig</rdfs:label>
    <rdfs:label xml:lang="en-US">petaloid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002362"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling petals with soft, often curved edges</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt Blütenblättern mit weichen, oft gebogenen Kanten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'petaloid' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002362.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Petaloid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;petaloid&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The modified stamens of Nymphaea alba are petaloid, resembling normal petals with soft rounded edges</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LateralAndRotionalCurvature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RotationalCurvature"/>
    <rdfs:label xml:lang="en-US">lateral and rotational curvature</rdfs:label>
    <rdfs:label xml:lang="de">laterale und rotatorisch Krümmung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002049"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature involving rotational twist and lateral bending</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung mit Rotationsverdrehung und seitlicher Biegung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lateral and rotational curvature' have not yet been formalized. The term is defined as a specific subtype of 'rotational curvature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002049.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RotationalCurvature(x) ← LateralAndRotionalCurvature(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lateral and rotational curvature&apos; then x is a &apos;rotational curvature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The scoliotic human spine shows lateral and rotational curvature, bending sideways while twisting around the vertical axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Mixed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">gemischt</rdfs:label>
    <rdfs:label xml:lang="en-US">mixed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002122"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mixed is a composition quality inhering in a bearer by virtue of being composed of more than one identifiable entity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">„Gemischt“ ist eine Kompositionseigenschaft, die einem Träger dadurch innewohnt, dass er aus mehr als einer identifizierbaren Einheit besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mixed' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002122.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Mixed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mixed&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The inflammatory infiltrate in granulomatous hepatitis is mixed, containing macrophages, lymphocytes, and neutrophils together</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Stabilität</rdfs:label>
    <rdfs:label xml:lang="en-US">stability</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015026"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Stability is the quality, state, or degree of being stable</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stabilität ist die Qualität, der Zustand oder der Grad der Stabilität</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'stability' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015026.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Stability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;stability&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cancellous scaffold of trabecular bone provides structural stability even under repeated compressive loading</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fasciculation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Verbüschelung</rdfs:label>
    <rdfs:label xml:lang="en-US">fasciculation</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002013"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural appearance involving the gathering of fibers or cells into bundles, often parallel or concentric</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelles Erscheinungsbild, das die Ansammlung von Fasern oder Zellen zu Bündeln beinhaltet, oft parallel oder konzentrisch</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fasciculation' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002013.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Fasciculation(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fasciculation&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Skeletal muscle fibers in a normal limb show fasciculation into discrete bundles surrounded by perimysium</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Veined">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Networked"/>
    <rdfs:label xml:lang="de">aderig</rdfs:label>
    <rdfs:label xml:lang="en-US">veined</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002310"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Networked pattern characterized by vein-like lines or networks</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Vernetztes Muster, gekennzeichnet durch venenartige Linien oder Netzwerke</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'veined' have not yet been formalized. The term is defined as a specific subtype of 'networked'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002310.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Networked(x) ← Veined(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;veined&apos; then x is a &apos;networked&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The wing of Dragonfly species is veined with an intricate network of chitin tubes supporting the membrane</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subdermal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">subdermal</rdfs:label>
    <rdfs:label xml:lang="en-US">subdermal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002438"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Subdermal is a structural quality inhering in a bearer by virtue of being located or placed beneath the skin</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Subdermal ist eine strukturelle Eigenschaft, die einem Träger dadurch innewohnt, dass er sich unter der Haut befindet oder platziert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subdermal' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002438.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Subdermal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subdermal&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The subdermal fat deposits of cetaceans form a thick blubber layer beneath the skin for thermal insulation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Purple">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">lila</rdfs:label>
    <rdfs:label xml:lang="en-US">purple</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000951"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue located between blue and red, typically produced by wavelengths of approximately 390-455 nanometers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton zwischen Blau und Rot, typischerweise erzeugt durch Wellenlängen von etwa 390–455 Nanometern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'purple' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000951.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Purple(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;purple&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The gill tissue of Mytilus edulis exhibits a characteristic purple coloration from hemocyanin pigmentation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/FunnelShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">funnel shaped</rdfs:label>
    <rdfs:label xml:lang="de">trichterförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002521"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a funnel, narrow at the base and widening at the top</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einem Trichter, an der Basis schmal und nach oben hin breiter</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'funnel shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002521.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← FunnelShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;funnel shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The corolla of Convolvulus arvensis is funnel shaped, expanding from a narrow tube to a wide open mouth</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tapering">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tapered"/>
    <rdfs:label xml:lang="de">schmaler werdend</rdfs:label>
    <rdfs:label xml:lang="en-US">tapering</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002327"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tapered quality characterized by continuous reduction in size towards a point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konische Qualität, gekennzeichnet durch eine kontinuierliche Verkleinerung zur Spitze hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tapering' have not yet been formalized. The term is defined as a specific subtype of 'tapered'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002327.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Tapered(x) ← Tapering(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tapering&apos; then x is a &apos;tapered&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tail of Anguilla anguilla is tapering, gradually narrowing from the body toward the terminal tip</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ParallelSided">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">parallel seitig</rdfs:label>
    <rdfs:label xml:lang="en-US">parallel sided</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002485"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape quality having two sides that maintain a consistent distance relative to each other</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formqualität mit zwei Seiten, die einen gleichmäßigen Abstand zueinander einhalten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'parallel sided' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002485.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← ParallelSided(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;parallel sided&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The laminar leaf of Lolium perenne is parallel sided, with both margins running at equal distance</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Decussate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RegularSpatialPattern"/>
    <rdfs:label xml:lang="en-US">decussate</rdfs:label>
    <rdfs:label xml:lang="de">gegenständig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001953"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial pattern involving opposite crossing elements in pairs, arranged diagonally</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Räumliches Muster mit paarweise gegenüberliegenden Kreuzungselementen, diagonal angeordnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'decussate' have not yet been formalized. The term is defined as a specific subtype of 'regular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001953.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RegularSpatialPattern(x) ← Decussate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;decussate&apos; then x is a &apos;regular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Leaf arrangement in Salvia officinalis is decussate, with opposite pairs of leaves crossing at right angles</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ObservationProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <owl:equivalentClass rdf:nodeID="Nd8a3b2d3b87c4dd582a295aba650e1e6"/>
    <owl:equivalentClass rdf:nodeID="N1fac2ecf83714a36ac4ea826a0524c95"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <rdfs:label xml:lang="de">Beobachtungsprozess</rdfs:label>
    <rdfs:label xml:lang="en-US">observation process</rdfs:label>
    <skos:example>The perception of the attribute yellow of a flower at daylight</skos:example>
    <iof-av:counterExample>a process of a human determining the length of an object with a caliper</iof-av:counterExample>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Process for determining attributes like dependent continuants, temporal regions, or process characteristics of entities as perceived by humans, which are of interest and categorical</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verfahren zur Bestimmung von Attributen wie abhängigen Kontinuen, zeitlichen Regionen oder Prozessmerkmalen von Entitäten, wie sie von Menschen wahrgenommen werden und die von Interesse und kategorisch sind</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en-US">ObservationProcess(x) ↔ ∃b ((Agent(b) ∧ ∃c (ObservationCapability(c) ∧ hasCapability(b, c))) ∧ obo:BFO_0000057(x, b)) ∧ ∃d (MorphologicalQuality(d) ∧ hasSpecifiedOutput(x, d))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-US">every instance of 'observation process' is defined as exactly that 'obo:BFO_0000057' some an instance of 'Agent' and that 'hasCapability' some 'observation capability' and that 'hasSpecifiedOutput' some 'Morphological quality'</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pigmented">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DegreeOfPigmentation"/>
    <rdfs:label xml:lang="de">pigmentiert</rdfs:label>
    <rdfs:label xml:lang="en-US">pigmented</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002248"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pigmented is a degree of pigmentation quality inhering in a bearer by virtue of having substances produced by living organisms that have a color resulting from selective color absorption</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Pigmentiert ist ein Grad der Pigmentierung, der einem Träger dadurch innewohnt, dass er über Substanzen verfügt, die von lebenden Organismen produziert werden und deren Farbe durch selektive Farbabsorption entsteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pigmented' have not yet been formalized. The term is defined as a specific subtype of 'degree of pigmentation'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002248.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">DegreeOfPigmentation(x) ← Pigmented(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pigmented&apos; then x is a &apos;degree of pigmentation&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The melanocytes in human epidermis are pigmented with melanin granules giving skin its characteristic color</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Netted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="en-US">netted</rdfs:label>
    <rdfs:label xml:lang="de">vernetzt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001947"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Irregular spatial pattern featuring a mesh-like network or arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unregelmäßiges räumliches Muster mit einem netzartigen Netzwerk oder einer netzartigen Anordnung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'netted' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001947.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Netted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;netted&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The seed coat of Cucumis melo cultivars shows a netted surface with raised irregular mesh-like ridges</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LanceolateTriangular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lanceolate"/>
    <rdfs:label xml:lang="de">dreieckig lanzetförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">lanceolate triangular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002338"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Lanceolate form featuring triangular shape with tapering sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Lanzettliche Form mit dreieckiger Form und sich verjüngenden Seiten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lanceolate triangular' have not yet been formalized. The term is defined as a specific subtype of 'lanceolate'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002338.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Lanceolate(x) ← LanceolateTriangular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lanceolate triangular&apos; then x is a &apos;lanceolate&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bract of Stachys sylvatica is lanceolate triangular, combining a lance tip with a broad triangular base</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hexagonal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="en-US">hexagonal</rdfs:label>
    <rdfs:label xml:lang="de">sechseckig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002509"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">2D shape characterized by having six straight edges and angles, forming a hexagon</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">2D-Form, gekennzeichnet durch sechs gerade Kanten und Winkel, die ein Sechseck bilden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hexagonal' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002509.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← Hexagonal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hexagonal&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ommatidium of a compound insect eye is hexagonal in cross-section, tessellating with neighboring facets</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MuscleShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subcylindrical"/>
    <rdfs:label xml:lang="de">Muskelartig</rdfs:label>
    <rdfs:label xml:lang="en-US">muscle shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000929"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Subcylindrical form resembling muscular fibers, typically elongated and rounded</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Subzylindrische Form, die Muskelfasern ähnelt, typischerweise länglich und abgerundet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'muscle shaped' have not yet been formalized. The term is defined as a specific subtype of 'subcylindrical'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000929.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Subcylindrical(x) ← MuscleShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;muscle shaped&apos; then x is a &apos;subcylindrical&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The rhinarium of Canis familiaris is muscle shaped, with a rounded elongated form resembling muscular tissue</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleMagenta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Magenta"/>
    <rdfs:label xml:lang="de">blass magenta</rdfs:label>
    <rdfs:label xml:lang="en-US">pale magenta</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002010"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue characterized by lighter shades of magenta, often subtle and less vivid</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der durch hellere Magenta-Töne gekennzeichnet ist, oft subtil und weniger lebendig</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale magenta' have not yet been formalized. The term is defined as a specific subtype of 'magenta'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002010.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Magenta(x) ← PaleMagenta(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale magenta&apos; then x is a &apos;magenta&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The petals of Rosa canina fade to pale magenta as the flower ages and pigment concentration decreases</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convolute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curled"/>
    <rdfs:label xml:lang="en-US">convolute</rdfs:label>
    <rdfs:label xml:lang="de">eingerollt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001966"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curled shape characterized by overlapping curved layers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gewellte Form, gekennzeichnet durch überlappende gebogene Schichten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'convolute' have not yet been formalized. The term is defined as a specific subtype of 'curled'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001966.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curled(x) ← Convolute(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;convolute&apos; then x is a &apos;curled&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bud scales of Quercus robur are convolute, wrapped in overlapping curved layers around the inner meristem</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Maroon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">kastanienbraun</rdfs:label>
    <rdfs:label xml:lang="en-US">maroon</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001426"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color consisting of purple and brown hue</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbe bestehend aus violetten und braunen Farbtönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'maroon' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001426.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Maroon(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;maroon&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mature seed coat of Vicia faba is maroon, a deep purple-brown characteristic of the species</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DesaturatedBlue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Blue"/>
    <rdfs:label xml:lang="en-US">desaturated blue</rdfs:label>
    <rdfs:label xml:lang="de">entsättigtes Blau</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001266"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue where blue tones are mixed with white or grey, reducing color intensity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, bei dem Blautöne mit Weiß oder Grau gemischt werden, wodurch die Farbintensität verringert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'desaturated blue' have not yet been formalized. The term is defined as a specific subtype of 'blue'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001266.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Blue(x) ← DesaturatedBlue(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;desaturated blue&apos; then x is a &apos;blue&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The blue-grey plumage of some juvenile herons appears desaturated blue, blending with overcast sky backgrounds</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape3D">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">3-d form</rdfs:label>
    <rdfs:label xml:lang="en-US">shape3 d</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002266"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape3D is a form that inheres in a three-dimensional entity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Shape3D ist eine Form, die einer dreidimensionalen Einheit innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shape3 d' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002266.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Shape3D(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shape3 d&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The three-dimensional shape of a human molar crown is assessed in dental morphology studies for taxonomic identification</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Symmetrical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RegularSpatialPattern"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Symmetry"/>
    <rdfs:label xml:lang="de">symmetrisch</rdfs:label>
    <rdfs:label xml:lang="en-US">symmetrical</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000632"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Symmetry characterized by balanced and equivalent distribution of parts on either side of an axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Symmetrie, gekennzeichnet durch eine ausgewogene und gleichwertige Verteilung der Teile auf beiden Seiten einer Achse</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'symmetrical' have not yet been formalized. The term is defined as a specific subtype of 'regular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000632.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RegularSpatialPattern(x) ← Symmetrical(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;symmetrical&apos; then x is a &apos;regular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bilateral symmetry of the human face is symmetrical in morphological analysis though minor asymmetries exist</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkMagenta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Magenta"/>
    <rdfs:label xml:lang="en-US">dark magenta</rdfs:label>
    <rdfs:label xml:lang="de">dunkelmagenta</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001254"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue characterized by deep and intense magenta tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der durch tiefe und intensive Magentatöne gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark magenta' have not yet been formalized. The term is defined as a specific subtype of 'magenta'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001254.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Magenta(x) ← DarkMagenta(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark magenta&apos; then x is a &apos;magenta&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The carpels of Magnolia grandiflora show dark magenta coloration at their mature fused margins</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Arched">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave"/>
    <rdfs:label xml:lang="en-US">arched</rdfs:label>
    <rdfs:label xml:lang="de">gewölbt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001594"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave shape with a curved, arching form</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave Form mit geschwungener, gewölbter Form</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'arched' have not yet been formalized. The term is defined as a specific subtype of 'concave'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001594.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave(x) ← Arched(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;arched&apos; then x is a &apos;concave&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The palatine vault of humans is arched, curving upward from the alveolar ridges to the midline</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/HeartShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="en-US">heart shaped</rdfs:label>
    <rdfs:label xml:lang="de">herzförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000948"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling a heart, often featuring a pointed lower end and rounded upper lobes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die einem Herzen ähnelt, oft mit einem spitzen unteren Ende und abgerundeten oberen Lappen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'heart shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000948.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← HeartShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;heart shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Tilia cordata is heart shaped, with a cordate base and rounded lobes on either side of the petiole</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Barred">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="en-US">barred</rdfs:label>
    <rdfs:label xml:lang="de">balkengestreift</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002276"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored pattern featuring bars or stripes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbiges Muster mit Balken oder Streifen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'barred' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002276.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Barred(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;barred&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The plumage of Accipiter nisus shows barred pattern on the underside with alternating brown and white transverse bands</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Reinforced">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">reinforced</rdfs:label>
    <rdfs:label xml:lang="de">verstärkt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000493"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Reinforced is a structural quality enhancing durability and strength through additional support materials or techniques</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verstärkt ist eine Struktureigenschaft, die durch zusätzliche Trägermaterialien oder -techniken die Haltbarkeit und Festigkeit erhöht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'reinforced' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000493.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Reinforced(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;reinforced&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The turtle shell is reinforced with fused bony plates providing structural resistance against predator attack</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Retrorse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">retrorse</rdfs:label>
    <rdfs:label xml:lang="de">rückwärts gebogen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002237"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Retrorse is a curvature quality inhering in a bearer by virtue of being curved backward or downward</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Retrorse ist eine Krümmungseigenschaft, die einem Träger dadurch innewohnt, dass er nach hinten oder unten gekrümmt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'retrorse' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002237.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← Retrorse(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;retrorse&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The barbs on the quills of Erethizon dorsatum are retrorse, curving backward to prevent removal once embedded</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RegularSpatialPattern"/>
    <rdfs:label xml:lang="de">eng</rdfs:label>
    <rdfs:label xml:lang="en-US">tight</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001809"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tight is a pattern quality inhering in a bearer by virtue of being compact or dense in arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eng ist eine Musterqualität, die einem Träger aufgrund seiner kompakten oder dichten Anordnung innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tight' have not yet been formalized. The term is defined as a specific subtype of 'regular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001809.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RegularSpatialPattern(x) ← Tight(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tight&apos; then x is a &apos;regular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fascicular arrangement of cardiomyocytes forms a tight pattern with minimal intercellular space between fibers</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkYellow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Yellow"/>
    <rdfs:label xml:lang="en-US">dark yellow</rdfs:label>
    <rdfs:label xml:lang="de">dunkelgelb</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001263"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue with deep and dense yellow tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit tiefen und dichten Gelbtönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark yellow' have not yet been formalized. The term is defined as a specific subtype of 'yellow'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001263.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Yellow(x) ← DarkYellow(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark yellow&apos; then x is a &apos;yellow&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The xanthophyll-rich autumn leaves of Betula pendula display dark yellow pigmentation before abscission</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Monocystic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cystic"/>
    <rdfs:label xml:lang="de">monozystisch</rdfs:label>
    <rdfs:label xml:lang="en-US">monocystic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002088"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Monocystic is a structural quality inhering in a bearer due to containing one cyst, a formation of a sac-like closed membranous structure not associated with neoplasia</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Monozystisch ist eine strukturelle Eigenschaft, die einem Träger innewohnt, weil er eine Zyste enthält, eine Bildung einer sackartigen geschlossenen Membranstruktur, die nicht mit einer Neoplasie verbunden ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'monocystic' have not yet been formalized. The term is defined as a specific subtype of 'cystic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002088.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cystic(x) ← Monocystic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;monocystic&apos; then x is a &apos;cystic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A developmental hepatic cyst is monocystic, consisting of a single fluid-filled membranous sac in the liver</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Vacuolated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities"/>
    <rdfs:label xml:lang="en-US">vacuolated</rdfs:label>
    <rdfs:label xml:lang="de">vakuolisiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000941"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Vacuolated is a structural quality inhering in a cytoplasm due to containing fluid-filled cavities</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Vakuolisiert ist eine strukturelle Eigenschaft, die einem Zytoplasma innewohnt, da es flüssigkeitsgefüllte Hohlräume enthält</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'vacuolated' have not yet been formalized. The term is defined as a specific subtype of 'cavities'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000941.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavities(x) ← Vacuolated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;vacuolated&apos; then x is a &apos;cavities&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Adipocytes appear vacuolated under light microscopy, with lipid droplets creating large optically clear spaces in the cytoplasm</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Retuse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Blunt"/>
    <rdfs:label xml:lang="de">retus</rdfs:label>
    <rdfs:label xml:lang="en-US">retuse</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001974"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Retuse is a shape quality inhering in a bearer due to terminating in a round end with the center depressed</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Retuse ist eine Formqualität, die einem Träger innewohnt, da sie in einem runden Ende mit abgesenkter Mitte endet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'retuse' have not yet been formalized. The term is defined as a specific subtype of 'blunt'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001974.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Blunt(x) ← Retuse(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;retuse&apos; then x is a &apos;blunt&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The apex of the leaf of Medicago sativa is retuse, terminating in a round end with a shallow central notch</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rotated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Oriented"/>
    <rdfs:label xml:lang="de">gedreht</rdfs:label>
    <rdfs:label xml:lang="en-US">rotated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001599"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Orientation quality indicating twisting or turning around a central point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Orientierungsqualität, die eine Drehung oder Wendung um einen zentralen Punkt anzeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rotated' have not yet been formalized. The term is defined as a specific subtype of 'oriented'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001599.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Oriented(x) ← Rotated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rotated&apos; then x is a &apos;oriented&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tibia of patients with tibial torsion is rotated along its longitudinal axis relative to the femur</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Perpendicular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Angular"/>
    <rdfs:label xml:lang="en-US">perpendicular</rdfs:label>
    <rdfs:label xml:lang="de">rechtwinklig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001035"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Angular quality indicating intersection at right angles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Winkelqualität, die einen Schnittpunkt im rechten Winkel anzeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'perpendicular' have not yet been formalized. The term is defined as a specific subtype of 'angular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001035.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Angular(x) ← Perpendicular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;perpendicular&apos; then x is a &apos;angular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The trabecular bone struts in vertebral cancellous tissue are often perpendicular to the loading axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaturatedPurple">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Purple"/>
    <rdfs:label xml:lang="de">sattes lila</rdfs:label>
    <rdfs:label xml:lang="en-US">saturated purple</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001281"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saturated purple is a color consisting of purple hue with high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gesättigtes Lila ist eine Farbe, die aus einem violetten Farbton mit hoher Sättigung besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saturated purple' have not yet been formalized. The term is defined as a specific subtype of 'purple'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001281.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Purple(x) ← SaturatedPurple(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saturated purple&apos; then x is a &apos;purple&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The flowers of Allium atropurpureum show saturated purple coloration with vivid intense hue throughout the tepals</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Involute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curled"/>
    <rdfs:label xml:lang="de">eingewunden</rdfs:label>
    <rdfs:label xml:lang="en-US">involute</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001962"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curled form characterized by inward rolling or turning edges</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gewellte Form, gekennzeichnet durch nach innen gerichtete Roll- oder Wendekanten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'involute' have not yet been formalized. The term is defined as a specific subtype of 'curled'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001962.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curled(x) ← Involute(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;involute&apos; then x is a &apos;curled&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf margin of Rosmarinus officinalis is involute, with edges tightly rolled inward toward the lower surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Motley">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="de">kunterbunt</rdfs:label>
    <rdfs:label xml:lang="en-US">motley</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001534"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Motley is a color pattern inhering in a bearer by virtue of having three or more hues or degrees of saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Motley ist ein Farbmuster, das einem Träger dadurch innewohnt, dass es drei oder mehr Farbtöne oder Sättigungsgrade aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'motley' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001534.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Motley(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;motley&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The plumage of some male pheasants is motley, combining three or more distinct hues in an elaborate pattern</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Serration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/EdgeShape"/>
    <rdfs:label xml:lang="de">Sägezahnung</rdfs:label>
    <rdfs:label xml:lang="en-US">serration</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001976"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Serration is a surface feature shape quality inhering in a bearer by virtue of having or lacking sharp straight-edged teeth pointing to the apex</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Verzahnung ist eine Formqualität eines Oberflächenmerkmals, die einem Träger dadurch innewohnt, dass scharfe, gerade Kanten zur Spitze zeigende Zähne vorhanden sind oder fehlen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'serration' have not yet been formalized. The term is defined as a specific subtype of 'edge shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001976.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">EdgeShape(x) ← Serration(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;serration&apos; then x is a &apos;edge shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Castanea sativa bears prominent serration, with sharp-edged teeth pointing toward the apex along each margin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Bifurcated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branched"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Split"/>
    <rdfs:label xml:lang="en-US">bifurcated</rdfs:label>
    <rdfs:label xml:lang="de">gegabelt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001784"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Branched pattern characterized by division into two parts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verzweigtes Muster, gekennzeichnet durch die Teilung in zwei Teile</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bifurcated' have not yet been formalized. The term is defined as a specific subtype of 'branched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001784.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branched(x) ← Bifurcated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bifurcated&apos; then x is a &apos;branched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The rachis of feathers may become bifurcated in certain genetic variants, splitting into two parallel shafts</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SplitRadially">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Split"/>
    <rdfs:label xml:lang="de">radial geteilt</rdfs:label>
    <rdfs:label xml:lang="en-US">split radially</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002172"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Split radially is a shape quality inhering in a bearer by virtue of being split along the radial axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Radiale Spaltung ist eine Formeigenschaft, die einem Träger dadurch innewohnt, dass er entlang der radialen Achse geteilt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'split radially' have not yet been formalized. The term is defined as a specific subtype of 'split'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002172.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Split(x) ← SplitRadially(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;split radially&apos; then x is a &apos;split&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hull of Hordeum vulgare can be split radially along the polar axis during germination</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/VariableColor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ColorPattern"/>
    <rdfs:label xml:lang="de">variable Farbe</rdfs:label>
    <rdfs:label xml:lang="en-US">variable color</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001515"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Variable color is a color quality inhering in a bearer due to its uneven color pattern</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Variable Farbe ist eine Farbqualität, die einem Träger aufgrund seines ungleichmäßigen Farbmusters innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'variable color' have not yet been formalized. The term is defined as a specific subtype of 'color pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001515.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ColorPattern(x) ← VariableColor(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;variable color&apos; then x is a &apos;color pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mantle of Sepia officinalis displays variable color due to rapid chromatophore activation creating uneven patterns</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DesaturatedGreen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Green"/>
    <rdfs:label xml:lang="en-US">desaturated green</rdfs:label>
    <rdfs:label xml:lang="de">entsättigtes Grün</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001272"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue denoting reduced green intensity, often merging with white or grey</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der auf eine verminderte Grünintensität hinweist und häufig mit Weiß oder Grau übergeht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'desaturated green' have not yet been formalized. The term is defined as a specific subtype of 'green'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001272.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Green(x) ← DesaturatedGreen(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;desaturated green&apos; then x is a &apos;green&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fading leaves of overwintered Hedera helix appear desaturated green, with chlorophyll degradation reducing vibrancy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BrownGreen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Green"/>
    <rdfs:label xml:lang="de">braun grün</rdfs:label>
    <rdfs:label xml:lang="en-US">brown green</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001942"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color consisting of green hue mixed with brown tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbe bestehend aus einem Grünton gemischt mit Brauntönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'brown green' have not yet been formalized. The term is defined as a specific subtype of 'green'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001942.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Green(x) ← BrownGreen(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;brown green&apos; then x is a &apos;green&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The lichen thallus of Peltigera canina appears brown green in a mixture of its photobiont and dried cortex</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202507/qualities/Qualities-Morphological/"/>
    <owl:versionInfo>202507</owl:versionInfo>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <dcterms:abstract xml:lang="en-us">The IOF Morphological Qualities Ontology represents Qualities of material entities that describe the look and feel.</dcterms:abstract>
    <dcterms:contributor xml:lang="en-us">Thomas Hanke, Fraunhofer IWM</dcterms:contributor>
    <dcterms:creator xml:lang="en-us">IOF Materials Working Group</dcterms:creator>
    <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
    <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
    <dcterms:references rdf:resource="http://spec.org/dc/terms/"/>
    <dcterms:references rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    <dcterms:title xml:lang="en-us">Industrial Ontology Foundry (IOF) Morphological Qualities Ontology</dcterms:title>
    <rdfs:label xml:lang="en-us">Morphological Qualities Ontology</rdfs:label>
    <iof-av:copyright xml:lang="en-US">Copyright (c) 2025 Industrial Ontology Foundry (IOF)</iof-av:copyright>
    <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Speculated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spotty"/>
    <rdfs:label xml:lang="de">befleckt</rdfs:label>
    <rdfs:label xml:lang="en-US">speculated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002488"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spotty characteristic marked by small spots or patches</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Fleckiges Merkmal, gekennzeichnet durch kleine Flecken oder Flecken</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'speculated' have not yet been formalized. The term is defined as a specific subtype of 'spotty'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002488.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spotty(x) ← Speculated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;speculated&apos; then x is a &apos;spotty&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The adaxial surface of Phytolacca americana leaves shows speculated coloration with small pale spots under certain light</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fragility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Zerbrechlichkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">fragility</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001662"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality denoting the ease with which an entity may fracture</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, die die Leichtigkeit angibt, mit der ein Objekt brechen kann</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fragility' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001662.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Fragility(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fragility&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The egg shells of hummingbirds have notable fragility, requiring minimal force to crack during hatching</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pedunculate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">gestielt</rdfs:label>
    <rdfs:label xml:lang="en-US">pedunculate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002388"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pedunculate is a structure quality inhering in a bearer by virtue of being supported by a peduncle or stalk</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stiel ist eine Struktureigenschaft, die einem Träger dadurch innewohnt, dass er von einem Stiel oder Stiel getragen wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pedunculate' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002388.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Pedunculate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pedunculate&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The acorn of Quercus robur is pedunculate, borne on a long stalk extending from the twig</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightRedBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RedBrown"/>
    <rdfs:label xml:lang="de">hellrotbraun</rdfs:label>
    <rdfs:label xml:lang="en-US">light red brown</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001289"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue characterized by lighter tones blending red and brown, often muted and subtle</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der sich durch hellere Rot- und Brauntöne auszeichnet, oft gedämpft und subtil</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light red brown' have not yet been formalized. The term is defined as a specific subtype of 'red brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001289.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RedBrown(x) ← LightRedBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light red brown&apos; then x is a &apos;red brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal scales of Natrix natrix show light red brown coloration as juveniles before adult pigment develops</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hemispheroid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:label xml:lang="de">halbkugelförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">hemispheroid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0005000"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Convex 3D shape resembling a hemisphere or half-sphere</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konvexe 3D-Form, die einer Halbkugel oder Halbkugel ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hemispheroid' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0005000.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← Hemispheroid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hemispheroid&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The head of a tick capitulum is hemispheroid, resembling a half-sphere in dorsal view</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lumenized">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavitated"/>
    <rdfs:label xml:lang="de">Lumenisiert</rdfs:label>
    <rdfs:label xml:lang="en-US">lumenized</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001897"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure quality inhering in a bearer by virtue of the bearer's having a three dimensional space surrounded by one or more anatomical structures and containing one or more anatomical substances</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, die einem Träger dadurch innewohnt, dass der Träger über einen dreidimensionalen Raum verfügt, der von einer oder mehreren anatomischen Strukturen umgeben ist und eine oder mehrere anatomische Substanzen enthält</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lumenized' have not yet been formalized. The term is defined as a specific subtype of 'cavitated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001897.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavitated(x) ← Lumenized(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lumenized&apos; then x is a &apos;cavitated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The intestinal crypt is lumenized, with a central open space surrounded by epithelial cells and accessible for digestion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Vestigial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">rudimentär</rdfs:label>
    <rdfs:label xml:lang="en-US">vestigial</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000588"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Vestigial is a quality inhering in a bearer by virtue of being a remnant structure from earlier developmental or evolutionary stages</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Überbleibsel ist eine Eigenschaft, die einem Träger dadurch innewohnt, dass es sich um eine Überbleibselstruktur aus früheren Entwicklungs- oder Evolutionsstadien handelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'vestigial' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000588.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Vestigial(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;vestigial&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The caudal vertebrae of humans fused into the coccyx represent a vestigial remnant of ancestral tail structures</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/JShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">J-förmig</rdfs:label>
    <rdfs:label xml:lang="en-US">j shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015020"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling the letter "J", often with a hook or curve</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die dem Buchstaben „J“ ähnelt, oft mit einem Haken oder einer Kurve</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'j shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015020.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← JShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;j shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The duodenum of Homo sapiens is j shaped, curving from the pylorus in a hook-like arc around the pancreas</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Triradiate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">dreiradig</rdfs:label>
    <rdfs:label xml:lang="en-US">triradiate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002391"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Triradiate is a shape quality inhering in a bearer by virtue of having three rays or radiating branches</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Triradiate ist eine Formqualität, die einem Träger innewohnt, weil er drei Strahlen oder strahlende Zweige hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'triradiate' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002391.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Triradiate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;triradiate&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The central spicule of some foraminifera is triradiate, with three rays radiating at equal angles from the center</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Blotchy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="en-US">blotchy</rdfs:label>
    <rdfs:label xml:lang="de">gesprenkelt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000329"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored pattern characterized by irregular spots</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbiges Muster, gekennzeichnet durch unregelmäßige Flecken</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'blotchy' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000329.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Blotchy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;blotchy&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin lesions in Kaposi sarcoma form a blotchy pattern of irregular purple-red patches on the surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Scaphoid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">kahnbeinförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">scaphoid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002426"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Scaphoid is a shape quality inhering in a bearer by virtue of resembling a boat</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Das Kahnbein ist eine Formeigenschaft, die einem Träger innewohnt, da sie einem Boot ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scaphoid' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002426.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Scaphoid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scaphoid&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The scaphoid carpal bone of the human wrist is scaphoid in shape, resembling a shallow boat</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Defasciculated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fasciculation"/>
    <rdfs:label xml:lang="en-US">defasciculated</rdfs:label>
    <rdfs:label xml:lang="de">defaszikuliert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001959"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Fasciculation quality manifesting ungrouping of previously aggregated bundles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Faszikulationsqualität, die die Auflösung zuvor aggregierter Bündel manifestiert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'defasciculated' have not yet been formalized. The term is defined as a specific subtype of 'fasciculation'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001959.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fasciculation(x) ← Defasciculated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;defasciculated&apos; then x is a &apos;fasciculation&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Injured peripheral nerve bundles become defasciculated when the perineurium ruptures, releasing axons from their organized clusters</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Powdery">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="en-US">powdery</rdfs:label>
    <rdfs:label xml:lang="de">pulvrig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000764"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality characterized by a surface covered with fine, loose particles similar to powder</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Texturqualität, gekennzeichnet durch eine Oberfläche, die mit feinen, losen, pulverähnlichen Partikeln bedeckt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'powdery' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000764.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Powdery(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;powdery&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface of Botrytis cinerea-infected grapes becomes powdery from dense masses of asexual spores covering the tissue</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RingLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RingShape"/>
    <rdfs:label xml:lang="en-US">ring like</rdfs:label>
    <rdfs:label xml:lang="de">ringähnlich</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002484"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ring shape quality resembling or related to the form of a ring</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Qualität der Ringform, die der Form eines Rings ähnelt oder mit dieser in Zusammenhang steht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ring like' have not yet been formalized. The term is defined as a specific subtype of 'ring shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002484.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RingShape(x) ← RingLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ring like&apos; then x is a &apos;ring shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ring like structure of the tracheal cartilage provides semi-rigid support keeping the airway patent</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subcylindrical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cylindrical"/>
    <rdfs:label xml:lang="de">kurzzylindrisch</rdfs:label>
    <rdfs:label xml:lang="en-US">subcylindrical</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002226"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Convex 3D shape closely resembling a cylinder but shorter in proportion to diameter</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konvexe 3D-Form, die stark einem Zylinder ähnelt, jedoch im Verhältnis zum Durchmesser kürzer ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subcylindrical' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002226.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← Subcylindrical(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subcylindrical&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The femur of Homo sapiens is subcylindrical in the mid-diaphysis, approximately round but proportionally short</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DesaturatedViolet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Violet"/>
    <rdfs:label xml:lang="en-US">desaturated violet</rdfs:label>
    <rdfs:label xml:lang="de">entsättigtes Violett</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001703"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue where violet tones are blended with white or grey, lessening saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, bei dem violette Töne mit Weiß oder Grau gemischt werden, wodurch die Sättigung verringert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'desaturated violet' have not yet been formalized. The term is defined as a specific subtype of 'violet'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001703.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Violet(x) ← DesaturatedViolet(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;desaturated violet&apos; then x is a &apos;violet&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The aging petals of Viola odorata fade to desaturated violet as anthocyanin pigments break down</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TwistedObliquely">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Twisted"/>
    <rdfs:label xml:lang="de">schräg verdreht</rdfs:label>
    <rdfs:label xml:lang="en-US">twisted obliquely</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000374"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Twisted characteristic exhibiting a slanted or angled orientation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verdrehtes Merkmal, das eine schräge oder abgewinkelte Ausrichtung aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'twisted obliquely' have not yet been formalized. The term is defined as a specific subtype of 'twisted'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000374.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Twisted(x) ← TwistedObliquely(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;twisted obliquely&apos; then x is a &apos;twisted&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dental roots of some molar teeth are twisted obliquely, with an angled curvature along the apical third</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/NonPorous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Porosity"/>
    <rdfs:label xml:lang="de">nicht porös</rdfs:label>
    <rdfs:label xml:lang="en-US">non porous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000985"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Non-porous is a porosity quality inhering in a bearer due to being incapable of admitting the passage of gas or liquid through pores or interstices</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Nicht porös ist eine Porositätseigenschaft, die einem Träger innewohnt, da er nicht in der Lage ist, den Durchgang von Gas oder Flüssigkeit durch Poren oder Zwischenräume zu ermöglichen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'non porous' have not yet been formalized. The term is defined as a specific subtype of 'porosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000985.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Porosity(x) ← NonPorous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;non porous&apos; then x is a &apos;porosity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The enamel surface of human teeth is non porous, resisting penetration of liquids and bacterial infiltration</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BoomerangShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">boomerang shaped</rdfs:label>
    <rdfs:label xml:lang="de">bumerangförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002536"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a boomerang with a curved or arc form and pointed ends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die einem Bumerang ähnelt, mit gebogener oder bogenförmiger Form und spitzen Enden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'boomerang shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002536.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← BoomerangShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;boomerang shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The wishbone of birds is boomerang shaped, with two lateral arms joined at an angle at the midline</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BiomaterialPurity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">Reinheit des Biomaterials</rdfs:label>
    <rdfs:label xml:lang="en-US">biomaterial purity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001339"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation relating to the cleanliness and impurity level of biomaterial</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beobachtung der Zusammensetzung in Bezug auf die Reinheit und den Verunreinigungsgrad von Biomaterial</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biomaterial purity' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001339.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← BiomaterialPurity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biomaterial purity&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The biomaterial purity of processed cortical bone grafts is assessed by testing for residual lipids and cell debris</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SplayedLateral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Splayed"/>
    <rdfs:label xml:lang="de">gespreizte seitenwölbung</rdfs:label>
    <rdfs:label xml:lang="en-US">splayed lateral</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002152"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Splayed lateral is a curvature quality inhering in a bearer by virtue of being curved outwards from the side</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Seitlich gespreizt ist eine Krümmungseigenschaft, die einem Träger dadurch innewohnt, dass er von der Seite nach außen gekrümmt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'splayed lateral' have not yet been formalized. The term is defined as a specific subtype of 'splayed'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002152.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Splayed(x) ← SplayedLateral(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;splayed lateral&apos; then x is a &apos;splayed&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The distal phalanges of arboreal chameleons are splayed lateral, spreading outward to grip opposite sides of branches</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/YellowGreen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Green"/>
    <rdfs:label xml:lang="de">gelb grün</rdfs:label>
    <rdfs:label xml:lang="en-US">yellow green</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001941"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Yellow green is a color consisting of yellow and green hues</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gelbgrün ist eine Farbe, die aus Gelb- und Grüntönen besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'yellow green' have not yet been formalized. The term is defined as a specific subtype of 'green'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001941.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Green(x) ← YellowGreen(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;yellow green&apos; then x is a &apos;green&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The immature fruit of Olea europaea is yellow green before ripening to purple-black at full maturity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shriveled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">geschrumpft</rdfs:label>
    <rdfs:label xml:lang="en-US">shriveled</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002460"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shriveled is a structural quality inhering in a bearer by virtue of being smaller and contracted, especially due to loss of moisture</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schrumpfen ist eine Struktureigenschaft, die einem Träger innewohnt, weil er kleiner und zusammengezogen ist, insbesondere aufgrund von Feuchtigkeitsverlust</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shriveled' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002460.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Shriveled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shriveled&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The seeds of drought-stressed Phaseolus vulgaris are shriveled, contracted and wrinkled from desiccation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpindleShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">spindelformig</rdfs:label>
    <rdfs:label xml:lang="en-US">spindle shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001409"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a spindle, tapering at both ends, often bulging in the middle</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form ähnlich einer Spindel, an beiden Enden spitz zulaufend, in der Mitte oft gewölbt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spindle shaped' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001409.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← SpindleShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spindle shaped&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The smooth muscle cells of blood vessel walls are spindle shaped, tapering at both ends with a central nucleus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tubular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cylindrical"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hollow"/>
    <rdfs:label xml:lang="de">rohrform</rdfs:label>
    <rdfs:label xml:lang="en-US">tubular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002299"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tubular is a cylindrical shape that is hollow</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Röhrenförmig ist eine zylindrische Form, die hohl ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tubular' have not yet been formalized. The term is defined as a specific subtype of 'cylindrical'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002299.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cylindrical(x) ← Tubular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tubular&apos; then x is a &apos;cylindrical&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The corolla of Salvia officinalis flowers is tubular, forming a hollow cylindrical passage for pollinators</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Upswept">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="de">aufgeschwungen</rdfs:label>
    <rdfs:label xml:lang="en-US">upswept</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002094"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curved characteristic exhibiting upward sweeping motion or angle</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gekrümmtes Merkmal, das eine nach oben gerichtete Bewegung oder einen nach oben gerichteten Winkel aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'upswept' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002094.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← Upswept(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;upswept&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal fin of Orcinus orca is upswept, curving steeply upward from the body with an anteriorly inclined leading edge</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pitted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">grübchenförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">pitted</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002426"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture characterized by depressions or indentations</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Textur, gekennzeichnet durch Vertiefungen oder Vertiefungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pitted' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002426.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Pitted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pitted&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bone surface affected by osteoclastic resorption is pitted with Howship lacunae of varying depth</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpadeShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">spade shaped</rdfs:label>
    <rdfs:label xml:lang="de">spatenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002432"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling or characterized by broad, pointed curvature like a spade</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die einer breiten, spitzen Krümmung wie einem Spaten ähnelt oder durch diese gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spade shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002432.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← SpadeShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spade shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spatula-like appendages of Mantis shrimp are spade shaped, broadening at the distal end for burrowing</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Complex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Complexity"/>
    <rdfs:label xml:lang="en-US">complex</rdfs:label>
    <rdfs:label xml:lang="de">komplex</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001504"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Complexity characterized by intricate or complicated structures</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Komplexität, gekennzeichnet durch komplizierte oder komplizierte Strukturen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'complex' have not yet been formalized. The term is defined as a specific subtype of 'complexity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001504.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Complexity(x) ← Complex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;complex&apos; then x is a &apos;complexity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The morphology of the human inner ear is complex, with a labyrinthine arrangement of cochlea and semicircular canals</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/FanShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="en-US">fan shaped</rdfs:label>
    <rdfs:label xml:lang="de">fächerförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002219"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">2D shape resembling a fan, radiating from a point and widening outward</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">2D-Form, die einem Fächer ähnelt, der von einem Punkt ausgeht und sich nach außen erweitert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fan shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002219.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← FanShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fan shaped&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tail feathers of Pavo cristatus form a fan shaped display, radiating outward from a common base</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/NonDegenerate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Degeneration"/>
    <rdfs:label xml:lang="de">nicht-degenerativ</rdfs:label>
    <rdfs:label xml:lang="en-US">non degenerate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002038"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Non-degenerate is a structural quality inhering in a bearer by virtue of a structure that does not deteriorate</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Nicht degeneriert ist eine strukturelle Eigenschaft, die einem Träger aufgrund einer Struktur innewohnt, die sich nicht verschlechtert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'non degenerate' have not yet been formalized. The term is defined as a specific subtype of 'degeneration'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002038.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Degeneration(x) ← NonDegenerate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;non degenerate&apos; then x is a &apos;degeneration&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The healthy articular cartilage of a young adult knee joint is non degenerate, intact and evenly surfaced</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ObliquelyStriated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Striated"/>
    <rdfs:label xml:lang="de">obliqu gestreift</rdfs:label>
    <rdfs:label xml:lang="en-US">obliquely striated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002479"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape marked by narrow lines or grooves that are oriented obliquely relative to the long axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die durch schmale Linien oder Rillen gekennzeichnet ist, die schräg zur Längsachse ausgerichtet sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'obliquely striated' have not yet been formalized. The term is defined as a specific subtype of 'striated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002479.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Striated(x) ← ObliquelyStriated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;obliquely striated&apos; then x is a &apos;striated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The muscle fibers of some mollusks are obliquely striated, with filament bands angled to the long axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Orange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">orange</rdfs:label>
    <rdfs:label xml:lang="en-US">orange</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000953"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue situated between red and yellow, produced by wavelengths of around 590 nm</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton zwischen Rot und Gelb, erzeugt bei Wellenlängen um 590 nm</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'orange' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000953.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Orange(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;orange&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The carotenoid-rich integument of Pleuronectes platessa larvae is orange before camouflage pigmentation develops</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Supple">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">geschmeidig</rdfs:label>
    <rdfs:label xml:lang="en-US">supple</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002504"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Flexibility quality characterized by ease of bending without breaking, adaptability in movement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Flexibilitätsqualität, gekennzeichnet durch leichtes Biegen ohne Bruch, Anpassungsfähigkeit in der Bewegung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'supple' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002504.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Supple(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;supple&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin of neonatal mammals is supple, bending easily without resistance as it has not yet undergone keratinization</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Multifid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Split"/>
    <rdfs:label xml:lang="de">multifid</rdfs:label>
    <rdfs:label xml:lang="en-US">multifid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002231"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multifid is a split shape quality inhering in a bearer due to being divided into many lobes or similar segments</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Multifid ist eine gespaltene Formqualität, die einem Träger innewohnt, da er in viele Lappen oder ähnliche Segmente unterteilt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multifid' have not yet been formalized. The term is defined as a specific subtype of 'split'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002231.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Split(x) ← Multifid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multifid&apos; then x is a &apos;split&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Chelidonium majus is multifid, divided into several distinct lobes along each side of the midrib</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ShellShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">muschelförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">shell shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040007"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shell shaped is a shape quality inhering in a bearer by virtue of having a shape resembling a shell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Muschelförmig ist eine Formeigenschaft, die einem Träger innewohnt, weil er eine muschelähnliche Form hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shell shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040007.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← ShellShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shell shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The operculum of Patella vulgata is shell shaped, following the curved contour of the conical outer shell</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Upturned">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="de">nachobengedreht</rdfs:label>
    <rdfs:label xml:lang="en-US">upturned</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002031"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Upturned is a curvature quality inhering in a bearer by virtue of being curved or tilted such that the tip points upwards</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">„Upturned“ ist eine Krümmungseigenschaft, die einem Träger dadurch innewohnt, dass er so gebogen oder geneigt ist, dass die Spitze nach oben zeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'upturned' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002031.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← Upturned(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;upturned&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The snout of Sus scrofa is upturned, with the nasal disc angled upward relative to the rostral axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stubby">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">kurzstämmig</rdfs:label>
    <rdfs:label xml:lang="en-US">stubby</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001643"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Stubby is a size quality inhering in a bearer by virtue of having a short, stocky build</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stubby ist eine Größenqualität, die einem Träger durch seinen kurzen, stämmigen Körperbau innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'stubby' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001643.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Stubby(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;stubby&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The digits of Ambystoma maculatum larvae are stubby, short and stout relative to the overall limb length</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Uncoiled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Coiling"/>
    <rdfs:label xml:lang="de">nichtgerollt</rdfs:label>
    <rdfs:label xml:lang="en-US">uncoiled</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000415"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Uncoiled is a shape quality inhering in a bearer by virtue of not being curled or wound, especially in concentric rings or spirals</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">„Abgewickelt“ ist eine Formeigenschaft, die einem Träger innewohnt, weil er weder gekräuselt noch gewickelt ist, insbesondere bei konzentrischen Ringen oder Spiralen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'uncoiled' have not yet been formalized. The term is defined as a specific subtype of 'coiling'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000415.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Coiling(x) ← Uncoiled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;uncoiled&apos; then x is a &apos;coiling&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The extended gut of an autopsied Boa constrictor is uncoiled, straightened out and no longer wound in spiral loops</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Oriented">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RegularSpatialPattern"/>
    <rdfs:label xml:lang="de">ausgerichtet</rdfs:label>
    <rdfs:label xml:lang="en-US">oriented</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000614"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Regular pattern quality where repeated elements are oriented in the same direction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Regelmäßige Musterqualität, bei der wiederholte Elemente in die gleiche Richtung ausgerichtet sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'oriented' have not yet been formalized. The term is defined as a specific subtype of 'regular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000614.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RegularSpatialPattern(x) ← Oriented(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;oriented&apos; then x is a &apos;regular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The collagen fibers in tendon are uniformly oriented along the long axis of the tissue, maximizing tensile strength</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Nodular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Knobbled"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">knotig</rdfs:label>
    <rdfs:label xml:lang="en-US">nodular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002125"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Knobbled quality marked by rounded lumps or swellings often found in aggregates</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Knubbelige Qualität, gekennzeichnet durch abgerundete Klumpen oder Schwellungen, die häufig in Aggregaten vorkommen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'nodular' have not yet been formalized. The term is defined as a specific subtype of 'knobbled'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002125.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Knobbled(x) ← Nodular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;nodular&apos; then x is a &apos;knobbled&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface of the cirrhotic liver is nodular, with regenerative modules creating a coarse irregular topography</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Scaly">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rough"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="en-US">scaly</rdfs:label>
    <rdfs:label xml:lang="de">schuppig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001804"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rough quality resulting from overlapping or distinct scales, often dry or cracked texture</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Raue Qualität aufgrund überlappender oder deutlicher Schuppen, oft trockene oder rissige Textur</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scaly' have not yet been formalized. The term is defined as a specific subtype of 'rough'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001804.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rough(x) ← Scaly(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scaly&apos; then x is a &apos;rough&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin of Iguana iguana is scaly, covered in overlapping keratinized scales over the entire dorsal surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Distributed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="en-US">distributed</rdfs:label>
    <rdfs:label xml:lang="de">erteilt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001566"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial pattern characterized by evenly spread elements across a surface or area</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Räumliches Muster, das durch gleichmäßig verteilte Elemente über eine Oberfläche oder Fläche gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'distributed' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001566.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Distributed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;distributed&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The melanin granules in the feathers of Gallus domesticus are evenly distributed across the rachis and barbules</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TerminallySplayed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Splayed"/>
    <rdfs:label xml:lang="de">am ende gespreizt</rdfs:label>
    <rdfs:label xml:lang="en-US">terminally splayed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002058"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Splayed characteristic with broadening or spreading at the ends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gespreiztes Merkmal mit Verbreiterung oder Spreizung an den Enden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'terminally splayed' have not yet been formalized. The term is defined as a specific subtype of 'splayed'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002058.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Splayed(x) ← TerminallySplayed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;terminally splayed&apos; then x is a &apos;splayed&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The claws of Varanus komodoensis are terminally splayed, spreading wider at the tips for grip on substrate</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">braun</rdfs:label>
    <rdfs:label xml:lang="en-US">brown</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000952"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue consisting of reddish and yellowish tones with a medium to low brightness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton bestehend aus rötlichen und gelblichen Tönen mit mittlerer bis geringer Helligkeit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'brown' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000952.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Brown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;brown&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cortex of the walnut Juglans regia contains brown tannin-rich tissues visible on cross-section</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightOrange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Orange"/>
    <rdfs:label xml:lang="de">hellorange</rdfs:label>
    <rdfs:label xml:lang="en-US">light orange</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001255"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue displaying lighter tones of orange, often appearing bright and cheerful</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit helleren Orangetönen, der oft hell und fröhlich wirkt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light orange' have not yet been formalized. The term is defined as a specific subtype of 'orange'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001255.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Orange(x) ← LightOrange(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light orange&apos; then x is a &apos;orange&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The throat patch of Sylvia atricapilla males shows light orange coloration in certain light conditions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ringed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="de">bering</rdfs:label>
    <rdfs:label xml:lang="en-US">ringed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001775"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored pattern characterized by concentric circles or bands encircling the surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbiges Muster, gekennzeichnet durch konzentrische Kreise oder Bänder, die die Oberfläche umgeben</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ringed' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001775.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Ringed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ringed&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The abdomen of Vespa crabro is ringed with alternating yellow and dark brown transverse bands</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Keratinous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">keratinous</rdfs:label>
    <rdfs:label xml:lang="de">verhornt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002507"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation indicating the presence of keratinizing materials</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beobachtung der Zusammensetzung, die auf das Vorhandensein von keratinisierenden Materialien hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'keratinous' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002507.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Keratinous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;keratinous&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The horn of Rhinoceros unicornis is keratinous, composed entirely of compressed and hardened keratin filaments</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RegularSpatialPattern">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">regelmäßiges räumliches muster</rdfs:label>
    <rdfs:label xml:lang="en-US">regular spatial pattern</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000440"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial pattern showing uniform distribution and arrangement of elements</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Räumliches Muster, das die gleichmäßige Verteilung und Anordnung der Elemente zeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'regular spatial pattern' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000440.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← RegularSpatialPattern(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;regular spatial pattern&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hexagonal cells of a honeybee comb exhibit a regular spatial pattern with uniform cell spacing</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ColorPattern"/>
    <rdfs:label xml:lang="de">mehrfarbig</rdfs:label>
    <rdfs:label xml:lang="en-US">multi colored</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001533"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color feature exhibiting a variety or blend of multiple hues</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbmerkmal, das eine Vielfalt oder Mischung mehrerer Farbtöne aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multi colored' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001533.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← MultiColored(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multi colored&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The plumage of Agapornis roseicollis is multi colored, combining green wings with an orange-red face and breast</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Unlumenized">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities"/>
    <rdfs:label xml:lang="de">unlumenisiert</rdfs:label>
    <rdfs:label xml:lang="en-US">unlumenized</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001896"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unlumenized is a structure quality inhering in a bearer by virtue of lacking a three-dimensional space surrounded by anatomical structures and containing anatomical substances</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unlumenisiert ist eine Struktureigenschaft, die einem Träger innewohnt, weil ihm ein dreidimensionaler Raum fehlt, der von anatomischen Strukturen umgeben ist und anatomische Substanzen enthält</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unlumenized' have not yet been formalized. The term is defined as a specific subtype of 'cavities'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001896.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavities(x) ← Unlumenized(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unlumenized&apos; then x is a &apos;cavities&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dense nodular liver metastasis is unlumenized, lacking any internal canal system within the tumor mass</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Patelliform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">patelliform</rdfs:label>
    <rdfs:label xml:lang="de">sebenscheibenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002340"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a small, flat dish or saucer marked by slightly raised borders</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einer kleinen, flachen Schüssel oder Untertasse mit leicht erhabenen Rändern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'patelliform' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002340.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Patelliform(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;patelliform&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The scale of Archaeopteryx is patelliform, resembling a small flat dish with a slightly raised rim</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightYellowBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/YellowBrown"/>
    <rdfs:label xml:lang="de">hellgelbbraun</rdfs:label>
    <rdfs:label xml:lang="en-US">light yellow brown</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002413"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue blending lighter shades of yellow and brown, often appearing warm and earthy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der hellere Gelb- und Brauntöne mischt und oft warm und erdig wirkt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light yellow brown' have not yet been formalized. The term is defined as a specific subtype of 'yellow brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002413.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">YellowBrown(x) ← LightYellowBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light yellow brown&apos; then x is a &apos;yellow brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fur of juvenile Capreolus capreolus is light yellow brown, providing camouflage in grassland habitats</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Circinate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curled"/>
    <rdfs:label xml:lang="en-US">circinate</rdfs:label>
    <rdfs:label xml:lang="de">kreisförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001964"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curled shape displaying a circular or spiraled arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gewellte Form mit kreisförmiger oder spiralförmiger Anordnung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'circinate' have not yet been formalized. The term is defined as a specific subtype of 'curled'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001964.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curled(x) ← Circinate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;circinate&apos; then x is a &apos;curled&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The young fronds of Pteridium aquilinum are circinate, coiled in a tight fiddlehead before unfurling</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TaperedSize">
    <rdfs:seeAlso rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tapered"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Dappled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="en-US">dappled</rdfs:label>
    <rdfs:label xml:lang="de">gepunktet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001535"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored pattern characterized by rounded spots or splotches</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbiges Muster, gekennzeichnet durch abgerundete Punkte oder Flecken</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dappled' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001535.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Dappled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dappled&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The coat of Dama dama displays a dappled pattern of pale rounded spots on a rufous brown background</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleViolet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Violet"/>
    <rdfs:label xml:lang="de">blass lila</rdfs:label>
    <rdfs:label xml:lang="en-US">pale violet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002016"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Violet hue with diminished intensity or brightness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Violetter Farbton mit verminderter Intensität oder Helligkeit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale violet' have not yet been formalized. The term is defined as a specific subtype of 'violet'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002016.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Violet(x) ← PaleViolet(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale violet&apos; then x is a &apos;violet&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bracts of Lavandula stoechas show pale violet coloration at the tips with reduced pigment intensity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Anvil">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">ambossförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">anvil</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002386"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3-D shape resembling an anvil</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die einem Amboss ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'anvil' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002386.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← Anvil(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;anvil&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The incus bone of the human middle ear is anvil shaped with a body and two diverging processes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PatchyPigmentation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pigmented"/>
    <rdfs:label xml:lang="de">fleckig pigmentiert</rdfs:label>
    <rdfs:label xml:lang="en-US">patchy pigmentation</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0065002"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Patchy pigmentation is a degree of pigmentation quality that is diversified with patches or irregularity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bei der fleckigen Pigmentierung handelt es sich um einen Grad der Pigmentierungsqualität, der durch Flecken oder Unregelmäßigkeiten variiert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'patchy pigmentation' have not yet been formalized. The term is defined as a specific subtype of 'pigmented'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0065002.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pigmented(x) ← PatchyPigmentation(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;patchy pigmentation&apos; then x is a &apos;pigmented&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin of Piebald horses shows patchy pigmentation with large irregular white and colored areas across the coat</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkViolet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Violet"/>
    <rdfs:label xml:lang="en-US">dark violet</rdfs:label>
    <rdfs:label xml:lang="de">dunkelviolett</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001705"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue featuring intense and dark violet tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit intensiven und dunklen Violetttönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark violet' have not yet been formalized. The term is defined as a specific subtype of 'violet'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001705.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Violet(x) ← DarkViolet(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark violet&apos; then x is a &apos;violet&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The flowers of Viola tricolor show dark violet upper petals contrasting with lighter lower petals</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subtriangular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Triangular"/>
    <rdfs:label xml:lang="de">annähernd dreieckig</rdfs:label>
    <rdfs:label xml:lang="en-US">subtriangular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002230"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Triangular form with less defined angles or sides, exhibiting slight variations</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Dreieckige Form mit weniger definierten Winkeln oder Seiten, die leichte Abweichungen aufweisen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subtriangular' have not yet been formalized. The term is defined as a specific subtype of 'triangular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002230.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Triangular(x) ← Subtriangular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subtriangular&apos; then x is a &apos;triangular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cross-section of the olecranon process of the human ulna is subtriangular with rounded angles</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/AnteroPosteriorlyFlattened">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flattened"/>
    <rdfs:label xml:lang="en-US">antero posteriorly flattened</rdfs:label>
    <rdfs:label xml:lang="de">antero-posteriorly abgeflacht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002252"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Flattening in the anteroposterior direction, so shape is flatting to the front and back</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Abflachung in anteroposteriorer Richtung, sodass die Form nach vorne und hinten abflacht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'antero posteriorly flattened' have not yet been formalized. The term is defined as a specific subtype of 'flattened'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002252.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Flattened(x) ← AnteroPosteriorlyFlattened(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;antero posteriorly flattened&apos; then x is a &apos;flattened&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The disc of an intervertebral fibrocartilage is antero posteriorly flattened, with reduced thickness front to back</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tetrahedral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape3D"/>
    <rdfs:label xml:lang="de">tetraedrisch</rdfs:label>
    <rdfs:label xml:lang="en-US">tetrahedral</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002052"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">3D shape resembling a tetrahedron with four triangular faces often forming a pyramid</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">3D-Form, die einem Tetraeder mit vier dreieckigen Flächen ähnelt, die oft eine Pyramide bilden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tetrahedral' have not yet been formalized. The term is defined as a specific subtype of 'shape3 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002052.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape3D(x) ← Tetrahedral(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tetrahedral&apos; then x is a &apos;shape3 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The carbon atoms in diamond lattice form tetrahedral bonding geometry around each central atom</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spiny">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="en-US">spiny</rdfs:label>
    <rdfs:label xml:lang="de">stachelig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001365"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spiny is a surface feature shape quality inhering in a bearer by virtue of having spines, thorns, or similar thin projections on its surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stachelig ist eine Formqualität eines Oberflächenmerkmals, die einem Träger dadurch innewohnt, dass sich auf seiner Oberfläche Stacheln, Dornen oder ähnliche dünne Vorsprünge befinden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spiny' have not yet been formalized. The term is defined as a specific subtype of 'surface feature shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001365.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SurfaceFeatureShape(x) ← Spiny(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spiny&apos; then x is a &apos;surface feature shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The epidermis of the sea urchin Strongylocentrotus purpuratus is spiny, covered with moveable calcareous spines</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">2-d form</rdfs:label>
    <rdfs:label xml:lang="en-US">shape2 d</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002006"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape2D is a quality inhering in a two-dimensional entity, such as a cross-section or projection of a three-dimensional entity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Shape2D ist eine Qualität, die einer zweidimensionalen Entität innewohnt, beispielsweise einem Querschnitt oder einer Projektion einer dreidimensionalen Entität</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shape2 d' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002006.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Shape2D(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shape2 d&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The two-dimensional shape of a cross-section through the femur is analyzed in biomechanical studies of bone geometry</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Reniform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">nierenförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">reniform</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001871"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave shape that resembles a kidney structure, typically rounded on one side, with narrowing indentation opposite</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave Form, die einer Nierenstruktur ähnelt, typischerweise auf einer Seite abgerundet, mit einer sich verjüngenden Vertiefung auf der gegenüberliegenden Seite</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'reniform' have not yet been formalized. The term is defined as a specific subtype of 'concave'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001871.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave(x) ← Reniform(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;reniform&apos; then x is a &apos;concave&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The kidney of Homo sapiens is reniform, with a convex lateral border and an indented medial hilum</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Unlocalised">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">nicht-lokalisiert</rdfs:label>
    <rdfs:label xml:lang="en-US">unlocalised</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000635"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unlocalised is a spatial pattern inhering in a bearer due to not being confined to a particular location</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Nicht lokalisiert ist ein räumliches Muster, das einem Träger innewohnt, weil es nicht auf einen bestimmten Ort beschränkt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unlocalised' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000635.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Unlocalised(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unlocalised&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The lymphocytic infiltration in autoimmune thyroiditis appears unlocalised, spread throughout the gland without focal concentration</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Erose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Serration"/>
    <rdfs:label xml:lang="de">erodiert</rdfs:label>
    <rdfs:label xml:lang="en-US">erose</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001368"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Serration quality marked by irregular or jagged edges appearing eroded</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Verzahnung zeichnet sich durch unregelmäßige oder gezackte Kanten aus, die erodiert wirken</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'erose' have not yet been formalized. The term is defined as a specific subtype of 'serration'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001368.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Serration(x) ← Erose(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;erose&apos; then x is a &apos;serration&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The petal margin of Papaver rhoeas is erose, with an irregular jagged edge resembling erosion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightPurple">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Purple"/>
    <rdfs:label xml:lang="de">helllila</rdfs:label>
    <rdfs:label xml:lang="en-US">light purple</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001260"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue evidenced by lighter shades of purple, producing a calm and soft appearance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Farbton wird durch hellere Violetttöne hervorgehoben und sorgt für ein ruhiges und weiches Erscheinungsbild</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light purple' have not yet been formalized. The term is defined as a specific subtype of 'purple'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001260.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Purple(x) ← LightPurple(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light purple&apos; then x is a &apos;purple&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fruit of Solanum melongena shows light purple coloration in certain cultivar varieties before full maturity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Roughened">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rough"/>
    <rdfs:label xml:lang="de">aufgeraut</rdfs:label>
    <rdfs:label xml:lang="en-US">roughened</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001797"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rough quality enhanced with additional irregularities or texture on the surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Raue Qualität, verstärkt durch zusätzliche Unregelmäßigkeiten oder Textur auf der Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'roughened' have not yet been formalized. The term is defined as a specific subtype of 'rough'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001797.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rough(x) ← Roughened(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;roughened&apos; then x is a &apos;rough&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The periosteal surface of a healing fracture is roughened by callus deposition over the cortical bone</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BandShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">band shaped</rdfs:label>
    <rdfs:label xml:lang="de">bandförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040014"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a band or ribbon</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die einem Band oder Band ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'band shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040014.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← BandShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;band shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tapeworm proglottids are band shaped segments of flat ribbon-like form</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Semicircular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="de">halbrundig</rdfs:label>
    <rdfs:label xml:lang="en-US">semicircular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002232"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Semicircular is a 2-D shape quality inhering in a bearer by virtue of having the shape or form of half a circle</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Halbkreisförmig ist eine zweidimensionale Formqualität, die einem Träger innewohnt, da er die Form oder Gestalt eines Halbkreises hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'semicircular' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002232.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← Semicircular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;semicircular&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cross-section of the human semicircular canal is semicircular, forming a half-circle arc within the petrous bone</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightDeepPink">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pink"/>
    <rdfs:label xml:lang="de">hell-tiefrosa</rdfs:label>
    <rdfs:label xml:lang="en-US">light deep pink</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001257"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue showing lighter shades of deep pink, often delicate and soft</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit helleren Tiefrosatönen, oft zart und weich</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light deep pink' have not yet been formalized. The term is defined as a specific subtype of 'pink'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001257.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pink(x) ← LightDeepPink(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light deep pink&apos; then x is a &apos;pink&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mucous membrane of the healthy human cheek is light deep pink with good vascular perfusion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ScoopShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">schaufelförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">scoop shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002404"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling the curvature of a scoop or ladle, often broad and slightly deep</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die der Krümmung einer Schaufel oder Schöpfkelle ähnelt, oft breit und leicht tief</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scoop shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002404.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← ScoopShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scoop shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mandibular fossa of the temporal bone is scoop shaped, providing a shallow concavity for the condyle</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/InvertedVShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Angular"/>
    <rdfs:label xml:lang="en-US">inverted v shaped</rdfs:label>
    <rdfs:label xml:lang="de">umgekehrt v-förmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002484"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Angular form resembling an upside-down "V", often seen in structures or formations</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eckige Form, die einem umgedrehten „V“ ähnelt und oft in Strukturen oder Formationen zu sehen ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'inverted v shaped' have not yet been formalized. The term is defined as a specific subtype of 'angular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002484.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Angular(x) ← InvertedVShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;inverted v shaped&apos; then x is a &apos;angular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal arch of the foot in pes cavus appears inverted v shaped with an elevated midfoot arch</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Planar">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flat"/>
    <rdfs:label xml:lang="de">planar</rdfs:label>
    <rdfs:label xml:lang="en-US">planar</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002533"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Flat quality characterized by or occupying a plane, having no curvature</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Flache Qualität, die dadurch gekennzeichnet ist, dass sie eine Ebene einnimmt und keine Krümmung aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'planar' have not yet been formalized. The term is defined as a specific subtype of 'flat'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002533.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Flat(x) ← Planar(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;planar&apos; then x is a &apos;flat&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The glabrous skin of the human palm has a planar surface without significant surface relief features</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rubbery">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">gummiartig</rdfs:label>
    <rdfs:label xml:lang="en-US">rubbery</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001783"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality characteristic of rubber materials, often elastic and flexible</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Für Gummimaterialien charakteristische Texturqualität, oft elastisch und flexibel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rubbery' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001783.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Rubbery(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rubbery&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cartilage of the human pinna is rubbery, bending under pressure but returning to its original shape</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/HourglassShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="en-US">hourglass shaped</rdfs:label>
    <rdfs:label xml:lang="de">sanduhrenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002239"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling an hourglass, featuring a narrowing center and widening ends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die einer Sanduhr ähnelt, mit einer schmaler werdenden Mitte und breiter werdenden Enden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hourglass shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002239.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← HourglassShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hourglass shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The constricted isthmus of the uterine tube is hourglass shaped where it connects to the uterine body</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Prominent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">prominent</rdfs:label>
    <rdfs:label xml:lang="en-US">prominent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001911"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Protrusion, elevation, or visibility above surrounding parts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Vorsprung, Höhe oder Sichtbarkeit über umgebende Teile</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'prominent' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001911.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Prominent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;prominent&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The masseteric tuberosity of the mandible is prominent, projecting noticeably from the ramus surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/EdgeShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">edge shape</rdfs:label>
    <rdfs:label xml:lang="de">kantenform</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002267"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by the contour or profile of an object's boundary</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die durch die Kontur oder das Profil der Grenze eines Objekts gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'edge shape' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002267.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← EdgeShape(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;edge shape&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The edge shape of a leaf is a key diagnostic character in plant taxonomy, evaluated for crenation and serration</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/YellowBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brown"/>
    <rdfs:label xml:lang="de">gelbbraun</rdfs:label>
    <rdfs:label xml:lang="en-US">yellow brown</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002411"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color made of intermixed yellow and brown hues</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbe aus gemischten Gelb- und Brauntönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'yellow brown' have not yet been formalized. The term is defined as a specific subtype of 'brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002411.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Brown(x) ← YellowBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;yellow brown&apos; then x is a &apos;brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fur of Mustela putorius ferrets is yellow brown on the dorsum with darker guard hairs</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Digitate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">digitate</rdfs:label>
    <rdfs:label xml:lang="de">fingerförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001980"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling fingers radiating from a central point, often clustered or spread</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt Fingern, die von einem zentralen Punkt ausgehen und oft gebündelt oder gespreizt sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'digitate' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001980.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Digitate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;digitate&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaves of Aesculus hippocastanum are digitate, with five to seven leaflets radiating from a central point</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaturatedViolet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Violet"/>
    <rdfs:label xml:lang="de">sattes violett</rdfs:label>
    <rdfs:label xml:lang="en-US">saturated violet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001702"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saturated vilett is a color consisting of vilet hue and high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gesättigtes Violett ist eine Farbe, die aus einem violetten Farbton und einer hohen Sättigung besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saturated violet' have not yet been formalized. The term is defined as a specific subtype of 'violet'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001702.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Violet(x) ← SaturatedViolet(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saturated violet&apos; then x is a &apos;violet&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The flower color of Consolida ajacis is saturated violet with highly vivid intense purple-blue hues</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TrumpetShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">trompetenförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">trumpet shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002375"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Trumpet-shaped is a concave 3-D shape quality inhering in a bearer by virtue of resembling the shape of a trumpet</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Trompetenförmig ist eine konkave dreidimensionale Formeigenschaft, die einem Träger innewohnt, weil sie der Form einer Trompete ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'trumpet shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002375.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← TrumpetShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;trumpet shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The corolla of Brugmansia arborea is trumpet shaped, flaring from a narrow tube to a wide bell</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Undulate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">undulate</rdfs:label>
    <rdfs:label xml:lang="de">undulierend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000967"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Undulate is a shape quality inhering in a bearer due to having a sinuate margin and rippled surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Wellig ist eine Formeigenschaft, die einem Träger innewohnt, weil er einen geschwungenen Rand und eine gewellte Oberfläche hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'undulate' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000967.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Undulate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;undulate&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf margin of Viburnum lantana is undulate, with low irregular sinusoidal waves along the edge</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:label xml:lang="de">D-förmig</rdfs:label>
    <rdfs:label xml:lang="en-US">d shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002357"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Convex 3D shape resembling the letter "D", typically flat on one side</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konvexe 3D-Form, die dem Buchstaben „D“ ähnelt und typischerweise auf einer Seite flach ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'd shaped' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002357.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← DShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;d shaped&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cross-section of the trachea is d shaped, with the flat posterior side adjacent to the esophagus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightMagenta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Magenta"/>
    <rdfs:label xml:lang="de">hellmagenta</rdfs:label>
    <rdfs:label xml:lang="en-US">light magenta</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001253"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue displaying a bright yet light magenta tone, less saturated than pure magenta</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit einem hellen, aber hellen Magenta-Ton, weniger gesättigt als reines Magenta</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light magenta' have not yet been formalized. The term is defined as a specific subtype of 'magenta'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001253.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Magenta(x) ← LightMagenta(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light magenta&apos; then x is a &apos;magenta&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The petals of Dianthus deltoides show light magenta coloration with a paler central zone</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Porous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Porosity"/>
    <rdfs:label xml:lang="en-US">porous</rdfs:label>
    <rdfs:label xml:lang="de">porös</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000984"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Porous is a porosity quality inhering in a bearer by virtue of permitting the passage of gas or liquid through pores or interstices</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Porös ist eine Porositätseigenschaft, die einem Träger innewohnt, weil er den Durchgang von Gas oder Flüssigkeit durch Poren oder Zwischenräume ermöglicht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'porous' have not yet been formalized. The term is defined as a specific subtype of 'porosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000984.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Porosity(x) ← Porous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;porous&apos; then x is a &apos;porosity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cancellous bone in the vertebral body is porous, allowing vascular perfusion through the trabecular spaces</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Robust">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">robust</rdfs:label>
    <rdfs:label xml:lang="en-US">robust</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002310"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Robust is a quality inhering in a bearer by virtue of being strong, thick, or sturdy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Robust ist eine Eigenschaft, die einem Träger dadurch innewohnt, dass er stark, dick oder robust ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'robust' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002310.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Robust(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;robust&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The zygomatic arch of Paranthropus boisei is robust, reflecting the large jaw musculature of this hominin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Edematous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">edematous</rdfs:label>
    <rdfs:label xml:lang="de">ödematös</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001450"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation indicating the presence of swelling caused by fluid accumulation in tissues</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Beobachtung der Zusammensetzung weist auf das Vorhandensein einer Schwellung hin, die durch Flüssigkeitsansammlung im Gewebe verursacht wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'edematous' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001450.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Edematous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;edematous&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The paw of a mouse injected with carrageenan becomes edematous due to fluid accumulation in the subcutaneous tissue</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/YellowOrange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Orange"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Yellow"/>
    <rdfs:label xml:lang="de">gelborange</rdfs:label>
    <rdfs:label xml:lang="en-US">yellow orange</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001944"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color made of intermixed yellow and orange hues</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbe aus gemischten Gelb- und Orangetönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'yellow orange' have not yet been formalized. The term is defined as a specific subtype of 'orange'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001944.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Orange(x) ← YellowOrange(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;yellow orange&apos; then x is a &apos;orange&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ripe fruit of Prunus persica displays a yellow orange coloration blending both hues in the exocarp</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Interdigitated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">interdigitated</rdfs:label>
    <rdfs:label xml:lang="de">verzahnt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001960"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by being intertwined or interlocked like fingers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die dadurch gekennzeichnet ist, dass sie fingerartig ineinander verschlungen oder verschränkt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'interdigitated' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001960.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Interdigitated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;interdigitated&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The keratinocytes at the dermal-epidermal junction are interdigitated with dermal papillae, increasing adhesion surface area</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tensed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">angespannt</rdfs:label>
    <rdfs:label xml:lang="en-US">tensed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001536"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality denoting tightness or rigidity due to stretching or pulling forces</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, die die Festigkeit oder Steifigkeit aufgrund von Dehnungs- oder Zugkräften bezeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tensed' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001536.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Tensed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tensed&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The intima of an arteriosclerotic artery is tensed and rigid, no longer relaxing with the cardiac cycle</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Split">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">gespalten</rdfs:label>
    <rdfs:label xml:lang="en-US">split</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001786"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural characteristic marked by division or separation into two parts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelles Merkmal, das durch Teilung oder Trennung in zwei Teile gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'split' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001786.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Split(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;split&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The palate of a child with cleft palate is split along the midline, exposing the nasal cavity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Square">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Parallelogram"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rectangular"/>
    <rdfs:label xml:lang="de">quadratisch</rdfs:label>
    <rdfs:label xml:lang="en-US">square</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000413"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rectangular shape characterized by equal-length sides and four right angles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rechteckige Form, gekennzeichnet durch gleich lange Seiten und vier rechte Winkel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'square' have not yet been formalized. The term is defined as a specific subtype of 'parallelogram'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000413.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Parallelogram(x) ← Square(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;square&apos; then x is a &apos;parallelogram&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The scale outline of Polypterus senegalus has a nearly square outline with four approximately equal sides</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SandColor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightYellowBrown"/>
    <rdfs:label xml:lang="en-US">sand color</rdfs:label>
    <rdfs:label xml:lang="de">sandfarbe</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000766"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Resembling the color of sand or beach sediment</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ähnelt der Farbe von Sand oder Strandsedimenten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sand color' have not yet been formalized. The term is defined as a specific subtype of 'light yellow brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000766.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">LightYellowBrown(x) ← SandColor(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sand color&apos; then x is a &apos;light yellow brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal skin of Bufo bufo shows a sand color matching the soil substrate for cryptic concealment</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkPurple">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Purple"/>
    <rdfs:label xml:lang="en-US">dark purple</rdfs:label>
    <rdfs:label xml:lang="de">dunkellila</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001259"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue denoting deep and rich purple tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der tiefe und satte Lilatöne kennzeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark purple' have not yet been formalized. The term is defined as a specific subtype of 'purple'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001259.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Purple(x) ← DarkPurple(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark purple&apos; then x is a &apos;purple&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ripe berries of Sambucus nigra are dark purple, nearly black with intense anthocyanin pigmentation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TemporospatialPattern">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="en-US">temporospatial pattern</rdfs:label>
    <rdfs:label xml:lang="de">zeitlich-räumliches muster</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002305"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial pattern influenced by temporal coordination or sequence</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Räumliches Muster, das durch zeitliche Koordination oder Reihenfolge beeinflusst wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'temporospatial pattern' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002305.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← TemporospatialPattern(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;temporospatial pattern&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dermatomal distribution of a herpes zoster rash shows a temporospatial pattern following the sequence of viral reactivation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleBlue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Blue"/>
    <rdfs:label xml:lang="de">blass blau</rdfs:label>
    <rdfs:label xml:lang="en-US">pale blue</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002005"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Blue hue with less brightness or purity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Blauer Farbton mit geringerer Helligkeit oder Reinheit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale blue' have not yet been formalized. The term is defined as a specific subtype of 'blue'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002005.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Blue(x) ← PaleBlue(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale blue&apos; then x is a &apos;blue&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The iridescent wing scales of Morpho butterflies create a pale blue sheen under diffuse illumination</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CurvedDorsal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">curved dorsal</rdfs:label>
    <rdfs:label xml:lang="de">dorsal gekrümmt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001468"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature along the back or upper surface, often arching outward</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung entlang der Rückseite oder Oberseite, oft nach außen gewölbt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'curved dorsal' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001468.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← CurvedDorsal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;curved dorsal&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spine of Balaenoptera musculus has a curved dorsal profile, arching upward at the lower back region</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cupulate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CupShaped"/>
    <rdfs:label xml:lang="de">becherartig</rdfs:label>
    <rdfs:label xml:lang="en-US">cupulate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002342"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cup-shaped structure often associated with being deeply bowl-like</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die becherförmige Struktur wird oft mit einer tiefen Schalenform in Verbindung gebracht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cupulate' have not yet been formalized. The term is defined as a specific subtype of 'cup shaped'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002342.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">CupShaped(x) ← Cupulate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cupulate&apos; then x is a &apos;cup shaped&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The base of the acorn of Quercus petraea is cupulate, held in a deep cup formed by hardened bracts</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DumbbellShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="en-US">dumbbell shaped</rdfs:label>
    <rdfs:label xml:lang="de">hantelartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001876"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling a dumbbell, featuring two rounded ends connected by a thinner portion</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die einer Hantel ähnelt, mit zwei abgerundeten Enden, die durch einen dünneren Teil verbunden sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dumbbell shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001876.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← DumbbellShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dumbbell shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The halters of dipteran flies are dumbbell shaped, with two expanded knobs connected by a thin stem</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">oberflächenmerkmalsform</rdfs:label>
    <rdfs:label xml:lang="en-US">surface feature shape</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001925"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Surface feature shape is a quality inhering in a bearer by virtue of the shape of features present on its surface or outer shell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form von Oberflächenmerkmalen ist eine Eigenschaft, die einem Träger aufgrund der Form der auf seiner Oberfläche oder Außenhülle vorhandenen Merkmale innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'surface feature shape' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001925.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← SurfaceFeatureShape(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;surface feature shape&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface feature shape of a pollen grain is documented to distinguish species in palynological analysis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Translucent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <rdfs:label xml:lang="de">durchscheinend</rdfs:label>
    <rdfs:label xml:lang="en-US">translucent</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Translucent is a Morphological quality inhering in a bearer by virtue of allowing light to pass through diffusely, without clear image formation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Durchscheinend ist eine morphologische Eigenschaft, die einem Träger dadurch innewohnt, dass er Licht diffus durchlässt, ohne dass ein klares Bild entsteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'translucent' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← Translucent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;translucent&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The petals of Gypsophila paniculata are translucent, allowing diffuse light passage without clear image formation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Permeability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">durchlässigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">permeability</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000970"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality denoting the capacity for fluids or substances to pass through a material</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, die die Fähigkeit von Flüssigkeiten oder Substanzen bezeichnet, durch ein Material zu dringen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'permeability' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000970.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Permeability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;permeability&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The permeability of the alveolar wall allows gas exchange between inhaled air and pulmonary capillary blood</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PubescentHair">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy"/>
    <rdfs:label xml:lang="de">mit flaum bedeckt</rdfs:label>
    <rdfs:label xml:lang="en-US">pubescent hair</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001320"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Covered with short hairs or soft down</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bedeckt mit kurzen Haaren oder weichen Daunen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pubescent hair' have not yet been formalized. The term is defined as a specific subtype of 'hairy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001320.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hairy(x) ← PubescentHair(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pubescent hair&apos; then x is a &apos;hairy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The young stems of Quercus pubescens are covered with pubescent hair, giving a soft downy texture</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pectinate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Serrated"/>
    <rdfs:label xml:lang="de">kammförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">pectinate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000458"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Serrated form marked by projections or ridges resembling the teeth of a comb</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gezackte Form, gekennzeichnet durch Vorsprünge oder Grate, die den Zähnen eines Kamms ähneln</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pectinate' have not yet been formalized. The term is defined as a specific subtype of 'serrated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000458.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Serrated(x) ← Pectinate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pectinate&apos; then x is a &apos;serrated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The antenna of Saturnia pavonia is pectinate, with comb-like lateral extensions along each segment</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/NaturalColor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="en-US">natural color</rdfs:label>
    <rdfs:label xml:lang="de">Naturfarbe</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Natural color is a color quality of a material entity characterized by a hue that occurs or is perceived as occurring without artificial alteration</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Natürliche Farbe ist eine Farbqualität einer materiellen Einheit, die durch einen Farbton gekennzeichnet ist, der ohne künstliche Veränderung auftritt oder als auftretend wahrgenommen wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'natural color' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← NaturalColor(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;natural color&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The natural color of ivory from Loxodonta africana tusks is a warm cream-white without artificial alteration</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rusty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">rostig</rdfs:label>
    <rdfs:label xml:lang="en-US">rusty</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0070059"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rusty is a texture quality inhering in a bearer by virtue of being covered by iron oxide as a result of oxidation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rostig ist eine Textureigenschaft, die einem Träger innewohnt, weil er durch Oxidation mit Eisenoxid bedeckt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rusty' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0070059.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Rusty(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rusty&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface of the horseshoe crab Limulus polyphemus can appear rusty after exposure to iron-rich marine sediment</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Thin">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Slender"/>
    <rdfs:label xml:lang="de">dünn</rdfs:label>
    <rdfs:label xml:lang="en-US">thin</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001893"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Slender characteristic marked by reduced width or volume relative to length</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schlankes Merkmal, gekennzeichnet durch eine im Verhältnis zur Länge verringerte Breite oder ein geringeres Volumen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'thin' have not yet been formalized. The term is defined as a specific subtype of 'slender'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001893.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Slender(x) ← Thin(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;thin&apos; then x is a &apos;slender&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The nasal bones of Homo sapiens are thin, forming a delicate overlapping bridge above the piriform aperture</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleCyan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cyan"/>
    <rdfs:label xml:lang="de">blass cyan</rdfs:label>
    <rdfs:label xml:lang="en-US">pale cyan</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002007"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cyan color with decreased brightness or saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Cyan-Farbe mit verringerter Helligkeit oder Sättigung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale cyan' have not yet been formalized. The term is defined as a specific subtype of 'cyan'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002007.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cyan(x) ← PaleCyan(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale cyan&apos; then x is a &apos;cyan&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The eggshell of Turdus migratorius is pale cyan with a soft blue-green tint throughout</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cyan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">cyan</rdfs:label>
    <rdfs:label xml:lang="en-US">cyan</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000319"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue composed mainly of greenish blue tones, perceived at wavelengths between 490 and 520 nanometers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der hauptsächlich aus grünlichen Blautönen besteht und bei Wellenlängen zwischen 490 und 520 Nanometern wahrgenommen wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cyan' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000319.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Cyan(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cyan&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The head plumage of male Alcedo atthis shows brilliant cyan coloration from structural light interference</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Aliform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="en-US">aliform</rdfs:label>
    <rdfs:label xml:lang="de">flügelförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002236"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">2-D shape resembling wings or wing-like structures</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">2-D-Form, die Flügeln oder flügelähnlichen Strukturen ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'aliform' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002236.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← Aliform(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;aliform&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The transverse processes of thoracic vertebrae are aliform, extending laterally like wings from the vertebral body</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cylindrical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:label xml:lang="en-US">cylindrical</rdfs:label>
    <rdfs:label xml:lang="de">zylindrisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001873"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Convex 3D shape characterized by having parallel circular ends and continuous surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konvexe 3D-Form, gekennzeichnet durch parallele kreisförmige Enden und eine durchgehende Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cylindrical' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001873.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← Cylindrical(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cylindrical&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The diaphysis of the human humerus is cylindrical, with a round cross-section and continuous cortical surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Oblate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spheroid"/>
    <rdfs:label xml:lang="de">oblate</rdfs:label>
    <rdfs:label xml:lang="en-US">oblate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000409"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spheroid exhibiting an equatorial diameter greater than its polar diameter</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Sphäroid mit einem äquatorialen Durchmesser, der größer als sein Poldurchmesser ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'oblate' have not yet been formalized. The term is defined as a specific subtype of 'spheroid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000409.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spheroid(x) ← Oblate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;oblate&apos; then x is a &apos;spheroid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The red blood cells of camels are oblate, with equatorial diameter greater than the polar dimension</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Undistributed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">nicht verteilt</rdfs:label>
    <rdfs:label xml:lang="en-US">undistributed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001567"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Undistributed is a spatial pattern inhering in a bearer by virtue of not being spread out, scattered, or divided</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unverteilt ist ein räumliches Muster, das einem Träger dadurch innewohnt, dass es nicht ausgebreitet, zerstreut oder geteilt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'undistributed' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001567.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Undistributed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;undistributed&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tumor mass in a primary hepatocellular carcinoma is undistributed, remaining as a single cohesive lesion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Aggregated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="en-US">aggregated</rdfs:label>
    <rdfs:label xml:lang="de">aggregiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001629"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Irregular pattern formed by clustering or collecting</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unregelmäßiges Muster, das durch Clustern oder Sammeln entsteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'aggregated' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001629.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Aggregated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;aggregated&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The lymphocytes in Peyer patches form aggregated clusters along the intestinal wall</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Discolored">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ColorPattern"/>
    <rdfs:label xml:lang="en-US">discolored</rdfs:label>
    <rdfs:label xml:lang="de">verfärbt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000331"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color pattern displaying irregularity or deviation from its natural hue</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbmuster, das Unregelmäßigkeiten oder Abweichungen von seinem natürlichen Farbton aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'discolored' have not yet been formalized. The term is defined as a specific subtype of 'color pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000331.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ColorPattern(x) ← Discolored(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;discolored&apos; then x is a &apos;color pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The devitalized pulp of a non-vital tooth becomes discolored over time as hemoglobin breaks down within dentinal tubules</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Kinked">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Bent"/>
    <rdfs:label xml:lang="de">geknickt</rdfs:label>
    <rdfs:label xml:lang="en-US">kinked</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001798"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Bent quality featuring sharp angles or abrupt curves, often forming a wrinkle or fold</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gebogene Qualität mit scharfen Winkeln oder abrupten Kurven, die häufig eine Falte oder Falte bilden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'kinked' have not yet been formalized. The term is defined as a specific subtype of 'bent'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001798.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Bent(x) ← Kinked(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;kinked&apos; then x is a &apos;bent&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ureter in retrocaval ureter syndrome is kinked, forming a sharp angle as it passes behind the vena cava</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CurvedCaudal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">curved caudal</rdfs:label>
    <rdfs:label xml:lang="de">geschwungene Schwanzform</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001467"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature at the tail end of an organism, often leading upward</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung am Schwanzende eines Organismus, die oft nach oben führt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'curved caudal' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001467.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← CurvedCaudal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;curved caudal&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tail of a scorpion is curved caudal, arching upward and backward at the telson</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concavity"/>
    <rdfs:label xml:lang="en-US">convex</rdfs:label>
    <rdfs:label xml:lang="de">konvex</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001355"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by an outward-curved surface, bulging outwards</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, gekennzeichnet durch eine nach außen gewölbte Oberfläche, die sich nach außen wölbt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'convex' have not yet been formalized. The term is defined as a specific subtype of 'concavity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001355.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concavity(x) ← Convex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;convex&apos; then x is a &apos;concavity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The outer surface of the human calvarial bones is convex, bulging smoothly outward from the midline</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Viscid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Coating"/>
    <rdfs:label xml:lang="de">klebrig</rdfs:label>
    <rdfs:label xml:lang="en-US">viscid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001370"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Viscid is a coating quality which is sticky or clammy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zähflüssig ist eine Beschichtungsqualität, die klebrig oder klamm ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'viscid' have not yet been formalized. The term is defined as a specific subtype of 'coating'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001370.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Coating(x) ← Viscid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;viscid&apos; then x is a &apos;coating&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stigma of Fritillaria imperialis is viscid, coated with a sticky secretion to trap pollen</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RingedShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RingShape"/>
    <rdfs:label xml:lang="en-US">ringed shape</rdfs:label>
    <rdfs:label xml:lang="de">ringgestalt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002486"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ring shape quality marked by distinct rings or loops in configuration</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Qualität der Ringform, gekennzeichnet durch deutliche Ringe oder Schleifen in der Konfiguration</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ringed shape' have not yet been formalized. The term is defined as a specific subtype of 'ring shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002486.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RingShape(x) ← RingedShape(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ringed shape&apos; then x is a &apos;ring shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ringed shape of annelid segments in Lumbricus terrestris forms the external appearance of the body</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Knobbled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="en-US">knobbled</rdfs:label>
    <rdfs:label xml:lang="de">knollig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002427"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Surface feature shape characterized by raised, rounded protrusions or nodes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form eines Oberflächenmerkmals, gekennzeichnet durch erhabene, abgerundete Vorsprünge oder Knoten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'knobbled' have not yet been formalized. The term is defined as a specific subtype of 'surface feature shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002427.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SurfaceFeatureShape(x) ← Knobbled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;knobbled&apos; then x is a &apos;surface feature shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface of the American toad Anaxyrus americanus is knobbled with raised warty protuberances</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Separating">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">separating</rdfs:label>
    <rdfs:label xml:lang="de">trennend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002525"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Separating is a structural quality inhering in a bearer by virtue of being positioned to produce a separation or act to separate another entity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Trennung ist eine strukturelle Eigenschaft, die einem Träger dadurch innewohnt, dass er in der Lage ist, eine Trennung herbeizuführen oder eine andere Entität zu trennen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'separating' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002525.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Separating(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;separating&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The placenta acts as a separating structure between maternal and fetal circulation in the uterus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Obtuse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Circular"/>
    <rdfs:label xml:lang="en-US">obtuse</rdfs:label>
    <rdfs:label xml:lang="de">stumpf</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001935"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape quality characterized by a roundish form slightly inclining to be oblong</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formqualität gekennzeichnet durch eine rundliche, leicht längliche Form</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'obtuse' have not yet been formalized. The term is defined as a specific subtype of 'circular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001935.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Circular(x) ← Obtuse(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;obtuse&apos; then x is a &apos;circular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf apex of Hymenophyllum tunbrigense is obtuse, ending in a rounded slightly extended form</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Smooth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">glatt</rdfs:label>
    <rdfs:label xml:lang="en-US">smooth</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000701"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality characterized by an even and regular surface free of projections or roughness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Texturqualität, gekennzeichnet durch eine gleichmäßige und regelmäßige Oberfläche ohne Vorsprünge oder Rauheiten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'smooth' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000701.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Smooth(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;smooth&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The inner surface of the bovine small intestine is smooth at the macroscopic level in the duodenum</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Elongated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">elongated</rdfs:label>
    <rdfs:label xml:lang="de">verlängert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001154"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape displaying extended length relative to width, often slender</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form mit größerer Länge im Verhältnis zur Breite, oft schlank</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'elongated' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001154.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Elongated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;elongated&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skull of Canis lupus familiaris is elongated in dolichocephalic breeds with an extended muzzle</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hispid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy"/>
    <rdfs:label xml:lang="en-US">hispid</rdfs:label>
    <rdfs:label xml:lang="de">seinhaarig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002339"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Hairy quality characterized by stiff, bristly hairs on a surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Behaarte Qualität, gekennzeichnet durch steife, borstige Haare auf einer Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hispid' have not yet been formalized. The term is defined as a specific subtype of 'hairy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002339.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hairy(x) ← Hispid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hispid&apos; then x is a &apos;hairy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stem of Echium vulgare is hispid, covered with stiff white bristly hairs</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkGrey">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Grey"/>
    <rdfs:label xml:lang="en-US">dark grey</rdfs:label>
    <rdfs:label xml:lang="de">dunkelgrau</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001251"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue denoting darker shades of grey, commonly perceived as neutral</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der dunklere Grautöne bezeichnet und allgemein als neutral wahrgenommen wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark grey' have not yet been formalized. The term is defined as a specific subtype of 'grey'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001251.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Grey(x) ← DarkGrey(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark grey&apos; then x is a &apos;grey&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mantle of the giant squid Architeuthis dux is dark grey with sparse chromatophore activity in preserved specimens</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Roughness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <obo:IAO_0000117>PERSON: Thomas Hanke</obo:IAO_0000117>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">rauheit</rdfs:label>
    <rdfs:label xml:lang="en-US">roughness</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture or irregularities on a surface, quantified by vertical deviations from its ideal form</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Textur oder Unregelmäßigkeiten auf einer Oberfläche, quantifiziert durch vertikale Abweichungen von ihrer Idealform</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'roughness' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← Roughness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;roughness&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The roughness of shark skin is created by dermal denticles reducing hydrodynamic drag</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Introverted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Oriented"/>
    <rdfs:label xml:lang="en-US">introverted</rdfs:label>
    <rdfs:label xml:lang="de">introvertiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001856"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Orientation quality characterized by inward curve or projection</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Orientierungsqualität, gekennzeichnet durch eine Krümmung oder Projektion nach innen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'introverted' have not yet been formalized. The term is defined as a specific subtype of 'oriented'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001856.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Oriented(x) ← Introverted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;introverted&apos; then x is a &apos;oriented&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The umbilicus of Helix pomatia is introverted, curving inward into the shell along the columellar axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rectangular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Parallelogram"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Superelliptic"/>
    <rdfs:label xml:lang="de">rechteckig</rdfs:label>
    <rdfs:label xml:lang="en-US">rectangular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001867"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Parallelogram shape characterized by four right angles and straight sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Parallelogrammform, gekennzeichnet durch vier rechte Winkel und gerade Seiten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rectangular' have not yet been formalized. The term is defined as a specific subtype of 'parallelogram'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001867.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Parallelogram(x) ← Rectangular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rectangular&apos; then x is a &apos;parallelogram&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The scale of the body of Anguilla anguilla is rectangular in outline when removed and laid flat</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tessellated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Reticular"/>
    <rdfs:label xml:lang="de">mosaikförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">tessellated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000780"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Reticular pattern resembling a tiled or mosaic arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Netzförmiges Muster, das einer Fliesen- oder Mosaikanordnung ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tessellated' have not yet been formalized. The term is defined as a specific subtype of 'reticular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000780.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Reticular(x) ← Tessellated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tessellated&apos; then x is a &apos;reticular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin of the monitor lizard Varanus niloticus is tessellated with closely packed bead-like scales</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleGrey">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Grey"/>
    <rdfs:label xml:lang="de">blass grau</rdfs:label>
    <rdfs:label xml:lang="en-US">pale grey</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002009"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue exhibiting very pale grey tones, appearing nearly white and highly neutral</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit sehr blassen Grautönen, der fast weiß und sehr neutral erscheint</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale grey' have not yet been formalized. The term is defined as a specific subtype of 'grey'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002009.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Grey(x) ← PaleGrey(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale grey&apos; then x is a &apos;grey&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bone surface of a dried museum specimen of Homo sapiens is pale grey from mineral exposure</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DiamondShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Superelliptic"/>
    <rdfs:label xml:lang="en-US">diamond shaped</rdfs:label>
    <rdfs:label xml:lang="de">rautenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002320"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Superelliptic shape resembling a diamond or rhombus, with equal-length sides forming opposite angles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Superelliptische Form, die einer Raute oder Raute ähnelt, wobei gleichlange Seiten entgegengesetzte Winkel bilden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'diamond shaped' have not yet been formalized. The term is defined as a specific subtype of 'superelliptic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002320.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Superelliptic(x) ← DiamondShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;diamond shaped&apos; then x is a &apos;superelliptic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dermal scales of Varanus exanthematicus form a diamond shaped pattern visible on the dorsal surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Plumose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branched"/>
    <rdfs:label xml:lang="de">federnartig</rdfs:label>
    <rdfs:label xml:lang="en-US">plumose</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0005010"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Feathery quality resembling or having features akin to a feather or plume</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Federartige Qualität, die einer Feder oder einem Federbusch ähnelt oder ähnliche Merkmale aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'plumose' have not yet been formalized. The term is defined as a specific subtype of 'branched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0005010.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branched(x) ← Plumose(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;plumose&apos; then x is a &apos;branched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The setae of many polychaete worms are plumose, with fine lateral branches resembling feather vanes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SemiCrystallineStructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MaterialStructure"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="en-US">semi crystalline structure</rdfs:label>
    <rdfs:label xml:lang="de">teilkristalline Struktur</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Material structure with both crystalline and amorphous sections</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Materialstruktur mit sowohl kristallinen als auch amorphen Abschnitten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'semi crystalline structure' have not yet been formalized. The term is defined as a specific subtype of 'material structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructure(x) ← SemiCrystallineStructure(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;semi crystalline structure&apos; then x is a &apos;material structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cuticle of arthropod exoskeletons has a semi crystalline structure combining ordered chitin crystallites with amorphous protein</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Impermeable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Permeability"/>
    <rdfs:label xml:lang="en-US">impermeable</rdfs:label>
    <rdfs:label xml:lang="de">undurchlässig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000983"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Permeability quality marked by obstruction to fluid passage</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Durchlässigkeitsqualität, gekennzeichnet durch Behinderung des Flüssigkeitsdurchgangs</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'impermeable' have not yet been formalized. The term is defined as a specific subtype of 'permeability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000983.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Permeability(x) ← Impermeable(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;impermeable&apos; then x is a &apos;permeability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cornified layer of human epidermis is impermeable to water, preventing transepidermal water loss</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Triangular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="de">dreieckig</rdfs:label>
    <rdfs:label xml:lang="en-US">triangular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001875"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Triangular is a shape quality inhering in a bearer by virtue of having three angles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Dreieckig ist eine Formeigenschaft, die einem Träger innewohnt, weil er drei Winkel hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'triangular' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001875.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← Triangular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;triangular&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sacrum of the human pelvis is triangular in anterior view, widening superiorly and tapering to the coccyx</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Coating">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">Beschichtung</rdfs:label>
    <rdfs:label xml:lang="en-US">coating</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002012"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Coating is a texture quality of a material entity characterized by a layer of substance applied to or covering the surface of the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beschichtung ist eine Texturqualität einer materiellen Einheit, die durch eine Substanzschicht gekennzeichnet ist, die auf die Oberfläche des Trägers aufgetragen wird oder diese bedeckt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'coating' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002012.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Coating(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;coating&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mucous coating on the skin of Cyprinus carpio serves as a protective antimicrobial barrier</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Coiling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">Windung</rdfs:label>
    <rdfs:label xml:lang="en-US">coiling</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001794"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by a form of twisted loops</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, gekennzeichnet durch eine Form verdrehter Schleifen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'coiling' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001794.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Coiling(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;coiling&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The coiling of the intestines of Bos taurus creates a compact arrangement of many meters of gut</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fasciculated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fasciculation"/>
    <rdfs:label xml:lang="de">büschelweise</rdfs:label>
    <rdfs:label xml:lang="en-US">fasciculated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001861"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure quality characterized by grouped bundles or clusters, often parallel</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, gekennzeichnet durch gruppierte Bündel oder Cluster, oft parallel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fasciculated' have not yet been formalized. The term is defined as a specific subtype of 'fasciculation'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001861.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fasciculation(x) ← Fasciculated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fasciculated&apos; then x is a &apos;fasciculation&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The collagen fibers in tendon are fasciculated into primary bundles aligned parallel to the mechanical load axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ColorPattern">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">Farbmuster</rdfs:label>
    <rdfs:label xml:lang="en-US">color pattern</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000019"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial pattern involving the arrangement and distribution of color hues on a surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Räumliches Muster, bei dem es um die Anordnung und Verteilung von Farbtönen auf einer Oberfläche geht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'color pattern' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000019.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← ColorPattern(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;color pattern&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The color pattern of the poison dart frog Dendrobates azureus signals toxicity to predators</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaturatedGreen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Green"/>
    <rdfs:label xml:lang="de">sattes grün</rdfs:label>
    <rdfs:label xml:lang="en-US">saturated green</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001271"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saturated green is a color consisting of green hue and high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gesättigtes Grün ist eine Farbe, die aus einem grünen Farbton und hoher Sättigung besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saturated green' have not yet been formalized. The term is defined as a specific subtype of 'green'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001271.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Green(x) ← SaturatedGreen(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saturated green&apos; then x is a &apos;green&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal surface of a healthy frog Rana temporaria shows saturated green coloration from melanin and lipophores</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/XShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">x förmig</rdfs:label>
    <rdfs:label xml:lang="en-US">x shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002429"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">X-shaped is a shape quality inhering in a bearer due to resembling the form of the letter X</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">X-förmig ist eine Formeigenschaft, die einem Träger innewohnt, weil sie der Form des Buchstabens X ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'x shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002429.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← XShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;x shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The decussation of pyramidal tracts at the medullary-spinal junction forms an x shaped crossing pattern</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tripodal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">dreibeinig</rdfs:label>
    <rdfs:label xml:lang="en-US">tripodal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002428"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tripodal is a 3-D shape with three supports or legs</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Tripodal ist eine dreidimensionale Form mit drei Stützen oder Beinen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tripodal' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002428.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Tripodal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tripodal&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Some trichome structures on plant surfaces are tripodal, with three radiating prongs from a central attachment point</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Antrorse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">antrorse</rdfs:label>
    <rdfs:label xml:lang="de">vorwärts/hoch gebogen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002238"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature bending forward or upwards</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung nach vorne oder oben gebogen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'antrorse' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002238.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← Antrorse(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;antrorse&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spines on the stem of Rosa canina are antrorse, curved forward toward the apex of the stem</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Loose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="de">locker</rdfs:label>
    <rdfs:label xml:lang="en-US">loose</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001802"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural attribute indicating less compactness or rigidity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturmerkmal, das auf eine geringere Kompaktheit oder Steifigkeit hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'loose' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001802.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Loose(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;loose&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The connective tissue beneath the skin of Rattus norvegicus is loose, allowing the skin to move freely</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CurvedLingually">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">curved lingually</rdfs:label>
    <rdfs:label xml:lang="de">geschwungene Zungenform</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0005019"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature oriented towards the tongue or inner side of the mouth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zur Zunge oder Innenseite des Mundes gerichtete Krümmung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'curved lingually' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0005019.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← CurvedLingually(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;curved lingually&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The incisor roots of many rodents are curved lingually, arcing toward the tongue as they develop in the jaw</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/EquilateralTriangular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Triangular"/>
    <rdfs:label xml:lang="en-US">equilateral triangular</rdfs:label>
    <rdfs:label xml:lang="de">gleichseitig dreieckig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002306"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Triangular shape characterized by equal length sides and angles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Dreieckige Form, gekennzeichnet durch gleich lange Seiten und Winkel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'equilateral triangular' have not yet been formalized. The term is defined as a specific subtype of 'triangular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002306.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Triangular(x) ← EquilateralTriangular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;equilateral triangular&apos; then x is a &apos;triangular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The arrangement of three ocelli on the head of a wasp forms an equilateral triangular pattern</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/AmorphousStructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MaterialStructure"/>
    <rdfs:label xml:lang="de">amorphe Struktur</rdfs:label>
    <rdfs:label xml:lang="en-US">amorphous structure</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Material structure characterized by lacking a defined shape</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Materialstruktur, die durch das Fehlen einer definierten Form gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'amorphous structure' have not yet been formalized. The term is defined as a specific subtype of 'material structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructure(x) ← AmorphousStructure(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;amorphous structure&apos; then x is a &apos;material structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The vitreous humor of the eye has an amorphous structure, lacking defined form or regular organization</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MediallyRotated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rotated"/>
    <rdfs:label xml:lang="de">Medial Rotiert</rdfs:label>
    <rdfs:label xml:lang="en-US">medially rotated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002155"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rotation quality inhering in a bearer by virtue of being rotated towards the middle of an organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rotationseigenschaft, die einem Träger innewohnt, weil er zur Mitte eines Organismus hin gedreht wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'medially rotated' have not yet been formalized. The term is defined as a specific subtype of 'rotated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002155.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rotated(x) ← MediallyRotated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;medially rotated&apos; then x is a &apos;rotated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The foot in pes varus is medially rotated, turning inward toward the midline of the body</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaturatedMagenta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Magenta"/>
    <rdfs:label xml:lang="de">sattes magenta</rdfs:label>
    <rdfs:label xml:lang="en-US">saturated magenta</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001275"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saturated magenta is a color consisting of magenta with high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gesättigtes Magenta ist eine Farbe, die aus Magenta mit hoher Sättigung besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saturated magenta' have not yet been formalized. The term is defined as a specific subtype of 'magenta'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001275.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Magenta(x) ← SaturatedMagenta(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saturated magenta&apos; then x is a &apos;magenta&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The flower of Bougainvillea spectabilis shows saturated magenta bracts with highly vivid intense color</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Olive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BrownGreen"/>
    <rdfs:label xml:lang="en-US">olive</rdfs:label>
    <rdfs:label xml:lang="de">olivgrün</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002773"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Brown-green color hue associated with green olives, often dull</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Braungrüner Farbton, assoziiert mit grünen Oliven, oft matt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'olive' have not yet been formalized. The term is defined as a specific subtype of 'brown green'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002773.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BrownGreen(x) ← Olive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;olive&apos; then x is a &apos;brown green&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal scales of Testudo hermanni show an olive coloration with dull yellow-green tones</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ligneous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">holzartig</rdfs:label>
    <rdfs:label xml:lang="en-US">ligneous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002348"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality characterized by wood-like appearance or texture</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, gekennzeichnet durch holzähnliches Aussehen oder eine holzähnliche Textur</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ligneous' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002348.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Ligneous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ligneous&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The secondary xylem of Quercus suber has a ligneous quality, with thickened cell walls giving a wood-like texture</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TransverselyStriated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Striated"/>
    <rdfs:label xml:lang="de">transvers gestreift</rdfs:label>
    <rdfs:label xml:lang="en-US">transversely striated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002478"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Transversely striated is a shape quality inhering in a bearer due to narrow lines or grooves, usually parallel, being oriented transversely to the bearer's long axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Quergestreift ist eine Formeigenschaft, die einem Träger innewohnt, weil schmale Linien oder Rillen, meist parallel, quer zur Längsachse des Trägers ausgerichtet sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'transversely striated' have not yet been formalized. The term is defined as a specific subtype of 'striated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002478.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Striated(x) ← TransverselyStriated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;transversely striated&apos; then x is a &apos;striated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Skeletal muscle is transversely striated, with Z-lines creating cross-banding visible under light microscopy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Plush">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">flauschig</rdfs:label>
    <rdfs:label xml:lang="en-US">plush</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040004"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Plush is a texture quality inhering in a bearer by virtue of being covered with hair that has increased thickness and softness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Plüsch ist eine Texturqualität, die einem Träger innewohnt, weil er mit Haaren bedeckt ist, die dicker und weicher sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'plush' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040004.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Plush(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;plush&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The velvet antler covering of growing deer is plush, with dense soft hair of increased thickness and softness</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Squircle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Superelliptic"/>
    <rdfs:label xml:lang="de">squircle</rdfs:label>
    <rdfs:label xml:lang="en-US">squircle</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002319"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Squircle is a shape with properties between those of a square and those of a circle</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ein Squircle ist eine Form mit Eigenschaften, die zwischen denen eines Quadrats und denen eines Kreises liegen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'squircle' have not yet been formalized. The term is defined as a specific subtype of 'superelliptic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002319.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Superelliptic(x) ← Squircle(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;squircle&apos; then x is a &apos;superelliptic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cross-section of some tree trunks approaches a squircle, intermediate between round and square outline</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DorsallyRotated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rotated"/>
    <rdfs:label xml:lang="en-US">dorsally rotated</rdfs:label>
    <rdfs:label xml:lang="de">rückenwärts gedreht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001658"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rotation towards the back side of an organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Drehung zur Rückseite eines Organismus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dorsally rotated' have not yet been formalized. The term is defined as a specific subtype of 'rotated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001658.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rotated(x) ← DorsallyRotated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dorsally rotated&apos; then x is a &apos;rotated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The scapula in winged scapula syndrome is dorsally rotated, tilting its inferior angle toward the back</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RandomPattern">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="en-US">random pattern</rdfs:label>
    <rdfs:label xml:lang="de">zufälliges Muster</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002401"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Random pattern is characterized by an unidentifiable or unpredictable arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zufällige Muster zeichnen sich durch eine nicht identifizierbare oder unvorhersehbare Anordnung aus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'random pattern' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002401.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← RandomPattern(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;random pattern&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cells in a poorly differentiated carcinoma show a random pattern with no recognizable spatial organization</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SculptedSurface">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="de">geschnitzte Oberfläche</rdfs:label>
    <rdfs:label xml:lang="en-US">sculpted surface</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002433"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sculpted surface is a surface feature shape marked by large amounts of relief, often with multiple ridges and grooves in close association</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine geformte Oberfläche ist eine Oberflächenform, die durch große Reliefmengen gekennzeichnet ist, oft mit mehreren Rippen und Rillen in enger Verbindung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sculpted surface' have not yet been formalized. The term is defined as a specific subtype of 'surface feature shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002433.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SurfaceFeatureShape(x) ← SculptedSurface(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sculpted surface&apos; then x is a &apos;surface feature shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface of the cranium of Triceratops horridus is sculpted with numerous ridges and grooves for horn attachment</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Friability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Bröckeligkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">friability</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002405"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality indicating an entity's tendency to crumble or break apart</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, die die Tendenz einer Einheit zum Zerfall oder Auseinanderbrechen angibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'friability' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002405.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Friability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;friability&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The adenoma of the colon exhibits marked friability, crumbling when touched during colonoscopic biopsy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Radiopacity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">radiodichte</rdfs:label>
    <rdfs:label xml:lang="en-US">radiopacity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015010"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality indicating ability to obstruct X-rays or radiographic rays, appearing whiter on film</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, die auf die Fähigkeit hinweist, Röntgen- oder Röntgenstrahlen abzuschirmen und auf Film weißer zu erscheinen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'radiopacity' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015010.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Radiopacity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;radiopacity&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The enamel of human teeth shows high radiopacity on dental X-rays due to high calcium mineral density</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/AbsenceDueToDegeneration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Degenerate"/>
    <rdfs:label xml:lang="de">Fehlen aufgrund von Degeneration</rdfs:label>
    <rdfs:label xml:lang="en-US">absence due to degeneration</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Degeneration resulting in complete loss of function or structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Degeneration, die zum vollständigen Funktions- oder Strukturverlust führt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'absence due to degeneration' have not yet been formalized. The term is defined as a specific subtype of 'degenerate'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015001.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Degenerate(x) ← AbsenceDueToDegeneration(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;absence due to degeneration&apos; then x is a &apos;degenerate&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The absence due to degeneration of the tail vertebrae during amphibian metamorphosis results in the adult tailless body plan</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ornamentation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="de">Ornamentierung</rdfs:label>
    <rdfs:label xml:lang="en-US">ornamentation</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002440"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Surface feature shape quality with highly topographical surface with ridges, pits, rugosity, or other structures</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Oberflächenmerkmalsformqualität mit stark topografischer Oberfläche mit Graten, Vertiefungen, Unebenheiten oder anderen Strukturen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ornamentation' have not yet been formalized. The term is defined as a specific subtype of 'surface feature shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002440.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SurfaceFeatureShape(x) ← Ornamentation(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ornamentation&apos; then x is a &apos;surface feature shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface ornamentation of pollen grains in Asteraceae includes elaborate spinules and reticulate ridges visible under SEM</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ScimitarShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">krummsäbelartig</rdfs:label>
    <rdfs:label xml:lang="en-US">scimitar shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002417"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling a scimitar or curved blade with sweeping edges</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die einem Krummsäbel oder einer gebogenen Klinge mit geschwungenen Kanten ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scimitar shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002417.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← ScimitarShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scimitar shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spleen of Homo sapiens is scimitar shaped in some anatomical variants with a curved blade-like outline</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkPalePink">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pink"/>
    <rdfs:label xml:lang="en-US">dark pale pink</rdfs:label>
    <rdfs:label xml:lang="de">dunkelblassrosa</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001280"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue with darker tones of pale pink, often subtle and muted</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit dunkleren Tönen von blassem Rosa, oft dezent und gedämpft</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark pale pink' have not yet been formalized. The term is defined as a specific subtype of 'pink'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001280.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pink(x) ← DarkPalePink(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark pale pink&apos; then x is a &apos;pink&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The gingival tissue affected by mild periodontitis shows dark pale pink coloration from subtle vascular changes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DegreeOfPigmentation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Grad der Pigmentierung</rdfs:label>
    <rdfs:label xml:lang="en-US">degree of pigmentation</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002247"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality reflecting the level or extent of color presence in pigmentation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, die den Grad oder das Ausmaß der Farbpräsenz in der Pigmentierung widerspiegelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'degree of pigmentation' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002247.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← DegreeOfPigmentation(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;degree of pigmentation&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The degree of pigmentation in melanotic skin lesions is graded to assess melanocyte activity and tumor progression</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="en-US">Morphological quality</rdfs:label>
    <rdfs:label xml:lang="de">morphologische Qualität</rdfs:label>
    <skos:editorialNote xml:lang="en-US">Though Morphological qualities like color need a process (with lighting) to exist, they are modeled to be independent of processes to favor the scope of reflecting a broad perception.</skos:editorialNote>
    <skos:editorialNote>through one can argue that Morphological qualitiies like color need a process (with ligthing) to exist, they are here modeled to be independed of processes to favour the scope of reflecting the perception of persons in general.</skos:editorialNote>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Morphological quality is the quality related to the size, shape, and appearance of objects focusing on human perception</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Morphologische Qualität ist die Qualität in Bezug auf Größe, Form und Aussehen von Objekten, die sich auf die menschliche Wahrnehmung konzentriert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'Morphological quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000019'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000019(x) ← MorphologicalQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;morphological quality&apos; then x is a &apos;b f o_0000019&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The morphological quality of leaf shape in herbarium specimens is used for taxonomic identification of plant species</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalRelationalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
    <rdfs:label xml:lang="en-US">morphological relational quality</rdfs:label>
    <rdfs:label xml:lang="de">morphologische relationale Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Morphological relational quality is a quality related to the structural or morphological characteristics of an entity that is inherently dependent on a relation to another entity or quantity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Morphologische relationale Qualität ist eine Qualität, die sich auf strukturelle oder morphologische Eigenschaften einer Entität bezieht, die inhärent von einer Relation zu einer anderen Entität oder Größe abhängt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for &apos;morphological relational quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;BFO_0000145&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000145(x) ← MorphologicalRelationalQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;morphological relational quality&apos; then x is a &apos;BFO_0000145&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The aspect ratio of vertebral bodies is a morphological relational quality used to detect osteoporotic compression fractures</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ossified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Calcified"/>
    <rdfs:label xml:lang="de">ossifiziert</rdfs:label>
    <rdfs:label xml:lang="en-US">ossified</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001448"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Quality inhering in a bearer by virtue of being hardened by the deposition of calcium into bone</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Qualität, die dem Träger innewohnt, da er durch die Ablagerung von Kalzium im Knochen gehärtet wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ossified' have not yet been formalized. The term is defined as a specific subtype of 'calcified'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001448.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Calcified(x) ← Ossified(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ossified&apos; then x is a &apos;calcified&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tendon attachment of Achilles tendon in elderly individuals can become ossified with calcium deposits replacing fibrous tissue</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SplayedRostral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Splayed"/>
    <rdfs:label xml:lang="de">rostral gespreizte</rdfs:label>
    <rdfs:label xml:lang="en-US">splayed rostral</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002153"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Splayed rostral is a curvature quality inhering in a bearer due to being curved outwards toward the front of an organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gespreizter Rostral ist eine Krümmungseigenschaft, die einem Träger innewohnt, weil er nach außen zur Vorderseite eines Organismus hin gekrümmt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'splayed rostral' have not yet been formalized. The term is defined as a specific subtype of 'splayed'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002153.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Splayed(x) ← SplayedRostral(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;splayed rostral&apos; then x is a &apos;splayed&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The nasal cartilages of Platypus anatinus are splayed rostral, spreading outward at the front of the bill</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CurvedMedial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">curved medial</rdfs:label>
    <rdfs:label xml:lang="de">geschwungene Medianform</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002164"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature along the median axis of an organism, typically along a balance plane</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung entlang der Mittelachse eines Organismus, typischerweise entlang einer Gleichgewichtsebene</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'curved medial' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002164.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← CurvedMedial(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;curved medial&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The femoral neck has a curved medial profile as seen in the coronal plane in hip X-rays</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Zygomorphic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BilateralSymmetry"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Symmetry"/>
    <rdfs:label xml:lang="de">zygomorph</rdfs:label>
    <rdfs:label xml:lang="en-US">zygomorphic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001327"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Symmetry characterized by bilateral symmetry, typically dividing an organism into two mirror-image halves</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Symmetrie, gekennzeichnet durch bilaterale Symmetrie, die typischerweise einen Organismus in zwei spiegelbildliche Hälften teilt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'zygomorphic' have not yet been formalized. The term is defined as a specific subtype of 'bilateral symmetry'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001327.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BilateralSymmetry(x) ← Zygomorphic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;zygomorphic&apos; then x is a &apos;bilateral symmetry&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The flower of Antirrhinum majus is zygomorphic, with bilateral symmetry dividing it into mirror-image halves</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SinglePlacement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RegularSpatialPattern"/>
    <rdfs:label xml:lang="de">einzelanordnung</rdfs:label>
    <rdfs:label xml:lang="en-US">single placement</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001898"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Regular spatial pattern characterized by isolated or singular positioning of elements in a sequence</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Regelmäßiges räumliches Muster, das durch die isolierte oder singuläre Positionierung von Elementen in einer Sequenz gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'single placement' have not yet been formalized. The term is defined as a specific subtype of 'regular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001898.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RegularSpatialPattern(x) ← SinglePlacement(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;single placement&apos; then x is a &apos;regular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The terminal bud of Acer platanoides shows single placement at the apex of each twig</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fasciated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">fasciated</rdfs:label>
    <rdfs:label xml:lang="de">gebündelt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000949"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape alteration characterized by abnormal fusion or branching of parts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formveränderung, gekennzeichnet durch abnormale Verschmelzung oder Verzweigung von Teilen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fasciated' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000949.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Fasciated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fasciated&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The terminal shoot of Celosia argentea shows fasciated growth with multiple shoots fused into a flat crested form</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/AnteromediallyRotated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rotated"/>
    <rdfs:label xml:lang="en-US">anteromedially rotated</rdfs:label>
    <rdfs:label xml:lang="de">anteromedially rotiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002399"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rotation towards the anterior and medial positions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rotation nach anterior und medial</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'anteromedially rotated' have not yet been formalized. The term is defined as a specific subtype of 'rotated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002399.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rotated(x) ← AnteromediallyRotated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;anteromedially rotated&apos; then x is a &apos;rotated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The lesser tubercle of the humerus is anteromedially rotated, facing inward toward the chest wall</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CarpelLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">carpel like</rdfs:label>
    <rdfs:label xml:lang="de">fruchtblätterartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002454"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a carpel of a flower, typically having a curved structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einem Fruchtblatt einer Blüte und weist typischerweise eine gebogene Struktur auf</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'carpel like' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002454.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← CarpelLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;carpel like&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The modified sepals of some Ranunculaceae flowers become carpel like in structure through homeotic transformation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Porosity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Porösität</rdfs:label>
    <rdfs:label xml:lang="en-US">porosity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000973"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Porosity is a structure quality inhering in a bearer by virtue of the disposition to admit the passage of gas or liquid through pores or interstices</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Porosität ist eine Struktureigenschaft, die einem Träger aufgrund der Eigenschaft innewohnt, den Durchgang von Gas oder Flüssigkeit durch Poren oder Zwischenräume zu ermöglichen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'porosity' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000973.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Porosity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;porosity&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The porosity of trabecular bone in the femoral head is quantified by micro-CT to assess osteoporotic risk</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PorosityFraction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalRelationalQuality"/>
    <rdfs:label xml:lang="en-US">porosity fraction</rdfs:label>
    <rdfs:label xml:lang="de">Porositätsgrad</rdfs:label>
    <skos:altLabel xml:lang="en-US">void fraction</skos:altLabel>
    <skos:altLabel xml:lang="en-US">open porosity</skos:altLabel>
    <skos:altLabel xml:lang="de">Hohlraumanteil</skos:altLabel>
    <iof-av:symbol xml:lang="en-US">φ</iof-av:symbol>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Porosity fraction is a morphological relational quality of a material that quantifies the ratio of void volume to total volume as a dimensionless fraction between 0 and 1</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Porositätsgrad ist eine morphologische relationale Qualität eines Materials, die das Verhältnis von Leervolumen zu Gesamtvolumen als dimensionslose Zahl zwischen 0 und 1 angibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for &apos;porosity fraction&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;morphological relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalRelationalQuality(x) ← PorosityFraction(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;porosity fraction&apos; then x is a &apos;morphological relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The porosity fraction of cancellous bone in a lumbar vertebra is approximately 0.75, meaning 75% void volume</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ovate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spheroid"/>
    <rdfs:label xml:lang="de">eiförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">ovate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001891"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Oval shape tapering at one end</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ovale Form, die sich an einem Ende verjüngt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ovate' have not yet been formalized. The term is defined as a specific subtype of 'spheroid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001891.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spheroid(x) ← Ovate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ovate&apos; then x is a &apos;spheroid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Betula pendula is ovate, widest below the middle and tapering toward the pointed apex</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/FocallyExtensive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Localized"/>
    <rdfs:label xml:lang="en-US">focally extensive</rdfs:label>
    <rdfs:label xml:lang="de">fokal ausgedehnt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002415"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Localized pattern displayed over a wide area but centered around a focal point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Lokalisiertes Muster, das über einen weiten Bereich angezeigt wird, aber um einen Brennpunkt zentriert ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'focally extensive' have not yet been formalized. The term is defined as a specific subtype of 'localized'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002415.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Localized(x) ← FocallyExtensive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;focally extensive&apos; then x is a &apos;localized&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The inflammatory lesion in bovine pneumonia is focally extensive, concentrated in one lung lobe but widely spread within it</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Villiform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">villiform</rdfs:label>
    <rdfs:label xml:lang="en-US">villiform</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002022"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Villiform is a concave 3-D shape quality inhering in a bearer due to resembling a minute projection or villus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Villiform ist eine konkave dreidimensionale Form, die einem Träger innewohnt, weil sie einem winzigen Vorsprung oder einer Zotte ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'villiform' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002022.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← Villiform(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;villiform&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The intestinal villi are villiform projections of the mucosal surface increasing absorptive area in the jejunum</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Granular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">granular</rdfs:label>
    <rdfs:label xml:lang="de">körnig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001759"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation characterized by the presence of small, grain-like particles or structures</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beobachtung der Zusammensetzung, gekennzeichnet durch das Vorhandensein kleiner, körniger Partikel oder Strukturen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'granular' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001759.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Granular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;granular&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cytoplasm of mast cells appears granular due to large metachromatic secretory granules filling the cell body</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Obclavate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">obclavate</rdfs:label>
    <rdfs:label xml:lang="en-US">obclavate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002213"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3-D shape characterized by an inversely clavate form</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, gekennzeichnet durch eine umgekehrt klavierte Form</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'obclavate' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002213.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← Obclavate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;obclavate&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fruit of some species of Eragrostis is obclavate, broadening toward the apex unlike the club shape</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subparallel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">subparallel</rdfs:label>
    <rdfs:label xml:lang="en-US">subparallel</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002400"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape marked by lines or structures that are mostly but not completely parallel</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die durch Linien oder Strukturen gekennzeichnet ist, die größtenteils, aber nicht vollständig parallel sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subparallel' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002400.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Subparallel(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subparallel&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The secondary veins in leaves of Acer saccharum run subparallel, mostly but not perfectly aligned to each other</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RingShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">ring shape</rdfs:label>
    <rdfs:label xml:lang="de">ringförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002485"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by a circular or looped configuration</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, gekennzeichnet durch eine kreisförmige oder schleifenförmige Konfiguration</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ring shape' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002485.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← RingShape(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ring shape&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ring shape of the annular ligament of the radius holds the radial head in its articulation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hollow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavitated"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities"/>
    <rdfs:label xml:lang="de">hohl</rdfs:label>
    <rdfs:label xml:lang="en-US">hollow</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002078"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cavity quality defined by a void or emptiness inside a structure or material</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Hohlraumqualität, definiert durch einen Hohlraum oder eine Leere innerhalb einer Struktur oder eines Materials</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hollow' have not yet been formalized. The term is defined as a specific subtype of 'cavitated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002078.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavitated(x) ← Hollow(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hollow&apos; then x is a &apos;cavitated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hollow medullary cavity of long bones is filled with marrow and bordered by dense cortical bone</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Contamination">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">Kontamination</rdfs:label>
    <rdfs:label xml:lang="en-US">contamination</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015031"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Observation of foreign elements presence in a material, causing impurity or pollution</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beobachtung des Vorhandenseins von Fremdelementen in einem Material, die zu Verunreinigungen oder Verschmutzungen führen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'contamination' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015031.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Contamination(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;contamination&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bone graft material shows contamination with bacterial biofilm detected by microbiological culture</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sinuous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curvature"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sinuate"/>
    <rdfs:label xml:lang="de">schwungvoll</rdfs:label>
    <rdfs:label xml:lang="en-US">sinuous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001989"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sinuate quality characterized by smooth, rounded, and flowing curves</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Geschwungene Qualität, gekennzeichnet durch glatte, abgerundete und fließende Kurven</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sinuous' have not yet been formalized. The term is defined as a specific subtype of 'curvature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001989.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curvature(x) ← Sinuous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sinuous&apos; then x is a &apos;curvature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The lateral line of Poecilia reticulata runs sinuously along the flank with gentle smooth undulations</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rugose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="de">faltig</rdfs:label>
    <rdfs:label xml:lang="en-US">rugose</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001359"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Irregular spatial pattern marked by wrinkled or ridged surfaces</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unregelmäßiges räumliches Muster, gekennzeichnet durch faltige oder geriffelte Oberflächen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rugose' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001359.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Rugose(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rugose&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The seed surface of Nelumbo nucifera is rugose, marked by deep wrinkles and ridges from drying</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rosaceous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pink"/>
    <rdfs:label xml:lang="en-US">rosaceous</rdfs:label>
    <rdfs:label xml:lang="de">rosafarbig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000396"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pink hue resembling or associated with roses, typically displaying a vibrant tone</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rosa Farbton, der Rosen ähnelt oder mit ihnen assoziiert wird und typischerweise einen lebendigen Ton aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rosaceous' have not yet been formalized. The term is defined as a specific subtype of 'pink'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000396.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pink(x) ← Rosaceous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rosaceous&apos; then x is a &apos;pink&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The rosaceous petals of Rosa centifolia display a vibrant pink hue characteristic of cultivated garden roses</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Looseness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">Lockerheit</rdfs:label>
    <rdfs:label xml:lang="en-US">looseness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002010"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality inhering in a bearer by virtue of the bearer's being full of small openings or gaps</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Texturqualität, die einem Träger innewohnt, weil der Träger voller kleiner Öffnungen oder Lücken ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'looseness' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002010.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Looseness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;looseness&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The looseness of the submucosal layer allows the mucosa of the rectum to slide freely over the muscular wall</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PerpendicularCurvature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curvature"/>
    <rdfs:label xml:lang="en-US">perpendicular curvature</rdfs:label>
    <rdfs:label xml:lang="de">rechtwinklige krümmung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015016"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature indicating bending towards right angles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung, die eine Biegung zum rechten Winkel anzeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'perpendicular curvature' have not yet been formalized. The term is defined as a specific subtype of 'curvature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015016.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curvature(x) ← PerpendicularCurvature(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;perpendicular curvature&apos; then x is a &apos;curvature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The secondary roots emerge from the primary root of maize at perpendicular curvature to the main axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Navicular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">kahnförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">navicular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000344"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling a boat or ship structure, typically elongated and hollowed</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die einer Boots- oder Schiffsstruktur ähnelt, typischerweise länglich und ausgehöhlt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'navicular' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000344.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← Navicular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;navicular&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The navicular bone of the human wrist is navicular in shape, elongated and hollowed like a small boat</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MaterialStructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <obo:IAO_0000119 xml:lang="en-US">“Material - Classification by structure.” Wikipedia The Free Encyclopedia, https://en.wikipedia.org/wiki/Material#Classification_by_structure. Accessed 13 Jan. 2023.</obo:IAO_0000119>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Materialstruktur</rdfs:label>
    <rdfs:label xml:lang="en-US">material structure</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure quality of materials on diffent dimentional scales, ranging from macro, meso, micro to nano scale</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität von Materialien auf verschiedenen Dimensionsskalen, von der Makro-, Meso-, Mikro- bis zur Nanoskala</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'material structure' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← MaterialStructure(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;material structure&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The material structure of cortical bone is assessed at macro, micro, and nano scales to understand fracture resistance</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lobed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lobate"/>
    <rdfs:label xml:lang="de">gelappt</rdfs:label>
    <rdfs:label xml:lang="en-US">lobed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001979"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Lobate characteristic marked by distinct sections or lobes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Lobate-Merkmal, gekennzeichnet durch deutliche Abschnitte oder Lappen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lobed' have not yet been formalized. The term is defined as a specific subtype of 'lobate'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001979.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Lobate(x) ← Lobed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lobed&apos; then x is a &apos;lobate&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The liver of Homo sapiens is lobed, divided into four morphological lobes with distinct venous territories</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleBlack">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Black"/>
    <rdfs:label xml:lang="de">blass schwarz</rdfs:label>
    <rdfs:label xml:lang="en-US">pale black</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002004"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Black color with reduced intensity or saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schwarze Farbe mit reduzierter Intensität oder Sättigung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale black' have not yet been formalized. The term is defined as a specific subtype of 'black'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002004.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Black(x) ← PaleBlack(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale black&apos; then x is a &apos;black&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The melanized pycnidia of some fungal pathogens appear pale black, with reduced melanin compared to typical dark forms</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DesaturatedRed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Red"/>
    <rdfs:label xml:lang="en-US">desaturated red</rdfs:label>
    <rdfs:label xml:lang="de">entsättigtes Rot</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001284"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue characterized by red tones mixed with white or grey, reducing saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der durch Rottöne gekennzeichnet ist, die mit Weiß oder Grau gemischt werden und die Sättigung verringern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'desaturated red' have not yet been formalized. The term is defined as a specific subtype of 'red'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001284.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Red(x) ← DesaturatedRed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;desaturated red&apos; then x is a &apos;red&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The faded red coloration of aging museum specimens of red-winged blackbirds becomes desaturated red from light exposure</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tapered">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sharp"/>
    <rdfs:label xml:lang="de">spitz zulaufend</rdfs:label>
    <rdfs:label xml:lang="en-US">tapered</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001500"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape narrowing or gradually reducing in thickness towards one end</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form wird zu einem Ende hin schmaler oder nimmt allmählich an Dicke ab</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tapered' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001500.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Tapered(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tapered&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The root of the canine tooth is tapered, gradually narrowing from the cemento-enamel junction to the apex</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DesaturatedCyan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cyan"/>
    <rdfs:label xml:lang="en-US">desaturated cyan</rdfs:label>
    <rdfs:label xml:lang="de">entsättigtes Cyan</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001270"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue where cyan tones are mixed with white or grey, reducing saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, bei dem Cyan-Töne mit Weiß oder Grau gemischt werden, wodurch die Sättigung verringert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'desaturated cyan' have not yet been formalized. The term is defined as a specific subtype of 'cyan'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001270.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cyan(x) ← DesaturatedCyan(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;desaturated cyan&apos; then x is a &apos;cyan&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The blue-grey skin of Tursiops truncatus appears desaturated cyan when viewed under natural illumination</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/YShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="de">y förmig</rdfs:label>
    <rdfs:label xml:lang="en-US">y shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001201"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Y-shaped is a concave 3-D shape quality inhering in a bearer by virtue of resembling the form of the letter Y</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Y-förmig ist eine konkave dreidimensionale Form, die einem Träger innewohnt, da sie der Form des Buchstabens Y ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'y shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001201.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← YShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;y shaped&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bifurcation of the abdominal aorta into the common iliac arteries forms a y shaped branching pattern</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/NonFragile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fragility"/>
    <rdfs:label xml:lang="de">nicht zerbrechlich</rdfs:label>
    <rdfs:label xml:lang="en-US">non fragile</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001716"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Non-fragile is a structural quality inhering in a bearer by virtue of being able to withstand great strain without tearing or breaking</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Nicht zerbrechlich ist eine strukturelle Eigenschaft, die einem Träger innewohnt, da er großen Belastungen standhalten kann, ohne zu reißen oder zu brechen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'non fragile' have not yet been formalized. The term is defined as a specific subtype of 'fragility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001716.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fragility(x) ← NonFragile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;non fragile&apos; then x is a &apos;fragility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cortical bone of a healthy young adult femur is non fragile, resisting fracture under normal loading</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Parallelodromous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branched"/>
    <rdfs:label xml:lang="de">Parallelodrom</rdfs:label>
    <rdfs:label xml:lang="en-US">parallelodromous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001968"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Quality having two or more parallel primary branches originating beside each other and converging apically</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Qualität mit zwei oder mehr parallelen Primärzweigen, die nebeneinander entspringen und apikal zusammenlaufen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'parallelodromous' have not yet been formalized. The term is defined as a specific subtype of 'branched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001968.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branched(x) ← Parallelodromous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;parallelodromous&apos; then x is a &apos;branched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf venation of Musa acuminata is parallelodromous, with parallel veins running alongside each other to the apex</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Colored">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="en-US">colored</rdfs:label>
    <rdfs:label xml:lang="de">farbig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000336"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color quality exhibiting visible hues</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbqualität mit sichtbaren Farbtönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'colored' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000336.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Colored(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;colored&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pigmented iris of Homo sapiens is colored with variable melanin distribution giving blue, green or brown appearance</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pink">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Red"/>
    <rdfs:label xml:lang="de">rosa</rdfs:label>
    <rdfs:label xml:lang="en-US">pink</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000954"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue produced by blending red with white, often appearing as soft or pale red</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der durch Mischen von Rot mit Weiß entsteht und oft als weiches oder blasses Rot erscheint</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pink' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000954.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Pink(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pink&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mucosal lining of the healthy human esophagus is pink with good vascular supply visible on endoscopy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hydrocephalic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Edematous"/>
    <rdfs:label xml:lang="en-US">hydrocephalic</rdfs:label>
    <rdfs:label xml:lang="de">wasserkopfartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001853"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Edematous quality presenting swollen head due to fluid accumulation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ödematöse Qualität mit geschwollenem Kopf aufgrund von Flüssigkeitsansammlung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hydrocephalic' have not yet been formalized. The term is defined as a specific subtype of 'edematous'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001853.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Edematous(x) ← Hydrocephalic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hydrocephalic&apos; then x is a &apos;edematous&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skull of a hydrocephalic infant is enlarged and dome-like due to cerebrospinal fluid accumulation in the ventricles</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Wavy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curvature"/>
    <rdfs:label xml:lang="en-US">wavy</rdfs:label>
    <rdfs:label xml:lang="de">wellig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000211"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature marked by repetitive undulations or waves</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung, die durch sich wiederholende Wellen oder Wellen gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'wavy' have not yet been formalized. The term is defined as a specific subtype of 'curvature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000211.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curvature(x) ← Wavy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;wavy&apos; then x is a &apos;curvature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The wall of the stomach is wavy in the relaxed state forming rugae visible on endoscopy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Yellow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">gelb</rdfs:label>
    <rdfs:label xml:lang="en-US">yellow</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000324"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue perceptible between green and orange due to wavelengths around 570-590 nanometers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Aufgrund der Wellenlängen um 570-590 Nanometer ist ein Farbton zwischen Grün und Orange wahrnehmbar</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'yellow' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000324.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Yellow(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;yellow&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fat deposits of Ovis aries are yellow, colored by carotenoids absorbed from ingested vegetation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Organized">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/OrganizationQuality"/>
    <rdfs:label xml:lang="de">organisiert</rdfs:label>
    <rdfs:label xml:lang="en-US">organized</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000938"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Organized is a structural quality inhering in a bearer by virtue of exhibiting organization</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Organisiert ist eine strukturelle Qualität, die einem Träger aufgrund der ausgestellten Organisation innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'organized' have not yet been formalized. The term is defined as a specific subtype of 'organization quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000938.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganizationQuality(x) ← Organized(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;organized&apos; then x is a &apos;organization quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The collagen fibers in normal tendon are organized in parallel bundles aligned with the tensile force axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiLocalised">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">mehrfachlokalisiert</rdfs:label>
    <rdfs:label xml:lang="en-US">multi localised</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001791"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-localised is a spatial pattern inhering in a bearer by virtue of being confined or restricted to multiple locations</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Multilokalisiert ist ein räumliches Muster, das einem Träger dadurch innewohnt, dass es auf mehrere Standorte beschränkt oder beschränkt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multi localised' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001791.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← MultiLocalised(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multi localised&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The metastatic melanoma deposits in a liver are multi localised, found at multiple separate foci throughout the organ</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N8f5052841bf4431d9d0c9ac85882f126">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="N32abe31e2b034313bf9583d9f5bcf99c"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Raised">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">erhöht</rdfs:label>
    <rdfs:label xml:lang="en-US">raised</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001369"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Raised is a shape quality inhering in a colony by virtue of appearing above the medium surface with terraced edges</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Erhaben ist eine Formeigenschaft, die einer Kolonie dadurch innewohnt, dass sie über der mittleren Oberfläche mit terrassierten Rändern erscheint</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'raised' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001369.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Raised(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;raised&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bacterial colony of Bacillus cereus on agar has a raised profile with terraced edges above the medium surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brown"/>
    <rdfs:label xml:lang="de">hellbraun</rdfs:label>
    <rdfs:label xml:lang="en-US">light brown</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001246"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue depicting lighter tones of brown, often warm and earthy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit helleren Brauntönen, oft warm und erdig</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light brown' have not yet been formalized. The term is defined as a specific subtype of 'brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001246.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Brown(x) ← LightBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light brown&apos; then x is a &apos;brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The iris of many common domestic dogs is light brown, reflecting moderate melanin density in the stromal layer</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stepped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">abgestuft</rdfs:label>
    <rdfs:label xml:lang="en-US">stepped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015016"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Stepped is a shape or form resembling a step of a stairway, such as a ledge or offset margin</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Abgestuft ist eine Form oder Form, die einer Treppenstufe ähnelt, beispielsweise ein Sims oder ein versetzter Rand</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'stepped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015016.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Stepped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;stepped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cross-section of the cochlea shows a stepped arrangement of the scala media between the two outer scalae</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cystic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavitated"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities"/>
    <rdfs:label xml:lang="en-US">cystic</rdfs:label>
    <rdfs:label xml:lang="de">zystenartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001673"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cavity quality characterized by hollow, fluid-filled sacs or lesions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Hohlraumqualität, gekennzeichnet durch hohle, mit Flüssigkeit gefüllte Säcke oder Läsionen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cystic' have not yet been formalized. The term is defined as a specific subtype of 'cavitated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001673.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavitated(x) ← Cystic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cystic&apos; then x is a &apos;cavitated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The thyroglossal duct remnant presents as a cystic midline neck mass with fluid-filled interior</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SickleShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Falciform"/>
    <rdfs:label xml:lang="de">sicheformig</rdfs:label>
    <rdfs:label xml:lang="en-US">sickle shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002056"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Falciform shape resembling a sickle, often marked by crescent curvature with pointed ends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Falzförmige Form, die einer Sichel ähnelt, oft durch eine sichelförmige Krümmung mit spitzen Enden gekennzeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sickle shaped' have not yet been formalized. The term is defined as a specific subtype of 'falciform'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002056.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Falciform(x) ← SickleShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sickle shaped&apos; then x is a &apos;falciform&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The red blood cells in sickle cell disease are sickle shaped, deformed by polymerized hemoglobin S</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rough">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">rauh</rdfs:label>
    <rdfs:label xml:lang="en-US">rough</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000700"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality characterized by irregularities or abrupt variations on a surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Texturqualität, gekennzeichnet durch Unregelmäßigkeiten oder abrupte Variationen auf einer Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rough' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000700.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Rough(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rough&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The outer surface of the human parietal bone has a rough texture from vascular foramina and muscle attachment marks</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subelliptical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Superelliptic"/>
    <rdfs:label xml:lang="de">fast elliptisch</rdfs:label>
    <rdfs:label xml:lang="en-US">subelliptical</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0005004"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Almost equivalent to an ellipse</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Entspricht fast einer Ellipse</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subelliptical' have not yet been formalized. The term is defined as a specific subtype of 'superelliptic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0005004.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Superelliptic(x) ← Subelliptical(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subelliptical&apos; then x is a &apos;superelliptic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf outline of Quercus robur is subelliptical, closely approximating an ellipse with minor deviations</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concavity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">Konkavität</rdfs:label>
    <rdfs:label xml:lang="en-US">concavity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002005"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape quality indicating an inward curved surface or depression</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formqualität, die auf eine nach innen gekrümmte Oberfläche oder Vertiefung hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'concavity' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002005.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Concavity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;concavity&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The concavity of the glenoid fossa provides a shallow socket for the humeral head in the glenohumeral joint</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Greasy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Coated"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Coating"/>
    <rdfs:label xml:lang="en-US">greasy</rdfs:label>
    <rdfs:label xml:lang="de">schmierig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001606"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Coated texture marked by an oily or slick surface quality</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beschichtete Textur mit öliger oder glatter Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'greasy' have not yet been formalized. The term is defined as a specific subtype of 'coated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001606.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Coated(x) ← Greasy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;greasy&apos; then x is a &apos;coated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin of some amphibians is greasy to the touch from mucous gland secretions containing lipids</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Glabrous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pilosity"/>
    <rdfs:label xml:lang="en-US">glabrous</rdfs:label>
    <rdfs:label xml:lang="de">unbehaart</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000453"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pilosity quality marked by lacking hair or surface protrusions, smooth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Behaarungsqualität, gekennzeichnet durch fehlende Haare oder Oberflächenvorsprünge, glatt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'glabrous' have not yet been formalized. The term is defined as a specific subtype of 'pilosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000453.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pilosity(x) ← Glabrous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;glabrous&apos; then x is a &apos;pilosity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf surface of Magnolia grandiflora is glabrous on the adaxial side, smooth and lacking any hair</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/OrganizationQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Organisationsqualität</rdfs:label>
    <rdfs:label xml:lang="en-US">organization quality</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002264"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality denoting arrangement and distribution of components in a systematic manner</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, die die systematische Anordnung und Verteilung von Komponenten bezeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'organization quality' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002264.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← OrganizationQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;organization quality&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The organization quality of the collagen network in normal cornea determines its optical transparency</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Beige">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightYellowBrown"/>
    <rdfs:label xml:lang="de">beige</rdfs:label>
    <rdfs:label xml:lang="en-US">beige</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002410"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color consisting of light yellow-brown hues</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbe bestehend aus hellen gelbbraunen Farbtönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'beige' have not yet been formalized. The term is defined as a specific subtype of 'light yellow brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002410.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">LightYellowBrown(x) ← Beige(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;beige&apos; then x is a &apos;light yellow brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sandy skin of the desert-adapted Scincus scincus is beige, blending with the light-colored substrate</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Uninflated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities"/>
    <rdfs:label xml:lang="de">unaufgeblasen</rdfs:label>
    <rdfs:label xml:lang="en-US">uninflated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002377"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Uninflated is a structure quality inhering in a bearer by virtue of not being filled with air</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unaufgeblasen ist eine Struktureigenschaft, die einem Träger dadurch innewohnt, dass er nicht mit Luft gefüllt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'uninflated' have not yet been formalized. The term is defined as a specific subtype of 'cavities'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002377.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavities(x) ← Uninflated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;uninflated&apos; then x is a &apos;cavities&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The lung of a stillborn animal is uninflated, dense and sinking in water as air never entered the alveoli</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Torsioned">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RotationalCurvature"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">torsioned</rdfs:label>
    <rdfs:label xml:lang="de">verdreht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002445"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rotational curvature marked by a twist or rotation around an axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rotationskrümmung, gekennzeichnet durch eine Drehung oder Drehung um eine Achse</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'torsioned' have not yet been formalized. The term is defined as a specific subtype of 'rotational curvature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002445.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RotationalCurvature(x) ← Torsioned(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;torsioned&apos; then x is a &apos;rotational curvature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spermatic cord in testicular torsion is torsioned, twisted around its own axis obstructing blood supply</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sharpness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">schärfe</rdfs:label>
    <rdfs:label xml:lang="en-US">sharpness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000944"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sharpness is a shape quality inhering in a bearer by virtue of having a sharp or tapered end or point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schärfe ist eine Formeigenschaft, die einem Träger dadurch innewohnt, dass er ein scharfes oder sich verjüngendes Ende oder eine spitze Spitze hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sharpness' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000944.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Sharpness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sharpness&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sharpness of the spine of Cactaceae is assessed by the degree of taper and point angle at the tip</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Matte">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Gloss"/>
    <rdfs:label xml:lang="de">matt</rdfs:label>
    <rdfs:label xml:lang="en-US">matte</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Gloss quality characterized by a non-reflective or dull surface finish</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Glanzqualität, gekennzeichnet durch eine nicht reflektierende oder matte Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'matte' have not yet been formalized. The term is defined as a specific subtype of 'gloss'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Gloss(x) ← Matte(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;matte&apos; then x is a &apos;gloss&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal scales of Vipera aspis have a matte finish with minimal reflectance of ambient light</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightCyan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cyan"/>
    <rdfs:label xml:lang="de">hellcyan</rdfs:label>
    <rdfs:label xml:lang="en-US">light cyan</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001247"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue characterized by light cyan tones, softer and less intense</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, gekennzeichnet durch helle Cyan-Töne, weicher und weniger intensiv</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light cyan' have not yet been formalized. The term is defined as a specific subtype of 'cyan'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001247.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cyan(x) ← LightCyan(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light cyan&apos; then x is a &apos;cyan&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The eggshell of the European Starling is light cyan with a delicate blue-green tint</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Thick">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">dick</rdfs:label>
    <rdfs:label xml:lang="en-US">thick</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001892"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality denoting increased volume or width relative to length or height</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, die ein vergrößertes Volumen oder eine größere Breite im Verhältnis zur Länge oder Höhe bezeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'thick' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001892.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Thick(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;thick&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cortical bone of the femoral midshaft in Homo sapiens is thick relative to the medullary cavity diameter</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Invaginated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave"/>
    <rdfs:label xml:lang="de">Eingefaltet</rdfs:label>
    <rdfs:label xml:lang="en-US">Invaginated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001748"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape quality in which a portion of the outermost boundary of an entity folds in space such that a portion that was originally convex is now concave</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formqualität, bei der sich ein Teil der äußersten Grenze eines Objekts im Raum so faltet, dass ein ursprünglich konvexer Teil nun konkav ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'Invaginated' have not yet been formalized. The term is defined as a specific subtype of 'concave'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001748.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave(x) ← Invaginated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;invaginated&apos; then x is a &apos;concave&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The gastrulation process produces an invaginated endoderm as the blastula surface folds inward to form the archenteron</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DesaturatedYellow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Yellow"/>
    <rdfs:label xml:lang="en-US">desaturated yellow</rdfs:label>
    <rdfs:label xml:lang="de">entsättigtes Gelb</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001286"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue blending yellow tones with white or grey, diminishing brightness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der Gelbtöne mit Weiß oder Grau vermischt und die Helligkeit verringert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'desaturated yellow' have not yet been formalized. The term is defined as a specific subtype of 'yellow'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001286.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Yellow(x) ← DesaturatedYellow(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;desaturated yellow&apos; then x is a &apos;yellow&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The yellowing leaves of nitrogen-deficient Zea mays show desaturated yellow coloration from chloroplast degradation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/AlternatePlacement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RegularSpatialPattern"/>
    <rdfs:label xml:lang="de">abwechselnde Platzierung</rdfs:label>
    <rdfs:label xml:lang="en-US">alternate placement</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001932"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Regular spatial pattern where elements are alternately arranged in sequence</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Regelmäßiges räumliches Muster, bei dem Elemente abwechselnd der Reihe nach angeordnet sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'alternate placement' have not yet been formalized. The term is defined as a specific subtype of 'regular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001932.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RegularSpatialPattern(x) ← AlternatePlacement(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;alternate placement&apos; then x is a &apos;regular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaves of Rosa canina show alternate placement, with successive leaves positioned on opposite sides of the stem</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BrushLikeShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">borstenförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">brush like shape</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002315"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a brush, typically having multiple thin projections</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einem Pinsel und weist typischerweise mehrere dünne Vorsprünge auf</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'brush like shape' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002315.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← BrushLikeShape(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;brush like shape&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The styloid process of the temporal bone develops a brush like shape with multiple small spicules in some individuals</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Emarginate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Notched"/>
    <rdfs:label xml:lang="de">ausgebuchtet</rdfs:label>
    <rdfs:label xml:lang="en-US">emarginate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002234"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Notched quality characterized by a shallow depression or indented margin</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gekerbte Qualität, gekennzeichnet durch eine flache Vertiefung oder einen eingekerbten Rand</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'emarginate' have not yet been formalized. The term is defined as a specific subtype of 'notched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002234.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Notched(x) ← Emarginate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;emarginate&apos; then x is a &apos;notched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The apex of the leaf of Vicia sativa is emarginate, with a shallow V-shaped notch at the tip</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightYellow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Yellow"/>
    <rdfs:label xml:lang="de">hellgelb</rdfs:label>
    <rdfs:label xml:lang="en-US">light yellow</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001264"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue marked by paler shades of yellow, often bright and cheerful</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit helleren Gelbtönen, oft hell und fröhlich</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light yellow' have not yet been formalized. The term is defined as a specific subtype of 'yellow'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001264.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Yellow(x) ← LightYellow(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light yellow&apos; then x is a &apos;yellow&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bone marrow fat cells of a well-nourished individual appear light yellow from stored lipid deposits</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pentagonal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="de">pentagonal</rdfs:label>
    <rdfs:label xml:lang="en-US">pentagonal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040016"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pentagonal is a shape quality inhering in a bearer by virtue of having five angles and five sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Fünfeckig ist eine Formeigenschaft, die einem Träger innewohnt, da er fünf Winkel und fünf Seiten hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pentagonal' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040016.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← Pentagonal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pentagonal&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The calyx of Malva sylvestris is pentagonal in outline, formed by five fused sepals visible in cross-section</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Whorled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RegularSpatialPattern"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">wirtelig</rdfs:label>
    <rdfs:label xml:lang="en-US">whorled</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001951"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Regular spatial pattern characterized by circular or spiral arrangement around a central axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Regelmäßiges räumliches Muster, gekennzeichnet durch kreisförmige oder spiralförmige Anordnung um eine Mittelachse</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'whorled' have not yet been formalized. The term is defined as a specific subtype of 'regular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001951.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RegularSpatialPattern(x) ← Whorled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;whorled&apos; then x is a &apos;regular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaves of Galium aparine are whorled, arranged in circular clusters of six to eight around the stem</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Platy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flat"/>
    <rdfs:label xml:lang="de">platt</rdfs:label>
    <rdfs:label xml:lang="en-US">platy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000746"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Flat quality involving broad, typically regular surfaces resembling plates</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Flache Qualität mit breiten, typischerweise regelmäßigen, plattenähnlichen Oberflächen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'platy' have not yet been formalized. The term is defined as a specific subtype of 'flat'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000746.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Flat(x) ← Platy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;platy&apos; then x is a &apos;flat&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The biotite crystals in metamorphic rock are platy, with broad flat surfaces reflecting their sheet silicate structure</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LeafLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">blattartig</rdfs:label>
    <rdfs:label xml:lang="en-US">leaf like</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002457"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a leaf, often thin and flat with defined veins</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einem Blatt, oft dünn und flach mit ausgeprägten Adern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'leaf like' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002457.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← LeafLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;leaf like&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cephalic tentacles of the sea slug Plakobranchus ocellatus are leaf like, thin flat and veined</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curvature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">Krümmung</rdfs:label>
    <rdfs:label xml:lang="en-US">curvature</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001591"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape quality involving bent or curved configurations in geometry</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formqualität mit gebogenen oder gekrümmten Konfigurationen in der Geometrie</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'curvature' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001591.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Curvature(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;curvature&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The curvature of the human spine varies regionally, with cervical and lumbar lordosis and thoracic kyphosis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rotund">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spheroid"/>
    <rdfs:label xml:lang="en-US">rotund</rdfs:label>
    <rdfs:label xml:lang="de">rundlich</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002345"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spheroid form characterized by fullness and roundness, often spherical</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kugelform, gekennzeichnet durch Fülle und Rundheit, oft kugelförmig</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rotund' have not yet been formalized. The term is defined as a specific subtype of 'spheroid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002345.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spheroid(x) ← Rotund(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rotund&apos; then x is a &apos;spheroid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The body of the puffer fish Tetraodontidae is rotund when inflated, nearly spherical in all dimensions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Hohlräume</rdfs:label>
    <rdfs:label xml:lang="en-US">cavities</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002014"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality of a material entity characterized by the presence of hollow spaces or voids within or on the surface of the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität eines materiellen Gebildes, gekennzeichnet durch das Vorhandensein von Hohlräumen oder Hohlräumen innerhalb oder auf der Oberfläche des Trägers</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cavities' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002014.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Cavities(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cavities&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sinuses of the human skull are cavities within the bone filled with air and lined by mucosa</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rosy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">rosig</rdfs:label>
    <rdfs:label xml:lang="en-US">rosy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001425"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rosy is a color hue consisting of both red and yellow hues and high brightness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rosig ist ein Farbton, der sowohl aus roten als auch gelben Farbtönen besteht und eine hohe Helligkeit aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rosy' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001425.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Rosy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rosy&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin flush of a febrile patient is rosy, combining red and yellow hues with high brightness</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flaky">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="en-US">flaky</rdfs:label>
    <rdfs:label xml:lang="de">flockig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001805"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture characterized by thin layers that peel or flake off</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Textur, gekennzeichnet durch dünne Schichten, die sich ablösen oder abblättern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'flaky' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001805.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Flaky(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;flaky&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The psoriatic skin shows flaky texture with silver-white scaling that peels from the underlying erythematous plaque</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleYellow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Yellow"/>
    <rdfs:label xml:lang="de">blass gelb</rdfs:label>
    <rdfs:label xml:lang="en-US">pale yellow</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002017"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Yellow hue showing less chromatic intensity or saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gelber Farbton mit geringerer chromatischer Intensität oder Sättigung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale yellow' have not yet been formalized. The term is defined as a specific subtype of 'yellow'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002017.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Yellow(x) ← PaleYellow(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale yellow&apos; then x is a &apos;yellow&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fat deposits in the omentum of elderly patients are pale yellow from diluted carotenoid pigmentation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Perfoliate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">durchwachsen</rdfs:label>
    <rdfs:label xml:lang="en-US">perfoliate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001983"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Joined quality where leaves or other structures appear pierced by the stem</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verbundene Qualität, bei der Blätter oder andere Strukturen vom Stiel durchbohrt zu sein scheinen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'perfoliate' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001983.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Perfoliate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;perfoliate&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The upper leaves of Eupatorium perfoliatum are perfoliate, appearing pierced by the stem at their base</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ridged">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">gerippt</rdfs:label>
    <rdfs:label xml:lang="en-US">ridged</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002358"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality characterized by parallel raised strips or ridges</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Texturqualität, gekennzeichnet durch parallele erhabene Streifen oder Grate</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ridged' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002358.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Ridged(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ridged&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tracheal rings of Homo sapiens are ridged externally, with a series of parallel cartilaginous arches</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpoonShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">löffelartig</rdfs:label>
    <rdfs:label xml:lang="en-US">spoon shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002208"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spoon-shaped is a concave 3-D shape inhering in a bearer due to resembling the form of a spoon</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Löffelförmig ist eine konkave dreidimensionale Form, die einem Träger innewohnt, da sie der Form eines Löffels ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spoon shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002208.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← SpoonShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spoon shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The acetabulum of the hip joint is spoon shaped in ventral view, concave and rounded for femoral articulation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Acuminate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tapered"/>
    <rdfs:label xml:lang="en-US">acuminate</rdfs:label>
    <rdfs:label xml:lang="de">zugespitzt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002228"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tapered shape with a long-pointed apex</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konische Form mit langer spitzer Spitze</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'acuminate' have not yet been formalized. The term is defined as a specific subtype of 'tapered'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002228.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Tapered(x) ← Acuminate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;acuminate&apos; then x is a &apos;tapered&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaves of Fraxinus excelsior are acuminate, tapering to a long drawn-out pointed apex</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Unstratified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stratification"/>
    <rdfs:label xml:lang="de">ungeschichted</rdfs:label>
    <rdfs:label xml:lang="en-US">unstratified</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002069"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unstratified is a spatial pattern inhering in a bearer by virtue of lacking a layered configuration</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ungeschichtet ist ein räumliches Muster, das einem Träger aufgrund des Fehlens einer geschichteten Konfiguration innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unstratified' have not yet been formalized. The term is defined as a specific subtype of 'stratification'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002069.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Stratification(x) ← Unstratified(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unstratified&apos; then x is a &apos;stratification&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The epithelium of the olfactory mucosa is unstratified, consisting of a single continuous layer of cells</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpearShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">spear shaped</rdfs:label>
    <rdfs:label xml:lang="de">speerförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002079"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a spear, typically elongated and pointed at one end</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einem Speer, typischerweise länglich und an einem Ende spitz</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spear shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002079.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← SpearShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spear shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal spine of the stickleback Gasterosteus aculeatus is spear shaped, pointed and narrow for defense</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Permeable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Permeability"/>
    <rdfs:label xml:lang="de">durchlässig</rdfs:label>
    <rdfs:label xml:lang="en-US">permeable</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000982"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Permeability quality characterized by allowing the passage of fluids through openings or pores</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Durchlässigkeitsqualität, die dadurch gekennzeichnet ist, dass sie den Durchgang von Flüssigkeiten durch Öffnungen oder Poren ermöglicht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'permeable' have not yet been formalized. The term is defined as a specific subtype of 'permeability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000982.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Permeability(x) ← Permeable(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;permeable&apos; then x is a &apos;permeability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The wall of the renal glomerulus is permeable to water and small solutes during blood filtration</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/VentrallyRotated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rotated"/>
    <rdfs:label xml:lang="de">ventral rotiert</rdfs:label>
    <rdfs:label xml:lang="en-US">ventrally rotated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001659"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ventrally rotated is a rotation quality inhering in a bearer due to being rotated towards the abdomen of an organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ventral rotiert ist eine Rotationseigenschaft, die einem Träger innewohnt, weil er in Richtung Bauch eines Organismus gedreht wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ventrally rotated' have not yet been formalized. The term is defined as a specific subtype of 'rotated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001659.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rotated(x) ← VentrallyRotated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ventrally rotated&apos; then x is a &apos;rotated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The femoral head is ventrally rotated toward the abdomen during normal hip flexion in Homo sapiens</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleRed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Red"/>
    <rdfs:label xml:lang="de">blass rot</rdfs:label>
    <rdfs:label xml:lang="en-US">pale red</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002014"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Red hue with less intensity or vibrancy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Roter Farbton mit geringerer Intensität oder Lebendigkeit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale red' have not yet been formalized. The term is defined as a specific subtype of 'red'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002014.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Red(x) ← PaleRed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale red&apos; then x is a &apos;red&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The gills of an anemic fish show pale red coloration from reduced hemoglobin content in the blood</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Elliptic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Superelliptic"/>
    <rdfs:label xml:lang="en-US">elliptic</rdfs:label>
    <rdfs:label xml:lang="de">elliptisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000947"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Superelliptic shape resembling an ellipse, featuring a symmetrical oval form</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Superelliptische Form, die einer Ellipse ähnelt und eine symmetrische ovale Form aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'elliptic' have not yet been formalized. The term is defined as a specific subtype of 'superelliptic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000947.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Superelliptic(x) ← Elliptic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;elliptic&apos; then x is a &apos;superelliptic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf shape of Quercus robur is elliptic, with a symmetric oval outline and length greater than width</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RegularlyStriated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Striated"/>
    <rdfs:label xml:lang="de">regelmäßig gestreift</rdfs:label>
    <rdfs:label xml:lang="en-US">regularly striated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002339"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Evenly spaced linear marks or grooves</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gleichmäßig verteilte lineare Markierungen oder Rillen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'regularly striated' have not yet been formalized. The term is defined as a specific subtype of 'striated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002339.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Striated(x) ← RegularlyStriated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;regularly striated&apos; then x is a &apos;striated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The shell of the bivalve Pecten maximus is regularly striated with evenly spaced radial ribs</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Coated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">beschichted</rdfs:label>
    <rdfs:label xml:lang="en-US">coated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000117"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality involving a layer or covering that adheres to the surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Texturqualität mit einer Schicht oder Abdeckung, die an der Oberfläche haftet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'coated' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000117.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Coated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;coated&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The seed of Physalis alkekengi is coated with a thin papery membrane that must be removed before germination</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/KeyholeShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">keyhole shaped</rdfs:label>
    <rdfs:label xml:lang="de">schlüssellochförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002466"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a keyhole, often with circular top and stem-like bottom</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einem Schlüsselloch, oft mit kreisförmiger Oberseite und stielartiger Unterseite</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'keyhole shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002466.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← KeyholeShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;keyhole shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The foramen lacerum at the base of the skull is keyhole shaped in some anatomical variants</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Setaceous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy"/>
    <rdfs:label xml:lang="de">borstig</rdfs:label>
    <rdfs:label xml:lang="en-US">setaceous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000308"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Hairy quality characterized by bristle-like or stiff slender hairs</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Behaarte Qualität, gekennzeichnet durch borstenartige oder steife, schlanke Haare</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'setaceous' have not yet been formalized. The term is defined as a specific subtype of 'hairy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000308.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hairy(x) ← Setaceous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;setaceous&apos; then x is a &apos;hairy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The posterior margin of the carapace of some crustaceans is setaceous, bearing fine bristle-like spines</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Multicolored">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="en-US">multicolored</rdfs:label>
    <rdfs:label xml:lang="de">vielfarbig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001556"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored quality presenting more than two different colors or shades</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbige Qualität mit mehr als zwei verschiedenen Farben oder Schattierungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multicolored' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001556.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Multicolored(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multicolored&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The feathers of Pharomachrus mocinno are multicolored with iridescent green, red, and white regions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Disorganized">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/OrganizationQuality"/>
    <rdfs:label xml:lang="en-US">disorganized</rdfs:label>
    <rdfs:label xml:lang="de">ungeordnet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000937"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Organization quality characterized by lack of orderly arrangement or structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Organisationsqualität, gekennzeichnet durch das Fehlen einer geordneten Anordnung oder Struktur</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'disorganized' have not yet been formalized. The term is defined as a specific subtype of 'organization quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000937.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">OrganizationQuality(x) ← Disorganized(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;disorganized&apos; then x is a &apos;organization quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The growth plate cartilage in rickets is disorganized with irregular columnar cell arrangement</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightGreen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Green"/>
    <rdfs:label xml:lang="de">hellgrün</rdfs:label>
    <rdfs:label xml:lang="en-US">light green</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001250"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue exhibiting lighter tones of green, often fresh and vibrant</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit helleren Grüntönen, oft frisch und lebendig</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light green' have not yet been formalized. The term is defined as a specific subtype of 'green'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001250.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Green(x) ← LightGreen(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light green&apos; then x is a &apos;green&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The new fronds of Asplenium scolopendrium unfurl as light green before developing darker mature pigmentation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Striated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">gestreift (fein)</rdfs:label>
    <rdfs:label xml:lang="en-US">striated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001410"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored pattern characterized by alternating colors or shades arranged in parallel lines</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbiges Muster, gekennzeichnet durch abwechselnde Farben oder Schattierungen, die in parallelen Linien angeordnet sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'striated' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001410.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Striated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;striated&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cardiac muscle cells of Rattus norvegicus are striated, showing alternating light and dark sarcomere bands</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flattened">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curvature"/>
    <rdfs:label xml:lang="de">abgeflacht</rdfs:label>
    <rdfs:label xml:lang="en-US">flattened</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002254"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature characterized by reduction in height or volume, creating flatness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung, gekennzeichnet durch eine Verringerung der Höhe oder des Volumens, wodurch Flachheit entsteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'flattened' have not yet been formalized. The term is defined as a specific subtype of 'curvature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002254.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curvature(x) ← Flattened(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;flattened&apos; then x is a &apos;curvature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skull of the platypus Ornithorhynchus anatinus is flattened dorso-ventrally for its semi-aquatic lifestyle</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaddleShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">paddelformig</rdfs:label>
    <rdfs:label xml:lang="en-US">paddle shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0005003"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Quality inhering in a bearer by virtue of resembling the form of a paddle</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Qualität, die einem Träger innewohnt, da er der Form eines Paddels ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'paddle shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0005003.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← PaddleShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;paddle shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The flippers of Tursiops truncatus are paddle shaped, broadened for hydrodynamic propulsion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Warty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rough"/>
    <rdfs:label xml:lang="de">warzig</rdfs:label>
    <rdfs:label xml:lang="en-US">warty</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001361"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Warty is a texture quality inhering in a bearer by virtue of being covered with warts or projections that resemble warts, resulting in a hard rough surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Warzig ist eine Textureigenschaft, die einem Träger innewohnt, weil er mit Warzen oder warzenähnlichen Vorsprüngen bedeckt ist, was zu einer harten, rauen Oberfläche führt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'warty' have not yet been formalized. The term is defined as a specific subtype of 'rough'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001361.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rough(x) ← Warty(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;warty&apos; then x is a &apos;rough&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin of Bufo bufo is warty, covered with raised rounded projections from the parotoid and dorsal glands</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkRed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Red"/>
    <rdfs:label xml:lang="en-US">dark red</rdfs:label>
    <rdfs:label xml:lang="de">dunkelrot</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001261"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue with deep and bold red tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit tiefen und kräftigen Rottönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark red' have not yet been formalized. The term is defined as a specific subtype of 'red'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001261.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Red(x) ← DarkRed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark red&apos; then x is a &apos;red&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The muscle tissue of tuna shows dark red coloration due to high myoglobin content in slow-twitch fibers</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Complexity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Komplexität</rdfs:label>
    <rdfs:label xml:lang="en-US">complexity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001502"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality involving multiple interconnections or components</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität mit mehreren Verbindungen oder Komponenten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'complexity' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001502.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Complexity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;complexity&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The complexity of the human brain is reflected in its intricate network of synaptic connections and cortical areas</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaturatedRed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Red"/>
    <rdfs:label xml:lang="de">gesättigtes Rot</rdfs:label>
    <rdfs:label xml:lang="en-US">saturated red</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001283"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saturated red is a color consisting of red hue and high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gesättigtes Rot ist eine Farbe, die aus einem roten Farbton und hoher Sättigung besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saturated red' have not yet been formalized. The term is defined as a specific subtype of 'red'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001283.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Red(x) ← SaturatedRed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saturated red&apos; then x is a &apos;red&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ripe fruit of Cornus mas is saturated red with a highly vivid deep color from anthocyanins</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleOrange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Orange"/>
    <rdfs:label xml:lang="de">blass orange</rdfs:label>
    <rdfs:label xml:lang="en-US">pale orange</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002011"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue exhibiting pale orange tones, appearing washed out and softer than standard orange</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit blassen Orangetönen, der verwaschen und weicher als Standardorange wirkt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale orange' have not yet been formalized. The term is defined as a specific subtype of 'orange'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002011.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Orange(x) ← PaleOrange(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale orange&apos; then x is a &apos;orange&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin of premature neonates with mild jaundice shows pale orange tones from low bilirubin accumulation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Localized">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">lokalisiert</rdfs:label>
    <rdfs:label xml:lang="en-US">localized</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000627"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial pattern quality inhering in a bearer by virtue of the bearer's being confined or restricted to a particular location.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Räumliche Musterqualität, die einem Träger innewohnt, weil der Träger auf einen bestimmten Ort beschränkt oder beschränkt ist.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'localized' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000627.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Localized(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;localized&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The inflammatory reaction to a subcutaneous injection is localized to the injection site within a few centimeters</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Oblong">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="de">länglich</rdfs:label>
    <rdfs:label xml:lang="en-US">oblong</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000946"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape possessing an elongated form with approximately parallel sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form mit länglicher Form und annähernd parallelen Seiten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'oblong' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000946.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← Oblong(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;oblong&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Plantago lanceolata is oblong, with approximately parallel sides and length roughly three times the width</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lilac">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Purple"/>
    <rdfs:label xml:lang="de">fliederfarben</rdfs:label>
    <rdfs:label xml:lang="en-US">lilac</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001943"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue marked by pale shades of purple with hints of pink</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Farbton ist durch blasse Violetttöne mit einem Hauch von Rosa gekennzeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lilac' have not yet been formalized. The term is defined as a specific subtype of 'purple'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001943.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Purple(x) ← Lilac(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lilac&apos; then x is a &apos;purple&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The flower of Syringa vulgaris is lilac in color, with soft pale purple petals characteristic of the genus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkRedBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RedBrown"/>
    <rdfs:label xml:lang="en-US">dark red brown</rdfs:label>
    <rdfs:label xml:lang="de">dunkelrotbraun</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001288"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue blending deep tones of red and brown</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der tiefe Rot- und Brauntöne mischt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark red brown' have not yet been formalized. The term is defined as a specific subtype of 'red brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001288.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RedBrown(x) ← DarkRedBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark red brown&apos; then x is a &apos;red brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The iron-rich nodules in tropical laterite soil have a dark red brown color from ferric oxide concentration</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/StepShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">step shaped</rdfs:label>
    <rdfs:label xml:lang="de">stufenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002431"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by structural segments resembling steps</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die durch stufenartige Struktursegmente gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'step shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002431.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← StepShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;step shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The profile of a bird's bill in certain corvids appears step shaped with a distinct angular notch</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Inflamed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">entzündet</rdfs:label>
    <rdfs:label xml:lang="en-US">inflamed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002104"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition depicting redness, swelling, and painful irritation due to inflammation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Komposition, die Rötungen, Schwellungen und schmerzhafte Reizungen aufgrund einer Entzündung darstellt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'inflamed' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002104.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Inflamed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;inflamed&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The synovial membrane of a rheumatoid knee joint is inflamed, appearing red and swollen with increased vascularity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Biconvex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex"/>
    <rdfs:label xml:lang="en-US">biconvex</rdfs:label>
    <rdfs:label xml:lang="de">bikonvex</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002040"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Convex quality featuring outward curving surfaces on both sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konvexe Qualität mit beidseitig nach außen gewölbten Flächen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biconvex' have not yet been formalized. The term is defined as a specific subtype of 'convex'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002040.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex(x) ← Biconvex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biconvex&apos; then x is a &apos;convex&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The intervertebral disc of a young healthy spine is biconvex in lateral view, bulging on both surfaces</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Vermilion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="en-US">vermilion</rdfs:label>
    <rdfs:label xml:lang="de">zinnoberrot</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001302"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Vermilion is a color consisting of red and orange hues with a slight amount of gray</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zinnoberrot ist eine Farbe, die aus Rot- und Orangetönen mit einem leichten Grauanteil besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'vermilion' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001302.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Vermilion(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;vermilion&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bill of Fratercula arctica shows vermilion coloration at the grooved distal portion during breeding season</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpurShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">spornförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">spur shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002540"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spur shaped is a shape quality inhering in a bearer due to possessing a small, spike-like shape</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Spornförmig ist eine Formeigenschaft, die einem Träger innewohnt, da er eine kleine, stachelartige Form besitzt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spur shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002540.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← SpurShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spur shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The nectar spur of Aquilegia vulgaris is spur shaped, forming a slender hollow projection from the petal base</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/UShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">u förmig</rdfs:label>
    <rdfs:label xml:lang="en-US">u shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001879"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">U-shaped is a concave 3-D shape quality inhering in a bearer by virtue of resembling the form of the letter U</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">U-förmig ist eine konkave dreidimensionale Form, die einem Träger innewohnt, weil sie der Form des Buchstabens U ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'u shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001879.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← UShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;u shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The notch at the base of the human mandible is u shaped as seen from the anterior view</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Abrased">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">abgerieben</rdfs:label>
    <rdfs:label xml:lang="en-US">abrased</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001849"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture characterized by a surface that is worn or scraped</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Textur, gekennzeichnet durch eine abgenutzte oder abgekratzte Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'abrased' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001849.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Abrased(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;abrased&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The enamel surface of teeth subjected to bruxism becomes abrased with visible flat wear facets from grinding</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Reclinate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curled"/>
    <rdfs:label xml:lang="en-US">reclinate</rdfs:label>
    <rdfs:label xml:lang="de">zurückgebogen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001965"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Reclinate is a curled quality inhering in a bearer by virtue of having edges bent down upon their stalk</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Reclinate ist eine gekräuselte Eigenschaft, die einem Träger innewohnt, da die Kanten nach unten auf den Stiel gebogen sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'reclinate' have not yet been formalized. The term is defined as a specific subtype of 'curled'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001965.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curled(x) ← Reclinate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;reclinate&apos; then x is a &apos;curled&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaves of some sedge species are reclinate, bending down and draping over their own supporting sheath</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ConcavoConvex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concavity"/>
    <rdfs:label xml:lang="en-US">concavo convex</rdfs:label>
    <rdfs:label xml:lang="de">konkav-konvex</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002538"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape quality featuring both concave and convex surfaces or curves</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formqualität mit sowohl konkaven als auch konvexen Flächen oder Kurven</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'concavo convex' have not yet been formalized. The term is defined as a specific subtype of 'concavity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002538.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concavity(x) ← ConcavoConvex(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;concavo convex&apos; then x is a &apos;concavity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The lens of the human eye is concavo convex, with one concave and one convex surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Grooved">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">gefurcht</rdfs:label>
    <rdfs:label xml:lang="en-US">grooved</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002255"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality characterized by linear indentations or channels across the surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Texturqualität, gekennzeichnet durch lineare Vertiefungen oder Kanäle auf der Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'grooved' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002255.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Grooved(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;grooved&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cornea of patients with pellucid marginal degeneration is grooved at the inferior margin by thinning</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Polycystic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cystic"/>
    <rdfs:label xml:lang="en-US">polycystic</rdfs:label>
    <rdfs:label xml:lang="de">polyzystisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002089"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Polycystic is a structure quality inhering in a bearer by virtue of containing more than one cyst, formations of sac-like closed membranous structures not associated with neoplasia</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Polyzystisch ist eine Strukturqualität, die einem Träger dadurch innewohnt, dass sie mehr als eine Zyste enthält, also Bildungen sackartiger, geschlossener Membranstrukturen, die nicht mit Neoplasien assoziiert sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'polycystic' have not yet been formalized. The term is defined as a specific subtype of 'cystic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002089.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cystic(x) ← Polycystic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;polycystic&apos; then x is a &apos;cystic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The polycystic kidney contains numerous cortical and medullary cysts replacing normal nephron architecture</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fimbriated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">fimbriated</rdfs:label>
    <rdfs:label xml:lang="de">gefranst</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002311"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape featuring fringe-like projections or fine extensions along the edges</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form mit fransenartigen Vorsprüngen oder feinen Verlängerungen an den Rändern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fimbriated' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002311.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Fimbriated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fimbriated&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The infundibulum of the fallopian tube is fimbriated, with finger-like projections sweeping the ovulated oocyte</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Punctiform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">punktförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">punctiform</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001366"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Punctiform is a shape quality inhering in a bearer due to being small and resembling a point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Punktförmig ist eine Formeigenschaft, die einem Träger innewohnt, weil er klein ist und einem Punkt ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'punctiform' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001366.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Punctiform(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;punctiform&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The colony of Mycobacterium tuberculosis on solid media is punctiform, appearing as tiny pinpoint dots</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <rdfs:label xml:lang="de">Farbe</rdfs:label>
    <rdfs:label xml:lang="en-US">color</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000014"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Morphological quality perceived by the human eye as a hue, value, and intensity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Morphologische Qualität, die das menschliche Auge als Farbton, Wert und Intensität wahrnimmt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'color' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000014.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← Color(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;color&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The color of iris in Homo sapiens varies from blue to brown depending on melanin density and layering</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SplitMedially">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Split"/>
    <rdfs:label xml:lang="de">mittig geteilt</rdfs:label>
    <rdfs:label xml:lang="en-US">split medially</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002169"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Split medially is a shape quality inhering in a bearer due to being split along the median axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Medial gespalten ist eine Formeigenschaft, die einem Träger aufgrund der Spaltung entlang der Mittelachse innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'split medially' have not yet been formalized. The term is defined as a specific subtype of 'split'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002169.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Split(x) ← SplitMedially(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;split medially&apos; then x is a &apos;split&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cleft palate is split medially along the palatine raphe, exposing the nasal cavity below</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Attenuate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tapered"/>
    <rdfs:label xml:lang="en-US">attenuate</rdfs:label>
    <rdfs:label xml:lang="de">verjüngend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001982"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tapered shape narrowing gradually to a slender point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konische Form, die sich allmählich zu einer schlanken Spitze verjüngt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'attenuate' have not yet been formalized. The term is defined as a specific subtype of 'tapered'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001982.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Tapered(x) ← Attenuate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;attenuate&apos; then x is a &apos;tapered&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf apex of Salix alba is attenuate, drawn out into a long narrow tapering point</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fleshy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">fleischig</rdfs:label>
    <rdfs:label xml:lang="en-US">fleshy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002351"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation indicating the presence of tissue rich in moisture and solids</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Beobachtung der Zusammensetzung weist auf das Vorhandensein von Gewebe hin, das reich an Feuchtigkeit und Feststoffen ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fleshy' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002351.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Fleshy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fleshy&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cotyledons of Sedum telephium are fleshy, thick and succulent with high water-storage parenchyma</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Mottled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="de">fleckig</rdfs:label>
    <rdfs:label xml:lang="en-US">mottled</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002274"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored pattern consisting of irregular patches or blotches</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbiges Muster, bestehend aus unregelmäßigen Flecken oder Flecken</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mottled' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002274.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Mottled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mottled&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fur of Leopardus pardalis shows mottled irregular patches and rosettes on a pale background</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/AnchorShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">Ankerform</rdfs:label>
    <rdfs:label xml:lang="en-US">anchor shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002446"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling an anchor, typically having a pointed end and broad flukes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einem Anker und hat typischerweise ein spitzes Ende und breite Flossen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'anchor shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002446.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← AnchorShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;anchor shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The posterior of the planarian Dugesia tigrina appears anchor shaped with lateral auricles and a central groove</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Dendritic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branched"/>
    <rdfs:label xml:lang="en-US">dendritic</rdfs:label>
    <rdfs:label xml:lang="de">dendritisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002045"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Branched pattern resembling the structure of tree branches or arborescent formations</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verzweigtes Muster, das der Struktur von Baumzweigen oder Baumformationen ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dendritic' have not yet been formalized. The term is defined as a specific subtype of 'branched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002045.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branched(x) ← Dendritic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dendritic&apos; then x is a &apos;branched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The axonal arborization of Purkinje cells in the cerebellum is dendritic, branching in an elaborate planar tree</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lathlike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">lathlike</rdfs:label>
    <rdfs:label xml:lang="de">leistenartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002467"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a lath or thin strip of wood, narrow and elongated</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einer Latte oder einem dünnen Holzstreifen, schmal und länglich</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lathlike' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002467.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Lathlike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lathlike&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The prismatic spicules of hexactinellid sponges are lathlike, narrow and elongated like thin strips of wood</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Simple">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Complexity"/>
    <rdfs:label xml:lang="de">einfach</rdfs:label>
    <rdfs:label xml:lang="en-US">simple</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001503"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Simple is a complexity quality inhering in a bearer due to having few parts or being uncomplicated</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Einfach ist eine Komplexitätseigenschaft, die einem Träger innewohnt, weil es nur wenige Teile hat oder unkompliziert ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'simple' have not yet been formalized. The term is defined as a specific subtype of 'complexity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001503.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Complexity(x) ← Simple(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;simple&apos; then x is a &apos;complexity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Magnolia officinalis is simple, undivided into leaflets and attaching directly to the petiole</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Filamentous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">fadenförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">filamentous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001360"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling threads or filaments, often elongated and flexible</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt Fäden oder Filamenten, oft länglich und flexibel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'filamentous' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001360.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Filamentous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;filamentous&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hyphae of Aspergillus fumigatus are filamentous, forming long tubular threads that branch and extend through tissue</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/KeelShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">keel shaped</rdfs:label>
    <rdfs:label xml:lang="de">kielförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002522"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling the structure of a boat keel, elongated and tapering</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die der Struktur eines Bootskiels ähnelt, länglich und spitz zulaufend</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'keel shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002522.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← KeelShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;keel shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sternum of birds has a keel shaped projection serving as attachment for flight muscles</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Punctated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="en-US">punctated</rdfs:label>
    <rdfs:label xml:lang="de">punktiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002429"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Textured quality characterized by small punctures or depressions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturierte Qualität, gekennzeichnet durch kleine Einstiche oder Vertiefungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'punctated' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002429.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Punctated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;punctated&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The shell surface of the bivalve Nucula nucleus is punctated with fine depressions distributed across the outer valve</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Superficial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Localized"/>
    <rdfs:label xml:lang="de">oberflächlich</rdfs:label>
    <rdfs:label xml:lang="en-US">superficial</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001544"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Localized pattern confined to the surface without affecting deeper layers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Lokalisiertes Muster, das auf die Oberfläche beschränkt ist, ohne Auswirkungen auf tiefere Schichten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'superficial' have not yet been formalized. The term is defined as a specific subtype of 'localized'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001544.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Localized(x) ← Superficial(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;superficial&apos; then x is a &apos;localized&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The erosion of the gastric mucosa in stress ulcer remains superficial, not penetrating beyond the muscularis mucosae</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Osseous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">knöchern</rdfs:label>
    <rdfs:label xml:lang="en-US">osseous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002126"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Quality inhering in a bearer by virtue of containing bone</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Qualität, die einem Träger innewohnt, weil er Knochen enthält</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'osseous' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002126.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Osseous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;osseous&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cochlear capsule is osseous, formed from the densest bone in the human body surrounding the membranous labyrinth</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Distensibility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Dehnbarkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">distensibility</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015008"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality indicating the capacity to be stretched or extended without changing texture</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, die die Fähigkeit angibt, gedehnt oder gedehnt zu werden, ohne die Textur zu verändern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'distensibility' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015008.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Distensibility(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;distensibility&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The aortic wall has high distensibility, expanding with each systolic pulse and recoiling during diastole</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Isometrical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Symmetry"/>
    <rdfs:label xml:lang="en-US">isometrical</rdfs:label>
    <rdfs:label xml:lang="de">isometrisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001573"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Symmetry characterized by uniformity and equality in dimensions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Symmetrie, gekennzeichnet durch Einheitlichkeit und Gleichheit der Abmessungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'isometrical' have not yet been formalized. The term is defined as a specific subtype of 'symmetry'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001573.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Symmetry(x) ← Isometrical(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;isometrical&apos; then x is a &apos;symmetry&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The scale of Squamata lizards with isometrical growth shows proportional body size increases without shape change</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TongueShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">tongue shaped</rdfs:label>
    <rdfs:label xml:lang="de">zungenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002062"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a tongue, typically elongated and flat</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einer Zunge, typischerweise länglich und flach</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tongue shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002062.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← TongueShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tongue shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The radula of Helix pomatia is tongue shaped, a flat elongated ribbon bearing rows of denticles</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ParallelPlacement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RegularSpatialPattern"/>
    <rdfs:label xml:lang="de">Parallelanordnung</rdfs:label>
    <rdfs:label xml:lang="en-US">parallel placement</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001896"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Regular spatial pattern marked by even spacing between lines or segments alongside each other</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Regelmäßiges räumliches Muster, gekennzeichnet durch gleichmäßige Abstände zwischen Linien oder Segmenten nebeneinander</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'parallel placement' have not yet been formalized. The term is defined as a specific subtype of 'regular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001896.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RegularSpatialPattern(x) ← ParallelPlacement(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;parallel placement&apos; then x is a &apos;regular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The microfilaments in epithelial brush border show parallel placement, all aligned perpendicular to the apical surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkBlue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Blue"/>
    <rdfs:label xml:lang="en-US">dark blue</rdfs:label>
    <rdfs:label xml:lang="de">dunkelblau</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001244"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue characterized by deep and intense blue tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der durch tiefe und intensive Blautöne gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark blue' have not yet been formalized. The term is defined as a specific subtype of 'blue'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001244.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Blue(x) ← DarkBlue(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark blue&apos; then x is a &apos;blue&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The back plumage of Sialia sialis males is dark blue with deep saturated color from structural iridescence</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hispidulous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hispid"/>
    <rdfs:label xml:lang="de">fein borstig</rdfs:label>
    <rdfs:label xml:lang="en-US">hispidulous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002340"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Hispid quality with finer, sparse bristles or hairs on a surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Haarige Qualität mit feineren, spärlichen Borsten oder Haaren auf der Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hispidulous' have not yet been formalized. The term is defined as a specific subtype of 'hispid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002340.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hispid(x) ← Hispidulous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hispidulous&apos; then x is a &apos;hispid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The calyx of Malva neglecta is hispidulous, covered with very fine sparse bristles along the margin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Prickled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spiked"/>
    <rdfs:label xml:lang="de">bestachelt</rdfs:label>
    <rdfs:label xml:lang="en-US">prickled</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000482"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spiked quality marked by pointed protrusions over a surface, resembling thorns or points</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stachelige Qualität, gekennzeichnet durch spitze Vorsprünge auf einer Oberfläche, die Dornen oder Spitzen ähneln</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'prickled' have not yet been formalized. The term is defined as a specific subtype of 'spiked'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000482.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spiked(x) ← Prickled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;prickled&apos; then x is a &apos;spiked&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stem of Rubus fruticosus is prickled, bearing numerous sharp curved thorns of epidermal origin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pyramidal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape3D"/>
    <rdfs:label xml:lang="de">pyramidal</rdfs:label>
    <rdfs:label xml:lang="en-US">pyramidal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002336"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">3D shape resembling a pyramid, with a polygonal base and triangular faces meeting at a point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">3D-Form, die einer Pyramide ähnelt, mit einer polygonalen Basis und dreieckigen Flächen, die in einem Punkt zusammentreffen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pyramidal' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002336.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Pyramidal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pyramidal&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The apical dendrites of cortical pyramidal neurons are pyramidal in overall shape, tapering toward the soma</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CaneLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">cane like</rdfs:label>
    <rdfs:label xml:lang="de">rohrförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002511"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a cane, characterized by a long, slender form</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einem Stock und zeichnet sich durch eine lange, schlanke Form aus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cane like' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002511.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← CaneLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cane like&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stem of Arundo donax is cane like, long and hollow with rigid walls and distinct nodes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Inverted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Oriented"/>
    <rdfs:label xml:lang="en-US">inverted</rdfs:label>
    <rdfs:label xml:lang="de">invertiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000625"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Orientation quality indicating a reversed or flipped position</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Orientierungsqualität, die eine umgekehrte oder umgedrehte Position anzeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'inverted' have not yet been formalized. The term is defined as a specific subtype of 'oriented'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000625.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Oriented(x) ← Inverted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;inverted&apos; then x is a &apos;oriented&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The heart of patients with dextrocardia is inverted, positioned in the right thorax with reversed orientation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sinuate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="de">gewellt</rdfs:label>
    <rdfs:label xml:lang="en-US">sinuate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000486"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curved form describing wavy contours or edges, often repetitive in nature</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gebogene Form, die wellenförmige Konturen oder Kanten beschreibt, die sich häufig wiederholen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sinuate' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000486.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← Sinuate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sinuate&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf margin of Quercus robur is sinuate, with shallow rounded indentations alternating with rounded lobes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightBlue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Blue"/>
    <rdfs:label xml:lang="de">hellblau</rdfs:label>
    <rdfs:label xml:lang="en-US">light blue</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001243"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue featuring lighter shades of blue, often airy and bright</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit helleren Blautönen, oft luftig und hell</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light blue' have not yet been formalized. The term is defined as a specific subtype of 'blue'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001243.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Blue(x) ← LightBlue(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light blue&apos; then x is a &apos;blue&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sky-reflecting dorsal coloration of swallows Hirundo rustica appears light blue under open sky conditions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">curled</rdfs:label>
    <rdfs:label xml:lang="de">gekrümmt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000405"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape displaying a curved or spiral form, often with overlapping edges</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form mit gebogener oder spiralförmiger Form, oft mit überlappenden Kanten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'curled' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000405.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Curled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;curled&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spiral hair of Ovis aries fleece is curled, forming tight helical coils throughout the wool fiber</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Solid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">fest</rdfs:label>
    <rdfs:label xml:lang="en-US">solid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001535"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation exhibiting robust and firm structure, lacking voids or significant liquid content</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beobachtung der Zusammensetzung, die eine robuste und feste Struktur aufweist, ohne Hohlräume oder nennenswerten Flüssigkeitsgehalt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'solid' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001535.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Solid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;solid&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ivory of elephant tusks is solid, composed of dense mineralized dentine without a pulp cavity in the outer portions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CorymbLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">corymb like</rdfs:label>
    <rdfs:label xml:lang="de">doldenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002455"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a corymb structure where flower stalks grow upward, forming a flat or slightly convex surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einer Doldentraubenstruktur, bei der die Blütenstiele nach oben wachsen und eine flache oder leicht konvexe Oberfläche bilden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'corymb like' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002455.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← CorymbLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;corymb like&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The inflorescence of Sambucus nigra is corymb like, with stalks of unequal length forming a flat-topped cluster</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stretched">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Elongated"/>
    <rdfs:label xml:lang="de">gestreckt</rdfs:label>
    <rdfs:label xml:lang="en-US">stretched</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Stretched is a quality inhering in a bearer by virtue of being elongated or extended without breaking, increasing its length or area</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gestreckt ist eine Eigenschaft, die einem Träger dadurch innewohnt, dass er gedehnt oder gedehnt wird, ohne zu brechen, wodurch seine Länge oder Fläche vergrößert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'stretched' have not yet been formalized. The term is defined as a specific subtype of 'elongated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Elongated(x) ← Stretched(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;stretched&apos; then x is a &apos;elongated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin overlying a hematoma is stretched, thin and taut from the expanding blood collection beneath</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Disheveled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="en-US">disheveled</rdfs:label>
    <rdfs:label xml:lang="de">durcheinander</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001605"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Irregular spatial pattern involving untidy or disordered arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unregelmäßiges räumliches Muster mit unordentlicher oder ungeordneter Anordnung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'disheveled' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001605.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Disheveled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;disheveled&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The chromatin of apoptotic nuclei appears disheveled and fragmented under transmission electron microscopy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ScaleneTriangular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Triangular"/>
    <rdfs:label xml:lang="en-US">scalene triangular</rdfs:label>
    <rdfs:label xml:lang="de">ungleichseitig dreieckig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002308"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Scalene triangular is a triangular quality inhering in a bearer by virtue of having all sides of unequal length</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Scalene-Dreieck ist eine dreieckige Eigenschaft, die einem Träger dadurch innewohnt, dass alle Seiten ungleich lang sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scalene triangular' have not yet been formalized. The term is defined as a specific subtype of 'triangular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002308.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Triangular(x) ← ScaleneTriangular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scalene triangular&apos; then x is a &apos;triangular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The coronal section through the third molar socket in some individuals shows a scalene triangular profile</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spotty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="de">punktuell gefleckt</rdfs:label>
    <rdfs:label xml:lang="en-US">spotty</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002261"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored pattern characterized by distinct spots or patches</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbiges Muster, gekennzeichnet durch deutliche Flecken oder Flecken</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spotty' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002261.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Spotty(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spotty&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf surface of Hypericium androsaemum shows a spotty pattern of translucent oil glands when held to light</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/FiberShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subcylindrical"/>
    <rdfs:label xml:lang="de">faserförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">fiber shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002309"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Subcylindrical shape resembling a fiber or strand, typically long and thin</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Subzylindrische Form, die einer Faser oder einem Strang ähnelt, typischerweise lang und dünn</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fiber shaped' have not yet been formalized. The term is defined as a specific subtype of 'subcylindrical'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002309.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Subcylindrical(x) ← FiberShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fiber shaped&apos; then x is a &apos;subcylindrical&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The intermediate filaments of the cytoskeleton are fiber shaped, forming thin elongated structural threads within cells</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Waxiness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">wachsigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">waxiness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002381"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Waxiness is a composition quality inhering in a bearer by virtue of the presence of long-chain aliphatic lipids on the surface of an organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Wachshaftigkeit ist eine Zusammensetzungseigenschaft, die einem Träger durch das Vorhandensein langkettiger aliphatischer Lipide auf der Oberfläche eines Organismus innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'waxiness' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002381.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Waxiness(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;waxiness&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The waxiness of the cuticle of Eucalyptus globulus leaves prevents excess water loss in dry climates</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Conical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:label xml:lang="en-US">conical</rdfs:label>
    <rdfs:label xml:lang="de">kegelförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002021"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">3D shape resembling a cone, with a circular base tapering smoothly to a point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">3D-Form, die einem Kegel ähnelt, mit einer kreisförmigen Basis, die sich sanft zu einer Spitze verjüngt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'conical' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002021.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← Conical(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;conical&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The papillae of the mammalian tongue are conical, tapering to points from a broad base on the mucosal surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PinLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">nadelförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">pin like</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002458"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pin-like is a quality inhering in a bearer by virtue of being thin and lacking outgrowths</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stecknadelartig ist eine Eigenschaft, die einem Träger innewohnt, da er dünn ist und keine Auswüchse aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pin like' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002458.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← PinLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pin like&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spicules of some freshwater sponges are pin like, slender and smooth without outgrowths</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DesaturatedOrange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Orange"/>
    <rdfs:label xml:lang="en-US">desaturated orange</rdfs:label>
    <rdfs:label xml:lang="de">entsättigtes Orange</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001278"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue mixing orange tones with white or grey to reduce brightness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der Orangetöne mit Weiß oder Grau mischt, um die Helligkeit zu reduzieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'desaturated orange' have not yet been formalized. The term is defined as a specific subtype of 'orange'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001278.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Orange(x) ← DesaturatedOrange(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;desaturated orange&apos; then x is a &apos;orange&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The faded autumn leaves of Parthenocissus quinquefolia appear desaturated orange as pigment concentration declines</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Unstructured">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">unstructured</rdfs:label>
    <rdfs:label xml:lang="de">unstrukturiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001412"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unstructured is a structural quality inhering in a bearer due to lacking distinct structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unstrukturiert ist eine strukturelle Eigenschaft, die einem Träger innewohnt, weil ihm eine ausgeprägte Struktur fehlt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unstructured' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001412.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Unstructured(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unstructured&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The necrotic zone in an ischemic myocardial infarct appears unstructured under histology with complete loss of tissue architecture</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DeepPink">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pink"/>
    <rdfs:label xml:lang="en-US">deep pink</rdfs:label>
    <rdfs:label xml:lang="de">dunkelrosa</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001258"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue manifesting dark and intense pink tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit dunklen und intensiven Rosatönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'deep pink' have not yet been formalized. The term is defined as a specific subtype of 'pink'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001258.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pink(x) ← DeepPink(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;deep pink&apos; then x is a &apos;pink&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The petals of Camellia japonica show deep pink coloration with concentrated anthocyanin pigmentation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PlugShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">stöpselförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">plug shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040012"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Plug shaped is a shape quality in the form of a plug, being tube-like and expanded on one end</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stopfenförmig ist eine Formqualität in Form eines Stopfens, der rohrartig und an einem Ende erweitert ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'plug shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040012.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← PlugShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;plug shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cervical mucus plug is plug shaped, filling the cervical canal during pregnancy as a protective barrier</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Turgor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">turgor</rdfs:label>
    <rdfs:label xml:lang="en-US">turgor</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001620"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Turgor is a structural quality inhering in a cell or blood vessel or capillary due to being in a rigid state of fullness resulting from pressure of the contents against the wall or membrane</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Turgor ist eine Struktureigenschaft, die einer Zelle, einem Blutgefäß oder einer Kapillare innewohnt, weil sie sich aufgrund des Drucks des Inhalts gegen die Wand oder Membran in einem starren Füllzustand befindet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'turgor' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001620.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Turgor(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;turgor&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The high turgor of healthy plant leaf cells keeps the leaves erect and provides mechanical support to the lamina</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PearShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:label xml:lang="de">birnenförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">pear shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0005002"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pear shaped is a convex 3-D shape quality inhering in a bearer by virtue of having a shape that tapers near the top and bulges toward the base</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Birnenförmig ist eine konvexe 3D-Form, die einem Träger innewohnt, da er eine Form hat, die sich oben verjüngt und zur Basis hin ausbaucht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pear shaped' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0005002.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← PearShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pear shaped&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The uterus of nulliparous women is pear shaped, wider at the fundus and tapering toward the cervix</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Damage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Schaden</rdfs:label>
    <rdfs:label xml:lang="en-US">damage</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001020"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality indicating harm or impairment to an entity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, die auf einen Schaden oder eine Beeinträchtigung einer Einheit hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'damage' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001020.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Damage(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;damage&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The articular surface of the tibial plateau shows visible damage from impact loading in a tibial plateau fracture</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lobate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="de">lappenförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">lobate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001367"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Surface feature shape delineated by rounded projections or lobes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form eines Oberflächenmerkmals, das durch abgerundete Vorsprünge oder Lappen abgegrenzt wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lobate' have not yet been formalized. The term is defined as a specific subtype of 'surface feature shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001367.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SurfaceFeatureShape(x) ← Lobate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lobate&apos; then x is a &apos;surface feature shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The margin of the lichen Peltigera horizontalis is lobate, with rounded projections around the thallus perimeter</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Collapsed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">collapsed</rdfs:label>
    <rdfs:label xml:lang="de">eingefallen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001478"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure characterized by a reduction in volume or internal void space</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Struktur, die durch eine Verringerung des Volumens oder des inneren Hohlraums gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'collapsed' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001478.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Collapsed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;collapsed&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The alveoli in atelectatic lung are collapsed, with adjacent walls touching and no air space visible</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fragile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fragility"/>
    <rdfs:label xml:lang="en-US">fragile</rdfs:label>
    <rdfs:label xml:lang="de">zerbrechlich</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001362"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Fragility quality indicating susceptibility to breaking or damage under stress</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zerbrechlichkeitsqualität, die die Anfälligkeit für Bruch oder Beschädigung unter Belastung anzeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fragile' have not yet been formalized. The term is defined as a specific subtype of 'fragility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001362.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Fragility(x) ← Fragile(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fragile&apos; then x is a &apos;fragility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The eggshells of birds with DDT poisoning are fragile, breaking under the weight of incubating adults</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ligamentous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">ligamentous</rdfs:label>
    <rdfs:label xml:lang="de">ligamentös</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002314"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation indicating the presence of ligament-like structures</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Beobachtung der Zusammensetzung weist auf das Vorhandensein ligamentartiger Strukturen hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ligamentous' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002314.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Ligamentous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ligamentous&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The periodontal ligament appears ligamentous on histology with dense fibrous bundles connecting tooth root to alveolar bone</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/HighArched">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Arched"/>
    <rdfs:label xml:lang="en-US">high arched</rdfs:label>
    <rdfs:label xml:lang="de">hochgewölbt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002162"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Arched form characterized by elevation, reaching a higher curve</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gewölbte Form, gekennzeichnet durch eine Erhöhung, die eine höhere Kurve erreicht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'high arched' have not yet been formalized. The term is defined as a specific subtype of 'arched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002162.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Arched(x) ← HighArched(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;high arched&apos; then x is a &apos;arched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hard palate of dolichocephalic dog breeds is high arched, with a pronounced vertical curvature</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/VShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Angular"/>
    <rdfs:label xml:lang="de">v förmig</rdfs:label>
    <rdfs:label xml:lang="en-US">v shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002224"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Angular form resembling the letter "V" with divergent arms from a point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eckige Form, die dem Buchstaben „V“ ähnelt, mit von einer Spitze ausgehenden Armen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'v shaped' have not yet been formalized. The term is defined as a specific subtype of 'angular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002224.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Angular(x) ← VShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;v shaped&apos; then x is a &apos;angular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The angle of Louis at the manubriosternal junction creates a v shaped notch visible on the anterior chest</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Drooping">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">drooping</rdfs:label>
    <rdfs:label xml:lang="de">hängend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002165"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by downward sagging due to weight or loss of rigidity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die durch ein Durchhängen nach unten aufgrund von Gewicht oder Steifigkeitsverlust gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'drooping' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002165.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Drooping(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;drooping&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The eyelid in ptosis is drooping, hanging lower than normal from reduced levator palpebrae muscle tone</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shortened">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">gekürzt</rdfs:label>
    <rdfs:label xml:lang="en-US">shortened</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002364"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shortened is a quality inhering in a bearer by virtue of having a notably shorter length compared to its width</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verkürzt ist eine Eigenschaft, die einem Träger dadurch innewohnt, dass er im Vergleich zu seiner Breite eine deutlich geringere Länge aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shortened' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002364.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Shortened(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shortened&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The limbs of Achondroplastic dwarfism are shortened, with rhizomelic reduction in the proximal long bone segments</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lesioned">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">lesioned</rdfs:label>
    <rdfs:label xml:lang="de">läsioniert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040025"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality indicating localized damage or injury to tissues</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, die auf eine lokalisierte Schädigung oder Verletzung des Gewebes hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lesioned' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040025.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Lesioned(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lesioned&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cortical surface of the brain in multiple sclerosis appears lesioned with demyelinated plaques visible on imaging</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rhomboid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Parallelogram"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Superelliptic"/>
    <rdfs:label xml:lang="de">rhombisch</rdfs:label>
    <rdfs:label xml:lang="en-US">rhomboid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001938"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Superelliptic form resembling a rhombus or parallelogram with equal sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Superelliptische Form, die einer Raute oder einem Parallelogramm mit gleichen Seiten ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rhomboid' have not yet been formalized. The term is defined as a specific subtype of 'parallelogram'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001938.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Parallelogram(x) ← Rhomboid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rhomboid&apos; then x is a &apos;parallelogram&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The rhomboid minor muscle is rhomboid in shape, a parallelogram-like form connecting the scapula to the spine</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Anteverted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Oriented"/>
    <rdfs:label xml:lang="en-US">anteverted</rdfs:label>
    <rdfs:label xml:lang="de">nach vorne geneigt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001474"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Orientation inclined towards the front</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ausrichtung nach vorne geneigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'anteverted' have not yet been formalized. The term is defined as a specific subtype of 'oriented'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001474.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Oriented(x) ← Anteverted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;anteverted&apos; then x is a &apos;oriented&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The uterus in normal anatomy is anteverted, tilted anteriorly over the bladder</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pointed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sharp"/>
    <rdfs:label xml:lang="en-US">pointed</rdfs:label>
    <rdfs:label xml:lang="de">spitz</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002258"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pointed is a shape quality inhering in a bearer due to possessing a point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Spitz ist eine Formeigenschaft, die einem Träger innewohnt, weil er eine Spitze besitzt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pointed' have not yet been formalized. The term is defined as a specific subtype of 'sharp'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002258.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Sharp(x) ← Pointed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pointed&apos; then x is a &apos;sharp&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cusp of a carnassial tooth of Canis lupus familiaris is pointed for shearing meat</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SplayedCaudal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Splayed"/>
    <rdfs:label xml:lang="de">gespreizter schwanz</rdfs:label>
    <rdfs:label xml:lang="en-US">splayed caudal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002150"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Splayed caudal is a curvature quality inhering in a bearer by being curved outwards from the part of the body where the tail arises</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die gespreizte Schwanzflosse ist eine Krümmungseigenschaft, die einem Träger innewohnt, da sie von dem Körperteil, an dem der Schwanz entspringt, nach außen gebogen ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'splayed caudal' have not yet been formalized. The term is defined as a specific subtype of 'splayed'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002150.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Splayed(x) ← SplayedCaudal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;splayed caudal&apos; then x is a &apos;splayed&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The uropygial feathers of some birds are splayed caudal, curving outward from the tail base</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Setose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy"/>
    <rdfs:label xml:lang="de">dicht behaart</rdfs:label>
    <rdfs:label xml:lang="en-US">setose</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002289"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Setose is a hairy quality inhering in a bearer due to being covered with setae</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Setose ist eine haarige Eigenschaft, die einem Träger innewohnt, da sie mit Setae bedeckt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'setose' have not yet been formalized. The term is defined as a specific subtype of 'hairy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002289.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hairy(x) ← Setose(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;setose&apos; then x is a &apos;hairy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The legs of Aranea spiders are setose, bearing numerous sensory setae along the tibia and metatarsus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Serous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">serous</rdfs:label>
    <rdfs:label xml:lang="de">serös</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002128"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Serous is a composition quality inhering in a bearer by virtue of containing or resembling serum</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Serös ist eine Zusammensetzungseigenschaft, die einem Träger dadurch innewohnt, dass sie Serum enthält oder diesem ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'serous' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002128.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Serous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;serous&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fluid in a serous pericardial effusion is serous, resembling dilute serum with minimal cellular content</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Straggling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="en-US">straggling</rdfs:label>
    <rdfs:label xml:lang="de">zerstreuert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001616"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Irregular spatial pattern exhibiting spreading or sprawling growth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unregelmäßiges räumliches Muster, das sich ausbreitendes oder ausgedehntes Wachstum zeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'straggling' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001616.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Straggling(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;straggling&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The growth form of Galium aparine is straggling, with weak stems sprawling over neighboring vegetation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Waxy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Waxiness"/>
    <rdfs:label xml:lang="de">wachsartig</rdfs:label>
    <rdfs:label xml:lang="en-US">waxy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002384"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Waxy is a quality inhering in a bearer by virtue of the presence of long chain aliphatic lipids on the surface of an organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Wachsartig ist eine Eigenschaft, die einem Träger durch das Vorhandensein langkettiger aliphatischer Lipide auf der Oberfläche eines Organismus innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'waxy' have not yet been formalized. The term is defined as a specific subtype of 'waxiness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002384.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Waxiness(x) ← Waxy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;waxy&apos; then x is a &apos;waxiness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface of the leaves of Brassica oleracea is waxy, coated with epicuticular wax that causes water to bead</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spindly">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Slender"/>
    <rdfs:label xml:lang="de">spindeldürr</rdfs:label>
    <rdfs:label xml:lang="en-US">spindly</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002321"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Slender quality characterized by having an elongated, thin appearance, often lacking robustness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schlanke Qualität, die sich durch ein längliches, dünnes Aussehen auszeichnet, dem es oft an Robustheit mangelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spindly' have not yet been formalized. The term is defined as a specific subtype of 'slender'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002321.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Slender(x) ← Spindly(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spindly&apos; then x is a &apos;slender&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stipe of the mushroom Mycena galericulata is spindly, slender and fragile compared to the cap diameter</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subovoid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spheroid"/>
    <rdfs:label xml:lang="de">subovoid</rdfs:label>
    <rdfs:label xml:lang="en-US">subovoid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002537"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spheroid form resembling an elongated oval but less defined, slightly asymmetrical</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kugelförmige Form, die einem länglichen Oval ähnelt, aber weniger ausgeprägt ist und leicht asymmetrisch ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subovoid' have not yet been formalized. The term is defined as a specific subtype of 'spheroid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002537.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spheroid(x) ← Subovoid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subovoid&apos; then x is a &apos;spheroid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spore of Laccaria amethystina is subovoid, approximately oval but slightly asymmetrical about the long axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Auriculate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">auriculate</rdfs:label>
    <rdfs:label xml:lang="de">ohrförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001981"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling or having ear-like lobes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die ohrenähnlichen Lappen ähnelt oder diese aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'auriculate' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001981.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Auriculate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;auriculate&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The base of the leaf of Ranunculus repens is auriculate, with small ear-like lobes clasping the stem</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Unserrated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Serration"/>
    <rdfs:label xml:lang="de">ungezahnt</rdfs:label>
    <rdfs:label xml:lang="en-US">unserrated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001975"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unserrated is a surface feature shape quality inhering in a bearer due to lacking sharp straight-edged teeth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine ungezähnte Form ist ein Oberflächenmerkmal, das einem Träger innewohnt, weil ihm scharfe Zähne mit geraden Kanten fehlen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unserrated' have not yet been formalized. The term is defined as a specific subtype of 'serration'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001975.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Serration(x) ← Unserrated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unserrated&apos; then x is a &apos;serration&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The petal margin of Tulipa sylvestris is unserrated, presenting a smooth entire edge without any tooth-like projections</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaturatedBlue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Blue"/>
    <rdfs:label xml:lang="de">sattes blau</rdfs:label>
    <rdfs:label xml:lang="en-US">saturated blue</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001265"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color consisting of blue hue and high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbe bestehend aus blauem Farbton und hoher Sättigung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saturated blue' have not yet been formalized. The term is defined as a specific subtype of 'blue'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001265.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Blue(x) ← SaturatedBlue(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saturated blue&apos; then x is a &apos;blue&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal wing surfaces of Papilio ulysses are saturated blue from structural light interference in the scales</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Prolate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spheroid"/>
    <rdfs:label xml:lang="de">elongiert</rdfs:label>
    <rdfs:label xml:lang="en-US">prolate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001866"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Prolate is a spheroid quality inhering in a bearer by virtue of exhibiting a polar diameter longer than its equatorial diameter</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Prolat ist eine Sphäroideigenschaft, die einem Träger innewohnt, da sie einen polaren Durchmesser aufweist, der größer ist als sein äquatorialer Durchmesser</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'prolate' have not yet been formalized. The term is defined as a specific subtype of 'spheroid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001866.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spheroid(x) ← Prolate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;prolate&apos; then x is a &apos;spheroid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pollen grain of Lilium candidum is prolate, with the polar diameter exceeding the equatorial diameter</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Symmetry">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">symmetrie</rdfs:label>
    <rdfs:label xml:lang="en-US">symmetry</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000965"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Morphological quality denoting balanced proportions and equivalence across a central axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Morphologische Qualität, die ausgewogene Proportionen und Äquivalenz entlang einer Mittelachse bezeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'symmetry' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000965.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← Symmetry(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;symmetry&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The radial symmetry of echinoderm bodies is a defining morphological quality of the phylum Echinodermata</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CurvedRostral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">curved rostral</rdfs:label>
    <rdfs:label xml:lang="de">geschwungene Kopfteilform</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001466"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature at the anterior part of an organism, often bending forward</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung im vorderen Teil eines Organismus, oft nach vorne gebogen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'curved rostral' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001466.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← CurvedRostral(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;curved rostral&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bill of Numenius arquata is curved rostral, bending downward at the tip for probing soft substrates</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Actinodromous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branched"/>
    <rdfs:label xml:lang="de">Aktinodrom</rdfs:label>
    <rdfs:label xml:lang="en-US">actinodromous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001967"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Branching pattern with several primary veins radiating from the base</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verzweigtes Muster mit mehreren primären Adern, die strahlenförmig von der Basis ausgehen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'actinodromous' have not yet been formalized. The term is defined as a specific subtype of 'branched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001967.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branched(x) ← Actinodromous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;actinodromous&apos; then x is a &apos;branched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf venation of Vitis vinifera is actinodromous, with three to five primary veins radiating from the base</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/White">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">weiß</rdfs:label>
    <rdfs:label xml:lang="en-US">white</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000323"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">White is an achromatic color of maximum brightness, the color of objects that reflect nearly all light of visible wavelengths</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Weiß ist eine achromatische Farbe maximaler Helligkeit, die Farbe von Objekten, die nahezu das gesamte Licht sichtbarer Wellenlängen reflektieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'white' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000323.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← White(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;white&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sclerotic coat of the human eye is white, reflecting nearly all visible light from its dense collagen surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flattened"/>
    <rdfs:label xml:lang="de">eben</rdfs:label>
    <rdfs:label xml:lang="en-US">flat</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000407"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Flattened quality characterized by having a level surface without significant elevation or depth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Abgeflachte Qualität, gekennzeichnet durch eine ebene Oberfläche ohne nennenswerte Erhebung oder Tiefe</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'flat' have not yet been formalized. The term is defined as a specific subtype of 'flattened'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000407.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Flattened(x) ← Flat(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;flat&apos; then x is a &apos;flattened&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The squamous epithelium cells lining the esophagus are flat, with minimal height relative to their surface area</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">Morphological composition</rdfs:label>
    <rdfs:label xml:lang="de">morphologsche Zusammensetzung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000025"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Morphological Quality relating to the material components of an entity, through obeservation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Morphologische Qualität in Bezug auf die materiellen Bestandteile einer Entität durch Beobachtung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'Morphological composition' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000025.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← MorphologicalComposition(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;morphological composition&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The morphological composition of fibrocartilage includes collagen fibers and chondrocytes observable in stained histological sections</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subcircular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="de">fast kreisförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">subcircular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002397"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Subcircular is a circular shape quality inhering in a bearer due to being nearly, but not perfectly, circular</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Subrund ist eine Kreisformqualität, die einem Träger innewohnt, weil sie nahezu, aber nicht perfekt kreisförmig ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subcircular' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002397.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← Subcircular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subcircular&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The foramen ovale of the human skull is subcircular in outline, nearly but not perfectly circular</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Trapezoid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Quadrangular"/>
    <rdfs:label xml:lang="de">trapezoid</rdfs:label>
    <rdfs:label xml:lang="en-US">trapezoid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002044"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Trapezoid is a shape quality inhering in a bearer by virtue of being a quadrilateral with two parallel sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Trapez ist eine Formeigenschaft, die einem Träger innewohnt, da es sich um ein Viereck mit zwei parallelen Seiten handelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'trapezoid' have not yet been formalized. The term is defined as a specific subtype of 'quadrangular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002044.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Quadrangular(x) ← Trapezoid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;trapezoid&apos; then x is a &apos;quadrangular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The trapezoid carpal bone of the human wrist is trapezoid, a quadrilateral with two non-parallel sides</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PoorlyOssified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ossified"/>
    <rdfs:label xml:lang="en-US">poorly ossified</rdfs:label>
    <rdfs:label xml:lang="de">wenig verknöchert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002480"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Poorly ossified is a quality inhering in a bearer due to possessing minor levels of ossification</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine schlechte Verknöcherung ist eine Eigenschaft, die einem Träger innewohnt, weil er nur geringe Verknöcherungsgrade aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'poorly ossified' have not yet been formalized. The term is defined as a specific subtype of 'ossified'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002480.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Ossified(x) ← PoorlyOssified(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;poorly ossified&apos; then x is a &apos;ossified&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fontanelles of a newborn are poorly ossified regions where calvarial bones have not yet fused</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Wooly">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy"/>
    <rdfs:label xml:lang="de">wollig</rdfs:label>
    <rdfs:label xml:lang="en-US">wooly</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000305"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Hairy quality characterized by long, dense fibers or hairs resembling wool</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Haarige Qualität, gekennzeichnet durch lange, dichte Fasern oder Haare, die Wolle ähneln</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'wooly' have not yet been formalized. The term is defined as a specific subtype of 'hairy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000305.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hairy(x) ← Wooly(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;wooly&apos; then x is a &apos;hairy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The coat of Ovis aries merino breed is wooly with dense long fibers forming soft matted fleece</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Wrinkled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Grooved"/>
    <rdfs:label xml:lang="de">runzelig</rdfs:label>
    <rdfs:label xml:lang="en-US">wrinkled</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001810"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Wrinkled is a grooved texture quality inhering in a bearer due to being marked by one or more creases in a normally smooth surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Faltig ist eine gerillte Texturqualität, die einem Träger innewohnt und durch eine oder mehrere Falten in einer normalerweise glatten Oberfläche gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'wrinkled' have not yet been formalized. The term is defined as a specific subtype of 'grooved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001810.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Grooved(x) ← Wrinkled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;wrinkled&apos; then x is a &apos;grooved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface of the walnut Juglans regia seed is wrinkled with deep irregular folds visible on the tegument</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cartilaginous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">cartilaginous</rdfs:label>
    <rdfs:label xml:lang="de">knorpelig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001449"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation indicating the presence of cartilaginous material</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beobachtung der Zusammensetzung, die auf das Vorhandensein von Knorpelmaterial hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cartilaginous' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001449.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Cartilaginous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cartilaginous&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The growth plates of long bones are cartilaginous, composed of hyaline cartilage before ossification during development</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lysed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Lysiert</rdfs:label>
    <rdfs:label xml:lang="en-US">lysed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0065001"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure quality inhering in a bearer by virtue of the bearer due to the breaking of cell membranes by any means</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, die einem Träger aufgrund des Aufbrechens von Zellmembranen auf irgendeine Weise innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lysed' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0065001.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Lysed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lysed&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The red blood cells in hemolytic anemia appear lysed under microscopy, with ruptured membranes and released hemoglobin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pellucid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Translucent"/>
    <rdfs:label xml:lang="de">klar durchscheinend</rdfs:label>
    <rdfs:label xml:lang="en-US">pellucid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000654"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Translucent quality denoting clear or almost transparent material</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Durchscheinende Qualität bezeichnet klares oder fast transparentes Material</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pellucid' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000654.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Pellucid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pellucid&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The zona pellucida surrounding the mammalian oocyte is pellucid, nearly transparent under bright-field microscopy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subulate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Linear"/>
    <rdfs:label xml:lang="de">pfriemförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">subulate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001954"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Subulate is a shape quality inhering in a bearer by virtue of being linear, very narrow, and tapering to a fine point from a narrow base</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Subulate ist eine Formqualität, die einem Träger innewohnt, da sie linear, sehr schmal ist und sich von einer schmalen Basis zu einer feinen Spitze verjüngt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subulate' have not yet been formalized. The term is defined as a specific subtype of 'linear'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001954.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Linear(x) ← Subulate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subulate&apos; then x is a &apos;linear&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaves of Juniperus communis are subulate, linear and very narrow tapering to a sharp point from the base</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Superelliptic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="de">superelliptisch</rdfs:label>
    <rdfs:label xml:lang="en-US">superelliptic</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002318"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by equations defining elongated symmetries with higher powers of elliptical curvature</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die durch Gleichungen gekennzeichnet ist, die längliche Symmetrien mit höheren Potenzen der elliptischen Krümmung definieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'superelliptic' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002318.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← Superelliptic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;superelliptic&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The outline of the human pupil under moderate illumination is superelliptic, between a circle and rectangle</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Eroding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Erodierung</rdfs:label>
    <rdfs:label xml:lang="en-US">eroding</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002453"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure quality characterized by gradual wearing away through processes like abrasion</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, gekennzeichnet durch allmählichen Abrieb durch Prozesse wie Abrieb</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'eroding' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002453.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Eroding(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;eroding&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The articular surface in osteoarthritis is eroding, showing progressive loss of cartilage and underlying bone</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CrownLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">crown like</rdfs:label>
    <rdfs:label xml:lang="de">kronenartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040006"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a crown, often featuring an elevated center with surrounding protrusions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einer Krone und weist oft eine erhöhte Mitte mit umlaufenden Vorsprüngen auf</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'crown like' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040006.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← CrownLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;crown like&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The coronal suture of a neonate skull forms a crown like ridge encircling the anterior cranial vault</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Scorched">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="en-US">scorched</rdfs:label>
    <rdfs:label xml:lang="de">verbrannt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015052"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality marked by burning or singed appearance, often resulting in darkened and brittle surfaces</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Texturqualität zeichnet sich durch brennendes oder versengtes Aussehen aus, was häufig zu dunklen und spröden Oberflächen führt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scorched' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015052.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Scorched(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scorched&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal skin of Bufo bufo exposed to a heat source shows scorched texture with darkened dried areas</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Truncated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">abgetrennt</rdfs:label>
    <rdfs:label xml:lang="en-US">truncated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000936"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Truncated is a shape quality inhering in a bearer by virtue of terminating abruptly as if having an end or point cut off</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Abgeschnitten ist eine Formeigenschaft, die einem Träger innewohnt, weil sie abrupt endet, als ob ein Ende oder eine Spitze abgeschnitten wäre</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'truncated' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000936.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Truncated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;truncated&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The root apex of a primary tooth with root resorption appears truncated, ending abruptly rather than tapering</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ornamented">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ornamentation"/>
    <rdfs:label xml:lang="de">ornamentiert</rdfs:label>
    <rdfs:label xml:lang="en-US">ornamented</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002441"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Surface feature shape where surface is highly topographical with ridges, pits, rugosity, or other surface structures</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Oberflächenmerkmalsform, bei der die Oberfläche stark topographisch ist und Grate, Vertiefungen, Unebenheiten oder andere Oberflächenstrukturen aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ornamented' have not yet been formalized. The term is defined as a specific subtype of 'ornamentation'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002441.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Ornamentation(x) ← Ornamented(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ornamented&apos; then x is a &apos;ornamentation&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The seed surface of Ipomoea tricolor is ornamented with intricate rugose ridges and furrows visible under SEM</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Radiating">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">aufspannend</rdfs:label>
    <rdfs:label xml:lang="en-US">radiating</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0005005"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Radiating is a shape quality inhering in a bearer expanding outward, or having parts expanding outward, from a center point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strahlen ist eine Formqualität, die einem Träger innewohnt, der sich von einem Mittelpunkt aus nach außen ausdehnt oder Teile aufweist, die sich nach außen ausdehnen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'radiating' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0005005.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Radiating(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;radiating&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spines of the sea urchin Diadema antillarum are radiating outward in all directions from the test</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LanceOvate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lanceolate"/>
    <rdfs:label xml:lang="en-US">lance ovate</rdfs:label>
    <rdfs:label xml:lang="de">schmal eiförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002337"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Lanceolate form resembling an elongated oval with tapering ends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Lanzettliche Form, die einem länglichen Oval mit spitz zulaufenden Enden ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lance ovate' have not yet been formalized. The term is defined as a specific subtype of 'lanceolate'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002337.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Lanceolate(x) ← LanceOvate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lance ovate&apos; then x is a &apos;lanceolate&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Salix babylonica is lance ovate, combining a broad ovate base with lanceolate tapering toward the apex</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Calcified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">calcified</rdfs:label>
    <rdfs:label xml:lang="de">kalzifiziert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001447"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation involving the presence of calcium deposits</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beobachtung der Zusammensetzung unter Hinweis auf das Vorhandensein von Kalziumablagerungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'calcified' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001447.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Calcified(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;calcified&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mitral valve leaflets in chronic rheumatic heart disease become calcified with mineral deposits replacing fibrous tissue</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Degeneration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Degeneration</rdfs:label>
    <rdfs:label xml:lang="en-US">degeneration</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002037"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality characterized by loss of function or structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, gekennzeichnet durch Funktions- oder Strukturverlust</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'degeneration' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002037.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Degeneration(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;degeneration&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The nucleus pulposus of an intervertebral disc shows degeneration with reduced proteoglycan content and loss of hydration</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Perverse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="de">abartig</rdfs:label>
    <rdfs:label xml:lang="en-US">perverse</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001087"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Irregular spatial pattern unwilled or contrary to expectations</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unregelmäßiges räumliches Muster, ungewollt oder entgegen den Erwartungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'perverse' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001087.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Perverse(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;perverse&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The shell coiling of certain Lymnaea stagnalis mutants is perverse, sinistral instead of the normal dextral orientation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SheetShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flat"/>
    <rdfs:label xml:lang="de">plattenformig</rdfs:label>
    <rdfs:label xml:lang="en-US">sheet shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002491"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Flat shape resembling or characterized by a broad, thin layer or sheet</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Flache Form, die einer breiten, dünnen Schicht oder Platte ähnelt oder durch diese gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sheet shaped' have not yet been formalized. The term is defined as a specific subtype of 'flat'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002491.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Flat(x) ← SheetShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sheet shaped&apos; then x is a &apos;flat&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mesentery is sheet shaped, a broad thin fold of peritoneum suspending the intestinal loops from the posterior wall</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Violet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">violett</rdfs:label>
    <rdfs:label xml:lang="en-US">violet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001424"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue located between red and blue, often perceived in wavelengths around 380 to 450 nanometers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der zwischen Rot und Blau liegt und oft in Wellenlängen um 380 bis 450 Nanometer wahrgenommen wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'violet' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001424.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Violet(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;violet&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pigment in the photoreceptors of the mantis shrimp Odontodactylus scyllarus includes a violet-absorbing visual pigment</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="en-US">irregular spatial pattern</rdfs:label>
    <rdfs:label xml:lang="de">unregelmäßiges räumliches Muster</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000330"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial pattern lacking uniformity or consistent arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Räumliches Muster, dem es an Einheitlichkeit oder konsistenter Anordnung mangelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'irregular spatial pattern' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000330.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← IrregularSpatialPattern(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;irregular spatial pattern&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The distribution of melanocytes in a dysplastic nevus shows an irregular spatial pattern without uniform spacing</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BulletShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:label xml:lang="en-US">bullet shaped</rdfs:label>
    <rdfs:label xml:lang="de">geschossförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002087"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Convex 3-D shape resembling a bullet with a pointed end and wider base</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konvexe 3D-Form, die einer Kugel ähnelt, mit spitzem Ende und breiterer Basis</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bullet shaped' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002087.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← BulletShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bullet shaped&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The head of a sperm cell is bullet shaped, with a rounded anterior acrosome and tapered posterior</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LemonShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:label xml:lang="en-US">lemon shaped</rdfs:label>
    <rdfs:label xml:lang="de">zitronenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002345"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Convex 3D shape resembling a lemon, featuring tapering ends and rounded middle</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konvexe 3D-Form, die einer Zitrone ähnelt, mit sich verjüngenden Enden und abgerundeter Mitte</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lemon shaped' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002345.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← LemonShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lemon shaped&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pollen grain of Citrus sinensis is lemon shaped, with pointed ends and a rounded midsection</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Infiltrative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">einwachsend</rdfs:label>
    <rdfs:label xml:lang="en-US">infiltrative</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002103"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality characterized by permeation and diffusion into surrounding areas</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, gekennzeichnet durch Permeation und Diffusion in die Umgebung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'infiltrative' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002103.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Infiltrative(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;infiltrative&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tumor margin of a glioblastoma is infiltrative, with neoplastic cells diffusing into surrounding healthy brain tissue</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Metallic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="en-US">metallic</rdfs:label>
    <rdfs:label xml:lang="de">metallisch</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Metallic is a texture quality of a material entity characterized by a surface appearance or finish resembling metal</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Metallisch ist eine Texturqualität einer Materialeinheit, die durch eine metallähnliche Oberflächenerscheinung oder -beschaffenheit gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'metallic' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Metallic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;metallic&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The wing scales of the jewel beetle Buprestis aurulenta have a metallic sheen from multilayer thin-film interference</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Linear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">linear</rdfs:label>
    <rdfs:label xml:lang="en-US">linear</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001199"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by a straight line or elongated form with parallel sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, gekennzeichnet durch eine gerade Linie oder eine längliche Form mit parallelen Seiten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'linear' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001199.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Linear(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;linear&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Lolium perenne is linear, with parallel margins running the full length without broadening</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Scabrous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rough"/>
    <rdfs:label xml:lang="de">rau</rdfs:label>
    <rdfs:label xml:lang="en-US">scabrous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001721"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rough quality featuring abrasiveness or sharp texture on a surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Raue Qualität mit Abrasivität oder scharfer Textur auf einer Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scabrous' have not yet been formalized. The term is defined as a specific subtype of 'rough'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001721.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rough(x) ← Scabrous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scabrous&apos; then x is a &apos;rough&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf surface of Borago officinalis is scabrous, rough with pointed rigid trichomes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkGreen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Green"/>
    <rdfs:label xml:lang="en-US">dark green</rdfs:label>
    <rdfs:label xml:lang="de">dunkelgrün</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001249"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue showing deep and dense green tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit tiefen und dichten Grüntönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark green' have not yet been formalized. The term is defined as a specific subtype of 'green'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001249.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Green(x) ← DarkGreen(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark green&apos; then x is a &apos;green&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal scales of Bufo viridis appear dark green after metamorphosis in high-pigment environments</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaturatedCyan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cyan"/>
    <rdfs:label xml:lang="de">gesättigtes Cyan</rdfs:label>
    <rdfs:label xml:lang="en-US">saturated cyan</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001269"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saturated cyan is a color consisting of cyan hue and high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gesättigtes Cyan ist eine Farbe, die aus einem Cyan-Farbton und hoher Sättigung besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saturated cyan' have not yet been formalized. The term is defined as a specific subtype of 'cyan'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001269.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cyan(x) ← SaturatedCyan(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saturated cyan&apos; then x is a &apos;cyan&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The breast plumage of the kingfisher Alcedo atthis is saturated cyan with brilliant high-purity color</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TeardropShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">teardrop shaped</rdfs:label>
    <rdfs:label xml:lang="de">tropfenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002240"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a teardrop with rounded bottom and tapering top</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die einer Träne ähnelt, mit abgerundeter Unterseite und sich verjüngender Oberseite</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'teardrop shaped' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002240.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← TeardropShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;teardrop shaped&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The oil gland of a feather is teardrop shaped, with a rounded base narrowing toward the duct opening</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Falciform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">falciform</rdfs:label>
    <rdfs:label xml:lang="de">sichelförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002215"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a sickle, exhibiting a curved form with tapered ends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einer Sichel und weist eine gebogene Form mit spitz zulaufenden Enden auf</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'falciform' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002215.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Falciform(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;falciform&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sickle cell erythrocyte is falciform, curved like a sickle from hemoglobin S polymerization</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CurvedVentral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">curved ventral</rdfs:label>
    <rdfs:label xml:lang="de">geschwungene Bauchteilform</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001469"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature along the ventral side of an organism, arching downward towards the belly</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung entlang der Bauchseite eines Organismus, die sich nach unten zum Bauch hin wölbt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'curved ventral' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001469.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← CurvedVentral(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;curved ventral&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The costal cartilages are curved ventral, bending downward and inward from the ribs to the sternum</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaturatedYellow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Yellow"/>
    <rdfs:label xml:lang="de">gesättigtes gelb</rdfs:label>
    <rdfs:label xml:lang="en-US">saturated yellow</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001285"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saturated yellow is a color consisting of yellow hue and high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gesättigtes Gelb ist eine Farbe, die aus einem gelben Farbton und einer hohen Sättigung besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saturated yellow' have not yet been formalized. The term is defined as a specific subtype of 'yellow'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001285.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Yellow(x) ← SaturatedYellow(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saturated yellow&apos; then x is a &apos;yellow&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The petals of Ranunculus acris are saturated yellow with a waxy reflective surface and vivid color</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/NoduleLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">knötchenartig</rdfs:label>
    <rdfs:label xml:lang="en-US">nodule like</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002376"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling or characterized by small, rounded nodules</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die kleinen, abgerundeten Knötchen ähnelt oder durch diese gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'nodule like' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002376.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← NoduleLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;nodule like&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The secondary root nodules on Medicago sativa form nodule like structures housing nitrogen-fixing bacteria</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Mucoid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">mukoid</rdfs:label>
    <rdfs:label xml:lang="en-US">mucoid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001371"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mucoid is a composition quality inhering in a bearer by virtue of resembling mucus</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mukoid ist eine Zusammensetzungseigenschaft, die einem Träger innewohnt, weil sie Schleim ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mucoid' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001371.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Mucoid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mucoid&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mucoid secretion of the goblet cells in the trachea forms a continuous protective layer over the epithelium</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Heterotaxic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Inverted"/>
    <rdfs:label xml:lang="en-US">heterotaxic</rdfs:label>
    <rdfs:label xml:lang="de">heterotaxisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040000"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Inversion quality characterized by abnormal positioning or arrangement of body parts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Inversionsqualität, gekennzeichnet durch eine abnormale Positionierung oder Anordnung von Körperteilen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'heterotaxic' have not yet been formalized. The term is defined as a specific subtype of 'inverted'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040000.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Inverted(x) ← Heterotaxic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;heterotaxic&apos; then x is a &apos;inverted&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">In situs inversus the heart and abdominal organs show heterotaxic positioning mirrored from the normal arrangement</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PalePink">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pink"/>
    <rdfs:label xml:lang="de">blass rosa</rdfs:label>
    <rdfs:label xml:lang="en-US">pale pink</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002020"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pink hue marked by diminished saturation or brightness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rosa Farbton, der durch verminderte Sättigung oder Helligkeit gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale pink' have not yet been formalized. The term is defined as a specific subtype of 'pink'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002020.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Pink(x) ← PalePink(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale pink&apos; then x is a &apos;pink&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The petals of Rosa 'Felicia' are pale pink, gently fading from a slightly deeper center</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/AsymmetricallyCurved">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">asymmetrically curved</rdfs:label>
    <rdfs:label xml:lang="de">asymmetrisch gekrümmt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001848"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature not uniformly distributed along an axis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung nicht gleichmäßig entlang einer Achse verteilt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'asymmetrically curved' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001848.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← AsymmetricallyCurved(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;asymmetrically curved&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The scoliotic spine shows asymmetrically curved vertebral bodies, with more growth on the convex side</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sigmoid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">sigmoid</rdfs:label>
    <rdfs:label xml:lang="en-US">sigmoid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001878"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sigmoid is a shape quality inhering in a bearer by virtue of consisting of two curves, in opposite directions, resembling the letter S</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Sigmoid ist eine Formeigenschaft, die einem Träger innewohnt, da sie aus zwei Kurven in entgegengesetzter Richtung besteht und dem Buchstaben S ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:synonym>s-shaped</iof-av:synonym>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sigmoid' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001878.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Sigmoid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sigmoid&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sigmoid colon of Homo sapiens makes an S-shaped curve before entering the rectum</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Notched">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave"/>
    <rdfs:label xml:lang="de">Gekerbt</rdfs:label>
    <rdfs:label xml:lang="en-US">notched</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001495"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Notched shape characterized by V-shaped incisions in a concave form</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gekerbte Form, gekennzeichnet durch V-förmige Einschnitte in konkaver Form</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'notched' have not yet been formalized. The term is defined as a specific subtype of 'concave'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001495.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave(x) ← Notched(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;notched&apos; then x is a &apos;concave&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The trochlear notch of the ulna is a deep V-shaped concavity gripping the trochlea of the humerus</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stratification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Schichtung</rdfs:label>
    <rdfs:label xml:lang="en-US">stratification</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002067"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality marked by arrangement or layers within a material or tissue</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, die durch die Anordnung oder Schichten innerhalb eines Materials oder Gewebes gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'stratification' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002067.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Stratification(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;stratification&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stratification of the epidermis is visible from the basal layer to the cornified surface in histological sections</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Lanceolate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sharp"/>
    <rdfs:label xml:lang="en-US">lanceolate</rdfs:label>
    <rdfs:label xml:lang="de">lanzetförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001877"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sharp quality resembling a lance-tip, tapering to a pointed apex</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Scharfe Qualität, die einer Lanzenspitze ähnelt und sich zu einer spitzen Spitze verjüngt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'lanceolate' have not yet been formalized. The term is defined as a specific subtype of 'sharp'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001877.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Sharp(x) ← Lanceolate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;lanceolate&apos; then x is a &apos;sharp&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Salix alba is lanceolate, narrow and elongated with sides curving to a pointed tip</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">geformt</rdfs:label>
    <rdfs:label xml:lang="en-US">shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000162"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape quality denoting having a specific contour or configuration</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formqualität, die das Vorhandensein einer bestimmten Kontur oder Konfiguration bezeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000162.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Shaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bill of Pelecanus erythrorhynchos is distinctively shaped for scooping fish from shallow water</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subrectangular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Quadrangular"/>
    <rdfs:label xml:lang="de">annähernd rechteckig</rdfs:label>
    <rdfs:label xml:lang="en-US">subrectangular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002229"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Subrectangular is a quadrangular shape quality inhering in a bearer due to being approximately rectangular</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Subrechteckig ist eine viereckige Formqualität, die einem Träger innewohnt, da sie annähernd rechteckig ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subrectangular' have not yet been formalized. The term is defined as a specific subtype of 'quadrangular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002229.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Quadrangular(x) ← Subrectangular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subrectangular&apos; then x is a &apos;quadrangular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The outline of the patella viewed from the anterior is subrectangular, roughly oblong with rounded corners</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structured">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">structured</rdfs:label>
    <rdfs:label xml:lang="de">strukturiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001411"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structured is a structural quality inhering in a bearer by virtue of having distinct structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturiert ist eine strukturelle Eigenschaft, die einem Träger aufgrund seiner ausgeprägten Struktur innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'structured' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001411.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Structured(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;structured&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The striated muscle fiber shows a highly structured internal arrangement with regular sarcomere units</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Blistered">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="en-US">blistered</rdfs:label>
    <rdfs:label xml:lang="de">bläschenartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001928"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality marked by raised or bulbous areas</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Texturqualität gekennzeichnet durch erhabene oder bauchige Bereiche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'blistered' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001928.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Blistered(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;blistered&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin of patients with second-degree burns is blistered, with raised fluid-filled vesicles from epidermal separation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">C-förmig</rdfs:label>
    <rdfs:label xml:lang="en-US">c shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015019"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3-D shape resembling the letter "C"</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die dem Buchstaben „C“ ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'c shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015019.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← CShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;c shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The duodenum of Homo sapiens is c shaped in anterior view, curving around the head of the pancreas</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hydropic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">hydropic</rdfs:label>
    <rdfs:label xml:lang="de">wassergeschwollen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002119"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation indicating cellular swelling due to water influx</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine Beobachtung der Zusammensetzung deutet auf eine Zellschwellung aufgrund des Wassereinstroms hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hydropic' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002119.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Hydropic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hydropic&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hepatocytes in early toxic liver injury show hydropic degeneration with cellular swelling from water influx</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Platinate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flat"/>
    <rdfs:label xml:lang="en-US">platinate</rdfs:label>
    <rdfs:label xml:lang="de">platinierend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001499"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Flat quality characterized by flattened surfaces, often polished</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Flache Qualität, gekennzeichnet durch abgeflachte, oft polierte Oberflächen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'platinate' have not yet been formalized. The term is defined as a specific subtype of 'flat'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001499.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Flat(x) ← Platinate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;platinate&apos; then x is a &apos;flat&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The gill lamellae of bivalves are platinate, with flattened smooth surfaces facilitating water flow and gas exchange</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rolled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="de">gerollt</rdfs:label>
    <rdfs:label xml:lang="en-US">rolled</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002202"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curved form bent or turned around in a circular fashion</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gebogene Form, kreisförmig gebogen oder gedreht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rolled' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002202.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← Rolled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rolled&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Marram grass Ammophila arenaria is rolled when dry, enclosing the stomata to reduce water loss</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Short">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">kurz</rdfs:label>
    <rdfs:label xml:lang="en-US">short</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001022"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural representation indicating less length in proportion to width or height</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturdarstellung, die eine geringere Länge im Verhältnis zur Breite oder Höhe anzeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'short' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001022.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Short(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;short&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tarsal bones of the polar bear Ursus maritimus are short and compact for bearing large body weight</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ShovelShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">schaufelformig</rdfs:label>
    <rdfs:label xml:lang="en-US">shovel shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002498"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling or characterized by flat, broad curvature similar to a shovel</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die einer flachen, breiten Krümmung ähnlich einer Schaufel ähnelt oder durch diese gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shovel shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002498.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← ShovelShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shovel shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mandibular incisor of some East Asian populations is shovel shaped with raised marginal ridges on the lingual surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Plicate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Folded"/>
    <rdfs:label xml:lang="de">gefalzt</rdfs:label>
    <rdfs:label xml:lang="en-US">plicate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000465"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Folded quality described by repeating, sharply defined folds or parallel ridges</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Faltqualität, beschrieben durch sich wiederholende, scharf begrenzte Falten oder parallele Grate</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'plicate' have not yet been formalized. The term is defined as a specific subtype of 'folded'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000465.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Folded(x) ← Plicate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;plicate&apos; then x is a &apos;folded&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The corolla of Gentiana pneumonanthe is plicate with sharp longitudinal folds creating a ribbed appearance</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rhabdoid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RodShaped"/>
    <rdfs:label xml:lang="en-US">rhabdoid</rdfs:label>
    <rdfs:label xml:lang="de">stabartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000303"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rod-shaped quality resembling a rod, long and narrow</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stabförmige Qualität, die einer Stange ähnelt, lang und schmal</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rhabdoid' have not yet been formalized. The term is defined as a specific subtype of 'rod shaped'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000303.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RodShaped(x) ← Rhabdoid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rhabdoid&apos; then x is a &apos;rod shaped&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The large granular lymphocytes have a rhabdoid cytoplasmic inclusion visible in some lymphoproliferative disorders</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SourceWavenumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">Quellenwellenzahl</rdfs:label>
    <rdfs:label xml:lang="en-US">source wavenumber</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002490"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color attribute marked by specific frequency components in wave propagation; measure of oscillations per unit distance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbattribut, das durch bestimmte Frequenzkomponenten bei der Wellenausbreitung gekennzeichnet ist; Maß für Schwingungen pro Distanzeinheit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'source wavenumber' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002490.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← SourceWavenumber(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;source wavenumber&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The color of photonic crystals in butterfly wing scales corresponds to a source wavenumber of reflected light</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Scarred">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">scarred</rdfs:label>
    <rdfs:label xml:lang="de">narbig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001850"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Scarred is a structural quality inhering in a bearer by virtue of being fibrous tissue that replaces normal tissue destroyed by injury or disease</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Narben sind eine strukturelle Eigenschaft, die einem Träger innewohnt, da es sich um faseriges Gewebe handelt, das normales Gewebe ersetzt, das durch Verletzung oder Krankheit zerstört wurde</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scarred' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001850.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Scarred(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scarred&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The myocardium in a healed infarct is scarred, replaced by dense fibrous tissue that does not contract</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N32abe31e2b034313bf9583d9f5bcf99c">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Agent"/>
    <rdf:rest rdf:nodeID="N029019ec2d914b40a0e0a0fe99ad82ad"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Telescopic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">telescopic</rdfs:label>
    <rdfs:label xml:lang="de">teleskopisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002313"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Telescopic is a shape quality inhering in a bearer by virtue of having or resembling the shape of a telescope</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Teleskopisch ist eine Formeigenschaft, die einem Träger dadurch innewohnt, dass er die Form eines Teleskops hat oder dieser ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'telescopic' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002313.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Telescopic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;telescopic&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bill of some Sandpiper species is telescopic in function, with the tip flexing independently for tactile feeding</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brown"/>
    <rdfs:label xml:lang="en-US">dark brown</rdfs:label>
    <rdfs:label xml:lang="de">dunkelbraun</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001245"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue possessing deep and rich brown tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit tiefen und satten Brauntönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark brown' have not yet been formalized. The term is defined as a specific subtype of 'brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001245.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Brown(x) ← DarkBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark brown&apos; then x is a &apos;brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bark of Betula pendula is dark brown at the base of the trunk contrasting with white upper regions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Striped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="de">gestreift</rdfs:label>
    <rdfs:label xml:lang="en-US">striped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000889"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored pattern formed by long, narrow bands of contrasting color</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbiges Muster aus langen, schmalen Streifen in Kontrastfarbe</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'striped' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000889.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Striped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;striped&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin of the tiger Panthera tigris is striped with dark transverse bands on an orange background</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ArrowShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">arrow shaped</rdfs:label>
    <rdfs:label xml:lang="de">pfeilförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001881"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling an arrowhead, typically with pointed ends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einer Pfeilspitze, typischerweise mit spitzen Enden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'arrow shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001881.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← ArrowShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;arrow shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hastate leaf base of Rumex acetosella is arrow shaped with two downward-pointing basal lobes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shgarose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy"/>
    <rdfs:label xml:lang="en-US">shgarose</rdfs:label>
    <rdfs:label xml:lang="de">zottige</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000311"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Hairy quality indicative of thorns or small hairs, often rough</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Behaarte Qualität, die auf Dornen oder kleine Haare hinweist, oft rau</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shgarose' have not yet been formalized. The term is defined as a specific subtype of 'hairy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000311.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hairy(x) ← Shgarose(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shgarose&apos; then x is a &apos;hairy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface of some Opuntia cactus pads is shgarose with both glochids and rough epidermal projections</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightViolet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Violet"/>
    <rdfs:label xml:lang="de">hellviolett</rdfs:label>
    <rdfs:label xml:lang="en-US">light violet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001704"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue exemplified by lighter shades of violet, often producing a gentle and soft appearance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Farbton wird durch hellere Violetttöne veranschaulicht und erzeugt oft ein sanftes und weiches Erscheinungsbild</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light violet' have not yet been formalized. The term is defined as a specific subtype of 'violet'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001704.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Violet(x) ← LightViolet(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light violet&apos; then x is a &apos;violet&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The flowers of Viola cornuta show light violet coloration in some cultivar forms with reduced anthocyanin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleRedBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RedBrown"/>
    <rdfs:label xml:lang="de">blass rotbraun</rdfs:label>
    <rdfs:label xml:lang="en-US">pale red brown</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002015"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Red-brown hue diminished in saturation or tone</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Sättigung oder der Ton des rotbraunen Farbtons nimmt ab</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale red brown' have not yet been formalized. The term is defined as a specific subtype of 'red brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002015.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RedBrown(x) ← PaleRedBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale red brown&apos; then x is a &apos;red brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cortex of the liver of a jaundiced rabbit shows pale red brown coloration from bilirubin deposition</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SkinColor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/NaturalColor"/>
    <rdfs:label xml:lang="de">hautfarbe</rdfs:label>
    <rdfs:label xml:lang="en-US">skin color</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002496"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Natural color marked by pigmentation found in human skin, varying widely in hue</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Natürliche Farbe, die durch die in der menschlichen Haut vorkommende Pigmentierung gekennzeichnet ist und im Farbton stark variieren kann</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'skin color' have not yet been formalized. The term is defined as a specific subtype of 'natural color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002496.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">NaturalColor(x) ← SkinColor(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;skin color&apos; then x is a &apos;natural color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The melanin-based skin color of Homo sapiens varies from light to dark depending on UV exposure and genetics</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <rdfs:label xml:lang="de">räumliches muster</rdfs:label>
    <rdfs:label xml:lang="en-US">spatial pattern</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000060"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial pattern is a spatial quality inhering in a bearer by virtue of exhibiting repetition of placement of its parts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ein räumliches Muster ist eine räumliche Qualität, die einem Träger dadurch innewohnt, dass er die Wiederholung der Platzierung seiner Teile aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spatial pattern' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000060.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← SpatialPattern(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spatial pattern&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spatial pattern of stomata on the abaxial leaf surface of Quercus robur is evenly distributed</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Scattered">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="en-US">scattered</rdfs:label>
    <rdfs:label xml:lang="de">verstreut</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001899"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Irregular spatial pattern characterized by dispersion or distribution without apparent order</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unregelmäßiges räumliches Muster, gekennzeichnet durch Streuung oder Verteilung ohne erkennbare Ordnung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scattered' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001899.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Scattered(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scattered&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fibrous plaques in pulmonary fibrosis are scattered through the lung parenchyma without lobular preference</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spotted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="de">gefleckt</rdfs:label>
    <rdfs:label xml:lang="en-US">spotted</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000333"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spotted is a color pattern inhering in a bearer by virtue of being marked with a round area of a different hue or saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gefleckt ist ein Farbmuster, das einem Träger innewohnt, weil es mit einem runden Bereich mit einem anderen Farbton oder einer anderen Sättigung markiert ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spotted' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000333.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Spotted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spotted&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The spotted skin of Dalmatian dogs results from melanocyte distribution limited to rounded patches in the dermis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Columnar">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">columnar</rdfs:label>
    <rdfs:label xml:lang="de">säulenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002063"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a column with vertical emphasis</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form ähnlich einer Säule mit vertikaler Betonung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'columnar' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002063.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Columnar(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;columnar&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The intestinal epithelium is composed of columnar enterocytes with their long axis perpendicular to the basement membrane</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Papillomatous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">knötchenförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">papillomatous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002423"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape quality resembling a round or lobulated protruding form akin to a nipple</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formqualität, die einer runden oder gelappten hervorstehenden Form ähnelt, ähnlich einer Brustwarze</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'papillomatous' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002423.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Papillomatous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;papillomatous&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The papillomatous growths on the skin of a turtle with fibropapillomatosis form lobulated raised protrusions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightGrey">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Grey"/>
    <rdfs:label xml:lang="de">hellgrau</rdfs:label>
    <rdfs:label xml:lang="en-US">light grey</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001252"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue denoting paler shades of grey, often appearing neutral and soft</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton bezeichnet blassere Grautöne, die oft neutral und weich wirken</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light grey' have not yet been formalized. The term is defined as a specific subtype of 'grey'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001252.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Grey(x) ← LightGrey(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light grey&apos; then x is a &apos;grey&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fur of the arctic fox Vulpes lagopus in summer shows light grey coloration as an intermediate phase</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/OffRed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Red"/>
    <rdfs:label xml:lang="en-US">off red</rdfs:label>
    <rdfs:label xml:lang="de">unreinrot</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002468"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color variant of red that is dimmed or dulled</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbvariante von Rot, die gedimmt oder matt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'off red' have not yet been formalized. The term is defined as a specific subtype of 'red'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002468.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Red(x) ← OffRed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;off red&apos; then x is a &apos;red&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dull off red color of aged hemoglobin in a bruise indicates methemoglobin formation from oxidized iron</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Unpigmented">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DegreeOfPigmentation"/>
    <rdfs:label xml:lang="en-US">unpigmented</rdfs:label>
    <rdfs:label xml:lang="de">unpigmentiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002249"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unpigmented is a degree of pigmentation quality inhering in a bearer by lacking substances produced by organisms that result in color from selective color absorption</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unpigmentiert ist ein Grad der Pigmentierung, der einem Träger durch das Fehlen von Substanzen innewohnt, die von Organismen produziert werden und durch selektive Farbabsorption zu Farbe führen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unpigmented' have not yet been formalized. The term is defined as a specific subtype of 'degree of pigmentation'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002249.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">DegreeOfPigmentation(x) ← Unpigmented(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unpigmented&apos; then x is a &apos;degree of pigmentation&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The albino axolotl Ambystoma mexicanum lacks melanophores and is unpigmented in skin and eyes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TroughShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">trogförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">trough shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040015"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Trough shaped is a concave 3-D shape quality inhering in a bearer by virtue of resembling a trough being narrow, long, and boxlike</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Muldenform ist eine konkave dreidimensionale Form, die einem Träger innewohnt, da sie einer Mulde ähnelt, die schmal, lang und kastenförmig ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'trough shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040015.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← TroughShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;trough shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The groove of the bicipital sulcus of the humerus is trough shaped, a narrow long channel for the tendon</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Magenta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">magenta</rdfs:label>
    <rdfs:label xml:lang="en-US">magenta</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000321"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue characterized by a purplish-red tone, situated between red and blue</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, gekennzeichnet durch einen purpurroten Ton, der zwischen Rot und Blau liegt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'magenta' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000321.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Magenta(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;magenta&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The throat pouch of the magnificent frigatebird Fregata magnificens is magenta-red when inflated for display</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flared">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">ausgestellt</rdfs:label>
    <rdfs:label xml:lang="en-US">flared</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040022"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape exhibiting outward spreading from a narrowed base</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die sich von einer verengten Basis nach außen ausbreitet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'flared' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040022.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Flared(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;flared&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bell of the tulip Tulipa gesneriana is flared, with petals spreading outward from the narrow base</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tendrilous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">rankenartig</rdfs:label>
    <rdfs:label xml:lang="en-US">tendrilous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015005"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tendrilous is a slender and spirally coiled shape quality inhering in a bearer</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Tendrilous ist eine schlanke und spiralförmig gewundene Formqualität, die einem Träger innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tendrilous' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015005.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Tendrilous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tendrilous&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The climbing organs of Passiflora incarnata are tendrilous, with slender spirally coiled extensions grasping support</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Undivided">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">undivided</rdfs:label>
    <rdfs:label xml:lang="de">ungeteilt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002034"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Undivided is a shape quality inhering in a bearer by virtue of being unseparated into parts or divisions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ungeteilt ist eine Formqualität, die einem Träger dadurch innewohnt, dass er nicht in Teile oder Unterteilungen unterteilt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'undivided' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002034.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Undivided(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;undivided&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf of Ficus elastica is undivided, presenting a single entire lamina without any lobes or divisions</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/StarShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">star shaped</rdfs:label>
    <rdfs:label xml:lang="de">sternförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002065"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Star shaped is a shape quality inhering in a bearer due to being arranged like rays or radii, radiating from a common center</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Sternförmig ist eine Formqualität, die einem Träger innewohnt, weil sie wie Strahlen oder Radien angeordnet ist und von einem gemeinsamen Zentrum ausgeht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'star shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002065.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← StarShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;star shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stellate reticulum cells of developing enamel organ are star shaped with numerous radiating cytoplasmic processes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Necrotic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">necrotic</rdfs:label>
    <rdfs:label xml:lang="de">nekrotisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000647"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Necrotic is a structural quality inhering in a bearer due to undergoing unprogrammed cell death</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Nekrotisch ist eine strukturelle Eigenschaft, die einem Träger aufgrund des unprogrammierten Zelltods innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'necrotic' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000647.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Necrotic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;necrotic&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The central region of a tuberculosis granuloma is necrotic, with caseous cell death visible on histology</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pulvinate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:label xml:lang="de">kissenförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">pulvinate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001357"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pulvinate is a convex 3-D shape quality inhering in a bearer by virtue of resembling a cushion or having a marked convex cushion-like form</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Pulvinat ist eine konvexe dreidimensionale Form, die einem Träger innewohnt, weil sie einem Kissen ähnelt oder eine deutlich konvexe, kissenartige Form aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pulvinate' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001357.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← Pulvinate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pulvinate&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The head of a mushroom of the genus Boletus is pulvinate, with a convex cushion-like upper surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PerpendicularOrientation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Angular"/>
    <rdfs:label xml:lang="en-US">perpendicular orientation</rdfs:label>
    <rdfs:label xml:lang="de">rechtwinklige orientierung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015015"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Angular orientation characterized by positioning at right angles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Winkelausrichtung, gekennzeichnet durch die Positionierung im rechten Winkel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'perpendicular orientation' have not yet been formalized. The term is defined as a specific subtype of 'angular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015015.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Angular(x) ← PerpendicularOrientation(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;perpendicular orientation&apos; then x is a &apos;angular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The vertical trabeculae of cancellous bone have a perpendicular orientation relative to the horizontal cross-struts</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cuboid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:label xml:lang="en-US">cuboid</rdfs:label>
    <rdfs:label xml:lang="de">kubusförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001872"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Convex 3D shape resembling a cube, characterized by six faces meeting at right angles</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konvexe 3D-Form, die einem Würfel ähnelt und durch sechs Flächen gekennzeichnet ist, die sich im rechten Winkel treffen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cuboid' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001872.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← Cuboid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cuboid&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cuboid bone of the human foot is cuboid, approximating a six-sided box shape in morphological description</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/StrapShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">gurtförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">strap shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002430"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Strap-shaped is a shape quality in which the bearer is shaped like a narrow band, ligulate</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Riemenförmig ist eine Formqualität, bei der der Träger wie ein schmales Band, liguliert, geformt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'strap shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002430.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← StrapShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;strap shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ligulate florets of Taraxacum officinale are strap shaped with a flat ribbon-like petal blade</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Red">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="en-US">red</rdfs:label>
    <rdfs:label xml:lang="de">rot</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000322"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Red is a color hue with high wavelength at the long-wave end of the visible spectrum, evoked by radiant energy with wavelengths of approximately 630 to 750 nanometers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rot ist ein Farbton mit hoher Wellenlänge am langwelligen Ende des sichtbaren Spektrums, der durch Strahlungsenergie mit Wellenlängen von etwa 630 bis 750 Nanometern hervorgerufen wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'red' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000322.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Red(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;red&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The human red blood cell appears red from the absorption spectrum of oxyhemoglobin in the 620-750 nm range</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spiked">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spiky"/>
    <rdfs:label xml:lang="de">mit Stacheln</rdfs:label>
    <rdfs:label xml:lang="en-US">spiked</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000489"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spiky quality marked by prominent sharp projections or points</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stachelige Qualität, gekennzeichnet durch markante scharfe Vorsprünge oder Spitzen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spiked' have not yet been formalized. The term is defined as a specific subtype of 'spiky'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000489.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spiky(x) ← Spiked(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spiked&apos; then x is a &apos;spiky&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The seed pod of Datura stramonium is spiked with numerous rigid projections over the capsule surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SlitLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">schlitzartig</rdfs:label>
    <rdfs:label xml:lang="en-US">slit like</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002482"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Slit-like is a shape quality inhering in a bearer by virtue of exhibiting a narrow and elongate opening</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schlitzartig ist eine Formeigenschaft, die einem Träger dadurch innewohnt, dass er eine schmale und längliche Öffnung aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'slit like' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002482.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← SlitLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;slit like&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pupil of Felis catus contracts to a slit like vertical opening under bright illumination</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Indurated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Friability"/>
    <rdfs:label xml:lang="en-US">indurated</rdfs:label>
    <rdfs:label xml:lang="de">verhärtet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002407"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Friability quality indicating hardening of tissues or materials</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Brüchigkeitsqualität, die auf eine Verhärtung von Geweben oder Materialien hinweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'indurated' have not yet been formalized. The term is defined as a specific subtype of 'friability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002407.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Friability(x) ← Indurated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;indurated&apos; then x is a &apos;friability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The fibrous tissue in a desmoplastic reaction around a carcinoma is indurated and hard when palpated</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Everted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Oriented"/>
    <rdfs:label xml:lang="de">ausgestülpt</rdfs:label>
    <rdfs:label xml:lang="en-US">everted</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001597"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Orientation quality describing outward turning or protrusion</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Orientierungsqualität, die eine Drehung oder einen Vorsprung nach außen beschreibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'everted' have not yet been formalized. The term is defined as a specific subtype of 'oriented'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001597.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Oriented(x) ← Everted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;everted&apos; then x is a &apos;oriented&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The eyelid in ectropion is everted, with the palpebral margin turned outward exposing the conjunctival surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Bulbous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spheroid"/>
    <rdfs:label xml:lang="en-US">bulbous</rdfs:label>
    <rdfs:label xml:lang="de">zwiebelförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002210"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spheroid shape resembling a bulb, typically rounded and swollen</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kugelförmige Form, die einer Glühbirne ähnelt, typischerweise abgerundet und geschwollen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bulbous' have not yet been formalized. The term is defined as a specific subtype of 'spheroid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002210.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spheroid(x) ← Bulbous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bulbous&apos; then x is a &apos;spheroid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The olfactory bulb of Canis lupus familiaris is bulbous, enlarged and rounded for processing olfactory signals</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Disoriented">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="de">desorientiert</rdfs:label>
    <rdfs:label xml:lang="en-US">disoriented</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000613"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Irregular spatial pattern describing a lack of alignment or direction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unregelmäßiges räumliches Muster, das einen Mangel an Ausrichtung oder Richtung beschreibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'disoriented' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000613.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Disoriented(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;disoriented&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The collagen fibers in a scar are disoriented compared to the parallel alignment of normal dermis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Domed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">domed</rdfs:label>
    <rdfs:label xml:lang="de">kuppelförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001789"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curved form resembling a dome, characterized by rounded elevation on a flat base</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gebogene Form, die einer Kuppel ähnelt, gekennzeichnet durch eine abgerundete Erhebung auf einer flachen Basis</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'domed' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001789.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← Domed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;domed&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The calvaria of Homo sapiens is domed, with a smoothly rounded elevation above the level of the supraorbital ridges</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Slender">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">schlank</rdfs:label>
    <rdfs:label xml:lang="en-US">slender</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002212"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape form scarce in width, characterized by graceful or slim proportions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form mit geringer Breite, gekennzeichnet durch anmutige oder schlanke Proportionen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'slender' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002212.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Slender(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;slender&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The radius of the human forearm is slender, notably thinner than the ulna in the proximal third</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Scalloped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Serration"/>
    <rdfs:label xml:lang="de">gezackt</rdfs:label>
    <rdfs:label xml:lang="en-US">scalloped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001889"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Scalloped is a surface feature shape quality inhering in a bearer by virtue of having the border, edge, or outline cut into a series of segments of circles resembling a scallop-shell</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Wellenförmig ist eine Formqualität eines Oberflächenmerkmals, die einem Träger dadurch innewohnt, dass der Rand, die Kante oder der Umriss in eine Reihe von Kreissegmenten geschnitten ist, die einer Jakobsmuschel ähneln</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scalloped' have not yet been formalized. The term is defined as a specific subtype of 'serration'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001889.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Serration(x) ← Scalloped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scalloped&apos; then x is a &apos;serration&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The edge of the oyster shell Crassostrea gigas is scalloped, with a series of circular segment-shaped indentations</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Furrowed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Grooved"/>
    <rdfs:label xml:lang="en-US">furrowed</rdfs:label>
    <rdfs:label xml:lang="de">gekerbt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001948"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Grooved texture featuring deep linear indentations or channels</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gerillte Textur mit tiefen linearen Vertiefungen oder Kanälen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'furrowed' have not yet been formalized. The term is defined as a specific subtype of 'grooved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001948.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Grooved(x) ← Furrowed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;furrowed&apos; then x is a &apos;grooved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The surface of the walnut Juglans regia kernel is deeply furrowed with many channels and ridges</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CrystallineStructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MaterialStructure"/>
    <rdfs:label xml:lang="de">kristalline Struktur</rdfs:label>
    <rdfs:label xml:lang="en-US">crystalline structure</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Material structure organized in a regular and repeating geometric pattern, characterized by crystals</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Materialstruktur, organisiert in einem regelmäßigen und sich wiederholenden geometrischen Muster, gekennzeichnet durch Kristalle</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'crystalline structure' have not yet been formalized. The term is defined as a specific subtype of 'material structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructure(x) ← CrystallineStructure(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;crystalline structure&apos; then x is a &apos;material structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The enamel of human teeth has a crystalline structure of tightly packed hydroxyapatite prisms</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Alobate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="de">Alobate</rdfs:label>
    <rdfs:label xml:lang="en-US">alobate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002506"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Alobate is a surface feature shape quality inhering in a bearer due to lacking undulating edges forming lobes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Alobate ist eine Formqualität eines Oberflächenmerkmals, die einem Träger innewohnt, da wellenförmige Kanten fehlen, die Lappen bilden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'alobate' have not yet been formalized. The term is defined as a specific subtype of 'surface feature shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002506.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SurfaceFeatureShape(x) ← Alobate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;alobate&apos; then x is a &apos;surface feature shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The smooth leaf margin of Magnolia grandiflora is alobate, lacking any lobed or wavy projections</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PlowshareShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">pflugscharförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">plowshare shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002534"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Plowshare shaped is a shape quality inhering in a bearer due to resembling the shape of a plowshare</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form einer Pflugschar ist eine Formeigenschaft, die einem Träger innewohnt, da sie der Form einer Pflugschar ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'plowshare shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002534.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← PlowshareShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;plowshare shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The vomer bone at the base of the nasal septum is plowshare shaped, flat and angled like an agricultural plow</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Congested">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">congested</rdfs:label>
    <rdfs:label xml:lang="de">verstopft</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001836"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality characterized by overcrowded or overloaded elements</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, gekennzeichnet durch überfüllte oder überlastete Elemente</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'congested' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001836.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Congested(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;congested&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hepatic sinusoids in right heart failure are congested, distended with blood from obstructed venous drainage</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Dysplastic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">dysplastic</rdfs:label>
    <rdfs:label xml:lang="de">dysplastisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000640"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality indicating abnormal growth or development, often precancerous</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, die auf abnormales Wachstum oder Entwicklung hinweist, oft präkanzerös</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dysplastic' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000640.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Dysplastic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dysplastic&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cervical epithelium in CIN III is dysplastic, showing nuclear atypia and disorganized cell polarity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brittle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">brittle</rdfs:label>
    <rdfs:label xml:lang="de">spröde</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002477"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure quality characterized by fragility and susceptibility to breaking</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, gekennzeichnet durch Fragilität und Bruchanfälligkeit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'brittle' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002477.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Brittle(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;brittle&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The long bones of osteogenesis imperfecta patients are brittle from defective collagen reducing fracture resistance</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fatty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">fatty</rdfs:label>
    <rdfs:label xml:lang="de">fettreich</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002114"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition quality characterized by high lipid or fat content</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Qualität der Zusammensetzung, gekennzeichnet durch einen hohen Lipid- oder Fettgehalt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fatty' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002114.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Fatty(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fatty&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The liver in non-alcoholic fatty liver disease is fatty with abundant lipid vacuoles in hepatocytes on histology</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hemorrhagic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">hemorrhagic</rdfs:label>
    <rdfs:label xml:lang="de">hämorrhagisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002105"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure quality characterized by the presence of bleeding or accumulation of blood</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, gekennzeichnet durch das Vorhandensein von Blutungen oder Blutansammlungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hemorrhagic' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002105.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Hemorrhagic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hemorrhagic&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The necrotic center of a hemorrhagic infarct is hemorrhagic, saturated with extravasated erythrocytes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RidgeLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ridged"/>
    <rdfs:label xml:lang="en-US">ridge like</rdfs:label>
    <rdfs:label xml:lang="de">rippenartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002483"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ridged quality resembling or characterized by raised lines or strips</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Geriffelte Qualität, die erhabenen Linien oder Streifen ähnelt oder dadurch gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ridge like' have not yet been formalized. The term is defined as a specific subtype of 'ridged'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002483.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Ridged(x) ← RidgeLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ridge like&apos; then x is a &apos;ridged&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The linea aspera of the human femur is ridge like, a rough raised crest on the posterior diaphysis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Green">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="en-US">green</rdfs:label>
    <rdfs:label xml:lang="de">grün</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000320"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue perceived between 495-570 nanometers, commonly associated with vegetation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der wahrgenommene Farbton liegt zwischen 495 und 570 Nanometern und wird häufig mit Vegetation in Verbindung gebracht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'green' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000320.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Green(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;green&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The chloroplast-rich mesophyll cells of Spinacia oleracea give the leaf its characteristic green color</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Propinquity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">nähe</rdfs:label>
    <rdfs:label xml:lang="en-US">propinquity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000737"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Near proximity or closeness of elements</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Nahe Nähe oder Nähe von Elementen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'propinquity' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000737.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Propinquity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;propinquity&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The propinquity of the carotid arteries to the internal jugular vein in the carotid sheath reflects their shared fascial enclosure</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fenestrated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">fenestrated</rdfs:label>
    <rdfs:label xml:lang="de">fenestriert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002064"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure quality displaying small openings or windows within a surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, die kleine Öffnungen oder Fenster innerhalb einer Oberfläche anzeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fenestrated' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002064.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Fenestrated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fenestrated&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The capillaries of the glomerulus are fenestrated, with pores enabling fluid filtration into the Bowman capsule</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Inflated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavitated"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities"/>
    <rdfs:label xml:lang="de">aufgeblasen</rdfs:label>
    <rdfs:label xml:lang="en-US">inflated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002376"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cavity quality characterized by expansion due to internal pressure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Kavität ist durch eine Ausdehnung aufgrund des Innendrucks gekennzeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'inflated' have not yet been formalized. The term is defined as a specific subtype of 'cavitated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002376.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavitated(x) ← Inflated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;inflated&apos; then x is a &apos;cavitated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The air sacs of Pelicanus onocrotalus are inflated during display, expanding the throat pouch visibly</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Reticular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Networked"/>
    <rdfs:label xml:lang="de">netzförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">reticular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001931"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Networked quality characterized by a net-like pattern or structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Vernetzte Qualität, gekennzeichnet durch ein netzartiges Muster oder eine netzartige Struktur</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'reticular' have not yet been formalized. The term is defined as a specific subtype of 'networked'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001931.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Networked(x) ← Reticular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;reticular&apos; then x is a &apos;networked&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The reticular lamina beneath epithelial cells is a reticular meshwork of collagen fibrils providing basement membrane support</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Perforate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavitated"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities"/>
    <rdfs:label xml:lang="de">perforiert</rdfs:label>
    <rdfs:label xml:lang="en-US">perforate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002112"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Perforate is a structural quality inhering in a bearer by virtue of having a hole or holes, especially a row or array of small holes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Perforieren ist eine Struktureigenschaft, die einem Träger dadurch innewohnt, dass er ein oder mehrere Löcher aufweist, insbesondere eine Reihe oder Anordnung kleiner Löcher</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'perforate' have not yet been formalized. The term is defined as a specific subtype of 'cavitated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002112.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavitated(x) ← Perforate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;perforate&apos; then x is a &apos;cavitated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sieve plates of phloem sieve tubes are perforate, with numerous pores allowing assimilate flow between cells</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Transient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">transient structure</rdfs:label>
    <rdfs:label xml:lang="de">transiente Struktur</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002292"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Transient is a structural quality inhering in a bearer by virtue of the underlying structure being capable of change</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Vergänglichkeit ist eine strukturelle Eigenschaft, die einem Träger dadurch innewohnt, dass die zugrunde liegende Struktur veränderbar ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'transient structure' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002292.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Transient(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;transient structure&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The corpus luteum is a transient structure in the ovary, forming after ovulation and regressing if fertilization does not occur</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="de">T-förmig</rdfs:label>
    <rdfs:label xml:lang="en-US">t shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001200"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling the letter "T", characterized by a crossbeam and upright</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die dem Buchstaben „T“ ähnelt, gekennzeichnet durch einen Querbalken und aufrecht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 't shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001200.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← TShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;t shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The head and trunk arrangement of the hammer-headed shark Sphyrna mokarran is t shaped in dorsal view</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ShearShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">scherenförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">shear shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002499"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Resembling or characterized by symmetrical extensions similar to shears</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ähnelt oder zeichnet sich durch symmetrische Verlängerungen ähnlich einer Schere aus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shear shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002499.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← ShearShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shear shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The chelicera of some spider species is shear shaped with opposing blades adapted for cutting prey tissue</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pollution">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Contamination"/>
    <rdfs:label xml:lang="de">Verschmutzung</rdfs:label>
    <rdfs:label xml:lang="en-US">pollution</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001026"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Contamination quality marked by the presence of harmful or foreign substances within a material or environment</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kontaminationsqualität, die durch das Vorhandensein schädlicher oder fremder Substanzen in einem Material oder einer Umgebung gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pollution' have not yet been formalized. The term is defined as a specific subtype of 'contamination'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001026.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Contamination(x) ← Pollution(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pollution&apos; then x is a &apos;contamination&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The gills of fish in industrially polluted water show signs of pollution with mucus accumulation and epithelial lifting</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleYellowBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/YellowBrown"/>
    <rdfs:label xml:lang="de">blass gelbbraun</rdfs:label>
    <rdfs:label xml:lang="en-US">pale yellow brown</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002018"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Yellow-brown hue exhibiting subdued intensity or brightness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gelbbrauner Farbton mit gedämpfter Intensität oder Helligkeit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale yellow brown' have not yet been formalized. The term is defined as a specific subtype of 'yellow brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002018.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">YellowBrown(x) ← PaleYellowBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale yellow brown&apos; then x is a &apos;yellow brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dried herbarium specimen of Daucus carota shows pale yellow brown coloration from oxidation of carotenoid pigments</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PosteriorlyRotated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rotated"/>
    <rdfs:label xml:lang="de">hinten rotiert</rdfs:label>
    <rdfs:label xml:lang="en-US">posteriorly rotated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001600"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Posteriorly rotated is a rotation quality inhering in a bearer by being rotated towards the rear of the organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Nach hinten gedreht ist eine Rotationseigenschaft, die einem Träger innewohnt, wenn er zum hinteren Teil des Organismus gedreht wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'posteriorly rotated' have not yet been formalized. The term is defined as a specific subtype of 'rotated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001600.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rotated(x) ← PosteriorlyRotated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;posteriorly rotated&apos; then x is a &apos;rotated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The occiput in retroflexion of the head is posteriorly rotated, tilting the base of the skull rearward</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pilosity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">Behaarung</rdfs:label>
    <rdfs:label xml:lang="en-US">pilosity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000066"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Morphological quality regarding the presence or density of hair or hair-like structures</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Morphologische Qualität hinsichtlich des Vorhandenseins oder der Dichte von Haaren oder haarähnlichen Strukturen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pilosity' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000066.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← Pilosity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pilosity&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pilosity of the dorsal surface of Apis mellifera is assessed to distinguish subspecies morphologically</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Unilateral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">einseitig</rdfs:label>
    <rdfs:label xml:lang="en-US">unilateral</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000634"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unilateral is a spatial pattern inhering in a bearer by virtue of involving only one part or side</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Einseitig ist ein räumliches Muster, das einem Träger innewohnt, weil es nur einen Teil oder eine Seite betrifft</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unilateral' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000634.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Unilateral(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unilateral&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The facial palsy in Bell palsy is unilateral, affecting only one side of the face</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Areolate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="de">areolate</rdfs:label>
    <rdfs:label xml:lang="en-US">areolate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002295"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Surface feature shape marked by tiny, net-like divisions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form eines Oberflächenmerkmals, das durch winzige, netzartige Unterteilungen gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'areolate' have not yet been formalized. The term is defined as a specific subtype of 'surface feature shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002295.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SurfaceFeatureShape(x) ← Areolate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;areolate&apos; then x is a &apos;surface feature shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf surface of Primula vulgaris is areolate, with tiny angular areoles defined by a network of veins</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cribriform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Perforate"/>
    <rdfs:label xml:lang="en-US">cribriform</rdfs:label>
    <rdfs:label xml:lang="de">sieblöchrig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002113"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Perforate quality featuring closely spaced openings in a sieve-like pattern</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Perforierte Qualität mit eng beieinander liegenden Öffnungen in einem siebartigen Muster</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cribriform' have not yet been formalized. The term is defined as a specific subtype of 'perforate'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002113.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Perforate(x) ← Cribriform(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cribriform&apos; then x is a &apos;perforate&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ethmoid bone contains a cribriform plate with closely spaced foramina for olfactory nerve fibers</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Reticulodromous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branched"/>
    <rdfs:label xml:lang="de">reticulodromos</rdfs:label>
    <rdfs:label xml:lang="en-US">reticulodromous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001972"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Reticulodromous is a branched quality inhering in a bearer by virtue of having secondary branches that form a reticulum toward the margin</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Retikulodrom ist eine verzweigte Eigenschaft, die einem Träger innewohnt, da er sekundäre Zweige hat, die zum Rand hin ein Retikulum bilden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'reticulodromous' have not yet been formalized. The term is defined as a specific subtype of 'branched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001972.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branched(x) ← Reticulodromous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;reticulodromous&apos; then x is a &apos;branched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf venation of Cornus mas is reticulodromous, with secondary branches anastomosing toward the margin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Damaged">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Damage"/>
    <rdfs:label xml:lang="de">beschädigt</rdfs:label>
    <rdfs:label xml:lang="en-US">damaged</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001167"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality of having sustained harm or impairment</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität einer erlittenen Schädigung oder Beeinträchtigung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'damaged' have not yet been formalized. The term is defined as a specific subtype of 'damage'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001167.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Damage(x) ← Damaged(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;damaged&apos; then x is a &apos;damage&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The articular cartilage of an osteoarthritic hip is damaged, showing surface fibrillation and focal erosion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RotationalCurvature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curvature"/>
    <rdfs:label xml:lang="de">Rotationskrümmung</rdfs:label>
    <rdfs:label xml:lang="en-US">rotational curvature</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001787"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature involving twisting around an axis resulting in a spiral formation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung, bei der es um eine Achse verdreht wird und eine Spiralformation entsteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rotational curvature' have not yet been formalized. The term is defined as a specific subtype of 'curvature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001787.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curvature(x) ← RotationalCurvature(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rotational curvature&apos; then x is a &apos;curvature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The DNA double helix exhibits rotational curvature, wrapping around itself once per ten base pairs</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Gloss">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <rdfs:label xml:lang="de">Glanz</rdfs:label>
    <rdfs:label xml:lang="en-US">gloss</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Morphological quality imparting shine or luster to a surface due to reflection</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Morphologische Eigenschaft, die einer Oberfläche durch Reflexion Glanz oder Schimmer verleiht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'gloss' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← Gloss(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;gloss&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The gloss of the seed coat of Phaseolus lunatus contributes to its identification in archaeological plant remains</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Revolute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curled"/>
    <rdfs:label xml:lang="en-US">revolute</rdfs:label>
    <rdfs:label xml:lang="de">zurückgerollt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001963"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Revolute is a curled quality inhering in a bearer by virtue of having edges of its surface rolled backwards spirally on each side</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Revolute ist eine gekräuselte Eigenschaft, die einem Träger dadurch innewohnt, dass die Kanten seiner Oberfläche auf jeder Seite spiralförmig nach hinten gerollt sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'revolute' have not yet been formalized. The term is defined as a specific subtype of 'curled'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001963.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curled(x) ← Revolute(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;revolute&apos; then x is a &apos;curled&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf margin of Ledum palustre is revolute, with edges rolled backward along the lower surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DesaturatedBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brown"/>
    <rdfs:label xml:lang="en-US">desaturated brown</rdfs:label>
    <rdfs:label xml:lang="de">entsättigtes Braun</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001268"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue characterized by brown tones mixed with white or grey, diminishing their vividness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der durch Brauntöne gekennzeichnet ist, die mit Weiß oder Grau gemischt werden und deren Lebendigkeit verringern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'desaturated brown' have not yet been formalized. The term is defined as a specific subtype of 'brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001268.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Brown(x) ← DesaturatedBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;desaturated brown&apos; then x is a &apos;brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dried fur of a museum specimen of Ursus arctos appears desaturated brown with loss of natural luster</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sagittate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ArrowShaped"/>
    <rdfs:label xml:lang="de">pfeilspitzig</rdfs:label>
    <rdfs:label xml:lang="en-US">sagittate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000461"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Arrow-shaped form resembling the shape of an arrowhead, triangular with basal lobes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Pfeilförmige Form, die der Form einer Pfeilspitze ähnelt, dreieckig mit basalen Lappen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sagittate' have not yet been formalized. The term is defined as a specific subtype of 'arrow shaped'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000461.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ArrowShaped(x) ← Sagittate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sagittate&apos; then x is a &apos;arrow shaped&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf base of Sagittaria sagittifolia is sagittate, with two downward basal lobes flanking the petiole</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Orbicular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Circular"/>
    <rdfs:label xml:lang="de">kreisrund</rdfs:label>
    <rdfs:label xml:lang="en-US">orbicular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001934"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by a perfect circular quality</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die sich durch eine perfekte Rundheit auszeichnet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'orbicular' have not yet been formalized. The term is defined as a specific subtype of 'circular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001934.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Circular(x) ← Orbicular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;orbicular&apos; then x is a &apos;circular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The peltate leaf of Tropaeolum majus is orbicular, forming a nearly perfect circle around the central petiole</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PrismShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">prism shaped</rdfs:label>
    <rdfs:label xml:lang="de">prismenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002465"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Prism shaped is a quality inhering in a bearer due to resembling a prism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Prismenförmig ist eine Eigenschaft, die einem Träger innewohnt, da es einem Prisma ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'prism shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002465.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← PrismShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;prism shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The rod-shaped photoreceptors of the human retina are prism shaped in their outer segment cross-section</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Generalized">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="en-US">generalized</rdfs:label>
    <rdfs:label xml:lang="de">überall</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002403"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial pattern indicating distribution across most or all of a system or area</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Räumliches Muster, das die Verteilung über den größten Teil oder das gesamte System oder Gebiet angibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'generalized' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002403.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Generalized(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;generalized&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The edema in heart failure becomes generalized, affecting subcutaneous tissue throughout the body</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Friable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Friability"/>
    <rdfs:label xml:lang="de">bröckelig</rdfs:label>
    <rdfs:label xml:lang="en-US">friable</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002406"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Friability quality typically characterized by being easily crumbled</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Bröckeligkeit ist typischerweise dadurch gekennzeichnet, dass sie leicht zerbröckelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'friable' have not yet been formalized. The term is defined as a specific subtype of 'friability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002406.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Friability(x) ← Friable(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;friable&apos; then x is a &apos;friability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The caseous necrosis in tuberculosis is friable, easily crumbled when the granuloma is disturbed</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BladeLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tapered"/>
    <rdfs:label xml:lang="en-US">blade like</rdfs:label>
    <rdfs:label xml:lang="de">klingenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002235"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tapered shape resembling a blade with a sharp, elongated form</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konische Form, die einer Klinge mit scharfer, länglicher Form ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'blade like' have not yet been formalized. The term is defined as a specific subtype of 'tapered'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002235.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Tapered(x) ← BladeLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;blade like&apos; then x is a &apos;tapered&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The scapula has a blade like form, a flat triangular bone with sharp borders and a prominent spine</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Blunt">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sharpness"/>
    <rdfs:label xml:lang="en-US">blunt</rdfs:label>
    <rdfs:label xml:lang="de">abgestumpft</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001950"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sharpness quality reduced or absent, lacking a pointed end</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Schärfe ist vermindert oder fehlt, es fehlt ein spitzes Ende</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'blunt' have not yet been formalized. The term is defined as a specific subtype of 'sharpness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001950.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Sharpness(x) ← Blunt(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;blunt&apos; then x is a &apos;sharpness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The apex of the leaf of Ficus carica is blunt, rounded and lacking any pointed extension</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Straight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Linear"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">gerade</rdfs:label>
    <rdfs:label xml:lang="en-US">straight</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002180"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Linear form characterized by evenness, lacking curves or bends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Lineare Form, gekennzeichnet durch Gleichmäßigkeit, ohne Kurven oder Biegungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'straight' have not yet been formalized. The term is defined as a specific subtype of 'linear'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002180.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Linear(x) ← Straight(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;straight&apos; then x is a &apos;linear&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The diaphysis of the ulna is straight, without the curvature seen in the radius</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ShieldShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave"/>
    <rdfs:label xml:lang="de">schildformig</rdfs:label>
    <rdfs:label xml:lang="en-US">shield shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002061"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave shape resembling a traditional shield, typically featuring an enlarged face with prominent border</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave Form, die einem traditionellen Schild ähnelt und typischerweise eine vergrößerte Vorderseite mit markantem Rand aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shield shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002061.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave(x) ← ShieldShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shield shaped&apos; then x is a &apos;concave&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The plastron of the tortoise Testudo graeca is shield shaped, a broad flat ventral plate protecting the abdomen</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SplayedDorsal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Splayed"/>
    <rdfs:label xml:lang="de">dorsal gespreizte</rdfs:label>
    <rdfs:label xml:lang="en-US">splayed dorsal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002151"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Splayed dorsal is a curvature quality inhering in a bearer by virtue of being curved outwards from the back or upper surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gespreizter Rücken ist eine Krümmungseigenschaft, die einem Träger dadurch innewohnt, dass er von der Rückseite oder Oberseite nach außen gekrümmt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'splayed dorsal' have not yet been formalized. The term is defined as a specific subtype of 'splayed'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002151.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Splayed(x) ← SplayedDorsal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;splayed dorsal&apos; then x is a &apos;splayed&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal fins of some flatfish are splayed dorsal, spreading laterally outward from the fish's back</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spiky">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="en-US">spiky</rdfs:label>
    <rdfs:label xml:lang="de">scharf stachelig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001787"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality defined by sharp or pointed protrusions across a surface</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Texturqualität, definiert durch scharfe oder spitze Vorsprünge auf einer Oberfläche</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spiky' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001787.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Spiky(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spiky&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The crown of thorns sea star Acanthaster planci is spiky with numerous long rigid venomous spines over the aboral surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branched">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branchiness"/>
    <rdfs:label xml:lang="en-US">branched</rdfs:label>
    <rdfs:label xml:lang="de">verzweigt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000402"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Branchiness quality marked by divisions or offshoots</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verzweigungsqualität, gekennzeichnet durch Teilungen oder Ableger</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'branched' have not yet been formalized. The term is defined as a specific subtype of 'branchiness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000402.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branchiness(x) ← Branched(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;branched&apos; then x is a &apos;branchiness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bronchial tree of the human lung is branched, dividing repeatedly from the trachea to terminal bronchioles</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LaterallyRotated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rotated"/>
    <rdfs:label xml:lang="en-US">laterally rotated</rdfs:label>
    <rdfs:label xml:lang="de">seitenwärts gedreht</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002156"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rotation towards the lateral or side position</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Drehung in die Seiten- oder Seitenlage</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'laterally rotated' have not yet been formalized. The term is defined as a specific subtype of 'rotated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002156.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rotated(x) ← LaterallyRotated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;laterally rotated&apos; then x is a &apos;rotated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hindlimb in lateral rotation places the foot outward and the knee cap facing sideways</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/WShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Angular"/>
    <rdfs:label xml:lang="de">w förmig</rdfs:label>
    <rdfs:label xml:lang="en-US">w shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002439"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">W-shaped is an angular shape quality inhering in a bearer by virtue of having two angles in its length giving the bearer the form of the letter W</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">W-förmig ist eine eckige Formeigenschaft, die einem Träger innewohnt, da er zwei Winkel in seiner Länge aufweist, die dem Träger die Form des Buchstabens W verleihen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'w shaped' have not yet been formalized. The term is defined as a specific subtype of 'angular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002439.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Angular(x) ← WShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;w shaped&apos; then x is a &apos;angular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The outline of the coronary sulcus of the heart in some preparations appears w shaped from fat deposition</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Saccular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities"/>
    <rdfs:label xml:lang="de">saccular</rdfs:label>
    <rdfs:label xml:lang="en-US">saccular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001987"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saccular is a structural quality inhering in a bearer by virtue of having a three-dimensional cavity with a narrow or no opening, often containing an anatomical substance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Sakkulär ist eine strukturelle Eigenschaft, die einem Träger dadurch innewohnt, dass er über einen dreidimensionalen Hohlraum mit einer engen oder keiner Öffnung verfügt, der oft eine anatomische Substanz enthält</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saccular' have not yet been formalized. The term is defined as a specific subtype of 'cavities'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001987.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavities(x) ← Saccular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saccular&apos; then x is a &apos;cavities&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The gallbladder is saccular, a blind-ending pouch attached to the biliary system for bile storage</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SacLike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">sac like</rdfs:label>
    <rdfs:label xml:lang="de">sackartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002439"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a sack or pouch, often hollow and flexible</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form ähnelt einem Sack oder Beutel, oft hohl und flexibel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sac like' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002439.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← SacLike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sac like&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pericardial cavity is sac like, a fluid-filled pouch enclosing and protecting the heart</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Segmental">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">segmental</rdfs:label>
    <rdfs:label xml:lang="en-US">segmental</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002404"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Segmental is a spatial pattern affecting a segment or segments</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Segmental ist ein räumliches Muster, das sich auf ein oder mehrere Segmente auswirkt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'segmental' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002404.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Segmental(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;segmental&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The segmental distribution of dermatomes on the torso reflects the segmental origin of spinal nerve innervation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Banded">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="en-US">banded</rdfs:label>
    <rdfs:label xml:lang="de">gebändert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001946"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored pattern with bands or stripes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbiges Muster mit Bändern oder Streifen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'banded' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001946.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Banded(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;banded&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The shell of Zonaria pyrum is banded with alternating dark and pale zones encircling the dorsal surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkYellowBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/YellowBrown"/>
    <rdfs:label xml:lang="en-US">dark yellow brown</rdfs:label>
    <rdfs:label xml:lang="de">dunkelgelbbraun</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002412"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue amalgamating dark tones of yellow and brown</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, der dunkle Gelb- und Brauntöne vereint</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark yellow brown' have not yet been formalized. The term is defined as a specific subtype of 'yellow brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002412.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">YellowBrown(x) ← DarkYellowBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark yellow brown&apos; then x is a &apos;yellow brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The heartwood of Juglans regia shows dark yellow brown coloration from oxidized tannin compounds</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/VariouslyPigmented">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="en-US">variously pigmented</rdfs:label>
    <rdfs:label xml:lang="de">verschieden pigmentiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000638"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored variety showing different shades or colors due to varied pigmentation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbige Sorte, die aufgrund der unterschiedlichen Pigmentierung unterschiedliche Schattierungen oder Farben aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'variously pigmented' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000638.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← VariouslyPigmented(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;variously pigmented&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The skin of Chameleon calyptratus is variously pigmented, ranging from green to yellow and black depending on display state</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaturatedBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brown"/>
    <rdfs:label xml:lang="de">sattes Braun</rdfs:label>
    <rdfs:label xml:lang="en-US">saturated brown</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001267"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saturated brown is a color consisting of brown hue and high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gesättigtes Braun ist eine Farbe, die aus einem braunen Farbton und hoher Sättigung besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saturated brown' have not yet been formalized. The term is defined as a specific subtype of 'brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001267.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Brown(x) ← SaturatedBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saturated brown&apos; then x is a &apos;brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The heavily melanized skin of equatorial human populations shows saturated brown coloration with high melanin content</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">form</rdfs:label>
    <rdfs:label xml:lang="en-US">shape</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000052"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape is the visible makeup characteristic such as the spatial form or contour of a particular item or kind of item</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form ist das sichtbare Make-up-Merkmal, beispielsweise die räumliche Form oder Kontur eines bestimmten Gegenstands oder einer bestimmten Gegenstandsart</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'shape' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000052.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← Shape(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;shape&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The shape of the human ear pinna is a distinctive feature used in forensic identification and biometric analysis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tomentose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy"/>
    <rdfs:label xml:lang="de">filzig</rdfs:label>
    <rdfs:label xml:lang="en-US">tomentose</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002341"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tomentose is a quality of being covered with short, dense, matted hairs</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Filz ist eine Eigenschaft, die mit kurzen, dichten, verfilzten Haaren bedeckt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tomentose' have not yet been formalized. The term is defined as a specific subtype of 'hairy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002341.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Hairy(x) ← Tomentose(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tomentose&apos; then x is a &apos;hairy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The underside of the leaf of Quercus pubescens is tomentose, densely covered with short matted white hairs</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Platelike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flat"/>
    <rdfs:label xml:lang="de">plattenartig</rdfs:label>
    <rdfs:label xml:lang="en-US">platelike</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002253"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Platelike is a shape quality inhering in a bearer due to being roundish and flattish with potentially slightly angled edges</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Plattenförmig ist eine Formqualität, die einem Träger innewohnt, da sie rundlich und flach mit möglicherweise leicht abgewinkelten Kanten ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'platelike' have not yet been formalized. The term is defined as a specific subtype of 'flat'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002253.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Flat(x) ← Platelike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;platelike&apos; then x is a &apos;flat&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The frontal squama of the human skull is platelike, a roundish flattened bone with slightly angled lateral edges</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Botryoidal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="en-US">botryoidal</rdfs:label>
    <rdfs:label xml:lang="de">traubenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001907"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Surface feature shape resembling a cluster of grapes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Form der Oberfläche ähnelt einer Weintraube</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'botryoidal' have not yet been formalized. The term is defined as a specific subtype of 'surface feature shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001907.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SurfaceFeatureShape(x) ← Botryoidal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;botryoidal&apos; then x is a &apos;surface feature shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mineral surface of malachite from copper ore deposits is botryoidal, resembling a bunch of smooth green grapes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Blue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="de">blau</rdfs:label>
    <rdfs:label xml:lang="en-US">blue</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000318"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue situated in the middle range of the visible spectrum, perceived by wavelengths around 450 to 495 nanometers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton im mittleren Bereich des sichtbaren Spektrums, wahrgenommen bei Wellenlängen um 450 bis 495 Nanometer</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'blue' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000318.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Blue(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;blue&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal mantle of Octopus cyanea shows blue chromatophore patches when the animal signals agitation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Splayed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="de">gespreizt</rdfs:label>
    <rdfs:label xml:lang="en-US">splayed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001785"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Splayed is a curvature quality inhering in a bearer by virtue of being curved outward</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gespreizt ist eine Krümmungseigenschaft, die einem Träger dadurch innewohnt, dass er nach außen gebogen ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'splayed' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001785.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← Splayed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;splayed&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The toes of the tree frog Hyla arborea are splayed, spreading widely for adhesion to smooth surfaces</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Scrobiculate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="de">geschrobelt</rdfs:label>
    <rdfs:label xml:lang="en-US">scrobiculate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002294"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Scrobiculate is a texture quality uniformly covered in short, oblong, or trench-like depressions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Scrobiculate ist eine Texturqualität, die gleichmäßig mit kurzen, länglichen oder grabenartigen Vertiefungen bedeckt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scrobiculate' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002294.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Scrobiculate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scrobiculate&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The seed surface of Nicotiana tabacum is scrobiculate with numerous short trench-like depressions visible under SEM</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Uncrowded">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">nicht-überlaufen</rdfs:label>
    <rdfs:label xml:lang="en-US">uncrowded</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000633"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Uncrowded is a spatial pattern inhering in a bearer due to not being overfilled</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Nicht überfüllt ist ein räumliches Muster, das einem Träger innewohnt, weil es nicht überfüllt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'uncrowded' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000633.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Uncrowded(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;uncrowded&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cell arrangement in the loose connective tissue of the lamina propria is uncrowded with spaces between fibroblasts</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pointleted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sharp"/>
    <rdfs:label xml:lang="de">pointiert</rdfs:label>
    <rdfs:label xml:lang="en-US">pointleted</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001949"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Pointleted is a shape quality inhering in a bearer by virtue of terminating abruptly in a small point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Punktiert ist eine Formqualität, die einem Träger innewohnt, weil sie abrupt in einem kleinen Punkt endet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pointleted' have not yet been formalized. The term is defined as a specific subtype of 'sharp'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001949.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Sharp(x) ← Pointleted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pointleted&apos; then x is a &apos;sharp&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf apex of Agave americana is pointleted, ending abruptly in a stiff terminal spine</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Punctate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="de">punktförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">punctate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001512"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Punctate is a pattern inhering in a surface due to being marked by the presence of dots, punctures, points, or pits</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Punktiert ist ein Muster, das einer Oberfläche innewohnt, weil es durch das Vorhandensein von Punkten, Einstichen, Spitzen oder Vertiefungen gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'punctate' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001512.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Punctate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;punctate&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The gill surface of a fish infected with parasites shows a punctate pattern of small white dots</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Parallelogram">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Quadrangular"/>
    <rdfs:label xml:lang="e">Parallelogram</rdfs:label>
    <rdfs:label xml:lang="de">Parallelogramm</rdfs:label>
    <rdfs:label xml:lang="en-US">parallelogram</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002317"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Convex quadrilateral that satisfies certain statements regarding its diagonals, opposite sides, angles, or symmetry, also known through the parallelogram law</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konvexes Viereck, das bestimmte Aussagen hinsichtlich seiner Diagonalen, gegenüberliegenden Seiten, Winkel oder Symmetrie erfüllt, auch bekannt durch das Parallelogrammgesetz</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'parallelogram' have not yet been formalized. The term is defined as a specific subtype of 'quadrangular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002317.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Quadrangular(x) ← Parallelogram(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;parallelogram&apos; then x is a &apos;quadrangular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The outline of the psoas major muscle in cross-section approximates a parallelogram with two pairs of parallel sides</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RingShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Elliptic"/>
    <rdfs:label xml:lang="de">ringförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">ring shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002539"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ring shaped is a shape quality inhering in a bearer by virtue of having a shape like a ring, a circular shape enclosing a space</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ringförmig ist eine Formeigenschaft, die einem Träger innewohnt, weil er die Form eines Rings hat, eine kreisförmige Form, die einen Raum umschließt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ring shaped' have not yet been formalized. The term is defined as a specific subtype of 'elliptic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002539.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Elliptic(x) ← RingShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ring shaped&apos; then x is a &apos;elliptic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hyoid bone of Homo sapiens is ring shaped from lateral view forming a horseshoe-like bony arch</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleGreen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Green"/>
    <rdfs:label xml:lang="de">blass grün</rdfs:label>
    <rdfs:label xml:lang="en-US">pale green</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002008"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Green hue marked by subdued intensity or brightness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Grüner Farbton, gekennzeichnet durch gedämpfte Intensität oder Helligkeit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale green' have not yet been formalized. The term is defined as a specific subtype of 'green'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002008.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Green(x) ← PaleGreen(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale green&apos; then x is a &apos;green&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The new leaves of Acer palmatum are pale green before accumulating full chlorophyll at maturity</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RedBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brown"/>
    <rdfs:label xml:lang="en-US">red brown</rdfs:label>
    <rdfs:label xml:lang="de">rotbraun</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001287"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Red brown is a color consisting of red and brown hue</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rotbraun ist eine Farbe, die aus Rot- und Brauntönen besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'red brown' have not yet been formalized. The term is defined as a specific subtype of 'brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001287.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Brown(x) ← RedBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;red brown&apos; then x is a &apos;brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The rusty spots on the wing of a moth represent red brown melanin deposits from localized pigment cells</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pleated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Folded"/>
    <rdfs:label xml:lang="de">plissiert</rdfs:label>
    <rdfs:label xml:lang="en-US">pleated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000464"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Folded quality marked by multiple narrow folds resembling pleats</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gefaltete Qualität, gekennzeichnet durch mehrere schmale Falten, die an Falten erinnern</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pleated' have not yet been formalized. The term is defined as a specific subtype of 'folded'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000464.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Folded(x) ← Pleated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pleated&apos; then x is a &apos;folded&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The wall of the gallbladder has a pleated internal surface formed by the mucosal ridges called rugae</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularlyShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">irregularly shaped</rdfs:label>
    <rdfs:label xml:lang="de">unregelmäßig geformt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0005020"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape not conforming to regular or symmetric geometry</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form entspricht nicht der regulären oder symmetrischen Geometrie</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'irregularly shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0005020.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← IrregularlyShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;irregularly shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The amoeba Chaos carolinense is irregularly shaped with no fixed morphology due to constant pseudopod extension</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Swollen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Edematous"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">geschwollen</rdfs:label>
    <rdfs:label xml:lang="en-US">swollen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001851"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Edematous characteristic marked by expansion or enlargement of an area, often due to fluid accumulation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ödematöses Merkmal, das durch eine Ausdehnung oder Vergrößerung eines Bereichs gekennzeichnet ist, häufig aufgrund einer Flüssigkeitsansammlung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'swollen' have not yet been formalized. The term is defined as a specific subtype of 'edematous'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001851.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Edematous(x) ← Swollen(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;swollen&apos; then x is a &apos;edematous&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The parotid gland is swollen in mumps, enlarged bilaterally due to viral inflammation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DesaturatedMagenta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Magenta"/>
    <rdfs:label xml:lang="en-US">desaturated magenta</rdfs:label>
    <rdfs:label xml:lang="de">entsättigtes Magenta</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001276"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue where magenta tones are mixed with white or grey, lessening their vibrancy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton, bei dem Magentatöne mit Weiß oder Grau gemischt werden, wodurch ihre Lebendigkeit verringert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'desaturated magenta' have not yet been formalized. The term is defined as a specific subtype of 'magenta'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001276.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Magenta(x) ← DesaturatedMagenta(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;desaturated magenta&apos; then x is a &apos;magenta&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The aging petals of Dianthus caryophyllus fade to desaturated magenta as anthocyanin pigments break down</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Scandent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stretched"/>
    <rdfs:label xml:lang="de">rankend</rdfs:label>
    <rdfs:label xml:lang="en-US">scandent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001093"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Stretched quality describing climbing or ascending growth, often in plants</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gestreckte Eigenschaft, die kletterndes oder aufsteigendes Wachstum beschreibt, häufig bei Pflanzen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'scandent' have not yet been formalized. The term is defined as a specific subtype of 'stretched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001093.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Stretched(x) ← Scandent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;scandent&apos; then x is a &apos;stretched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stems of Humulus lupulus are scandent, climbing by twining clockwise around supports</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Demyelinated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">demyelinated</rdfs:label>
    <rdfs:label xml:lang="de">entmyeliniert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002218"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality characterized by loss or damage of the myelin sheath surrounding nerve fibers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität, gekennzeichnet durch Verlust oder Beschädigung der Myelinscheide, die die Nervenfasern umgibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'demyelinated' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002218.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Demyelinated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;demyelinated&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The optic nerve in multiple sclerosis appears demyelinated, with loss of the myelin sheath around axons</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/AnteriorlyRotated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Rotated"/>
    <rdfs:label xml:lang="en-US">anteriorly rotated</rdfs:label>
    <rdfs:label xml:lang="de">nach vorn rotiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001601"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rotation towards the front of an organism</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Drehung zur Vorderseite eines Organismus</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'anteriorly rotated' have not yet been formalized. The term is defined as a specific subtype of 'rotated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001601.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Rotated(x) ← AnteriorlyRotated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;anteriorly rotated&apos; then x is a &apos;rotated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The femur in hip flexion is anteriorly rotated, swinging the distal end forward relative to the acetabulum</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightRed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Red"/>
    <rdfs:label xml:lang="de">hellrot</rdfs:label>
    <rdfs:label xml:lang="en-US">light red</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001262"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue showing lighter tones of red, creating a softer and paler appearance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit helleren Rottönen, wodurch ein weicheres und blasseres Erscheinungsbild entsteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'light red' have not yet been formalized. The term is defined as a specific subtype of 'red'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001262.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Red(x) ← LightRed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;light red&apos; then x is a &apos;red&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The gills of a mildly anemic fish show light red coloration from reduced hemoglobin levels</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stalked">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">langgestielt</rdfs:label>
    <rdfs:label xml:lang="en-US">stalked</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002289"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characteristic defined by a long, thin extension resembling a stem or stalk</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formmerkmal, definiert durch eine lange, dünne Verlängerung, die einem Stiel oder Stiel ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'stalked' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002289.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Stalked(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;stalked&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The barnacle Lepas anatifera is stalked, attached to floating debris by a flexible muscular peduncle</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultifocalToCoalescing">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiLocalised"/>
    <rdfs:label xml:lang="de">multifokal bis koaleszierend</rdfs:label>
    <rdfs:label xml:lang="en-US">multifocal to coalescing</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002402"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multifocal to coalescing describes multiple lesions with some interconnecting with each other</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Multifokal bis koaleszierend beschreibt mehrere Läsionen, von denen einige miteinander verbunden sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'multifocal to coalescing' have not yet been formalized. The term is defined as a specific subtype of 'multi localised'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002402.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiLocalised(x) ← MultifocalToCoalescing(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;multifocal to coalescing&apos; then x is a &apos;multi localised&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pulmonary lesions in canine distemper are multifocal to coalescing, forming expanding zones of consolidation</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subglobose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spheroid"/>
    <rdfs:label xml:lang="en-US">subglobose</rdfs:label>
    <rdfs:label xml:lang="de">unterkugelig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000329"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spheroid shape nearly spherical but not perfectly round, having slight irregularities</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kugelform, fast kugelförmig, aber nicht perfekt rund, mit leichten Unregelmäßigkeiten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subglobose' have not yet been formalized. The term is defined as a specific subtype of 'spheroid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000329.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spheroid(x) ← Subglobose(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subglobose&apos; then x is a &apos;spheroid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The berry of Solanum nigrum is subglobose, nearly spherical but slightly flattened at the poles</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fusiform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpindleShaped"/>
    <rdfs:label xml:lang="en-US">fusiform</rdfs:label>
    <rdfs:label xml:lang="de">spindelförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002400"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spindle-shaped form tapering at both ends, bulging at the center</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Spindelförmige Form, die sich an beiden Enden verjüngt und in der Mitte vorwölbt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fusiform' have not yet been formalized. The term is defined as a specific subtype of 'spindle shaped'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002400.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpindleShaped(x) ← Fusiform(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fusiform&apos; then x is a &apos;spindle shaped&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The muscle belly of Biceps brachii is fusiform, tapering at both ends from a broad middle body</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Brown"/>
    <rdfs:label xml:lang="de">blass braun</rdfs:label>
    <rdfs:label xml:lang="en-US">pale brown</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002006"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Brown hue showing reduced intensity and depth</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Brauner Farbton mit reduzierter Intensität und Tiefe</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'pale brown' have not yet been formalized. The term is defined as a specific subtype of 'brown'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002006.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Brown(x) ← PaleBrown(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;pale brown&apos; then x is a &apos;brown&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cartilage of an aging joint shows pale brown coloration from early lipid oxidation products</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaddleShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">sattelförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">saddle shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002517"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saddle-shaped is a shape quality inhering in a bearer due to its similarity to the appearance of a saddle</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Sattelförmig ist eine Formeigenschaft, die einem Träger aufgrund seiner Ähnlichkeit mit dem Aussehen eines Sattels innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saddle shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002517.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← SaddleShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saddle shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The carpal-metacarpal joint of the human thumb is saddle shaped, with reciprocally curved articular surfaces</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CrescentShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape2D"/>
    <rdfs:label xml:lang="en-US">crescent shaped</rdfs:label>
    <rdfs:label xml:lang="de">halbmondförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001870"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">2D shape resembling a crescent moon</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">2D-Form, die einer Mondsichel ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'crescent shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape2 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001870.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape2D(x) ← CrescentShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;crescent shaped&apos; then x is a &apos;shape2 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The meniscus of the human knee joint is crescent shaped in superior view, with two tapering horns</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Regeneration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">regeneration</rdfs:label>
    <rdfs:label xml:lang="en-US">regeneration</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001547"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality characterized by the ability to renew or restore tissue structures spontaneously</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, gekennzeichnet durch die Fähigkeit, Gewebestrukturen spontan zu erneuern oder wiederherzustellen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'regeneration' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001547.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Regeneration(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;regeneration&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The liver of Mus musculus shows remarkable regeneration, restoring normal tissue mass after partial hepatectomy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SplitBilaterally">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Split"/>
    <rdfs:label xml:lang="de">geteilt bilateral</rdfs:label>
    <rdfs:label xml:lang="en-US">split bilaterally</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002171"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Split bilaterally is a shape quality inhering in a bearer due to being split on two sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Beidseitig gespalten ist eine Formeigenschaft, die einem Träger innewohnt, weil er auf zwei Seiten gespalten ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'split bilaterally' have not yet been formalized. The term is defined as a specific subtype of 'split'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002171.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Split(x) ← SplitBilaterally(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;split bilaterally&apos; then x is a &apos;split&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cleft lip is split bilaterally in severe cases, divided on both sides of the philtrum</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N1fac2ecf83714a36ac4ea826a0524c95">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasSpecifiedOutput"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Trabecular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="en-US">trabecular</rdfs:label>
    <rdfs:label xml:lang="de">trabekulär</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002121"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Trabecular is a spatial pattern inhering in a bearer by virtue of resembling an irregular meshwork with cross-linking struts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Trabekular ist ein räumliches Muster, das einem Träger innewohnt, da es einem unregelmäßigen Netzwerk mit sich vernetzenden Streben ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'trabecular' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002121.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Trabecular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;trabecular&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cancellous bone of the iliac crest shows a trabecular meshwork of cross-linking bony struts</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Imperforate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavitated"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavities"/>
    <rdfs:label xml:lang="en-US">imperforate</rdfs:label>
    <rdfs:label xml:lang="de">unperforiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001821"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cavity quality described by the absence of openings or perforations</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Hohlraumqualität, beschrieben durch das Fehlen von Öffnungen oder Perforationen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'imperforate' have not yet been formalized. The term is defined as a specific subtype of 'cavitated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001821.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cavitated(x) ← Imperforate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;imperforate&apos; then x is a &apos;cavitated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The imperforate hymen is described as imperforate, lacking any natural opening for menstrual flow</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Black">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Color"/>
    <rdfs:label xml:lang="en-US">black</rdfs:label>
    <rdfs:label xml:lang="de">schwarz</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000317"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue characterized as the darkest possible shade, absorbing all light</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Farbton ist der dunkelste mögliche Farbton, der alles Licht absorbiert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'black' have not yet been formalized. The term is defined as a specific subtype of 'color'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000317.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Color(x) ← Black(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;black&apos; then x is a &apos;color&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The melanin-rich integument of the sea urchin Arbacia punctulata is black, absorbing nearly all visible light</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Angular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">angular</rdfs:label>
    <rdfs:label xml:lang="de">winklig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001977"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by angles or angular outlines</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die durch Winkel oder kantige Umrisse gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'angular' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001977.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Angular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;angular&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The angular process of the mandible in rodents is angular, forming a pronounced lateral flange for muscle attachment</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Patchy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
    <rdfs:label xml:lang="de">fleckenartig</rdfs:label>
    <rdfs:label xml:lang="en-US">patchy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001608"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial pattern characterized by being marked by patches or diversified with patches</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Räumliches Muster, das dadurch gekennzeichnet ist, dass es durch Flecken markiert oder durch Flecken abwechslungsreich ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'patchy' have not yet been formalized. The term is defined as a specific subtype of 'irregular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001608.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">IrregularSpatialPattern(x) ← Patchy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;patchy&apos; then x is a &apos;irregular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The inflammatory infiltrate in focal segmental glomerulosclerosis is patchy, affecting some glomeruli while sparing others</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Steellike">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Metallic"/>
    <rdfs:label xml:lang="en-US">steellike</rdfs:label>
    <rdfs:label xml:lang="de">stählern</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000922"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Metallic quality resembling or characterized by the appearance or texture of steel</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Metallische Qualität, die dem Aussehen oder der Textur von Stahl ähnelt oder durch diese gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'steellike' have not yet been formalized. The term is defined as a specific subtype of 'metallic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000922.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Metallic(x) ← Steellike(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;steellike&apos; then x is a &apos;metallic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The metallic blue-grey of the fish scales of Thunnus thynnus gives a steellike appearance when fresh</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Broad">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">breit</rdfs:label>
    <rdfs:label xml:lang="en-US">broad</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002359"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape characterized by wide or expansive dimensions</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, gekennzeichnet durch breite oder expansive Abmessungen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'broad' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002359.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Broad(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;broad&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The acetabular labrum of the hip joint is broad at its base, narrowing toward the free edge</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <obo:IAO_0000117>PERSON: Thomas Hanke</obo:IAO_0000117>
    <rdfs:label xml:lang="de">textur</rdfs:label>
    <rdfs:label xml:lang="en-US">texture</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000150"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture is a Morphological quality inhering in a bearer by virtue of the relative size, organization, and distribution of its surface elements, or the appearance of its surface in visual and tactile characteristics</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Textur ist eine morphologische Qualität, die einem Träger aufgrund der relativen Größe, Organisation und Verteilung seiner Oberflächenelemente oder des Erscheinungsbilds seiner Oberfläche in Bezug auf visuelle und taktile Eigenschaften innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'texture' have not yet been formalized. The term is defined as a specific subtype of 'Morphological quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000150.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalQuality(x) ← Texture(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;texture&apos; then x is a &apos;morphological quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The texture of the skin of Crocodylus niloticus is assessed by the pattern and size of its scute arrangements</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/TwistedLingually">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Twisted"/>
    <rdfs:label xml:lang="de">lingual verdreht</rdfs:label>
    <rdfs:label xml:lang="en-US">twisted lingually</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000377"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Twisted characteristic oriented towards the tongue or inside oral cavity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verdrehtes Merkmal, das zur Zunge oder zur Mundhöhle hin ausgerichtet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'twisted lingually' have not yet been formalized. The term is defined as a specific subtype of 'twisted'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000377.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Twisted(x) ← TwistedLingually(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;twisted lingually&apos; then x is a &apos;twisted&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dental roots of mandibular incisors in some patients are twisted lingually toward the tongue side</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkCyan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cyan"/>
    <rdfs:label xml:lang="en-US">dark cyan</rdfs:label>
    <rdfs:label xml:lang="de">dunkelcyan</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001248"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color hue with deep and dark cyan tones</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbton mit tiefen und dunklen Cyan-Tönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dark cyan' have not yet been formalized. The term is defined as a specific subtype of 'cyan'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001248.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cyan(x) ← DarkCyan(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dark cyan&apos; then x is a &apos;cyan&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The tail feathers of the teal Anas crecca show dark cyan speculum patches with metallic sheen</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DorsoVentrallyFlattened">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flattened"/>
    <rdfs:label xml:lang="en-US">dorso ventrally flattened</rdfs:label>
    <rdfs:label xml:lang="de">rückenbauchwärtiges Flach</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002053"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Flattening from the dorsal side down to the ventral side</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Abflachung von der Rückenseite nach unten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dorso ventrally flattened' have not yet been formalized. The term is defined as a specific subtype of 'flattened'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002053.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Flattened(x) ← DorsoVentrallyFlattened(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dorso ventrally flattened&apos; then x is a &apos;flattened&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The body of the ray Raja clavata is dorso ventrally flattened for benthic locomotion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SphericallySymmetric">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Symmetry"/>
    <rdfs:label xml:lang="de">kugelsymmetrisch</rdfs:label>
    <rdfs:label xml:lang="en-US">spherically symmetric</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000614"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Symmetry describing identical parts around the center of a sphere</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Symmetrie beschreibt identische Teile um den Mittelpunkt einer Kugel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spherically symmetric' have not yet been formalized. The term is defined as a specific subtype of 'symmetry'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000614.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Symmetry(x) ← SphericallySymmetric(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spherically symmetric&apos; then x is a &apos;symmetry&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The radiolarian skeleton of Actinomma arcadophorum is spherically symmetric with equal latticed shells around the center</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spongy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">schwammartig</rdfs:label>
    <rdfs:label xml:lang="en-US">spongy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001480"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spongy is a structural quality inhering in a bearer due to resembling a sponge in elasticity, absorbency, or porousness</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schwammig ist eine strukturelle Eigenschaft, die einem Träger innewohnt, weil sie in ihrer Elastizität, Saugfähigkeit oder Porosität einem Schwamm ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spongy' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001480.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Spongy(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spongy&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The trabecular tissue of the corpus cavernosum is spongy, with lacunar spaces that fill with blood during erection</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Vascular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">gefäßartig</rdfs:label>
    <rdfs:label xml:lang="en-US">vascular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000388"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation indicating the presence of vessels or vein-like structures</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Beobachtung der Zusammensetzung weist auf das Vorhandensein von Gefäßen oder venenähnlichen Strukturen hin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'vascular' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000388.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Vascular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;vascular&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The rete testis is vascular, containing extensive networks of blood vessels supporting spermatogenesis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Unbranched">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branchiness"/>
    <rdfs:label xml:lang="en-US">unbranched</rdfs:label>
    <rdfs:label xml:lang="de">unverzweigt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000414"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Branchiness quality exhibiting absence of division or offshoots</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verzweigungsqualität, die das Fehlen von Teilungen oder Ablegern zeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unbranched' have not yet been formalized. The term is defined as a specific subtype of 'branchiness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000414.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branchiness(x) ← Unbranched(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unbranched&apos; then x is a &apos;branchiness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cilia of tracheal epithelial cells are unbranched, with a single shaft projecting from the cell surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Mineralized">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">mineralisiert</rdfs:label>
    <rdfs:label xml:lang="en-US">mineralized</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002444"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mineralized is a composition quality inhering in a bearer by virtue of being composed of or containing inorganic material</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mineralisiert ist eine Zusammensetzungsqualität, die einem Träger dadurch innewohnt, dass er aus anorganischem Material besteht oder dieses enthält</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mineralized' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002444.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Mineralized(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mineralized&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The shell of Crassostrea gigas is heavily mineralized, composed almost entirely of calcium carbonate crystals</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Vertical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">vertikal</rdfs:label>
    <rdfs:label xml:lang="en-US">vertical</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001854"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Vertical is a spatial pattern inhering in a bearer due to being situated at right angles to the horizon</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Vertikal ist ein räumliches Muster, das einem Träger innewohnt, weil es im rechten Winkel zum Horizont steht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'vertical' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001854.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Vertical(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;vertical&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The long axis of a standing human is vertical, perpendicular to the horizontal ground plane</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Discoid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cylindrical"/>
    <rdfs:label xml:lang="en-US">discoid</rdfs:label>
    <rdfs:label xml:lang="de">scheibenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001874"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Cylindrical shape characterized by a disc-like appearance with flat circular ends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zylindrische Form, gekennzeichnet durch ein scheibenartiges Aussehen mit flachen kreisförmigen Enden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'discoid' have not yet been formalized. The term is defined as a specific subtype of 'cylindrical'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001874.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cylindrical(x) ← Discoid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;discoid&apos; then x is a &apos;cylindrical&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The intervertebral disc is discoid, with a roughly circular cross-section and flat superior and inferior surfaces</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Glutinous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="en-US">glutinous</rdfs:label>
    <rdfs:label xml:lang="de">schleimig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001540"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Amylose composition indicating sticky or adhesive texture, often found in starch-rich substances</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Amylosezusammensetzung weist auf eine klebrige oder klebrige Textur hin und kommt häufig in stärkereichen Substanzen vor</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'glutinous' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001540.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Glutinous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;glutinous&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The seed coat of Plantago psyllium is glutinous, becoming adhesive when wetted by saliva or water</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Biconcave">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave"/>
    <rdfs:label xml:lang="en-US">biconcave</rdfs:label>
    <rdfs:label xml:lang="de">bikonkav</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002039"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave quality with inward curving surfaces on both sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave Qualität mit beidseitig nach innen gewölbten Flächen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'biconcave' have not yet been formalized. The term is defined as a specific subtype of 'concave'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002039.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave(x) ← Biconcave(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;biconcave&apos; then x is a &apos;concave&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The erythrocyte of Homo sapiens is biconcave, depressed on both faces to maximize surface-to-volume ratio</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stratified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stratification"/>
    <rdfs:label xml:lang="de">geschichtet</rdfs:label>
    <rdfs:label xml:lang="en-US">stratified</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002068"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Stratified is a spatial pattern inhering in a bearer by virtue of exhibiting a layered configuration</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stratifiziert ist ein räumliches Muster, das einem Träger innewohnt, weil es eine geschichtete Konfiguration aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'stratified' have not yet been formalized. The term is defined as a specific subtype of 'stratification'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002068.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Stratification(x) ← Stratified(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;stratified&apos; then x is a &apos;stratification&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The squamous epithelium of the human cornea is stratified, consisting of multiple stacked cell layers</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cavitated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">cavitated</rdfs:label>
    <rdfs:label xml:lang="de">gehöhlen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002379"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure characterized by hollow or void spaces within a material or object</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Struktur, gekennzeichnet durch hohle oder leere Räume innerhalb eines Materials oder Objekts</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cavitated' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002379.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Cavitated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cavitated&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pulmonary lesion in tuberculosis is cavitated, with a hollow air-filled center from liquefactive necrosis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cancellous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">Knochenporös</rdfs:label>
    <rdfs:label xml:lang="en-US">cancellous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002519"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality characterized by a spongy or porous framework</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturqualität, gekennzeichnet durch ein schwammiges oder poröses Gerüst</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cancellous' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002519.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Cancellous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cancellous&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The proximal epiphysis of the human tibia is cancellous, formed by a lightweight trabecular bony network</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Bracket">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">bracket</rdfs:label>
    <rdfs:label xml:lang="de">klammerförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002142"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling a bracket or support structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die einer Halterung oder Stützstruktur ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bracket' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002142.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Bracket(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bracket&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The bracket fungi Ganoderma applanatum grow in bracket shapes, horizontal shelves projecting from the trunk surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LaterallyCompressed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flattened"/>
    <rdfs:label xml:lang="en-US">laterally compressed</rdfs:label>
    <rdfs:label xml:lang="de">seitlich zusammengedrückt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002054"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Flattened quality resulting from applying pressure to the sides, reducing width</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Abgeflachte Qualität durch Druck auf die Seiten, wodurch die Breite verringert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'laterally compressed' have not yet been formalized. The term is defined as a specific subtype of 'flattened'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002054.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Flattened(x) ← LaterallyCompressed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;laterally compressed&apos; then x is a &apos;flattened&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The body of the angelfish Pterophyllum scalare is laterally compressed, giving a disc-like profile from the front</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Wilty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Drooping"/>
    <rdfs:label xml:lang="de">welkend</rdfs:label>
    <rdfs:label xml:lang="en-US">wilty</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002461"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Wilty is a condition of bending or hanging downwards due to loss of water</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Welke ist ein Zustand, in dem man sich aufgrund von Wasserverlust beugt oder nach unten hängt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'wilty' have not yet been formalized. The term is defined as a specific subtype of 'drooping'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002461.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Drooping(x) ← Wilty(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;wilty&apos; then x is a &apos;drooping&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaves of a dehydrated Ficus benjamina become wilty, drooping and bending from water loss</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SaturatedOrange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Orange"/>
    <rdfs:label xml:lang="de">sattes orange</rdfs:label>
    <rdfs:label xml:lang="en-US">saturated orange</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001277"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Saturated orange is a color consisting of orange hue and high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gesättigtes Orange ist eine Farbe, die aus einem orangefarbenen Farbton und hoher Sättigung besteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'saturated orange' have not yet been formalized. The term is defined as a specific subtype of 'orange'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001277.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Orange(x) ← SaturatedOrange(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;saturated orange&apos; then x is a &apos;orange&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The ripe fruit of Cucurbita maxima shows saturated orange coloration with vivid intense hue throughout the exocarp</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Undamaged">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Damage"/>
    <rdfs:label xml:lang="de">unbeschädigt</rdfs:label>
    <rdfs:label xml:lang="en-US">undamaged</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001168"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Undamaged is a structural quality inhering in a bearer by virtue of not being harmed or injured or spoiled</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unbeschädigt ist eine strukturelle Eigenschaft, die einem Träger innewohnt, weil er nicht beschädigt, verletzt oder verwöhnt wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'undamaged' have not yet been formalized. The term is defined as a specific subtype of 'damage'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001168.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Damage(x) ← Undamaged(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;undamaged&apos; then x is a &apos;damage&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The enamel of a newly erupted molar is undamaged, showing a smooth intact surface without any abrasion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ruffled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">gekräuselt</rdfs:label>
    <rdfs:label xml:lang="en-US">ruffled</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001799"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Ruffled is a shape quality inhering in a bearer due to exhibiting disturbance of its smoothness or regularity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kräuselt ist eine Formqualität, die einem Träger innewohnt, weil er eine Störung seiner Glätte oder Regelmäßigkeit aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ruffled' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001799.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Ruffled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ruffled&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The border of a squamous cell carcinoma shows a ruffled edge with irregular undulations of the advancing margin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PeripherallyLocated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Localized"/>
    <rdfs:label xml:lang="de">peripher gelegen</rdfs:label>
    <rdfs:label xml:lang="en-US">peripherally located</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015049"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Localized pattern situated at the outer edges or surface of an entity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Lokalisiertes Muster an den Außenkanten oder der Oberfläche eines Objekts</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'peripherally located' have not yet been formalized. The term is defined as a specific subtype of 'localized'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015049.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Localized(x) ← PeripherallyLocated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;peripherally located&apos; then x is a &apos;localized&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The inflammatory infiltrate in viral pneumonia is peripherally located within the lobules, adjacent to the pleural surface</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Asymmetrical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Symmetry"/>
    <rdfs:label xml:lang="en-US">asymmetrical</rdfs:label>
    <rdfs:label xml:lang="de">asymmetrisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000616"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Symmetry lacking equality between halves or sides</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Symmetrie ohne Gleichheit zwischen Hälften oder Seiten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'asymmetrical' have not yet been formalized. The term is defined as a specific subtype of 'symmetry'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000616.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Symmetry(x) ← Asymmetrical(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;asymmetrical&apos; then x is a &apos;symmetry&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The human face is slightly asymmetrical with minor differences between the right and left halves</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Degenerate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Degeneration"/>
    <rdfs:label xml:lang="en-US">degenerate</rdfs:label>
    <rdfs:label xml:lang="de">degeneriert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000639"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Degeneration characterized by deterioration or retrogressive development</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Degeneration, gekennzeichnet durch Verschlechterung oder rückläufige Entwicklung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'degenerate' have not yet been formalized. The term is defined as a specific subtype of 'degeneration'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000639.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Degeneration(x) ← Degenerate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;degenerate&apos; then x is a &apos;degeneration&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cartilage of an end-stage osteoarthritic joint is degenerate, showing full-thickness erosion and bone exposure</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Unornamented">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ornamentation"/>
    <rdfs:label xml:lang="de">nicht-ornamentiert</rdfs:label>
    <rdfs:label xml:lang="en-US">unornamented</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002442"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Unornamented is a surface feature shape in which the bearer's surface lacks ridges, pits, rugosity or other structures</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Unornamentiert ist eine Oberflächenform, bei der die Oberfläche des Trägers keine Grate, Vertiefungen, Unebenheiten oder andere Strukturen aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'unornamented' have not yet been formalized. The term is defined as a specific subtype of 'ornamentation'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002442.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Ornamentation(x) ← Unornamented(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;unornamented&apos; then x is a &apos;ornamentation&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The outer surface of the eggshell of Struthio camelus is unornamented, smooth and lacking any surface structures</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cleft">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave"/>
    <rdfs:label xml:lang="en-US">cleft</rdfs:label>
    <rdfs:label xml:lang="de">zerklüftet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000403"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave quality characterized by a division or split</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave Qualität, gekennzeichnet durch eine Teilung oder Spaltung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cleft' have not yet been formalized. The term is defined as a specific subtype of 'concave'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000403.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave(x) ← Cleft(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cleft&apos; then x is a &apos;concave&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cleft in the secondary palate of cleft palate patients creates an open communication between oral and nasal cavities</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CurvedLateral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="en-US">curved lateral</rdfs:label>
    <rdfs:label xml:lang="de">lateral gekrümmt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001649"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Curvature along the sides, forming a curve outwards from the medial line</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Krümmung entlang der Seiten, die von der Mittellinie aus eine Kurve nach außen bildet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'curved lateral' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001649.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← CurvedLateral(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;curved lateral&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The long bones of the lower limb show slight curved lateral bowing visible in anteroposterior X-rays</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concavity"/>
    <rdfs:label xml:lang="en-US">concave</rdfs:label>
    <rdfs:label xml:lang="de">konkav</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001857"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concavity characterized by being curved inward, like the interior of a bowl</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkavität, die dadurch gekennzeichnet ist, dass sie nach innen gewölbt ist, wie das Innere einer Schüssel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'concave' have not yet been formalized. The term is defined as a specific subtype of 'concavity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001857.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concavity(x) ← Concave(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;concave&apos; then x is a &apos;concavity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The inner surface of the scapular fossa is concave, providing an attachment area for subscapularis muscle</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hyperelliptic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Superelliptic"/>
    <rdfs:label xml:lang="en-US">hyperelliptic</rdfs:label>
    <rdfs:label xml:lang="de">überelliptisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002322"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Superelliptic shape defined by elongated central region tapering at the ends</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Superelliptische Form, definiert durch einen länglichen zentralen Bereich, der sich an den Enden verjüngt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hyperelliptic' have not yet been formalized. The term is defined as a specific subtype of 'superelliptic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002322.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Superelliptic(x) ← Hyperelliptic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hyperelliptic&apos; then x is a &apos;superelliptic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The outline of the operculum of Perca fluviatilis is hyperelliptic, elongated centrally and tapering at both ends</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RodShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cylindrical"/>
    <rdfs:label xml:lang="en-US">rod shaped</rdfs:label>
    <rdfs:label xml:lang="de">stabförmig</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Rod shaped is a shape quality inhering in a bearer by virtue of resembling a uniform, elongated cylinder or bar</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stabförmig ist eine Formeigenschaft, die einem Träger innewohnt, da sie einem gleichmäßigen, länglichen Zylinder oder Stab ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'rod shaped' have not yet been formalized. The term is defined as a specific subtype of 'cylindrical'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Cylindrical(x) ← RodShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;rod shaped&apos; then x is a &apos;cylindrical&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The rod photoreceptors of the mammalian retina are rod shaped, with a cylindrical outer segment</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/CupShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="de">becherförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">cup shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002227"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling a cup or goblet, typically round and open at one end</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die einer Tasse oder einem Kelch ähnelt, typischerweise rund und an einem Ende offen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cup shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002227.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← CupShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cup shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The acetabulum is cup shaped, forming a deep concavity that receives the femoral head in a ball-and-socket joint</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Procumbent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Stretched"/>
    <rdfs:label xml:lang="de">niederliegend</rdfs:label>
    <rdfs:label xml:lang="en-US">procumbent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001090"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Stretched quality describing horizontal growth or lying on the ground, often of plant stems trailing along the ground without rooting</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Gestreckte Qualität, die horizontales Wachstum beschreibt oder auf dem Boden liegt, oft von Pflanzenstängeln, die ohne Wurzeln über den Boden ziehen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'procumbent' have not yet been formalized. The term is defined as a specific subtype of 'stretched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001090.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Stretched(x) ← Procumbent(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;procumbent&apos; then x is a &apos;stretched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The stems of Thymus serpyllum are procumbent, lying flat along the ground surface before flowering</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SatelliteShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="en-US">satellite shaped</rdfs:label>
    <rdfs:label xml:lang="de">satellitenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002373"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Shape resembling or characterized by structures or extensions resembling satellites or secondary nodules</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Form, die Satelliten oder sekundären Knötchen ähnelt oder durch Strukturen oder Erweiterungen gekennzeichnet ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'satellite shaped' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002373.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← SatelliteShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;satellite shaped&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The accessory ossicle adjacent to the lateral malleolus in some individuals is satellite shaped, forming a secondary nodule</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Susceptible">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">empfänglich</rdfs:label>
    <rdfs:label xml:lang="en-US">susceptible</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002019"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structural quality denoting increased likelihood of undergoing changes due to external influence</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strukturelle Qualität bezeichnet eine erhöhte Wahrscheinlichkeit von Veränderungen aufgrund äußerer Einflüsse</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'susceptible' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002019.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Susceptible(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;susceptible&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cartilage of the aging knee is susceptible to erosion from reduced proteoglycan and collagen maintenance</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Waisted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">tailliert</rdfs:label>
    <rdfs:label xml:lang="en-US">waisted</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002431"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Waisted is a shape quality in which the bearer possesses a gradual yet distinct thinning from a wide starting point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Tailliert ist eine Formqualität, bei der der Träger von einem breiten Ausgangspunkt aus eine allmähliche, aber deutliche Ausdünnung aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'waisted' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002431.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Waisted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;waisted&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The waist of the scorpion shows a waisted narrowing between the cephalothorax and abdomen</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Angular"/>
    <rdfs:label xml:lang="de">L-förmig</rdfs:label>
    <rdfs:label xml:lang="en-US">l shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002225"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Angular form resembling the letter "L", with two perpendicular arms</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eckige Form, die dem Buchstaben „L“ ähnelt, mit zwei senkrechten Armen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'l shaped' have not yet been formalized. The term is defined as a specific subtype of 'angular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002225.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Angular(x) ← LShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;l shaped&apos; then x is a &apos;angular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The sigmoid notch of the ulna forms an l shaped groove that articulates with the radial head</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cuneate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Triangular"/>
    <rdfs:label xml:lang="en-US">cuneate</rdfs:label>
    <rdfs:label xml:lang="de">keilartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001955"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Triangular shape resembling a wedge, tapering to a point</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Dreieckige Form, die einem Keil ähnelt und spitz zuläuft</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cuneate' have not yet been formalized. The term is defined as a specific subtype of 'triangular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001955.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Triangular(x) ← Cuneate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cuneate&apos; then x is a &apos;triangular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cuneate leaf base of Erigeron annuus tapers sharply into the petiole at an acute angle</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape3D"/>
    <rdfs:label xml:lang="en-US">convex 3-d shape</rdfs:label>
    <rdfs:label xml:lang="de">konvex 3-d form</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002007"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">3D shape with a surface that curves outward, forming a bulge or protrusion</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">3D-Form mit einer nach außen gewölbten Oberfläche, die eine Ausbuchtung oder einen Vorsprung bildet</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'convex 3-d shape' have not yet been formalized. The term is defined as a specific subtype of 'shape3 d'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002007.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape3D(x) ← Convex3DShape(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;convex 3-d shape&apos; then x is a &apos;shape3 d&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The femoral condyle has a convex 3-D shape, bulging outward to articulate with the concave tibial plateau</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000119">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Constricted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">constricted</rdfs:label>
    <rdfs:label xml:lang="de">verengt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001847"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Structure featuring narrowing or tightening in a specific area, often restricting flow or movement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Struktur mit einer Verengung oder Verengung in einem bestimmten Bereich, die oft den Fluss oder die Bewegung einschränkt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'constricted' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001847.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Constricted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;constricted&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The pylorus is constricted in pyloric stenosis, narrowed by hypertrophic muscle obstructing gastric emptying</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Recurved">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Curved"/>
    <rdfs:label xml:lang="de">rückwärts gebogen</rdfs:label>
    <rdfs:label xml:lang="en-US">recurved</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002211"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Recurved is a curvature quality inhering in a bearer due to being curved backward or inward</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Recurved ist eine Krümmungseigenschaft, die einem Träger innewohnt, weil er nach hinten oder innen gebogen ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'recurved' have not yet been formalized. The term is defined as a specific subtype of 'curved'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002211.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Curved(x) ← Recurved(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;recurved&apos; then x is a &apos;curved&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The petal tips of Cyclamen persicum are recurved, curling backward away from the center of the flower</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Ochre">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/YellowOrange"/>
    <rdfs:label xml:lang="en-US">ochre</rdfs:label>
    <rdfs:label xml:lang="de">ocker</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001945"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color consisting of moderate yellow-orange to orange hues</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Farbe besteht aus mäßigen Gelb-Orange- bis Orangetönen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ochre' have not yet been formalized. The term is defined as a specific subtype of 'yellow orange'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001945.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">YellowOrange(x) ← Ochre(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;ochre&apos; then x is a &apos;yellow orange&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The feathers of the Eurasian golden plover show ochre coloration on the supercilium in breeding plumage</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/HighContrastColorPattern">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ColorPattern"/>
    <rdfs:label xml:lang="de">Hochkontrast-Farbmuster</rdfs:label>
    <rdfs:label xml:lang="en-US">high contrast color pattern</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002275"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color pattern marked by stark differences between hues and tones, enhancing visibility</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Farbmuster, das durch starke Unterschiede zwischen Farbtönen und Tönen gekennzeichnet ist und die Sichtbarkeit verbessert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'high contrast color pattern' have not yet been formalized. The term is defined as a specific subtype of 'color pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002275.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ColorPattern(x) ← HighContrastColorPattern(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;high contrast color pattern&apos; then x is a &apos;color pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The high contrast color pattern of the poison frog Dendrobates tinctorius serves as an aposematic warning signal</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Cladodromous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Branched"/>
    <rdfs:label xml:lang="en-US">cladodromous</rdfs:label>
    <rdfs:label xml:lang="de">kladodrom</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001971"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Branching pattern where secondary veins dichotomously fork away from the midrib</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verzweigungsmuster, bei dem sich sekundäre Venen dichotom von der Mittelrippe abzweigen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cladodromous' have not yet been formalized. The term is defined as a specific subtype of 'branched'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001971.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Branched(x) ← Cladodromous(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cladodromous&apos; then x is a &apos;branched&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The venation of Betula pendula is cladodromous, with secondary veins forking before reaching the leaf margin</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hypoelliptic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Superelliptic"/>
    <rdfs:label xml:lang="en-US">hypoelliptic</rdfs:label>
    <rdfs:label xml:lang="de">unterelliptisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002321"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Superelliptic shape characterized by shorter central axis compared to width</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Superelliptische Form, gekennzeichnet durch eine kürzere Mittelachse im Vergleich zur Breite</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'hypoelliptic' have not yet been formalized. The term is defined as a specific subtype of 'superelliptic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002321.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Superelliptic(x) ← Hypoelliptic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hypoelliptic&apos; then x is a &apos;superelliptic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The round window membrane of the inner ear is hypoelliptic, wider than long in its short axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Marbled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MultiColored"/>
    <rdfs:label xml:lang="en-US">marbled</rdfs:label>
    <rdfs:label xml:lang="de">marmoriert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002273"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Multi-colored pattern resembling marble, typically featuring swirling layers or veins of contrasting colors</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mehrfarbiges Muster, das an Marmor erinnert und typischerweise wirbelnde Schichten oder Adern in kontrastierenden Farben aufweist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'marbled' have not yet been formalized. The term is defined as a specific subtype of 'multi colored'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002273.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MultiColored(x) ← Marbled(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;marbled&apos; then x is a &apos;multi colored&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The cross-section of fatty liver shows marbled alternation of yellow lipid zones and red normal lobular tissue</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fringed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/EdgeShape"/>
    <rdfs:label xml:lang="en-US">fringed</rdfs:label>
    <rdfs:label xml:lang="de">randgefranst</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040008"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Edge shape characterized by having additional projections or thin appendages along the edges</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kantenform, gekennzeichnet durch zusätzliche Vorsprünge oder dünne Fortsätze entlang der Kanten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fringed' have not yet been formalized. The term is defined as a specific subtype of 'edge shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040008.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">EdgeShape(x) ← Fringed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fringed&apos; then x is a &apos;edge shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The mantle edge of Pecten maximus is fringed with long sensory tentacles projecting from the tissue border</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BowlShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave3DShape"/>
    <rdfs:label xml:lang="en-US">bowl shaped</rdfs:label>
    <rdfs:label xml:lang="de">schalenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040009"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3-D shape resembling a bowl or rounded hollow</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Konkave 3D-Form, die einer Schüssel oder einer abgerundeten Mulde ähnelt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bowl shaped' have not yet been formalized. The term is defined as a specific subtype of 'concave 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040009.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Concave3DShape(x) ← BowlShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bowl shaped&apos; then x is a &apos;concave3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The greater pelvis is bowl shaped in females, forming a wide shallow basin for the viscera</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MonoColored">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ColorPattern"/>
    <rdfs:label xml:lang="de">einfarbig</rdfs:label>
    <rdfs:label xml:lang="en-US">mono colored</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001532"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Mono-colored is a color pattern inhering in a bearer by virtue of having just one hue</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Einfarbig ist ein Farbmuster, das einem Träger innewohnt, weil es nur einen Farbton hat</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'mono colored' have not yet been formalized. The term is defined as a specific subtype of 'color pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001532.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ColorPattern(x) ← MonoColored(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;mono colored&apos; then x is a &apos;color pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The dorsal surface of Lacerta agilis is mono colored olive green without additional pattern elements</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Serrated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Serration"/>
    <rdfs:label xml:lang="de">gezahnt</rdfs:label>
    <rdfs:label xml:lang="en-US">serrated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001206"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Serration quality defined by saw-like or jagged projections along the edge</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Verzahnung wird durch sägeartige oder gezackte Vorsprünge entlang der Kante definiert</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'serrated' have not yet been formalized. The term is defined as a specific subtype of 'serration'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001206.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Serration(x) ← Serrated(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;serrated&apos; then x is a &apos;serration&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The leaf margin of Urtica dioica is serrated with evenly spaced sharp-pointed teeth pointing toward the apex</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Sparse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpatialPattern"/>
    <rdfs:label xml:lang="de">spärlich</rdfs:label>
    <rdfs:label xml:lang="en-US">sparse</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001609"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Sparse is a spatial pattern inhering in a bearer due to being scattered or irregularly spread at a distance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Spärlich ist ein räumliches Muster, das einem Träger innewohnt, weil es über eine Entfernung verstreut oder unregelmäßig verteilt ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'sparse' have not yet been formalized. The term is defined as a specific subtype of 'spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001609.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">SpatialPattern(x) ← Sparse(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;sparse&apos; then x is a &apos;spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The hair follicles on the dorsal skull of Homo sapiens in androgenic alopecia become sparse and miniaturized</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subspherical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Spheroid"/>
    <rdfs:label xml:lang="de">annähernd kugelförmig</rdfs:label>
    <rdfs:label xml:lang="en-US">subspherical</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0005014"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Subspherical is a spheroid shape quality inhering in a bearer by virtue of being nearly, but not perfectly, spherical</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Subsphärisch ist eine kugelförmige Form, die einem Träger innewohnt, da er nahezu, aber nicht perfekt, kugelförmig ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'subspherical' have not yet been formalized. The term is defined as a specific subtype of 'spheroid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0005014.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Spheroid(x) ← Subspherical(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;subspherical&apos; then x is a &apos;spheroid&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The head of the femur is subspherical, nearly but not perfectly round with slight flattening at the fovea</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000117">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Segmented">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="en-US">segmented</rdfs:label>
    <rdfs:label xml:lang="de">segmentiert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002312"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Segmented is a composition consisting of segments or similar parts arranged in a longitudinal series</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Segmentiert ist eine Komposition, die aus Segmenten oder ähnlichen Teilen besteht, die in einer Längsreihe angeordnet sind</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'segmented' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002312.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Structure(x) ← Segmented(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;segmented&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The exoskeleton of Scolopendra centipede is segmented, with distinct tergites repeating along the body axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fibrotic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="en-US">fibrotic</rdfs:label>
    <rdfs:label xml:lang="de">fibrotisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040019"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition describing abnormal fibrous tissue buildup, often leading to stiffness or scarring</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zusammensetzung, die eine abnormale Ansammlung von fibrösem Gewebe beschreibt, die häufig zu Steifheit oder Narbenbildung führt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'fibrotic' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0040019.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MorphologicalComposition(x) ← Fibrotic(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;fibrotic&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The portal tracts in cirrhotic liver are fibrotic, surrounded by dense bands of scar tissue extending into the parenchyma</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N029019ec2d914b40a0e0a0fe99ad82ad">
    <rdf:first rdf:nodeID="Nc3a84d80b3b149c5985e87164978be41"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nc3a84d80b3b149c5985e87164978be41">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasCapability"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ObservationCapability"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Twisted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Torsioned"/>
    <rdfs:label xml:lang="en-US">twisted</rdfs:label>
    <rdfs:label xml:lang="de">verdrillt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001077"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Torsioned quality defined by curvature induced by twisting or rotating movement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Torsionsqualität, definiert durch die Krümmung, die durch eine Dreh- oder Drehbewegung hervorgerufen wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'twisted' have not yet been formalized. The term is defined as a specific subtype of 'torsioned'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001077.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Torsioned(x) ← Twisted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;twisted&apos; then x is a &apos;torsioned&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The helix of the pinna of Homo sapiens has a twisted rim that curls back along the outer edge</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Networked">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture"/>
    <rdfs:label xml:lang="en-US">networked</rdfs:label>
    <rdfs:label xml:lang="de">netzartig</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Networked is a texture quality of a material entity characterized by a pattern of interconnected lines, fibers, or structures forming a net-like arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">„Vernetzt“ ist eine Texturqualität einer materiellen Einheit, die durch ein Muster miteinander verbundener Linien, Fasern oder Strukturen gekennzeichnet ist, die eine netzartige Anordnung bilden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'networked' have not yet been formalized. The term is defined as a specific subtype of 'texture'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Texture(x) ← Networked(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;networked&apos; then x is a &apos;texture&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The elastic cartilage of the ear pinna contains a networked arrangement of elastic fibers interlaced through the matrix</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Refractive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Translucent"/>
    <rdfs:label xml:lang="de">lichtbrechend</rdfs:label>
    <rdfs:label xml:lang="en-US">refractive</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0015018"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Translucent quality where light bends or changes direction passing through an object</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Durchscheinende Qualität, bei der Licht beim Durchdringen eines Objekts gebrochen oder seine Richtung geändert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'refractive' have not yet been formalized. The term is defined as a specific subtype of 'translucent'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0015018.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Translucent(x) ← Refractive(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;refractive&apos; then x is a &apos;translucent&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The lens of the human eye is refractive, bending incoming light to focus images on the retina</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/BilateralSymmetry">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Symmetry"/>
    <rdfs:label xml:lang="en-US">bilateral symmetry</rdfs:label>
    <rdfs:label xml:lang="de">bilaterale Symmetrie</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001324"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Symmetry quality where division by a longitudinal plane creates similar halves</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Symmetriequalität, bei der durch die Teilung durch eine Längsebene ähnliche Hälften entstehen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'bilateral symmetry' have not yet been formalized. The term is defined as a specific subtype of 'symmetry'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001324.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Symmetry(x) ← BilateralSymmetry(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;bilateral symmetry&apos; then x is a &apos;symmetry&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The body plan of Homo sapiens has bilateral symmetry with the sagittal plane as the dividing axis</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tholiform">
    <rdfs:seeAlso rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Domed"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000114">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ObservationCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
    <rdfs:label xml:lang="de">Beobachtungsfähgkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">observation capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Capability of persons to assess attributes of entities like qualities, temporal regions, and process characteristics</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Fähigkeit von Personen, Attribute von Entitäten wie Qualitäten, zeitliche Bereiche und Prozessmerkmale zu beurteilen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'observation capability' have not yet been formalized. The term is defined as a specific subtype of 'Capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Capability(x) ← ObservationCapability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;observation capability&apos; then x is a &apos;capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The observation capability of a trained anatomist allows accurate morphological characterization of tissue samples under light microscopy</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Clavate">
    <rdfs:seeAlso rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Concave"/>
  </rdf:Description>
