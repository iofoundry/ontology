    <rdfs:label xml:lang="de">prismenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002465"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Prism shaped is a quality inhering in a bearer due to resembling a prism</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
