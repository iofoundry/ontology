  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/ObservationCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
    <rdfs:label xml:lang="de">Beobachtungsfähgkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">observation capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Capability of persons to assess attributes of entities like qualities, temporal regions, and process characteristics</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'observation capability' have not yet been formalized. The term is defined as a specific subtype of 'Capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Capability(x) ← ObservationCapability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;observation capability&apos; then x is a &apos;capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;observation capability&apos;.</skos:example>
  </rdf:Description>
