    <rdfs:label xml:lang="en">coated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000117"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Texture quality involving a layer or covering that adheres to the surface</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
