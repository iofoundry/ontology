    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002466"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shape resembling a keyhole, often with circular top and stem-like bottom</iof-av:naturalLanguageDefinition>
