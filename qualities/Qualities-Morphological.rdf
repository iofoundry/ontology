    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001065"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shape characterized by curves or circular borders with smooth transitions</iof-av:naturalLanguageDefinition>
