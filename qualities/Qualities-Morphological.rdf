    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000066"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Morphological quality regarding the presence or density of hair or hair-like structures</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
