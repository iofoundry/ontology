    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001988"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Quadrangular is a shape quality inhering in a bearer by virtue of having four angles and four sides</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
