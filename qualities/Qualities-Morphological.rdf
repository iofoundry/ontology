    <rdfs:label xml:lang="de">spatenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002432"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Concave 3D shape resembling or characterized by broad, pointed curvature like a spade</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
