    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001361"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Warty is a texture quality inhering in a bearer by virtue of being covered with warts or projections that resemble warts, resulting in a hard rough surface</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
