    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002049"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Curvature involving rotational twist and lateral bending</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
