    <rdfs:label xml:lang="de">platinierend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001499"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Flat quality characterized by flattened surfaces, often polished</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'platinate' have not yet been formalized. The term is defined as a specific subtype of 'flat'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001499.</iof-av:primitiveRationale>
  </rdf:Description>
