    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002010"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Color hue characterized by lighter shades of magenta, often subtle and less vivid</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'pale magenta' have not yet been formalized. The term is defined as a specific subtype of 'magenta'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002010.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convolute">
