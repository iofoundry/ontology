    <rdfs:label xml:lang="en">tubular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002299"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Tubular is a cylindrical shape that is hollow</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
