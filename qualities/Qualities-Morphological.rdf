  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shgarose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Hairy"/>
    <rdfs:label xml:lang="en">shgarose</rdfs:label>
    <rdfs:label xml:lang="de">zottige</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000311"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Hairy quality indicative of thorns or small hairs, often rough</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'shgarose' have not yet been formalized. The term is defined as a specific subtype of 'hairy'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000311.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightViolet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Violet"/>
    <rdfs:label xml:lang="de">hellviolett</rdfs:label>
    <rdfs:label xml:lang="en">light violet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001704"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Color hue exemplified by lighter shades of violet, often producing a gentle and soft appearance</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'light violet' have not yet been formalized. The term is defined as a specific subtype of 'violet'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001704.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleRedBrown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/RedBrown"/>
    <rdfs:label xml:lang="de">blass rotbraun</rdfs:label>
    <rdfs:label xml:lang="en">pale red brown</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002015"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Red-brown hue diminished in saturation or tone</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
