    <rdfs:label xml:lang="en">saturated violet</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001702"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Saturated vilett is a color consisting of vilet hue and high saturation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
