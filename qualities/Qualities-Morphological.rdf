    <rdfs:label xml:lang="de">zugespitzt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002228"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Tapered shape with a long-pointed apex</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
