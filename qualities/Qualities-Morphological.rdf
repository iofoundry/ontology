    <iof-av:naturalLanguageDefinition xml:lang="en">Tapered shape resembling a blade with a sharp, elongated form</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
