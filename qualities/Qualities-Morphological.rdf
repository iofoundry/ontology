    <rdfs:label xml:lang="de">überall</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002403"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Spatial pattern indicating distribution across most or all of a system or area</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
