    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002426"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Texture characterized by depressions or indentations</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
