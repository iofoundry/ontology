    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002441"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Surface feature shape where surface is highly topographical with ridges, pits, rugosity, or other surface structures</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
