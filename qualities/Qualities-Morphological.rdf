  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Trabecular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/IrregularSpatialPattern"/>
