    <rdfs:label xml:lang="de">Knochenporös</rdfs:label>
    <rdfs:label xml:lang="en">cancellous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002519"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Structural quality characterized by a spongy or porous framework</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
