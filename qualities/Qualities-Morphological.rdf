    <rdfs:label xml:lang="en">ringed</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001775"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Multi-colored pattern characterized by concentric circles or bands encircling the surface</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
