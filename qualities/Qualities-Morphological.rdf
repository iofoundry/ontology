    <iof-av:naturalLanguageDefinition xml:lang="en-US">Polymeric is a quality inhering in a structure due to consisting of repeated, similar or identical subunits arranged orderly</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
