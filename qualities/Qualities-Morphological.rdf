    <rdfs:label xml:lang="en">wedge shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002423"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Triangular shape resembling a wedge, broad at one end and tapering to a point at the other</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
