    <rdfs:label xml:lang="en">light green</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001250"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Color hue exhibiting lighter tones of green, often fresh and vibrant</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
