    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001878"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Sigmoid is a shape quality inhering in a bearer by virtue of consisting of two curves, in opposite directions, resembling the letter S</iof-av:naturalLanguageDefinition>
    <iof-av:synonym>s-shaped</iof-av:synonym>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
