    <rdfs:label xml:lang="en">rosy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001425"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Rosy is a color hue consisting of both red and yellow hues and high brightness</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
