    <rdfs:label xml:lang="en-US">waisted</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002431"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Waisted is a shape quality in which the bearer possesses a gradual yet distinct thinning from a wide starting point</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'waisted' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002431.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Shape(x) ← Waisted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;waisted&apos; then x is a &apos;shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;waisted&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
