    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002468"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Color variant of red that is dimmed or dulled</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
