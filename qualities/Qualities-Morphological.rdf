    <iof-av:naturalLanguageDefinition xml:lang="en">Curvature involving twisting around an axis resulting in a spiral formation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'rotational curvature' have not yet been formalized. The term is defined as a specific subtype of 'curvature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001787.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Gloss">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <rdfs:label xml:lang="de">Glanz</rdfs:label>
    <rdfs:label xml:lang="en">gloss</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Morphological quality imparting shine or luster to a surface due to reflection</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
