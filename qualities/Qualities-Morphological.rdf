    <rdfs:label xml:lang="en-US">striate angular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002385"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Striate-angular is a shape quality inhering in a bearer by virtue of being marked by narrow lines, usually parallel, with at least one salient angle on the margin</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'striate angular' have not yet been formalized. The term is defined as a specific subtype of 'striated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002385.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Striated(x) ← StriateAngular(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;striate angular&apos; then x is a &apos;striated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;striate angular&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Delaminated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
