    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002121"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Trabecular is a spatial pattern inhering in a bearer by virtue of resembling an irregular meshwork with cross-linking struts</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
