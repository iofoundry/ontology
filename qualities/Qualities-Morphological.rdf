    <rdfs:label xml:lang="de">rund</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000411"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Elliptic quality representing a perfect circle</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
