    <rdfs:label xml:lang="de">hellgrau</rdfs:label>
    <rdfs:label xml:lang="en">light grey</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001252"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Color hue denoting paler shades of grey, often appearing neutral and soft</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
