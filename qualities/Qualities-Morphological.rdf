    <rdfs:label xml:lang="en">perfoliate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001983"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Joined quality where leaves or other structures appear pierced by the stem</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
