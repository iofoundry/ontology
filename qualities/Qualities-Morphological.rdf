    <rdfs:label xml:lang="de">bikonkav</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002039"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Concave quality with inward curving surfaces on both sides</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
