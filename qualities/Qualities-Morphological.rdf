    <rdfs:label xml:lang="en">pentagonal</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040016"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Pentagonal is a shape quality inhering in a bearer by virtue of having five angles and five sides</iof-av:naturalLanguageDefinition>
