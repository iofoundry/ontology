    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hydropic&apos; then x is a &apos;morphological composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;hydropic&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Platinate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
