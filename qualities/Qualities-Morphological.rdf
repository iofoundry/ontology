    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tangled&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;tangled&apos;.</skos:example>
