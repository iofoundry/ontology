    <iof-av:naturalLanguageDefinition xml:lang="en-US">Patchy pigmentation is a degree of pigmentation quality that is diversified with patches or irregularity</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
