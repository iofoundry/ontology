    <rdfs:label xml:lang="de">verschlungen</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001846"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tangled is a structural quality inhering in a bearer by virtue of being entwined and difficult to unravel</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
