    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001759"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Composition observation characterized by the presence of small, grain-like particles or structures</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
