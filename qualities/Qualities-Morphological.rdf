    <rdfs:label xml:lang="en">robust</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002310"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Robust is a quality inhering in a bearer by virtue of being strong, thick, or sturdy</iof-av:naturalLanguageDefinition>
