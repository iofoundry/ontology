    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;hollow&apos; then x is a &apos;cavitated&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;hollow&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Contamination">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
