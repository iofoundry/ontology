    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001474"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Orientation inclined towards the front</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'anteverted' have not yet been formalized. The term is defined as a specific subtype of 'oriented'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001474.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Oriented(x) ← Anteverted(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;anteverted&apos; then x is a &apos;oriented&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;anteverted&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Pointed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
