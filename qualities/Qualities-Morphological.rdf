    <rdfs:label xml:lang="de">grün</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000320"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Color hue perceived between 495-570 nanometers, commonly associated with vegetation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
