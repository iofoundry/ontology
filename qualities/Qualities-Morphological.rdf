    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001821"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Cavity quality described by the absence of openings or perforations</iof-av:naturalLanguageDefinition>
