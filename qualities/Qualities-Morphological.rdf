    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;polymeric&apos; then x is a &apos;structure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;polymeric&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Circular">
