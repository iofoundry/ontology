    <iof-av:naturalLanguageDefinition xml:lang="en-US">Slit-like is a shape quality inhering in a bearer by virtue of exhibiting a narrow and elongate opening</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
