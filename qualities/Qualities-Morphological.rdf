    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000937"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Organization quality characterized by lack of orderly arrangement or structure</iof-av:naturalLanguageDefinition>
