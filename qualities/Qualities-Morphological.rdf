    <rdfs:label xml:lang="en">porosity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000973"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Porosity is a structure quality inhering in a bearer by virtue of the disposition to admit the passage of gas or liquid through pores or interstices</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
