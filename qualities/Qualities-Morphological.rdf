    <skos:example xml:lang="en-US">Example of a &apos;curved caudal&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
