    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002375"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Trumpet-shaped is a concave 3-D shape quality inhering in a bearer by virtue of resembling the shape of a trumpet</iof-av:naturalLanguageDefinition>
