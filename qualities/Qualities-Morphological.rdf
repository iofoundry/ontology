    <rdfs:label xml:lang="en">papillomatous</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002423"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shape quality resembling a round or lobulated protruding form akin to a nipple</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'papillomatous' have not yet been formalized. The term is defined as a specific subtype of 'shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002423.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LightGrey">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
