    <rdfs:label xml:lang="de">transiente Struktur</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002292"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Transient is a structural quality inhering in a bearer by virtue of the underlying structure being capable of change</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
