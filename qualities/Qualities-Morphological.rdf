    <iof-av:naturalLanguageDefinition xml:lang="en">Spatulate is a shape quality inhering in a bearer by virtue of being oblong, with the lower end very much attenuated</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
