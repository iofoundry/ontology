    <rdfs:label xml:lang="de">fruchtblätterartig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002454"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shape resembling a carpel of a flower, typically having a curved structure</iof-av:naturalLanguageDefinition>
