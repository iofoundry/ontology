    <rdfs:label xml:lang="en">anchor shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002446"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shape resembling an anchor, typically having a pointed end and broad flukes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
