    <rdfs:label xml:lang="de">flüssigkeitsgefüllt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002409"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Cavity quality characterized by being filled with liquid substances</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'fluid filled' have not yet been formalized. The term is defined as a specific subtype of 'cavitated'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002409.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Bronze">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
