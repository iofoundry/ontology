    <rdfs:label xml:lang="en">cavities</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002014"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Structural quality of a material entity characterized by the presence of hollow spaces or voids within or on the surface of the bearer</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
