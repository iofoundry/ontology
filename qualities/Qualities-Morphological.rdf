    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001809"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Tight is a pattern quality inhering in a bearer by virtue of being compact or dense in arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'tight' have not yet been formalized. The term is defined as a specific subtype of 'regular spatial pattern'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001809.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">RegularSpatialPattern(x) ← Tight(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;tight&apos; then x is a &apos;regular spatial pattern&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;tight&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/DarkYellow">
