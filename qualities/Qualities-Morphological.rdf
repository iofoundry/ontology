    <rdfs:label xml:lang="en">light orange</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001255"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Color hue displaying lighter tones of orange, often appearing bright and cheerful</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
