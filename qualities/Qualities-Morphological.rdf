    <rdfs:label xml:lang="en">pale yellow</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002017"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Yellow hue showing less chromatic intensity or saturation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
