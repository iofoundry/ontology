    <rdfs:label xml:lang="en">rhomboid</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001938"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Superelliptic form resembling a rhombus or parallelogram with equal sides</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
