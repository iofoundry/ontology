    <rdfs:label xml:lang="en">bracket</rdfs:label>
    <rdfs:label xml:lang="de">klammerförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002142"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shape resembling a bracket or support structure</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
