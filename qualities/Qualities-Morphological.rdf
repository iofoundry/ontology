    <rdfs:label xml:lang="de">rautenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002320"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Superelliptic shape resembling a diamond or rhombus, with equal-length sides forming opposite angles</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
