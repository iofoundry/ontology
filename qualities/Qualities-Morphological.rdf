    <rdfs:label xml:lang="de">porös</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000984"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Porous is a porosity quality inhering in a bearer by virtue of permitting the passage of gas or liquid through pores or interstices</iof-av:naturalLanguageDefinition>
