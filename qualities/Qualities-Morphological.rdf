    <rdfs:label xml:lang="de">kubusförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001872"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Convex 3D shape resembling a cube, characterized by six faces meeting at right angles</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'cuboid' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001872.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Convex3DShape(x) ← Cuboid(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;cuboid&apos; then x is a &apos;convex3 d shape&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;cuboid&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/StrapShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
