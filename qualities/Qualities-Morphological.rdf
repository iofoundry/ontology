    <rdfs:label xml:lang="en">ridged</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002358"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Texture quality characterized by parallel raised strips or ridges</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
