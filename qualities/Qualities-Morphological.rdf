    <rdfs:label xml:lang="en">subglobose</rdfs:label>
    <rdfs:label xml:lang="de">unterkugelig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000329"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Spheroid shape nearly spherical but not perfectly round, having slight irregularities</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'subglobose' have not yet been formalized. The term is defined as a specific subtype of 'spheroid'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000329.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Fusiform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpindleShaped"/>
    <rdfs:label xml:lang="en">fusiform</rdfs:label>
    <rdfs:label xml:lang="de">spindelförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002400"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Spindle-shaped form tapering at both ends, bulging at the center</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'fusiform' have not yet been formalized. The term is defined as a specific subtype of 'spindle shaped'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002400.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/PaleBrown">
