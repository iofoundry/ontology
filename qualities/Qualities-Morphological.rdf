    <rdfs:label xml:lang="de">teleskopisch</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002313"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Telescopic is a shape quality inhering in a bearer by virtue of having or resembling the shape of a telescope</iof-av:naturalLanguageDefinition>
