    <rdfs:label xml:lang="de">schwammartig</rdfs:label>
    <rdfs:label xml:lang="en">spongy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001480"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Spongy is a structural quality inhering in a bearer due to resembling a sponge in elasticity, absorbency, or porousness</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'spongy' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001480.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Vascular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalComposition"/>
    <rdfs:label xml:lang="de">gefäßartig</rdfs:label>
    <rdfs:label xml:lang="en">vascular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000388"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Composition observation indicating the presence of vessels or vein-like structures</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
