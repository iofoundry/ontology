    <rdfs:label xml:lang="de">verstärkt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000493"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Reinforced is a structural quality enhancing durability and strength through additional support materials or techniques</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
