    <rdfs:label xml:lang="en">stratified</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002068"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Stratified is a spatial pattern inhering in a bearer by virtue of exhibiting a layered configuration</iof-av:naturalLanguageDefinition>
