    <rdfs:label xml:lang="en">unstratified</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002069"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Unstratified is a spatial pattern inhering in a bearer by virtue of lacking a layered configuration</iof-av:naturalLanguageDefinition>
