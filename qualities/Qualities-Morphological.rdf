    <rdfs:label xml:lang="en">orbicular</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001934"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shape characterized by a perfect circular quality</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
