    <rdfs:label xml:lang="en">upswept</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002094"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Curved characteristic exhibiting upward sweeping motion or angle</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
