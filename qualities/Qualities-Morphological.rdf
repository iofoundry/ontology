    <rdfs:label xml:lang="en">unilateral</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000634"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Unilateral is a spatial pattern inhering in a bearer by virtue of involving only one part or side</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
