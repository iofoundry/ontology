    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000948"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Concave 3D shape resembling a heart, often featuring a pointed lower end and rounded upper lobes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
