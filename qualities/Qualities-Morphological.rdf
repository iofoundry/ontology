    <iof-av:naturalLanguageDefinition xml:lang="en">Localized pattern displayed over a wide area but centered around a focal point</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
