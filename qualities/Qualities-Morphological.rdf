    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002112"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Perforate is a structural quality inhering in a bearer by virtue of having a hole or holes, especially a row or array of small holes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
