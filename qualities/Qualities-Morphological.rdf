    <rdfs:label xml:lang="de">säulenförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002063"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shape resembling a column with vertical emphasis</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
