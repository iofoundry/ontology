    <rdfs:label xml:lang="de">läsioniert</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0040025"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Structural quality indicating localized damage or injury to tissues</iof-av:naturalLanguageDefinition>
