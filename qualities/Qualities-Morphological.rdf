    <iof-av:naturalLanguageDefinition xml:lang="en">Undulate is a shape quality inhering in a bearer due to having a sinuate margin and rippled surface</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
