    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000141"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Structure is a morphology quality inhering in a bearer by virtue of how it is perceived by humans in aspects like overall composition, wholeness, or functionality</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
