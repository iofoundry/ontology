    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002402"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Multifocal to coalescing describes multiple lesions with some interconnecting with each other</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'multifocal to coalescing' have not yet been formalized. The term is defined as a specific subtype of 'multi localised'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002402.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Subglobose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
