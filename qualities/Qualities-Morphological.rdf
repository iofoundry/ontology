    <rdfs:label xml:lang="de">dunkelorange</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001256"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Color hue exhibiting deep orange tones with a lower brightness</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
