    <rdfs:label xml:lang="de">blass violett</rdfs:label>
    <rdfs:label xml:lang="en">pale purple</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002013"/>
