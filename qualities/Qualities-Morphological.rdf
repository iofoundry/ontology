    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spheroid shape nearly spherical but not perfectly round, having slight irregularities</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
