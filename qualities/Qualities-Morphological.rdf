    <rdfs:label xml:lang="en">spoon shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002208"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Spoon-shaped is a concave 3-D shape inhering in a bearer due to resembling the form of a spoon</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
