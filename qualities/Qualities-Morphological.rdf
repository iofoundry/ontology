    <rdfs:label xml:lang="en">mottled</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002274"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Multi-colored pattern consisting of irregular patches or blotches</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
