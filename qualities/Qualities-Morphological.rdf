    <rdfs:label xml:lang="en">biomaterial purity</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001339"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Composition observation relating to the cleanliness and impurity level of biomaterial</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'biomaterial purity' have not yet been formalized. The term is defined as a specific subtype of 'Morphological composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001339.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SplayedLateral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Splayed"/>
    <rdfs:label xml:lang="de">gespreizte seitenwölbung</rdfs:label>
    <rdfs:label xml:lang="en">splayed lateral</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002152"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Splayed lateral is a curvature quality inhering in a bearer by virtue of being curved outwards from the side</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'splayed lateral' have not yet been formalized. The term is defined as a specific subtype of 'splayed'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002152.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/YellowGreen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Green"/>
    <rdfs:label xml:lang="de">gelb grün</rdfs:label>
    <rdfs:label xml:lang="en">yellow green</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001941"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Yellow green is a color consisting of yellow and green hues</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'yellow green' have not yet been formalized. The term is defined as a specific subtype of 'green'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001941.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shriveled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Structure"/>
    <rdfs:label xml:lang="de">geschrumpft</rdfs:label>
    <rdfs:label xml:lang="en">shriveled</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002460"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shriveled is a structural quality inhering in a bearer by virtue of being smaller and contracted, especially due to loss of moisture</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'shriveled' have not yet been formalized. The term is defined as a specific subtype of 'structure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002460.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SpindleShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Convex3DShape"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Shape"/>
    <rdfs:label xml:lang="de">spindelformig</rdfs:label>
    <rdfs:label xml:lang="en">spindle shaped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001409"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shape resembling a spindle, tapering at both ends, often bulging in the middle</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'spindle shaped' have not yet been formalized. The term is defined as a specific subtype of 'convex 3-d shape'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001409.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Tubular">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
