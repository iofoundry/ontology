    <rdfs:label xml:lang="de">pfeilförmig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001881"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shape resembling an arrowhead, typically with pointed ends</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
