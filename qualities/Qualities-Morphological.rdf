    <rdfs:label xml:lang="de">steril</rdfs:label>
    <rdfs:label xml:lang="en">sterile</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002059"/>
