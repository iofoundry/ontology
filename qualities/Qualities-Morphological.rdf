  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/WedgeShaped">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
