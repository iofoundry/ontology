    <rdfs:label xml:lang="en">striped</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000889"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Multi-colored pattern formed by long, narrow bands of contrasting color</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
