    <rdfs:label xml:lang="en">inflated</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002376"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Cavity quality characterized by expansion due to internal pressure</iof-av:naturalLanguageDefinition>
