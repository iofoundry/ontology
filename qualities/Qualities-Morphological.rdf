    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002078"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Cavity quality defined by a void or emptiness inside a structure or material</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
