    <rdfs:label xml:lang="de">flockig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001805"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Texture characterized by thin layers that peel or flake off</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
