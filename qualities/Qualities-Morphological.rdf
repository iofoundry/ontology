  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/LaterallyCompressed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Flattened"/>
    <rdfs:label xml:lang="en">laterally compressed</rdfs:label>
    <rdfs:label xml:lang="de">seitlich zusammengedrückt</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002054"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Flattened quality resulting from applying pressure to the sides, reducing width</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
