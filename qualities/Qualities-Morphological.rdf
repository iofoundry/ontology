  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Knobbled">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/SurfaceFeatureShape"/>
    <rdfs:label xml:lang="en">knobbled</rdfs:label>
    <rdfs:label xml:lang="de">knollig</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002427"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Surface feature shape characterized by raised, rounded protrusions or nodes</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
