    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001928"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Texture quality marked by raised or bulbous areas</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
