    <rdfs:label xml:lang="en-US">surface feature shape</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001925"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Surface feature shape is a quality inhering in a bearer by virtue of the shape of features present on its surface or outer shell</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
