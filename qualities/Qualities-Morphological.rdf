  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Texture">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/MorphologicalQuality"/>
    <obo:IAO_0000117>PERSON: Thomas Hanke</obo:IAO_0000117>
    <rdfs:label xml:lang="de">textur</rdfs:label>
    <rdfs:label xml:lang="en">texture</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000150"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Texture is a Morphological quality inhering in a bearer by virtue of the relative size, organization, and distribution of its surface elements, or the appearance of its surface in visual and tactile characteristics</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
