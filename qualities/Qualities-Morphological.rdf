    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'v shaped' have not yet been formalized. The term is defined as a specific subtype of 'angular'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002224.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Angular(x) ← VShaped(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;v shaped&apos; then x is a &apos;angular&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Example of a &apos;v shaped&apos;.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Morphological/Drooping">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
