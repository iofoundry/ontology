<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202507/qualities/Qualities-MeasurementPerformance/"/>
    <owl:versionInfo>202507</owl:versionInfo>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <dcterms:abstract xml:lang="en-us">This Submodule, Measurement Performance Qualities, of the IOF Qualities Ontology aims to represent the generic constructs (including classes and properties) related bfo qualities covering Measurement Performance.</dcterms:abstract>
    <dcterms:contributor xml:lang="en-us">Thomas Hanke, Fraunhofer IWM</dcterms:contributor>
    <dcterms:creator xml:lang="en-us">IOF Materials Working Group</dcterms:creator>
    <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
    <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
    <dcterms:references rdf:resource="http://spec.org/dc/terms/"/>
    <dcterms:references rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    <dcterms:title xml:lang="en-us">Industrial Ontology Foundry (IOF) Process Qualities Ontology</dcterms:title>
    <rdfs:label xml:lang="en-us">Measurement Performance Qualities Ontology</rdfs:label>
    <iof-av:copyright>Industrial Ontology Foundry (IOF)</iof-av:copyright>
    <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicRange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/MeasurementRelationalQuality"/>
    <rdfs:label xml:lang="de">Dynamikbereich</rdfs:label>
    <rdfs:label xml:lang="en-US">dynamic range</rdfs:label>
    <iof-av:adaptedFrom xml:lang="en-US">https://en.wikipedia.org/wiki/Dynamic_range</iof-av:adaptedFrom>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Dynamic range is the ratio between the largest and smallest values a quantity can assume, often used in signal contexts like sound and light, measured as a ratio or logarithmic value in base-10 or base-2</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Dynamikbereich ist das Verhältnis zwischen dem größten und dem kleinsten Wert, den eine Größe annehmen kann. Er wird häufig in Signalkontexten wie Ton und Licht verwendet und als Verhältnis oder logarithmischer Wert zur Basis 10 oder zur Basis 2 gemessen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dynamic range' have not yet been formalized. The term is defined as a specific subtype of 'measurement relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Dynamic_range.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MeasurementRelationalQuality(x) ← DynamicRange(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dynamic range&apos; then x is a &apos;measurement relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A digital oscilloscope with a dynamic range of 60 dB can measure signals from 1 mV to 1 V without distortion</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/WorkingRange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicRange"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Arbeitsbereich</rdfs:label>
    <rdfs:label xml:lang="en-US">working range</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Working range is the region between limits within which a processing node, like a machine, is usable for its intended purpose, expressed through lower and upper range values of interest</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Arbeitsbereich ist der Bereich zwischen den Grenzen, innerhalb dessen ein Verarbeitungsknoten wie eine Maschine für seinen vorgesehenen Zweck verwendbar ist, ausgedrückt durch interessierende untere und obere Bereichswerte</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'working range' have not yet been formalized. The term is defined as a specific subtype of 'dynamic range'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">DynamicRange(x) ← WorkingRange(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;working range&apos; then x is a &apos;dynamic range&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A thermocouple temperature sensor has a working range of -200 to 1200 degrees Celsius for process monitoring</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/ns/prov#editorialNote">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000116">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en-US">Editor Note</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000119">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en-US">Definition Source</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/CalibrationRange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicRange"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Kalibrierbereich</rdfs:label>
    <rdfs:label xml:lang="en-US">calibration range</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Calibration range is the region between limits within which a quantity is measured, received, or transmitted, typically by a process node like a machine, expressed through lower and upper range values</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Kalibrierbereich ist der Bereich zwischen den Grenzen, innerhalb dessen eine Größe gemessen, empfangen oder übertragen wird, typischerweise von einem Prozessknoten wie einer Maschine, ausgedrückt durch untere und obere Bereichswerte</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'calibration range' have not yet been formalized. The term is defined as a specific subtype of 'dynamic range'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">DynamicRange(x) ← CalibrationRange(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;calibration range&apos; then x is a &apos;dynamic range&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A pressure transmitter is calibrated over a range of 0 to 10 bar using a deadweight tester as reference</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/Precision">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/MeasurementRelationalQuality"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Genauigkeit</rdfs:label>
    <rdfs:label xml:lang="en-US">precision</rdfs:label>
    <iof-av:adaptedFrom xml:lang="en-US">“Precision.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/precision. Accessed 13 Jan. 2023.</iof-av:adaptedFrom>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Precision is the degree of refinement with which an operation is performed or a measurement stated</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Präzision ist der Grad der Verfeinerung, mit dem eine Operation ausgeführt oder eine Messung angegeben wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'precision' have not yet been formalized. The term is defined as a specific subtype of 'measurement relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: “Precision.” Merriam-Webster.com Dictionary, Merriam-Webster, https://www.merriam-webster.com/dictionary/precision. Accessed 13 Jan. 2023..</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MeasurementRelationalQuality(x) ← Precision(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;precision&apos; then x is a &apos;measurement relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Repeated weighings of a 100 g standard on an analytical balance show a standard deviation of 0.02 mg indicating high precision</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000117">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en-US">Term Editor</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000114">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en-US">Has Curation Status</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/PerformanceQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="de">Leistungsqualität</rdfs:label>
    <rdfs:label xml:lang="en-US">performance quality</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Performance quality is an attribute related to the effectiveness or efficiency of an entity’s performance, typically evaluated in relation to a standard or requirement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Leistungsqualität ist ein Attribut, das sich auf die Wirksamkeit oder Effizienz der Leistung eines Unternehmens bezieht und typischerweise in Bezug auf einen Standard oder eine Anforderung bewertet wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'performance quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000019'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000019(x) ← PerformanceQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;performance quality&apos; then x is a &apos;b f o_0000019&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A flow meter achieves 0.5% accuracy over its rated range, meeting the performance quality specified in its datasheet</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/MeasurementRelationalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
    <rdfs:label xml:lang="en-US">measurement relational quality</rdfs:label>
    <rdfs:label xml:lang="de">messungsrelationale Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">measurement relational quality is a relational quality that pertains to the measurement attributes related to other entities, requiring another entity for its existence</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die relationale Messqualität ist eine relationale Qualität, die sich auf die Messattribute bezieht, die sich auf andere Entitäten beziehen und für deren Existenz eine andere Entität erforderlich ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'measurement relational quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000145'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000145(x) ← MeasurementRelationalQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;measurement relational quality&apos; then x is a &apos;b f o_0000145&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The accuracy of a thermometer is a measurement relational quality because it only exists relative to the temperature standard it is compared against</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MeasurementPerformance/DataAcquisitionRate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/ProcessCharacteristic"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Datenerfassungsrate</rdfs:label>
    <rdfs:label xml:lang="en-US">data acquisition rate</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Data acquisition rate is the number of measurements or queries per time period for a considered measurement of a parameter, representing sampling or query rate during data acquisition</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Datenerfassungsrate ist die Anzahl der Messungen oder Abfragen pro Zeitraum für eine betrachtete Messung eines Parameters und stellt die Abtast- oder Abfragerate während der Datenerfassung dar</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'data acquisition rate' have not yet been formalized. The term is defined as a specific subtype of 'ProcessCharacteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">ProcessCharacteristic(x) ← DataAcquisitionRate(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;data acquisition rate&apos; then x is a &apos;process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A strain gauge data logger records at a data acquisition rate of 1000 samples per second during a tensile test</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000412">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
