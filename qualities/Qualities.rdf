<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities/triggers">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <rdfs:domain rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Action"/>
    <rdfs:range rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Reaction"/>
    <rdfs:label xml:lang="en-US">triggers</rdfs:label>
    <rdfs:label xml:lang="de">verursacht</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Stimulus process that can trigger one or more response processes realizing a realizable entity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stimulusprozess, der einen oder mehrere Reaktionsprozesse auslösen kann, die eine realisierbare Entität realisieren</iof-av:naturalLanguageDefinition>
    <skos:example xml:lang="en-US">A UV exposure process triggers a photodegradation reaction in a polymer specimen.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities/Reaction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <owl:equivalentClass rdf:nodeID="N041830307049471ea9ce57124d713709"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <rdfs:label xml:lang="de">Reaktion</rdfs:label>
    <rdfs:label xml:lang="en-US">reaction</rdfs:label>
    <skos:altLabel xml:lang="de">Antwort</skos:altLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Reaction represents a process resulting in a realizable entity being realized in response to an action</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Reaktion stellt einen Prozess dar, der zu einem realisierbaren Wesen führt, das als Antwort auf eine Aktion realisiert wird</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en-US">Reaction(x) ↔ ∃b (Action(b) ∧ isTriggeredBy(x, b))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-US">every instance of 'reaction' is defined as exactly that 'isTriggeredBy' some 'action'</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202507/qualities/Qualities/"/>
    <owl:versionInfo>202507</owl:versionInfo>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202301/AboutIOFProd/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/202301/core/meta/AnnotationVocabulary/"/>
    <dcterms:abstract xml:lang="en-US">The IOF (common) Quality Ontology is an architectural construct allowing separate Quality ontologies for different domains e.g., Physical, Chemical, Biological, etc.
        This ontology also contains those qualities that may be considered 'common'.</dcterms:abstract>
    <dcterms:contributor xml:lang="en-us">Thomas Hanke, Fraunhofer IWM</dcterms:contributor>
    <dcterms:creator xml:lang="en-us">IOF Materials Working Group</dcterms:creator>
    <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
    <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
    <dcterms:references rdf:resource="http://spec.org/dc/terms/"/>
    <dcterms:references rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    <dcterms:title xml:lang="en-US">Industrial Ontology Foundry (IOF) Qualities Ontology (Base)</dcterms:title>
    <rdfs:label xml:lang="en-US">Qualities Ontology (base)</rdfs:label>
    <iof-av:copyright xml:lang="en-US">Industrial Ontology Foundry (IOF)</iof-av:copyright>
    <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N85b6e998e5314d2986f1450e5a7bb1f4">
    <rdf:first rdf:nodeID="N8642492d19844cc9ad2e59fdde64b0e9"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nff4fbda3a37d480e9cb574096ad1eb4a">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="N85cf6b22901842b18f02194182062e84"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities/Action">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <owl:equivalentClass rdf:nodeID="Nec07118e6b074da69ab1779c27716952"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <rdfs:label xml:lang="de">Aktion</rdfs:label>
    <rdfs:label xml:lang="en-US">action</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Action is a process introducing a change as a response or interaction in a participating material entity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Aktion ist ein Prozess, der eine Veränderung als Reaktion oder Interaktion in einer beteiligten materiellen Einheit herbeiführt</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en-US">Action(x) ↔ (∃b ((obo:BFO_0000040(b) ∧ ∃c (obo:BFO_0000145(c) ∧ hasQuality(b, c))) ∧ obo:BFO_0000057(x, b)) ∨ ∃d (iof-core:ProcessCharacteristic(d) ∧ hasProcessCharacteristic(x, d)))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-US">every instance of 'action' is defined as exactly an instance of 'that 'obo:BFO_0000057' some an instance of 'BFO_0000040' and that 'hasQuality' some 'BFO_0000145'' or 'that 'hasProcessCharacteristic' some 'ProcessCharacteristic''</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities/SpatialRelationalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
    <rdfs:label xml:lang="de">räumliche Relationsqualität</rdfs:label>
    <rdfs:label xml:lang="en-US">spatial relational quality</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Spatial relational quality is a quality that inheres in a material entity by virtue of its spatial relationship to one or more other entities, such as position, orientation, or distance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Räumliche Beziehungsqualität ist eine Qualität, die einer materiellen Entität aufgrund ihrer räumlichen Beziehung zu einer oder mehreren anderen Entitäten, wie z. B. Position, Ausrichtung oder Entfernung, innewohnt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'spatial relational quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000145'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000145(x) ← SpatialRelationalQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;spatial relational quality&apos; then x is a &apos;b f o_0000145&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the distance between a bolt and the nearest edge of a steel plate is a spatial relational quality of the bolt</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N85cf6b22901842b18f02194182062e84">
    <rdf:first rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
    <rdf:rest rdf:nodeID="Ne42916362cd44a5ca5b8ab22b3b3e50e"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N041830307049471ea9ce57124d713709">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/isTriggeredBy"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Action"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities/isTriggeredBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/triggers"/>
    <rdfs:label xml:lang="de">ausgelöst durch</rdfs:label>
    <rdfs:label xml:lang="en-US">is triggered by</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">inverse if triggers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Inverse von 'verursacht': Reaktionsprozess, der durch einen Stimulusprozess ausgelöst wird</iof-av:naturalLanguageDefinition>
    <skos:example xml:lang="en-US">A photodegradation reaction is triggered by a UV exposure process.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nec07118e6b074da69ab1779c27716952">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="N4d391631cdf44bb08921d5d6a9b88c62"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities/ToBeReviewed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <rdfs:label xml:lang="de">zu überprüfen</rdfs:label>
    <rdfs:label xml:lang="en-US">to be reviewed</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Temporary class used to hold constructs that have been identified but require additional review before formal classification</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Temporäre Klasse, die zum Speichern von Konstrukten verwendet wird, die identifiziert wurden, aber vor der formalen Klassifizierung einer zusätzlichen Überprüfung bedürfen</iof-av:naturalLanguageDefinition>
    <skos:note xml:lang="en-US">This is a temporary class to hold those constructs that need additional review.</skos:note>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'to be reviewed' have not yet been formalized. This is a temporary staging class and will be removed or replaced once its contents are formally classified.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Quality(x) ← ToBeReviewed(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;to be reviewed&apos; then x is a &apos;quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">a candidate term for a new quality class that has not yet been formally classified or validated</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N8642492d19844cc9ad2e59fdde64b0e9">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasProcessCharacteristic"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/ProcessCharacteristic"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities/DimensionQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="de">Dimensionsqualität</rdfs:label>
    <rdfs:label xml:lang="en-US">dimension quality</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Dimension quality is a quality of a material entity that pertains to its measurable spatial extent, such as length, area, or volume</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Dimensionsqualität ist eine Qualität einer materiellen Einheit, die sich auf ihre messbare räumliche Ausdehnung bezieht, beispielsweise Länge, Fläche oder Volumen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'dimension quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000019'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000019(x) ← DimensionQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;dimension quality&apos; then x is a &apos;b f o_0000019&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">the wall thickness of a steel pipe is a dimension quality determining its pressure resistance</skos:example>
  </rdf:Description>
