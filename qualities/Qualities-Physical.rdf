    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticAbsorptionCoefficient -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticAbsorptionCoefficient">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Schallabsorptionskoeffizient</rdfs:label>
        <rdfs:label xml:lang="en-us">acoustic absorption coefficient</rdfs:label>
        <skos:example xml:lang="en-us">A 50 mm mineral wool panel achieves an acoustic absorption coefficient of 0.9 at 1000 Hz</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000505"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">AcousticCapability(x) ← AcousticAbsorptionCoefficient(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Acoustic absorption coefficient is an acoustic capability of a material that manifests as the fraction of incident sound energy absorbed per unit area when sound waves interact with the material</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der akustische Absorptionskoeffizient ist eine akustische Fähigkeit eines Materials, die sich als Anteil der einfallenden Schallenergie manifestiert, die pro Flächeneinheit absorbiert wird, wenn Schallwellen mit dem Material interagieren</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;acoustic absorption coefficient&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;acoustic capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000505.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;acoustic absorption coefficient&apos; then x is a &apos;acoustic capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">acoustic capability</rdfs:label>
        <rdfs:label xml:lang="de">akustische Fähigkeit</rdfs:label>
        <skos:example xml:lang="en-us">A piezoelectric transducer has the acoustic capability to emit ultrasound at frequencies up to 10 MHz</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalCapability(x) ← AcousticCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Acoustic capability entails realization through an entity related to sound interaction</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Akustische Fähigkeiten erfordern die Realisierung durch eine Einheit, die mit der Klanginteraktion zusammenhängt</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;acoustic capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;acoustic capability&apos; then x is a &apos;physical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticQuality">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">acoustic quality</rdfs:label>
        <rdfs:label xml:lang="de">akustische Qualität</rdfs:label>
        <skos:example xml:lang="en-us">The acoustic quality of a concert hall material is characterized by its absorption and reflection coefficients</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← AcousticQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Acoustic quality pertains to properties related to sound or the science of sound, including aspects like pitch, volume, tone, timbre, echo, absorption, or sound wave propagation</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Akustische Qualität bezieht sich auf Eigenschaften, die mit Klang oder der Klangwissenschaft in Zusammenhang stehen, einschließlich Aspekten wie Tonhöhe, Lautstärke, Ton, Klangfarbe, Echo, Absorption oder Schallwellenausbreitung</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;acoustic quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;acoustic quality&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ActivityThermodynamic -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ActivityThermodynamic">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">activity (thermodynamic)</rdfs:label>
        <rdfs:label xml:lang="de">thermodynamische Aktivität</rdfs:label>
        <skos:example xml:lang="en-us">In a dilute NaCl solution the activity of Na+ ions deviates from its molar concentration due to ion-ion interactions</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020161"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← ActivityThermodynamic(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Activity (thermodynamic) is a thermo dynamic quality that inheres between a chemical species and a solution and represents the effective concentration of the species accounting for particle interactions</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Aktivität (Thermodynamik) ist eine thermodynamische Qualität, die zwischen einer chemischen Spezies und einer Lösung innewohnt und die effektive Konzentration der Spezies darstellt, die für Partikelwechselwirkungen verantwortlich ist</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;activity (thermodynamic)&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020161.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;activity (thermodynamic)&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Adhesion -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Adhesion">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pressure"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Adhäsion</rdfs:label>
        <rdfs:label xml:lang="en-us">adhesion</rdfs:label>
        <skos:example xml:lang="en-us">The adhesion between a paint film and a steel substrate determines its resistance to delamination</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Pressure(x) ← Adhesion(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Adhesion describes the ability of substances to bind to each other, involving attractive force between two bodies of different substances in contact and influencing material performance in scientific and industrial contexts</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Adhäsion beschreibt die Fähigkeit von Substanzen, sich aneinander zu binden. Dabei handelt es sich um eine Anziehungskraft zwischen zwei in Kontakt stehenden Körpern unterschiedlicher Substanzen, die die Materialleistung in wissenschaftlichen und industriellen Kontexten beeinflusst</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;adhesion&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;pressure&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;adhesion&apos; then x is a &apos;pressure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AdhesionStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AdhesionStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Haftfestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">adhesion strength</rdfs:label>
        <skos:altLabel xml:lang="en-us">Adhesive Strength</skos:altLabel>
        <skos:altLabel xml:lang="de">Klebkraft</skos:altLabel>
        <skos:example xml:lang="en-us">An epoxy adhesive joint on steel substrates has an adhesion strength of 20 MPa in lap shear testing</skos:example>
        <skos:prefLabel xml:lang="en-us">Adhesion Strength</skos:prefLabel>
        <skos:prefLabel xml:lang="de">Haftfestigkeit</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strength(x) ← AdhesionStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Adhesion strength measures the force required to separate two surfaces bonded together</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Haftfestigkeit ist das Maß für die Kraft, die erforderlich ist, um zwei miteinander verbundene Oberflächen zu trennen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;adhesion strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;adhesion strength&apos; then x is a &apos;strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AggregateState -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AggregateState">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Aggregatzustand</rdfs:label>
        <rdfs:label xml:lang="en-us">aggregate state</rdfs:label>
        <skos:example xml:lang="en-us">At room temperature, mercury is in the liquid aggregate state, unlike most metals</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000512"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← AggregateState(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Aggregate state is a thermo dynamic quality of a material entity that represents its physical state of matter, such as solid, liquid, or gaseous</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Aggregatzustand ist eine thermodynamische Eigenschaft einer materiellen Einheit, die den physikalischen Zustand der Materie darstellt, beispielsweise fest, flüssig oder gasförmig</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;aggregate state&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000512.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;aggregate state&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AgingTemperature -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AgingTemperature">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Temperature"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="de">Alterungstemperatur</rdfs:label>
        <rdfs:label xml:lang="en-us">aging temperature</rdfs:label>
        <skos:example xml:lang="en-us">Al-Cu alloys are artificially aged at 175 C to precipitate strengthening phases</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Temperature(x) ← AgingTemperature(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Aging temperature refers to variable temperature during an aging process depending on the desired deposition formations</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Unter Alterungstemperatur versteht man die variable Temperatur während eines Alterungsprozesses in Abhängigkeit von der gewünschten Ablagerungsbildung</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;aging temperature&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;temperature&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;aging temperature&apos; then x is a &apos;temperature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Angle -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Angle">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/SpatialRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Winkel</rdfs:label>
        <rdfs:label xml:lang="en-us">angle</rdfs:label>
        <skos:example xml:lang="en-us">The twist angle of a torsion bar under rated torque is 5 degrees</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Angle"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">SpatialRelationalQuality(x) ← Angle(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">In Euclidean geometry, angle refers to the figure formed by two rays sharing a common endpoint, called the vertex of the angle</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">In der euklidischen Geometrie bezieht sich der Winkel auf die Figur, die von zwei Strahlen gebildet wird, die einen gemeinsamen Endpunkt haben, der als Scheitelpunkt des Winkels bezeichnet wird</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;angle&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;SpatialRelationalQuality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Angle.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;angle&apos; then x is a &apos;spatial relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AnteriorPosteriorDiameter -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AnteriorPosteriorDiameter">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Diameter"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Antero Posteraler Durchmesser</rdfs:label>
        <rdfs:label xml:lang="en-us">anterior-posterior diameter</rdfs:label>
        <skos:example xml:lang="en-us">The anterior-posterior diameter of a cylindrical bone implant is 12 mm as measured by CT imaging</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002041"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Diameter(x) ← AnteriorPosteriorDiameter(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Anterior-posterior diameter characterizes the diameter along the anterior-posterior axis</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der anterior-posteriore Durchmesser charakterisiert den Durchmesser entlang der anterior-posterioren Achse</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;anterior-posterior diameter&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;diameter&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002041.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;anterior-posterior diameter&apos; then x is a &apos;diameter&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Area -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Area">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/DimensionQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Fläche</rdfs:label>
        <rdfs:label xml:lang="en-us">area</rdfs:label>
        <skos:example xml:lang="en-us">The cross-sectional area of a tensile specimen at the gauge section is 50 mm2</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001323"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">DimensionQuality(x) ← Area(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Area signifies a 2-D extent quality inhering by virtue of the bearer&apos;s two-dimensional extent</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Fläche bedeutet eine zweidimensionale Ausdehnungsqualität, die aufgrund der zweidimensionalen Ausdehnung des Trägers inhärent ist</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;area&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;DimensionQuality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001323.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;area&apos; then x is a &apos;dimension quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AtomicMass -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AtomicMass">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Mass"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Atommasse</rdfs:label>
        <rdfs:label xml:lang="en-us">atomic mass</rdfs:label>
        <skos:example xml:lang="en-us">The atomic mass of carbon-12 is exactly 12 u by definition of the atomic mass unit</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Atomic_mass"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Mass(x) ← AtomicMass(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Atomic mass refers to the mass of an atom, often expressed in the non-SI unit dalton, where 1 Da is defined as 1/12 of the mass of a free carbon-12 atom at rest in its ground state</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Atommasse bezieht sich auf die Masse eines Atoms, oft ausgedrückt in der Nicht-SI-Einheit Dalton, wobei 1 Da als 1/12 der Masse eines freien Kohlenstoff-12-Atoms im Ruhezustand in seinem Grundzustand definiert ist</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;atomic mass&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mass&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Atomic_mass.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;atomic mass&apos; then x is a &apos;mass&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AutoIgnitionTemperature -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AutoIgnitionTemperature">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Selbstzündungstemperatur</rdfs:label>
        <rdfs:label xml:lang="en-us">auto-ignition temperature</rdfs:label>
        <skos:altLabel xml:lang="de">Zündtemperatur</skos:altLabel>
        <skos:altLabel xml:lang="en-us">spontaneous ignition temperature</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← AutoIgnitionTemperature(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Auto-ignition temperature is a thermodynamic quality of a substance that specifies the lowest temperature at which it spontaneously ignites in a normal atmosphere without an external ignition source</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Selbstzündungstemperatur ist eine thermodynamische Qualität eines Stoffes, die die niedrigste Temperatur angibt, bei der er sich in normaler Atmosphäre ohne externe Zündquelle selbst entzündet</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;auto-ignition temperature&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;auto-ignition temperature&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">T_AIT</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BandGap -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BandGap">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Bandlücke</rdfs:label>
        <rdfs:label xml:lang="en-us">band gap</rdfs:label>
        <skos:example xml:lang="en-us">Silicon has a band gap of 1.12 eV at room temperature, making it suitable for photovoltaic applications</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090002"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalQuality(x) ← BandGap(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Band gap is an electrical quality of a material that specifies the energy range between the valence band and the conduction band in which no electron states exist</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Bandlücke ist eine elektrische Eigenschaft eines Materials, die den Energiebereich zwischen dem Valenzband und dem Leitungsband angibt, in dem keine Elektronenzustände existieren</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;band gap&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0090002.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;band gap&apos; then x is a &apos;electrical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Birefringence -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Birefringence">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Doppelbrechung</rdfs:label>
        <rdfs:label xml:lang="en-us">birefringence</rdfs:label>
        <skos:altLabel xml:lang="de">Zweistrahl-Brechung</skos:altLabel>
        <skos:altLabel xml:lang="en-us">double refraction</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← Birefringence(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Birefringence is a physical relational quality of an optically anisotropic material that specifies the difference in refractive indices along two principal optical axes, causing incident light to split into two rays with different velocities</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Doppelbrechung ist eine physikalische relationale Qualität eines optisch anisotropen Materials, die die Differenz der Brechungsindizes entlang zweier optischer Hauptachsen angibt und bewirkt, dass einfallendes Licht in zwei Strahlen mit unterschiedlichen Geschwindigkeiten aufgespalten wird</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;birefringence&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;birefringence&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">Δn</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BoilingPoint -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BoilingPoint">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Siedepunkt</rdfs:label>
        <rdfs:label xml:lang="en-us">boiling point</rdfs:label>
        <skos:example xml:lang="en-us">Water has a boiling point of 100 C at 1 atm, above which it transitions to vapor</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000535"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← BoilingPoint(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Boiling point is a thermo dynamic quality of a substance that specifies the temperature at which it transitions from liquid to gaseous state at a given pressure</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Siedepunkt ist eine thermodynamische Eigenschaft einer Substanz, die die Temperatur angibt, bei der sie bei einem bestimmten Druck vom flüssigen in den gasförmigen Zustand übergeht</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;boiling point&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000535.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;boiling point&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BreakingStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BreakingStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Toughness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Bruchfestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">breaking strength</rdfs:label>
        <skos:altLabel xml:lang="de">Bruchspannung</skos:altLabel>
        <skos:altLabel xml:lang="en-us">fracture stress</skos:altLabel>
        <skos:altLabel xml:lang="en-us">strength at break</skos:altLabel>
        <skos:altLabel xml:lang="en-us">stress at break</skos:altLabel>
        <skos:example xml:lang="en-us">A carbon fiber tow fractures at a breaking strength of 4900 MPa in a tensile test</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Fracture"/>
        <iof-av:firstOrderLogicDefinition xml:lang="en-us">BreakingStrength(x) ↔ Toughness(x) ∧ ∃b∃p∃i(obo:BFO_0000040(b) ∧ MeasurementProcess(p) ∧ MeasurementInformationContentEntity(i) ∧ bearerOf(b, x) ∧ describes(i, x) ∧ isOutputOf(i, p) ∧ ∃t(TimeOfBreak(t) ∧ occupiesTemporalRegion(p, t)))</iof-av:firstOrderLogicDefinition>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Breaking strength is a toughness quality of a specimen that denotes the stress at which the specimen fails via fracture, recorded as the final point on a stress-strain curve</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Bruchfestigkeit ist eine Zähigkeitsqualität einer Probe, die die Spannung angibt, bei der die Probe durch Bruch versagt, aufgezeichnet als Endpunkt auf einer Spannungs-Dehnungs-Kurve</iof-av:naturalLanguageDefinition>
        <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-us">every instance of &apos;breaking strength&apos; is defined as exactly an instance of &apos;toughness&apos; that inheres in some &apos;material entity&apos;, and there exists a &apos;measurement information content entity&apos; that &apos;describes&apos; it, which &apos;is output of&apos; some &apos;measurement process&apos; that &apos;occupies temporal region&apos; some &apos;time of break&apos;</iof-av:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BrinellHardness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BrinellHardness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/IndentationHardness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">Brinell hardness</rdfs:label>
        <rdfs:label xml:lang="de">Brinellhärte</rdfs:label>
        <skos:example xml:lang="en-us">Annealed copper has a Brinell hardness of 35 HB, measured using a 10 mm ball and 500 kg load</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000537"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">IndentationHardness(x) ← BrinellHardness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Brinell hardness is an indentation hardness of a material that specifies its resistance to indentation as measured by pressing a hardened steel or carbide ball indenter under a specified load</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Brinell-Härte ist die Eindruckhärte eines Materials, die den Widerstand gegen Eindrücke angibt, gemessen durch Drücken eines Eindringkörpers aus gehärtetem Stahl oder Hartmetall unter einer bestimmten Last</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;Brinell hardness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;indentation hardness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000537.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;brinell hardness&apos; then x is a &apos;indentation hardness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Brittleness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Brittleness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Sprödigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">brittleness</rdfs:label>
        <skos:altLabel xml:lang="de">Zerbrechlichkeit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">fragility</skos:altLabel>
        <skos:example xml:lang="en-us">Cast iron has high brittleness, fracturing without measurable plastic deformation under tensile loading</skos:example>
        <skos:prefLabel xml:lang="de">Sprödigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">brittleness</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalCapability(x) ← Brittleness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Opposite to toughness, brittleness is the property of being easily broken or damaged</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Sprödigkeit ist die Eigenschaft, leicht zu brechen oder zu beschädigen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;brittleness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;brittleness&apos; then x is a &apos;mechanical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BulkModulus -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BulkModulus">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Kompressionsmodul</rdfs:label>
        <rdfs:label xml:lang="en-us">bulk modulus</rdfs:label>
        <skos:altLabel xml:lang="de">Kompressionsmodul</skos:altLabel>
        <skos:example xml:lang="en-us">Water has a bulk modulus of 2.2 GPa, resisting compression under high hydrostatic pressure</skos:example>
        <skos:prefLabel xml:lang="en-us">bulk modulus</skos:prefLabel>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Bulk_modulus"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Stiffness(x) ← BulkModulus(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Bulk modulus is a measure of the resistance of a substance to bulk compression, defined as the ratio of infinitesimal pressure increase to relative volume decrease</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Volumenmodul ist ein Maß für den Widerstand einer Substanz gegenüber Massenkompression, definiert als das Verhältnis von verschwindend geringem Druckanstieg zur relativen Volumenabnahme</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;bulk modulus&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;stiffness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Bulk_modulus.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;bulk modulus&apos; then x is a &apos;stiffness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ChemicalPotential -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ChemicalPotential">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">chemical potential</rdfs:label>
        <rdfs:label xml:lang="de">chemisches Potential</rdfs:label>
        <skos:example xml:lang="en-us">The chemical potential of water vapor decreases with humidity, driving evaporation from a wet surface into dry air</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000553"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← ChemicalPotential(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Chemical potential is a thermo dynamic quality of a thermodynamic system that describes the change in energy associated with the addition of a small quantity of a substance at constant temperature and pressure</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Das chemische Potenzial ist eine thermodynamische Qualität eines thermodynamischen Systems, die die Energieänderung beschreibt, die mit der Zugabe einer kleinen Menge einer Substanz bei konstanter Temperatur und konstantem Druck verbunden ist</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;chemical potential&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000553.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;chemical potential&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Circumference -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Circumference">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Perimeter"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Kreisumfang</rdfs:label>
        <rdfs:label xml:lang="en-us">circumference</rdfs:label>
        <skos:example xml:lang="en-us">A wire of 2 mm diameter has a circumference of 6.28 mm</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001648"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Perimeter(x) ← Circumference(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Circumference characterizes a 1-D extent equal to the length of the closed curve of a circle</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Umfang charakterisiert eine eindimensionale Ausdehnung, die der Länge der geschlossenen Kurve eines Kreises entspricht</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;circumference&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;perimeter&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001648.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;circumference&apos; then x is a &apos;perimeter&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ClampingPressure -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ClampingPressure">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pressure"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="de">Klemmdruck</rdfs:label>
        <rdfs:label xml:lang="en-us">clamping pressure</rdfs:label>
        <skos:example xml:lang="en-us">A hydraulic fixture applies a clamping pressure of 5 MPa to hold a workpiece during machining</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Pressure(x) ← ClampingPressure(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Clamping pressure describes the force per area used during the mounting process of a sample, typically involving grips or similar tools</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Klemmdruck ist die Eigenschaft, die als quantitativer Wert die Kraft pro Fläche beschreibt, die beim Einbau einer Probe, eines Prüfkörpers oder eines Prüfstücks aufgebracht wird, typischerweise verbunden mit einer Art von Klemm- oder Spannzubehör</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;clamping pressure&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;pressure&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;clamping pressure&apos; then x is a &apos;pressure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CoefficientOfFriction -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CoefficientOfFriction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Reibungskoeffizient</rdfs:label>
        <rdfs:label xml:lang="en-us">coefficient of friction</rdfs:label>
        <skos:altLabel xml:lang="de">Reibwert</skos:altLabel>
        <skos:altLabel xml:lang="en-us">friction coefficient</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← CoefficientOfFriction(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Coefficient of friction is a dimensionless scalar quality of a pair of surfaces in contact that expresses the ratio of the friction force between them to the normal force pressing them together</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Reibungskoeffizient ist eine dimensionslose skalare Qualität eines Paars in Kontakt stehender Oberflächen, die das Verhältnis der Reibungskraft zwischen ihnen zur Normalkraft ausdrückt, die sie zusammendrückt</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;coefficient of friction&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;coefficient of friction&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">μ</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Coercivity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Coercivity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Koerzitivfeldstärke</rdfs:label>
        <rdfs:label xml:lang="en-us">coercivity</rdfs:label>
        <skos:altLabel xml:lang="de">Koerzitivkraft</skos:altLabel>
        <skos:altLabel xml:lang="en-us">coercive field</skos:altLabel>
        <skos:altLabel xml:lang="en-us">coercive force</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MagneticQuality(x) ← Coercivity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Coercivity is a magnetic quality of a ferromagnetic material that specifies the magnitude of the applied magnetic field required to reduce its magnetization to zero after it has been fully magnetised</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Koerzitivfeldstärke ist eine magnetische Qualität eines ferromagnetischen Materials, die die Stärke des aufzubringenden Magnetfelds angibt, das erforderlich ist, um seine Magnetisierung nach vollständiger Magnetisierung auf null zu reduzieren</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;coercivity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;magnetic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;coercivity&apos; then x is a &apos;magnetic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">H_c</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ComplexModulus -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ComplexModulus">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscoelasticity"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Komplexmodul</rdfs:label>
        <rdfs:label xml:lang="en-us">complex modulus</rdfs:label>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Viscoelasticity(x) ← ComplexModulus(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Complex modulus is a viscoelastic quality of a material that represents the total stiffness response under oscillatory loading as a complex number, comprising the storage modulus as the real part and the loss modulus as the imaginary part</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Komplexmodul ist eine viskoelastische Qualität eines Materials, die die gesamte Steifigkeitsantwort unter schwingender Belastung als komplexe Zahl darstellt, bestehend aus dem Speichermodul als Realteil und dem Verlustmodul als Imaginärteil</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;complex modulus&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;viscoelasticity&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;complex modulus&apos; then x is a &apos;viscoelasticity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">E*</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CompressiveStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CompressiveStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BreakingStrength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Druckfestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">compressive strength</rdfs:label>
        <skos:example xml:lang="en-us">Compressive strength of a concrete specimen measured as 30 MPa according to ISO 4012 test conditions.</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">BreakingStrength(x) ← CompressiveStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Compressive strength is the maximum stress a material can withstand under uniaxial compressive loading before failure</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Druckfestigkeit ist die maximale Spannung, die ein Material unter einachsiger Druckbelastung vor dem Versagen widerstehen kann</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;compressive strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;breaking strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;compressive strength&apos; then x is a &apos;breaking strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ContactAngle -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ContactAngle">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Kontaktwinkel</rdfs:label>
        <rdfs:label xml:lang="en-us">contact angle</rdfs:label>
        <skos:altLabel xml:lang="de">Benetzungswinkel</skos:altLabel>
        <skos:altLabel xml:lang="en-us">wetting angle</skos:altLabel>
        <skos:example xml:lang="en-us">A hydrophobic polymer coating shows a water contact angle of 110 degrees, indicating poor wettability</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← ContactAngle(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Contact angle is a physical relational quality of a solid surface that quantifies the angle formed at the three-phase contact line between a liquid droplet, the solid surface, and the surrounding gas phase, characterizing the wettability of the surface by the liquid</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Kontaktwinkel ist eine physikalische relationale Qualität einer festen Oberfläche, die den Winkel an der Dreiphasengrenzlinie zwischen einem Flüssigkeitstropfen, der festen Oberfläche und der umgebenden Gasphase beschreibt und die Benetzbarkeit der Oberfläche durch die Flüssigkeit charakterisiert</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;contact angle&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;contact angle&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">θ</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CoolingCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CoolingCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Abkühlfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">cooling capability</rdfs:label>
        <skos:example xml:lang="en-us">A heat pipe cooling system has a cooling capability of 150 W at a junction temperature below 85 C</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← CoolingCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Cooling capability refers to a material artifact&apos;s ability to cause temperature decrease in another material entity</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Kühlfähigkeit bezieht sich auf die Fähigkeit eines Materialartefakts, einen Temperaturabfall in einem anderen Materialgebilde zu verursachen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;cooling capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;cooling capability&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepModulus -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepModulus">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscoelasticity"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Kriechmodul</rdfs:label>
        <rdfs:label xml:lang="en-us">creep modulus</rdfs:label>
        <skos:example xml:lang="en-us">The creep modulus of polyethylene at 50 C and 1 MPa after 1000 hours is 200 MPa</skos:example>
        <skos:prefLabel xml:lang="de">Kriechmodul</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">creep modulus</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Viscoelasticity(x) ← CreepModulus(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Creep modulus measures a material&apos;s viscoelasticity, indicating its ability to deform under stress over time</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Kriechmodul ist ein Maß für die Viskoelastizität eines Materials, das seine Fähigkeit zur Verformung unter Belastung im Laufe der Zeit beschreibt</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;creep modulus&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;viscoelasticity&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;creep modulus&apos; then x is a &apos;viscoelasticity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepResistance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepResistance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Durability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Kriechfestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">creep resistance</rdfs:label>
        <skos:altLabel xml:lang="en-us">Creep Resistant</skos:altLabel>
        <skos:altLabel xml:lang="de">Kriechfestig</skos:altLabel>
        <skos:example xml:lang="en-us">Nickel superalloys have high creep resistance, maintaining shape under stress at 1000 C in turbine blades</skos:example>
        <skos:prefLabel xml:lang="en-us">Creep Resistance</skos:prefLabel>
        <skos:prefLabel xml:lang="de">Kriechfestigkeit</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Durability(x) ← CreepResistance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Creep resistance is the ability of a material to resist deformation under load over time</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Kriechfestigkeit ist die Fähigkeit eines Materials, unter Last über einen bestimmten Zeitraum eine Deformation zu widerstehen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;creep resistance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;durability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;creep resistance&apos; then x is a &apos;durability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepStrain -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepStrain">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Kriechverformung</rdfs:label>
        <rdfs:label xml:lang="en-us">creep strain</rdfs:label>
        <skos:altLabel xml:lang="de">Kriechbeanspruchung</skos:altLabel>
        <skos:altLabel xml:lang="en-us">creeping strain</skos:altLabel>
        <skos:example xml:lang="en-us">A nickel alloy turbine blade accumulates 0.5 % creep strain after 10000 hours at 900 C</skos:example>
        <skos:prefLabel xml:lang="de">Kriechverformung</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">creep strain</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strain(x) ← CreepStrain(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Creep strain occurs when a material is subjected to constant stress over a long period of time</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Eine Kriechverformung tritt auf, wenn ein Material einer konstanten Belastung über einen langen Zeitraum ausgesetzt ist</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;creep strain&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strain&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;creep strain&apos; then x is a &apos;strain&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepStress -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepStress">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stress"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="de">Kriechspannung</rdfs:label>
        <rdfs:label xml:lang="en-us">creep stress</rdfs:label>
        <skos:example xml:lang="en-us">A polymer gasket under a creep stress of 5 MPa at 60 C relaxes significantly over 1000 hours</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Stress(x) ← CreepStress(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Creep stress is characterized by strain occurring with time when a constant force is applied to a physical body</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Unter Kriechspannung versteht man eine Belastung, die mit der Zeit auftritt, wenn eine konstante Kraft auf einen physischen Körper ausgeübt wird</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;creep stress&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;stress&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;creep stress&apos; then x is a &apos;stress&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CriticalPressure -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CriticalPressure">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">critical pressure</rdfs:label>
        <rdfs:label xml:lang="de">kritischer Druck</rdfs:label>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← CriticalPressure(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Critical pressure is a thermodynamic quality of a pure substance that specifies the minimum pressure required to liquefy the substance at its critical temperature</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Kritischer Druck ist eine thermodynamische Qualität einer reinen Substanz, die den Mindestdruck angibt, der erforderlich ist, um die Substanz bei ihrer kritischen Temperatur zu verflüssigen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;critical pressure&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;critical pressure&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">p_c</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CriticalTemperature -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CriticalTemperature">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">critical temperature</rdfs:label>
        <rdfs:label xml:lang="de">kritische Temperatur</rdfs:label>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← CriticalTemperature(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Critical temperature is a thermodynamic quality of a pure substance that specifies the temperature above which the substance cannot exist as a liquid regardless of applied pressure</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Kritische Temperatur ist eine thermodynamische Qualität einer reinen Substanz, die die Temperatur angibt, oberhalb derer die Substanz unabhängig vom aufgebrachten Druck nicht als Flüssigkeit existieren kann</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;critical temperature&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;critical temperature&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">T_c</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CurieTemperature -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CurieTemperature">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">Curie temperature</rdfs:label>
        <rdfs:label xml:lang="de">Curie-Temperatur</rdfs:label>
        <skos:altLabel xml:lang="en-us">Curie point</skos:altLabel>
        <skos:altLabel xml:lang="de">Curie-Punkt</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← CurieTemperature(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Curie temperature is a thermodynamic quality of a ferromagnetic material that specifies the temperature above which it loses its permanent magnetic ordering and becomes paramagnetic</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Curie-Temperatur ist eine thermodynamische Qualität eines ferromagnetischen Materials, die die Temperatur angibt, oberhalb derer das Material seine permanente magnetische Ordnung verliert und paramagnetisch wird</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;Curie temperature&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;Curie temperature&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">T_C</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Deformation -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Deformation">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalQuality"/>
        <obo:IAO_0000116 xml:lang="en-us">excludes any rigid body motion</obo:IAO_0000116>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Verformung</rdfs:label>
        <rdfs:label xml:lang="en-us">deformation</rdfs:label>
        <skos:example xml:lang="en-us">Under a compressive load, a foam pad undergoes 10 mm of deformation before reaching densification</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Deformation_(physics)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalQuality(x) ← Deformation(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Deformation refers to the change in shape or size of an object, quantified as the residual displacement of particles in a non-rigid body, excluding average translation and rotation</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Unter Verformung versteht man die Änderung der Form oder Größe eines Objekts, quantifiziert als verbleibende Verschiebung von Partikeln in einem nicht starren Körper, ohne durchschnittliche Translation und Rotation</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;deformation&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Deformation_(physics).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;deformation&apos; then x is a &apos;mechanical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DeformationSpeed -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DeformationSpeed">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Speed"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Deformationsgeschwindigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">deformation speed</rdfs:label>
        <skos:altLabel xml:lang="de">Dehnrate</skos:altLabel>
        <skos:altLabel xml:lang="en-us">strain rate</skos:altLabel>
        <skos:example xml:lang="en-us">During high-rate forming, the deformation speed of the punch reaches 10 m/s</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Strain_rate"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Speed(x) ← DeformationSpeed(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Deformation speed measures the rate at which distances of adjacent material parcels change with time near a specific point, including expansion and shear rates</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Verformungsgeschwindigkeit misst die Geschwindigkeit, mit der sich die Abstände benachbarter Materialpakete in der Nähe eines bestimmten Punktes im Laufe der Zeit ändern, einschließlich Expansions- und Schergeschwindigkeiten</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;deformation speed&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;speed&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Strain_rate.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;deformation speed&apos; then x is a &apos;speed&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DendriticFieldSize -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DendriticFieldSize">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Volume"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Dendritische Feldgröße</rdfs:label>
        <rdfs:label xml:lang="en-us">dendritic field size</rdfs:label>
        <skos:example xml:lang="en-us">A rapidly solidified Al alloy has a dendritic field size of 20 µm, reflecting the cooling rate</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0070064"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Volume(x) ← DendriticFieldSize(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Dendritic field size characterizes a 3-D extent defined by the maximal span of a dendritic arbor</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Größe des dendritischen Feldes charakterisiert eine dreidimensionale Ausdehnung, die durch die maximale Spannweite eines dendritischen Dorns definiert wird</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;dendritic field size&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;volume&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0070064.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;dendritic field size&apos; then x is a &apos;volume&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Dichte</rdfs:label>
        <rdfs:label xml:lang="en-us">density</rdfs:label>
        <skos:example xml:lang="en-us">Titanium alloy Ti-6Al-4V has a density of 4430 kg/m3, about half that of steel</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000597"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← Density(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Density, or specific mass, is a substance&apos;s mass per unit of volume, typically denoted by ρ, defined as mass divided by volume: ρ = m / V</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Dichte oder spezifische Masse ist die Masse eines Stoffes pro Volumeneinheit, typischerweise bezeichnet mit ρ, definiert als Masse dividiert durch Volumen: ρ = m / V</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;density&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;density&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <AnnotationVocabulary1:naturalLanguageDefinition xml:lang="en-us">Density, or specific mass, is a substance&apos;s mass per unit of volume, typically denoted by ρ, defined as mass divided by volume: ρ = m / V</AnnotationVocabulary1:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
        <owl:annotatedTarget xml:lang="en-us">Density, or specific mass, is a substance&apos;s mass per unit of volume, typically denoted by ρ, defined as mass divided by volume: ρ = m / V</owl:annotatedTarget>
        <iof-av:directSource>https://en.wikipedia.org/wiki/Density</iof-av:directSource>
    </owl:Axiom>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Depth -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Depth">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Tiefe</rdfs:label>
        <rdfs:label xml:lang="en-us">depth</rdfs:label>
        <skos:example xml:lang="en-us">The weld penetration depth is 4 mm, fully fusing both steel plates</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001595"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Length(x) ← Depth(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Depth characterizes a 1-D extent measured from the front to the back, or inward, distinguishing it from width and length</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Tiefe charakterisiert eine eindimensionale Ausdehnung, gemessen von vorne nach hinten oder nach innen, und unterscheidet sie von Breite und Länge</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;depth&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;length&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001595.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;depth&apos; then x is a &apos;length&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Diameter -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Diameter">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Durchmesser</rdfs:label>
        <rdfs:label xml:lang="en-us">diameter</rdfs:label>
        <skos:example xml:lang="en-us">A standard M12 bolt has a nominal diameter of 12 mm</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001334"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Length(x) ← Diameter(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Durchmesser ist eine Längenqualität, die jedem geraden Liniensegment entspricht, das durch den Mittelpunkt eines Kreises verläuft und dessen Endpunkte auf der kreisförmigen Grenze liegen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Diameter is a length quality equal to any straight line segment passing through the center of a circle with endpoints on the circular boundary</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;diameter&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;length&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001334.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;diameter&apos; then x is a &apos;length&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DielectricConstant -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DielectricConstant">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Dielektrizitätskonstante</rdfs:label>
        <rdfs:label xml:lang="en-us">dielectric constant</rdfs:label>
        <skos:example xml:lang="en-us">Polyethylene has a dielectric constant of about 2.3 at 1 MHz, suitable for high-frequency cable insulation</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000604"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalCapability(x) ← DielectricConstant(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Dielektrizitätskonstante ist eine elektrische Fähigkeit eines Materials, die das Verhältnis der Permittivität des Materials zur Permittivität des freien Raums angibt und seine Fähigkeit angibt, elektrische Energie in einem elektrischen Feld zu speichern</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Dielectric constant is an electrical capability of a material that specifies the ratio of the material&apos;s permittivity to the permittivity of free space, representing its ability to store electrical energy in an electric field</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;dielectric constant&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000604.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;dielectric constant&apos; then x is a &apos;electrical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DielectricStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DielectricStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Durchschlagsfestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">dielectric strength</rdfs:label>
        <skos:altLabel xml:lang="de">Dielektrische Festigkeit</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalQuality(x) ← DielectricStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Dielectric strength is an electrical quality of an insulating material that specifies the maximum electric field intensity the material can sustain without undergoing electrical breakdown</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Durchschlagsfestigkeit ist eine elektrische Qualität eines Isoliermaterials, die die maximale elektrische Feldstärke angibt, die das Material aushalten kann, ohne einen elektrischen Durchschlag zu erleiden</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;dielectric strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;dielectric strength&apos; then x is a &apos;electrical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">E_ds</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Dispersion -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Dispersion">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Dispersion</rdfs:label>
        <rdfs:label xml:lang="en-us">dispersion</rdfs:label>
        <skos:example xml:lang="en-us">The dispersion of optical glass is characterized by an Abbe number, indicating wavelength dependence of refractive index</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020247"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OpticalCapability(x) ← Dispersion(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Dispersion is an optical capability of a material that manifests as the dependence of the phase velocity of electromagnetic radiation on its wavelength as it propagates through the material</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Dispersion ist eine optische Fähigkeit eines Materials, die sich als Abhängigkeit der Phasengeschwindigkeit elektromagnetischer Strahlung von ihrer Wellenlänge bei ihrer Ausbreitung durch das Material manifestiert</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;dispersion&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;optical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020247.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;dispersion&apos; then x is a &apos;optical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Displacement -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Displacement">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/SpatialRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Verschiebung</rdfs:label>
        <rdfs:label xml:lang="en-us">displacement</rdfs:label>
        <skos:altLabel xml:lang="de">Auslenkung</skos:altLabel>
        <skos:example xml:lang="en-us">The midpoint of a loaded steel beam deflects 3 mm, which is its displacement under the applied force</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Displacement_(geometry)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">SpatialRelationalQuality(x) ← Displacement(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">In der Geometrie und Mechanik ist die Verschiebung ein Vektor, der den kürzesten Abstand von der Anfangs- zur Endposition eines sich bewegenden Punktes darstellt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">In geometry and mechanics, displacement is a vector representing the shortest distance from the initial to the final position of a point undergoing motion</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;displacement&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;SpatialRelationalQuality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Displacement_(geometry).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;displacement&apos; then x is a &apos;spatial relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DistanceMeasurementCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DistanceMeasurementCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/MeasurementCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Entfernungsmessungsfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">distance measurement capability</rdfs:label>
        <skos:altLabel xml:lang="de">Entfernungsmessungsfähigkeit</skos:altLabel>
        <skos:example xml:lang="en-us">A laser interferometer has a distance measurement capability with a resolution of 1 nm over 1 m range</skos:example>
        <skos:prefLabel xml:lang="en-us">Distance Measurement Capability</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MeasurementCapability(x) ← DistanceMeasurementCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Distance measurement capability involves the use of an artifact to ascertain the distance between two objects or points in space</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Entfernungsmessungsfähigkeit ist die Messfähigkeit, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um eine Entfernung zwischen zwei Objekten oder Punkten im Raum zu messen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;distance measurement capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;MeasurementCapability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;distance measurement capability&apos; then x is a &apos;measurement capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DoseEquivalent -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DoseEquivalent">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">dose equivalent</rdfs:label>
        <rdfs:label xml:lang="de">Äquivalentdosis</rdfs:label>
        <skos:example xml:lang="en-us">A radiation worker receives a dose equivalent of 2 mSv per year from occupational exposure</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.nrc.gov/reading-rm/basic-ref/glossary/dose-equivalent.html"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← DoseEquivalent(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Das Dosisäquivalent misst die biologische Schädigung lebenden Gewebes durch Strahlenexposition, berechnet als absorbierte Dosis multipliziert mit einem Qualitätsfaktor und ausgedrückt in Rems oder Sievert</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Dose equivalent measures biological damage to living tissue from radiation exposure, calculated as absorbed dose multiplied by a quality factor, and expressed in rems or sieverts</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;dose equivalent&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.nrc.gov/reading-rm/basic-ref/glossary/dose-equivalent.html.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;dose equivalent&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DrivingForceOfPhaseInSystem -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DrivingForceOfPhaseInSystem">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Triebkraft einer Phase im System</rdfs:label>
        <rdfs:label xml:lang="en-us">driving force of phase in system</rdfs:label>
        <skos:example xml:lang="en-us">Undercooling below the liquidus temperature provides the driving force for austenite-to-martensite transformation in steel</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020130"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← DrivingForceOfPhaseInSystem(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die treibende Kraft einer Phase im System ist eine thermodynamische Eigenschaft, die einer Phase und einem thermodynamischen System innewohnt und die thermodynamische Tendenz der Phase zur Transformation, Keimbildung oder zum Wachstum darstellt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Driving force of phase in system is a thermo dynamic quality that inheres between a phase and a thermodynamic system and represents the thermodynamic tendency of the phase to transform, nucleate, or grow</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;driving force of phase in system&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020130.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;driving force of phase in system&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DryMass -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DryMass">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassRatio"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Trockenmasse</rdfs:label>
        <rdfs:label xml:lang="en-us">dry mass</rdfs:label>
        <skos:example xml:lang="en-us">A fiber composite sample has a dry mass of 48.5 g after 24 hours in a drying oven at 80 C</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MassRatio(x) ← DryMass(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Dry mass denotes mass after removing all humidity from an object, typically using qualified heating methods in an oven</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Trockenmasse bezeichnet die Masse, nachdem einem Objekt die gesamte Feuchtigkeit entzogen wurde, typischerweise durch geeignete Erhitzungsmethoden in einem Ofen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;dry mass&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mass ratio&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;dry mass&apos; then x is a &apos;mass ratio&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DuctileBrittleTransitionTemperature -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DuctileBrittleTransitionTemperature">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Duktil-Spröd-Übergangstemperatur</rdfs:label>
        <rdfs:label xml:lang="en-us">ductile-brittle transition temperature</rdfs:label>
        <skos:altLabel xml:lang="de">Nullduktilitäts-Übergangstemperatur</skos:altLabel>
        <skos:altLabel xml:lang="en-us">nil ductility transition temperature</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← DuctileBrittleTransitionTemperature(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Ductile-brittle transition temperature is a thermodynamic quality of a material that specifies the temperature below which the material exhibits brittle fracture behaviour rather than ductile deformation under impact loading</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Duktil-Spröd-Übergangstemperatur ist eine thermodynamische Qualität eines Materials, die die Temperatur angibt, unterhalb derer das Material unter Schlagbelastung ein sprödes Bruchverhalten anstelle einer duktilen Verformung zeigt</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;ductile-brittle transition temperature&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;ductile-brittle transition temperature&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">T_DBTT</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Ductility -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Ductility">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Duktilität</rdfs:label>
        <rdfs:label xml:lang="en-us">ductility</rdfs:label>
        <skos:altLabel xml:lang="de">Biegsamkeit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">flexibility</skos:altLabel>
        <skos:example xml:lang="en-us">Low-carbon steel has high ductility, with elongation at break exceeding 30 %</skos:example>
        <skos:prefLabel xml:lang="de">Duktilität</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">ductility</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalCapability(x) ← Ductility(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Ductility is the ability of a material to deform plastically without breaking</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Duktilität ist die Fähigkeit eines Materials, plastisch zu verformen, ohne zu brechen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;ductility&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;ductility&apos; then x is a &apos;mechanical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Durability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Durability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Dauerhaftigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">durability</rdfs:label>
        <skos:altLabel xml:lang="de">Langlebigkeit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">longevity</skos:altLabel>
        <skos:example xml:lang="en-us">Galvanized steel shows high durability in outdoor environments, resisting corrosion for over 50 years</skos:example>
        <skos:prefLabel xml:lang="de">Dauerhaftigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">durability</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalCapability(x) ← Durability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Dauerhaftigkeit ist die Fähigkeit eines Materials, Abnutzung, Rissbildung und andere Arten von Schäden im Laufe der Zeit zu widerstehen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Durability is the ability of a material to resist wear, tear, and other types of damage over time</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;durability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;durability&apos; then x is a &apos;mechanical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicModulus -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicModulus">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ComplexModulus"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">dynamic modulus</rdfs:label>
        <rdfs:label xml:lang="de">dynamischer Modul</rdfs:label>
        <skos:altLabel xml:lang="en-us">complex shear modulus</skos:altLabel>
        <skos:example xml:lang="en-us">The dynamic modulus of a rubber compound at 10 Hz is 15 MPa, relevant for vibration isolation design</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Dynamic_modulus"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ComplexModulus(x) ← DynamicModulus(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Dynamic modulus is the ratio of stress to strain under vibratory conditions, typically measured in shear, compression, or elongation tests, and characterizes viscoelastic materials</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Dynamischer Modul ist das Verhältnis von Spannung zu Dehnung unter schwingenden Bedingungen, typischerweise gemessen in Scher-, Druck- oder Dehnungstests, und charakterisiert viskoelastische Materialien</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;dynamic modulus&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;complex modulus&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Dynamic_modulus.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;dynamic modulus&apos; then x is a &apos;complex modulus&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicViscosity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicViscosity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">dynamic viscosity</rdfs:label>
        <rdfs:label xml:lang="de">dynamische Viskosität</rdfs:label>
        <skos:example xml:lang="en-us">Motor oil at 40 C has a dynamic viscosity of about 100 mPa·s, resisting flow under shear</skos:example>
        <skos:prefLabel xml:lang="en-us">dynamic viscosity</skos:prefLabel>
        <skos:prefLabel xml:lang="de">dynamische Viskosität</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Viscosity(x) ← DynamicViscosity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die dynamische Viskosität ist ein Maß für den Widerstand eines Fluids gegen eine allmähliche Verformung durch Scher- oder Zugspannung. Es ist ein Maß für den inneren Widerstand des Fluids gegen den Fluss und kann als Maß für die Flüssigkeitsreibung betrachtet werden</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Dynamic viscosity measures a fluid&apos;s resistance to gradual deformation by shear stress or tensile stress, indicative of the fluid&apos;s internal friction</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;dynamic viscosity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;viscosity&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;dynamic viscosity&apos; then x is a &apos;viscosity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElasticModulus -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElasticModulus">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Elastizitätsmodul</rdfs:label>
        <rdfs:label xml:lang="en-us">elastic modulus</rdfs:label>
        <skos:altLabel xml:lang="en-us">Young&apos;s modulus</skos:altLabel>
        <skos:altLabel xml:lang="en-us">modulus of elasticity</skos:altLabel>
        <skos:example xml:lang="en-us">The elastic modulus of structural steel is 210 GPa, governing its stiffness in beam bending</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000618"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Stiffness(x) ← ElasticModulus(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Elastic modulus represents the quotient of change of stress and change of percentage extension in the evaluation range, recommending reporting in GPa rounded to the nearest 0.1 GPa according to ISO 80000-1</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Quotient der Änderung der Spannung ΔR und Änderung der prozentualen Dehnung Δe in dem untersuchten Bereich multipliziert mit 100 %. Anmerkung: Es wird empfohlen, den Wert in GPa, gerundet auf 0,1 GPa, und nach ISO 80000-1 anzugeben</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;elastic modulus&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;stiffness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;elastic modulus&apos; then x is a &apos;stiffness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElasticStrain -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElasticStrain">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">elastic strain</rdfs:label>
        <rdfs:label xml:lang="de">elastische Deformation</rdfs:label>
        <skos:altLabel xml:lang="en-us">elastic deformation</skos:altLabel>
        <skos:altLabel xml:lang="de">elastische Verformung</skos:altLabel>
        <skos:example xml:lang="en-us">Steel loaded to 200 MPa exhibits an elastic strain of about 0.001, fully recovered upon unloading</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Plasticity_(physics)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strain(x) ← ElasticStrain(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Bei der elastischen Dehnung handelt es sich um eine Dehnungsqualität eines Materialgebildes, die durch eine reversible Verformung gekennzeichnet ist, die bei Wegnahme der aufgebrachten Last verschwindet</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Elastic strain is a strain quality of a material entity characterized by reversible deformation that disappears upon removal of the applied load</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;elastic strain&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strain&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Plasticity_(physics).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;elastic strain&apos; then x is a &apos;strain&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Elasticity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Elasticity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Elastizität</rdfs:label>
        <rdfs:label xml:lang="en-us">elasticity</rdfs:label>
        <skos:altLabel xml:lang="de">Widerstandsfähigkeit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">elastic</skos:altLabel>
        <skos:altLabel xml:lang="de">elastisch</skos:altLabel>
        <skos:altLabel xml:lang="en-us">resilience</skos:altLabel>
        <skos:example xml:lang="en-us">Rubber exhibits high elasticity, recovering its original shape after 300 % elongation</skos:example>
        <skos:prefLabel xml:lang="de">Elastizität</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">elasticity</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strength(x) ← Elasticity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Elasticity is the ability of an object or material to resume its normal shape after deformation</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Elastizität ist die Fähigkeit eines Objekts oder Materials, nach Deformation seine normale Form wiederherzustellen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;elasticity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;elasticity&apos; then x is a &apos;strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricCharge -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricCharge">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electric charge</rdfs:label>
        <rdfs:label xml:lang="de">elektrische Ladung</rdfs:label>
        <skos:altLabel xml:lang="de">elektrische Ladung</skos:altLabel>
        <skos:example xml:lang="en-us">A capacitor stores 10 µC of electric charge at a voltage of 5 V</skos:example>
        <skos:prefLabel xml:lang="en-us">electric charge</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalQuality(x) ← ElectricCharge(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electric charge refers to the physical property of matter causing it to experience a force when placed in an electromagnetic field</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Elektrische Ladung bezieht sich auf die physikalische Eigenschaft von Materie, die dazu führt, dass sie eine Kraft erfährt, wenn sie in ein elektromagnetisches Feld gebracht wird</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electric charge&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electric charge&apos; then x is a &apos;electrical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricCurrent -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricCurrent">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electric current</rdfs:label>
        <rdfs:label xml:lang="de">elektrischer Strom</rdfs:label>
        <skos:example xml:lang="en-us">A 100 W incandescent bulb draws an electric current of about 0.43 A at 230 V</skos:example>
        <skos:prefLabel xml:lang="en-us">electric current</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalProcessCharacteristic(x) ← ElectricCurrent(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electric current is the flow of electric charge per unit time</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Elektrischer Strom ist der Fluss elektrischer Ladung pro Zeiteinheit</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electric current&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical process characteristic&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electric current&apos; then x is a &apos;physical process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricFieldStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricFieldStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electric field strength</rdfs:label>
        <rdfs:label xml:lang="de">elektrische Feldstärke</rdfs:label>
        <skos:example xml:lang="en-us">Between parallel capacitor plates separated by 1 mm at 100 V, the electric field strength is 1e5 V/m</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/electric-field"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalQuality(x) ← ElectricFieldStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Stärke oder Intensität des elektrischen Feldes bezieht sich auf die Stärke und Richtung des elektrischen Feldes an einem Punkt und ist entscheidend für die Bestimmung der Auswirkungen auf elektrische Ladungen in der Nähe dieses Punktes</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electric field strength, or intensity, refers to the magnitude and direction of the electric field at a point, crucial for determining effects on electric charges near that point</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electric field strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/electric-field.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electric field strength&apos; then x is a &apos;electrical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricFluxDensity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricFluxDensity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electric flux density</rdfs:label>
        <rdfs:label xml:lang="de">elektrische Flussdichte</rdfs:label>
        <skos:example xml:lang="en-us">Near a charged plate, the electric flux density is 8.85e-12 C/m2 per V/m of field strength</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/electric-flux"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Density(x) ← ElectricFluxDensity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die elektrische Flussdichte misst die Gesamtzahl der elektrischen Kraftlinien, die ein bestimmtes Gebiet schneiden, von positiven Ladungen ausgehen und bei negativen Ladungen enden</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electric flux density measures the total number of electric lines of force intersecting a given area, originating on positive charges and terminating on negative charges</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electric flux density&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;density&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/electric-flux.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electric flux density&apos; then x is a &apos;density&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricPotential -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricPotential">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Potential"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electric potential</rdfs:label>
        <rdfs:label xml:lang="de">elektrisches Potential</rdfs:label>
        <skos:altLabel xml:lang="de">Stromspannung</skos:altLabel>
        <skos:altLabel xml:lang="en-us">voltage</skos:altLabel>
        <skos:example xml:lang="en-us">The electric potential at the positive terminal of a 9 V battery is 9 V relative to the negative terminal</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/electric-potential"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Potential(x) ← ElectricPotential(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Das elektrische Potenzial charakterisiert den Arbeitsaufwand, der erforderlich ist, um eine Einheitsladung von einem Referenzpunkt zu einem bestimmten Punkt gegen ein elektrisches Feld zu bewegen, typischerweise von der Erde oder einem anderen Punkt außerhalb des Einflussbereichs des Feldes</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electric potential characterizes the amount of work needed to move a unit charge from a reference point to a specific point against an electric field, typically from Earth or any point beyond the field&apos;s influence</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electric potential&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;potential&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electric potential&apos; then x is a &apos;potential&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electrical capability</rdfs:label>
        <rdfs:label xml:lang="de">elektrische Fähigkeit</rdfs:label>
        <skos:example xml:lang="en-us">The semiconductivity of doped silicon is an electrical capability enabling switching in transistors</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalCapability(x) ← ElectricalCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electrical capability entails realization through an entity related to electric interaction</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Elektrische Leistungsfähigkeit erfordert die Realisierung durch eine Entität, die mit der elektrischen Wechselwirkung zusammenhängt</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electrical capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electrical capability&apos; then x is a &apos;physical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapacitance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapacitance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electrical capacitance</rdfs:label>
        <rdfs:label xml:lang="de">elektrische Kapazität</rdfs:label>
        <skos:altLabel xml:lang="en-us">electrical capacity</skos:altLabel>
        <skos:altLabel xml:lang="de">elektrische Kapazität</skos:altLabel>
        <skos:example xml:lang="en-us">A ceramic capacitor has an electrical capacitance of 100 nF, storing charge in an electronic circuit</skos:example>
        <skos:prefLabel xml:lang="en-us">electrical capacitance</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalCapability(x) ← ElectricalCapacitance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die elektrische Kapazität bezieht sich auf die Fähigkeit eines Wesens, elektrische Ladung zu speichern, ausgedrückt als die Menge an elektrischer Ladung, die pro gegebenem elektrischem Potenzial gespeichert wird</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electrical capacitance refers to an entity&apos;s ability to store electric charge, expressed as the amount of electric charge stored per given electric potential</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electrical capacitance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electrical capacitance&apos; then x is a &apos;electrical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalConductance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalConductance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electrical conductance</rdfs:label>
        <rdfs:label xml:lang="de">elektrischer Leitwert</rdfs:label>
        <skos:altLabel xml:lang="de">Stromleitwert</skos:altLabel>
        <skos:example xml:lang="en-us">A copper wire of 1 m length and 1 mm2 cross-section has an electrical conductance of about 59 S</skos:example>
        <skos:prefLabel xml:lang="en-us">electrical conductance</skos:prefLabel>
        <skos:prefLabel xml:lang="de">elektrischer Leitwert</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalCapability(x) ← ElectricalConductance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der elektrische Leitwert stellt den Kehrwert des elektrischen Widerstands eines Leiters dar und misst seine Fähigkeit, elektrischen Strom zu leiten, angegeben in Siemens (S).</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electrical conductance represents the reciprocal of a conductor&apos;s electrical resistance, measuring its ability to conduct an electric current, denoted in siemens (S)</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electrical conductance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electrical conductance&apos; then x is a &apos;electrical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalConductivity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalConductivity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electrical conductivity</rdfs:label>
        <rdfs:label xml:lang="de">elektrische Leitfähigkeit</rdfs:label>
        <skos:example xml:lang="en-us">Copper has an electrical conductivity of 5.96e7 S/m, making it the standard material for electrical wiring</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000620"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalCapability(x) ← ElectricalConductivity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electrical conductivity is an electrical capability of a material that specifies its ability to conduct electric current, expressed as the reciprocal of electrical resistivity</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Elektrische Leitfähigkeit ist die elektrische Fähigkeit eines Materials, die seine Fähigkeit angibt, elektrischen Strom zu leiten, ausgedrückt als Kehrwert des spezifischen elektrischen Widerstands</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electrical conductivity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000620.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electrical conductivity&apos; then x is a &apos;electrical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalQuality">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electrical quality</rdfs:label>
        <rdfs:label xml:lang="de">elektrische Qualität</rdfs:label>
        <skos:example xml:lang="en-us">The semiconductivity of silicon is an electrical quality that determines its behavior in transistors</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← ElectricalQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die elektrische Qualität charakterisiert das Verhalten oder den Zustand einer materiellen Einheit in Bezug auf Elektrizität</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electrical quality characterizes a material entity&apos;s behavior or state concerning electricity</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electrical quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electrical quality&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalResistance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalResistance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electrical resistance</rdfs:label>
        <rdfs:label xml:lang="de">elektrischer Widerstand</rdfs:label>
        <skos:example xml:lang="en-us">A nichrome heating element has an electrical resistance of 10 Ω at room temperature</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/technology/resistance-electronics"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalCapability(x) ← ElectricalResistance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der elektrische Widerstand bezieht sich auf die Fähigkeit eines Stromkreises, elektrische Energie in Wärmeenergie umzuwandeln, indem er elektrischem Strom durch Teilchenkollisionen entgegenwirkt, die für Widerstände, Lampen und Drähte charakteristisch sind</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electrical resistance pertains to a circuit&apos;s capability to transform electric energy into heat energy, opposing electric current through particle collisions, characteristic of resistors, lamps, and wires</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electrical resistance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/technology/resistance-electronics.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electrical resistance&apos; then x is a &apos;electrical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectroMagneticWave -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectroMagneticWave">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasQuality"/>
                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Wavelength"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">electro magnetic wave</rdfs:label>
        <rdfs:label xml:lang="de">elektromagnetische Welle</rdfs:label>
        <iof-av:firstOrderLogicDefinition xml:lang="en-us">ElectroMagneticWave(x) ↔ ∃b (Wavelength(b) ∧ hasQuality(x, b))</iof-av:firstOrderLogicDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electromagnetic wave characterizes radiation generated by vibrating electrically charged particles, traveling as waves with specific wavelengths and intensities</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Elektromagnetische Wellen charakterisieren Strahlung, die durch vibrierende elektrisch geladene Teilchen erzeugt wird und sich als Wellen mit bestimmten Wellenlängen und Intensitäten ausbreitet</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition_source rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://ec.europa.eu/health/scientific_committees/opinions_layman/en/energy-saving-lamps/glossary/def/electromagnetic-wave.htm</iof-av:naturalLanguageDefinition_source>
        <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-us">every instance of &apos;electro magnetic wave&apos; is defined as exactly that &apos;hasQuality&apos; some &apos;wavelength&apos;</iof-av:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectromotiveForce -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectromotiveForce">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Quellenspannung</rdfs:label>
        <rdfs:label xml:lang="en-us">electromotive force</rdfs:label>
        <skos:example xml:lang="en-us">A standard zinc-copper galvanic cell produces an electromotive force of 1.1 V</skos:example>
        <iof-av:abbreviation xml:lang="en-us">EMP</iof-av:abbreviation>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Electromotive_force"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← ElectromotiveForce(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Electromotive force refers to energy transferred to an electric circuit per unit charge, measured in volts, produced by transducers converting forms of energy to electrical energy</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Unter elektromotorischer Kraft versteht man die Energie, die pro Ladungseinheit auf einen Stromkreis übertragen wird. Sie wird in Volt gemessen und von Wandlern erzeugt, die Energieformen in elektrische Energie umwandeln</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;electromotive force&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical rate quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Electromotive_force.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;electromotive force&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Emissivity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Emissivity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Emissionsgrad</rdfs:label>
        <rdfs:label xml:lang="en-us">emissivity</rdfs:label>
        <skos:altLabel xml:lang="de">Emissivität</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← Emissivity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Emissionsgrad ist eine physikalische Ratenqualität einer Materialoberfläche, die das Verhältnis der von der Oberfläche emittierten Wärmestrahlung zu der eines idealen schwarzen Körpers bei gleicher Temperatur ausdrückt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Emissivity is a physical rate quality of a material surface that expresses the ratio of thermal radiation emitted by the surface to that emitted by a perfect blackbody at the same temperature</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;emissivity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical rate quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;emissivity&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">ε</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Energy -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Energy">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Energie</rdfs:label>
        <rdfs:label xml:lang="en-us">energy</rdfs:label>
        <skos:example xml:lang="en-us">A tensile test specimen stores 5 J of elastic strain energy before reaching yield</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020142"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← Energy(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Energie ist eine thermodynamische Eigenschaft einer materiellen Einheit, die sich in ihrer Fähigkeit manifestiert, Arbeit zu verrichten, beispielsweise Bewegung zu verursachen oder molekulare Wechselwirkungen anzutreiben</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Energy is a thermo dynamic quality of a material entity that manifests as its capacity to perform work, such as causing motion or driving molecular interactions</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;energy&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020142.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;energy&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EngineeringStrain -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EngineeringStrain">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">engineering strain</rdfs:label>
        <rdfs:label xml:lang="de">technische Dehnung</rdfs:label>
        <skos:altLabel xml:lang="en-us">Cauchy strain</skos:altLabel>
        <skos:altLabel xml:lang="en-us">technical strain</skos:altLabel>
        <skos:example xml:lang="en-us">A tensile specimen elongates from 50 mm to 55 mm gauge length, giving an engineering strain of 10 %</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Strain_(mechanics)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strain(x) ← EngineeringStrain(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die technische Dehnung oder Cauchy-Dehnung drückt die Gesamtverformung relativ zur ursprünglichen Abmessung des Materials unter Last aus und spiegelt die Dehnung bei axialer Belastung wider</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Engineering strain, or Cauchy strain, expresses total deformation relative to the initial dimension of the material under load, reflecting elongation in axial loading</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;engineering strain&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strain&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Strain_(mechanics).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;engineering strain&apos; then x is a &apos;strain&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EngineeringStress -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EngineeringStress">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stress"/>
        <obo:IAO_0000116 xml:lang="en-us">Assumes unchanged size of Area the force is normalized to. Changes in the Area can only be neglected for very small deformations</obo:IAO_0000116>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">engineering stress</rdfs:label>
        <rdfs:label xml:lang="de">technische Spannung</rdfs:label>
        <skos:example xml:lang="en-us">At yield, a steel specimen with 50 mm2 cross-section under 12.5 kN shows engineering stress of 250 MPa</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Stress(x) ← EngineeringStress(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Engineering stress quantifies the internal force per unit area a material experiences under load, assuming the area remains constant</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Technische Spannung beschreibt die innere Kraft pro Fläche, die ein Material unter Last erfährt, unter der Annahme, dass die Fläche konstant bleibt</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;engineering stress&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;stress&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;engineering stress&apos; then x is a &apos;stress&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Enthalpy -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Enthalpy">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Energy"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Enthalpie</rdfs:label>
        <rdfs:label xml:lang="en-us">enthalpy</rdfs:label>
        <skos:example xml:lang="en-us">The enthalpy of fusion of aluminum is 397 J/g, energy required to melt it at its melting point</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/enthalpy"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Energy(x) ← Enthalpy(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die als H bezeichnete Enthalpie stellt die Summe der inneren Energie und das Produkt aus Druck und Volumen in einem thermodynamischen System dar und ist für Energieberechnungen von entscheidender Bedeutung</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Enthalpy, denoted as H, represents the sum of internal energy and the product of pressure and volume in a thermodynamic system, crucial for energy calculations</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;enthalpy&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;energy&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/enthalpy.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;enthalpy&apos; then x is a &apos;energy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Entropy -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Entropy">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Energy"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Entropie</rdfs:label>
        <rdfs:label xml:lang="en-us">entropy</rdfs:label>
        <skos:example xml:lang="en-us">Melting of ice at 0 C involves an entropy increase of 22 J/(mol·K), driving the phase transition</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/entropy-physics"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Energy(x) ← Entropy(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Entropie misst die Wärmeenergie pro Temperatureinheit, die für die Arbeit in einem System nicht zur Verfügung steht und auf molekulare Unordnung oder Zufälligkeit hinweist</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Entropy measures the thermal energy per unit temperature unavailable for work in a system, indicating molecular disorder or randomness</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;entropy&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;energy&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/entropy-physics.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;entropy&apos; then x is a &apos;energy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EnvironmentalTemperature -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EnvironmentalTemperature">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Temperature"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="de">Umgebungstemperatur</rdfs:label>
        <rdfs:label xml:lang="en-us">environmental temperature</rdfs:label>
        <skos:example xml:lang="en-us">A circuit board operates at an environmental temperature of 85 C in a high-reliability application</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Temperature(x) ← EnvironmentalTemperature(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Environmental temperature describes the observed temperature surrounding a tangible object, including room temperature and temperatures measured in test chambers</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Umgebungstemperatur ist die Eigenschaft, die die beobachtete Temperatur in der Umgebung eines betrachteten materiellen Objekts beschreibt. Dazu gehören Raumtemperatur und die in Prüfkammern gemessenen Temperaturen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;environmental temperature&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;temperature&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;environmental temperature&apos; then x is a &apos;temperature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EutecticPoint -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EutecticPoint">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">eutectic point</rdfs:label>
        <rdfs:label xml:lang="de">eutektischer Punkt</rdfs:label>
        <skos:altLabel xml:lang="en-us">eutectic temperature</skos:altLabel>
        <skos:altLabel xml:lang="de">eutektische Temperatur</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← EutecticPoint(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Eutectic point is a thermodynamic quality of a multi-component material system that specifies the composition and temperature at which all components simultaneously solidify from a liquid mixture at the lowest possible melting temperature</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Eutektischer Punkt ist eine thermodynamische Qualität eines Mehrkomponentenmaterialsystems, die die Zusammensetzung und Temperatur angibt, bei der alle Komponenten gleichzeitig aus einer flüssigen Mischung bei der niedrigstmöglichen Schmelztemperatur erstarren</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;eutectic point&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;eutectic point&apos; then it is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Exposure -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Exposure">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Belichtungszeit</rdfs:label>
        <rdfs:label xml:lang="en-us">exposure</rdfs:label>
        <skos:example xml:lang="en-us">A worker is exposed to a UV radiation exposure of 30 J/m2 during outdoor operations</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Exposure_(photography)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OpticalQuality(x) ← Exposure(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Exposure in photography refers to the amount of light per unit area reaching film or sensor, determined by shutter speed, lens F-number, and scene luminance</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Unter Belichtung versteht man in der Fotografie die Lichtmenge pro Flächeneinheit, die den Film oder Sensor erreicht, bestimmt durch Verschlusszeit, Blendenzahl des Objektivs und Helligkeit der Szene</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;exposure&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;optical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Exposure_(photography).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;exposure&apos; then x is a &apos;optical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ExtentionalViscosity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ExtentionalViscosity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Dehnviskosität</rdfs:label>
        <rdfs:label xml:lang="en-us">extentional viscosity</rdfs:label>
        <skos:example xml:lang="en-us">A polymer melt shows an extensional viscosity three times its shear viscosity at low strain rates</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Viscosity(x) ← ExtentionalViscosity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Dehnviskosität ist die Messung des Widerstands einer Flüssigkeit gegen den Fluss bei Dehnspannung</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Extentional viscosity measures a fluid&apos;s resistance to tension flow</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;extentional viscosity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;viscosity&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;extentional viscosity&apos; then x is a &apos;viscosity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ExtinctionCoefficient -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ExtinctionCoefficient">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RefractiveIndex"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Extinktionskoeffizient</rdfs:label>
        <rdfs:label xml:lang="en-us">extinction coefficient</rdfs:label>
        <skos:example xml:lang="en-us">The extinction coefficient of gold at 500 nm wavelength is 1.87, characterizing strong optical absorption</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Refractive_index#Complex_index_of_refraction_and_absorption"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">RefractiveIndex(x) ← ExtinctionCoefficient(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Extinktionskoeffizient, die imaginäre Komponente des komplexen Brechungsindex, gibt die Dämpfung elektromagnetischer Wellen durch ein Material an</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Extinction coefficient, the imaginary component of the complex refractive index, indicates attenuation of electromagnetic waves through a material</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;extinction coefficient&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;refractive index&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Refractive_index#Complex_index_of_refraction_and_absorption.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;extinction coefficient&apos; then x is a &apos;refractive index&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FatigueStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FatigueStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Ermüdungsfestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">fatigue strength</rdfs:label>
        <skos:altLabel xml:lang="de">Ermüdungsfestigkeit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">fatigue strength</skos:altLabel>
        <skos:example xml:lang="en-us">The fatigue strength of steel at 10^7 cycles is approximately half its tensile strength</skos:example>
        <skos:prefLabel xml:lang="de">Ermüdungsfestigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">fatigue strength</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strength(x) ← FatigueStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Ermüdungsfestigkeit bezeichnet die Fähigkeit eines Materials, Ermüdung oder zyklische Belastung zu widerstehen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Fatigue strength denotes a material&apos;s ability to resist fatigue or cyclic loading</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;fatigue strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;fatigue strength&apos; then x is a &apos;strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FlameResistance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FlameResistance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <owl:disjointWith rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Flammability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Flammbeständigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">flame resistance</rdfs:label>
        <skos:altLabel xml:lang="de">Brandbeständigkeit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">fire resistance</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← FlameResistance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Flame resistance is a thermal capability of a material that characterises its ability to resist ignition and inhibit the spread of combustion when exposed to a flame or heat source</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Flammbeständigkeit ist eine thermische Fähigkeit eines Materials, die seine Fähigkeit beschreibt, einer Entzündung zu widerstehen und die Ausbreitung der Verbrennung bei Exposition gegenüber einer Flamme oder Wärmequelle zu verhindern</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;flame resistance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;, disjoint from &apos;flammability&apos; as the inverse capability. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;flame resistance&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Flammability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Flammability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Entflammbarkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">flammability</rdfs:label>
        <skos:altLabel xml:lang="de">Brennbarkeit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">combustibility</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← Flammability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Entflammbarkeit ist eine thermische Fähigkeit eines Materials, die seine Fähigkeit beschreibt, bei Exposition gegenüber einer Flamme oder Wärmequelle unter festgelegten Bedingungen zu entzünden und die Verbrennung aufrechtzuerhalten</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Flammability is a thermal capability of a material that characterises its ability to ignite and sustain combustion when exposed to a flame or heat source under specified conditions</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;flammability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;flammability&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FlashPoint -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FlashPoint">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Flammpunkt</rdfs:label>
        <rdfs:label xml:lang="en-us">flash point</rdfs:label>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← FlashPoint(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Flammpunkt ist eine thermodynamische Qualität eines flüchtigen Materials, die die niedrigste Temperatur angibt, bei der sein Dampf an der Materialoberfläche ein zündfähiges Gemisch mit Luft bildet</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Flash point is a thermodynamic quality of a volatile material that specifies the lowest temperature at which its vapour forms an ignitable mixture with air near the surface of the material</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;flash point&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;flash point&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FlexuralModulus -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FlexuralModulus">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Biegemodul</rdfs:label>
        <rdfs:label xml:lang="en-us">flexural modulus</rdfs:label>
        <skos:altLabel xml:lang="en-us">bending modulus</skos:altLabel>
        <skos:example xml:lang="en-us">Flexural modulus of a glass-fibre reinforced polyamide measured as 9.5 GPa under ISO 178 three-point bending test conditions.</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Stiffness(x) ← FlexuralModulus(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Biegemodul ist eine Steifigkeitsqualität eines Materials, die das Verhältnis von Spannung zu Dehnung im elastischen Bereich eines Biegeversuchs beschreibt und den Widerstand gegen elastische Verformung unter Biegebelastung repräsentiert</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Flexural modulus is a stiffness quality of a material that specifies the ratio of stress to strain in the elastic region of a bending test, representing resistance to elastic deformation under flexural load</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;flexural modulus&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;stiffness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;flexural modulus&apos; then x is a &apos;stiffness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FlexuralStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FlexuralStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BreakingStrength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Biegefestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">flexural strength</rdfs:label>
        <skos:altLabel xml:lang="en-us">bending strength</skos:altLabel>
        <skos:example xml:lang="en-us">A ceramic bending bar fractures at a flexural strength of 350 MPa in a three-point bend test</skos:example>
        <skos:prefLabel xml:lang="de">Biegefestigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">flexural strength</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">BreakingStrength(x) ← FlexuralStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Biegefestigkeit bezeichnet die Fähigkeit eines Materials, unter Biegelast Deformationen zu widerstehen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Flexural strength indicates a material&apos;s ability to resist deformation under flexural load</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;flexural strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;breaking strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;flexural strength&apos; then x is a &apos;breaking strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FluidDynamicQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FluidDynamicQuality">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Strömungsqualität</rdfs:label>
        <rdfs:label xml:lang="en-us">fluid dynamic quality</rdfs:label>
        <skos:altLabel xml:lang="de">Qualität der Strömungslehre</skos:altLabel>
        <skos:example xml:lang="en-us">The Reynolds number of flow in a pipe is a fluid dynamic quality determining laminar or turbulent regime</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← FluidDynamicQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die dynamische Fluidqualität charakterisiert das Verhalten oder den Zustand einer materiellen Einheit in Bezug auf die Fluidinteraktion</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Fluid dynamic quality characterizes a material entity&apos;s behavior or state in relation to fluidic interaction</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;fluid dynamic quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;fluid dynamic quality&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FluidPermeability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FluidPermeability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Fluiddurchlässigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">fluid permeability</rdfs:label>
        <skos:altLabel xml:lang="en-us">Darcy permeability</skos:altLabel>
        <skos:altLabel xml:lang="de">Durchlässigkeit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">hydraulic permeability</skos:altLabel>
        <skos:example xml:lang="en-us">Sandstone with a Darcy permeability of 100 mD allows significant fluid flow under pressure gradients</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← FluidPermeability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Fluid permeability is a physical relational quality of a porous material that quantifies its capacity to allow fluid flow through its pore network under an applied pressure gradient, defined by Darcy&apos;s law as the ratio of fluid flux to the pressure gradient normalized by fluid viscosity</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Fluiddurchlässigkeit ist eine physikalische relationale Qualität eines porösen Materials, die seine Fähigkeit quantifiziert, Fluidfluss durch sein Porennetzwerk unter einem angelegten Druckgradienten zu ermöglichen, definiert durch das Darcy-Gesetz als Verhältnis des Fluidflusses zum Druckgradienten normiert durch die Viskosität des Fluids</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;fluid permeability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;fluid permeability&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">k</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="de">Kraft</rdfs:label>
        <rdfs:label xml:lang="en-us">force</rdfs:label>
        <skos:example xml:lang="en-us">A 100 kg mass exerts a gravitational force of 981 N on a supporting structure at sea level</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.merriam-webster.com/dictionary/force"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← Force(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Force refers to an influence causing an object to change its velocity, defined mathematically as a vector quantity measured in newtons (N)</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Kraft bezieht sich auf einen Einfluss, der dazu führt, dass ein Objekt seine Geschwindigkeit ändert, mathematisch definiert als eine Vektorgröße, die in Newton (N) gemessen wird.</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;force&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.merriam-webster.com/dictionary/force.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;force&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <AnnotationVocabulary1:naturalLanguageDefinition xml:lang="en-us">Force refers to an influence causing an object to change its velocity, defined mathematically as a vector quantity measured in newtons (N)</AnnotationVocabulary1:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
        <owl:annotatedTarget xml:lang="en-us">Force refers to an influence causing an object to change its velocity, defined mathematically as a vector quantity measured in newtons (N)</owl:annotatedTarget>
        <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Force</iof-av:directSource>
    </owl:Axiom>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ForceMeasurementCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ForceMeasurementCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/MeasurementCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Kraftmessfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">force measurement capability</rdfs:label>
        <skos:altLabel xml:lang="de">Kraft Messfähigkeit</skos:altLabel>
        <skos:example xml:lang="en-us">A calibrated strain gauge load cell has a force measurement capability of 0.1 N resolution at 100 kN full scale</skos:example>
        <skos:prefLabel xml:lang="en-us">Force Measurement Capability</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MeasurementCapability(x) ← ForceMeasurementCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Force measurement capability involves using an artifact to measure the force applied to a specific object or class of objects</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Kraft Messfähigkeit ist die Messfähigkeit, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um die auf ein bestimmtes Objekt oder eine Klasse von Objekten angewendete Kraft zu messen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition_source rdf:resource="https://en.wikipedia.org/wiki/Force_measurement"/>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;force measurement capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;MeasurementCapability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;force measurement capability&apos; then x is a &apos;measurement capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ForceRate -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ForceRate">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
        <obo:IAO_0000116 xml:lang="en-us">second derivative of momentum with respect to time</obo:IAO_0000116>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Kraftrate</rdfs:label>
        <rdfs:label xml:lang="en-us">force rate</rdfs:label>
        <skos:altLabel xml:lang="de">Ruck</skos:altLabel>
        <skos:altLabel xml:lang="en-us">yank</skos:altLabel>
        <skos:example xml:lang="en-us">During impact testing, the force rate on the specimen rises to 10 kN/ms within the first microsecond</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalProcessCharacteristic(x) ← ForceRate(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">In der Physik wird der Begriff &quot;Ruck&quot; manchmal verwendet, um die Ableitung der Kraft in Bezug auf die Zeit oder die mit dem Ruck multiplizierte Masse zu bezeichnen. In der relativistischen Physik wird dieser Begriff als die zweite Ableitung des Impulses in Bezug auf die Zeit ausgedrückt, da die Masse geschwindigkeitsabhängig ist. Obwohl nicht allgemein als offizieller Begriff für diese Größe anerkannt, wird der Begriff &quot;Ruck&quot; häufig von Physikbegeisterten verwendet</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">In physics, yank is sometimes used to denote the derivative of force with respect to time or mass multiplied by jerk. In relativistic physics, it is expressed as the second derivative of momentum with respect to time, because the mass is velocity-dependent. Though not universally accepted as an official term for this quantity, the term &quot;yank&quot; is commonly used among physics enthusiasts</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition_source xml:lang="en-us">https://en-academic.com/dic.nsf/enwiki/1620873</iof-av:naturalLanguageDefinition_source>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;force rate&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical process characteristic&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;force rate&apos; then x is a &apos;physical process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FractureToughness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FractureToughness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Toughness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Bruchzähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">fracture toughness</rdfs:label>
        <skos:altLabel xml:lang="en-us">critical stress intensity factor</skos:altLabel>
        <skos:example xml:lang="en-us">Fracture toughness of a high-strength steel measured as 50 MPa·√m according to ISO 17281 test conditions.</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Toughness(x) ← FractureToughness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Bruchzähigkeit ist eine Zähigkeitsqualität eines Materials, die die kritische Spannungsintensität beschreibt, bei der ein vorhandener Riss zu wachsen beginnt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Fracture toughness is a toughness quality of a material that specifies the critical stress intensity at which a pre-existing crack begins to propagate, expressed as the stress intensity factor at the onset of fracture</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;fracture toughness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;toughness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;fracture toughness&apos; then x is a &apos;toughness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">K_Ic</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Frequency -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Frequency">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Frequenz</rdfs:label>
        <rdfs:label xml:lang="en-us">frequency</rdfs:label>
        <skos:example xml:lang="en-us">An ultrasonic transducer operates at a frequency of 5 MHz for non-destructive flaw detection in steel</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/frequency-physics"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalProcessCharacteristic(x) ← Frequency(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Frequenz beschreibt die Anzahl der Wellen, die pro Zeiteinheit einen festen Punkt passieren, oder die Anzahl der Zyklen, die ein Körper in periodischer Bewegung durchläuft</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Frequency describes the number of waves passing a fixed point in unit time, or cycles undergone by a body in periodic motion</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;frequency&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical process characteristic&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/frequency-physics.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;frequency&apos; then x is a &apos;physical process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Friction -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Friction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Reibung</rdfs:label>
        <rdfs:label xml:lang="en-us">friction</rdfs:label>
        <skos:example xml:lang="en-us">Static friction between rubber and concrete has a coefficient of about 0.6, resisting sliding motion</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/friction"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Force(x) ← Friction(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Friction is the force resisting the sliding or rolling of one solid object over another, arising from shear between contact regions of microscopic irregularities</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Reibung ist die Kraft, die dem Gleiten oder Rollen eines festen Objekts über ein anderes entgegenwirkt und durch Scherung zwischen Kontaktbereichen mikroskopischer Unregelmäßigkeiten entsteht</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;friction&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;force&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/friction.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;friction&apos; then x is a &apos;force&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/GlassTransitionTemperature -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/GlassTransitionTemperature">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DuctileBrittleTransitionTemperature"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Glasübergangstemperatur</rdfs:label>
        <rdfs:label xml:lang="en-us">glass transition temperature</rdfs:label>
        <skos:example xml:lang="en-us">Glass transition temperature of polycarbonate measured at approximately 147 °C, above which the material softens and loses rigidity, determined according to ISO 11357-2.</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Glass_transition"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">DuctileBrittleTransitionTemperature(x) ← GlassTransitionTemperature(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Glass transition temperature is a ductile-brittle transition temperature of an amorphous or semi-crystalline material that specifies the temperature at which the material transitions from a hard, glassy state to a soft, rubbery state upon heating</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Glasübergangstemperatur ist eine Duktil-Spröd-Übergangstemperatur eines amorphen oder teilkristallinen Materials, die die Temperatur beschreibt, bei der das Material beim Erwärmen von einem harten, glasartigen in einen weichen, gummiartigen Zustand übergeht</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;glass transition temperature&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;ductile-brittle transition temperature&apos; specific to amorphous and semi-crystalline materials. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Glass_transition.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;glass transition temperature&apos; then x is a &apos;ductile-brittle transition temperature&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">Tg</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardenable -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardenable">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">hardenable</rdfs:label>
        <rdfs:label xml:lang="de">härtbar</rdfs:label>
        <skos:example xml:lang="en-us">High-carbon steel is hardenable by quenching from above the austenitizing temperature</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0010013"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalCapability(x) ← Hardenable(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Hardenable is a mechanical capability of a material to gain a greatly increased hardness at the surface or throughout its entire volume by the process of hardening</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Härtbarkeit ist die mechanische Fähigkeit eines Materials, durch den Härtungsprozess an der Oberfläche oder im gesamten Volumen eine stark erhöhte Härte zu erreichen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;hardenable&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0010013.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;hardenable&apos; then x is a &apos;mechanical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Härte</rdfs:label>
        <rdfs:label xml:lang="en-us">hardness</rdfs:label>
        <skos:example xml:lang="en-us">Hardened bearing steel achieves a hardness of 62 HRC after quench and tempering</skos:example>
        <skos:prefLabel xml:lang="de">Härte</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">hardness</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strength(x) ← Hardness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Hardness quantifies the resistance of a material to localized deformation or plasticity caused by mechanical action, such as bending, crushing, or scratching</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Härte ist die Widerstandsfähigkeit eines Materials gegen lokalisierte Verformung oder Plastizität, die durch mechanische Einwirkung wie Biegen, Quetschen oder Kratzen verursacht wird</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;hardness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;hardness&apos; then x is a &apos;strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HardnessMeasurementCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HardnessMeasurementCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/MeasurementCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Härtemessfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">hardness measurement capability</rdfs:label>
        <skos:altLabel xml:lang="de">Indentierungsartefaktfunktionalität</skos:altLabel>
        <skos:altLabel xml:lang="en-us">indenting Artifact Functionality</skos:altLabel>
        <skos:example xml:lang="en-us">A Vickers hardness tester has the hardness measurement capability to indent materials up to 3000 HV</skos:example>
        <skos:prefLabel xml:lang="de">Härte-Messfähigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">hardness measurement capability</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MeasurementCapability(x) ← HardnessMeasurementCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Hardness measurement capability is a function that is realized during events in which an artifact is used to create an impression in a wide object</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Härte Messfähigkeit ist eine Funktion, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um einen Eindruck in ein weiter Objekt zu erzeugen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;hardness measurement capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;MeasurementCapability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;hardness measurement capability&apos; then x is a &apos;measurement capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatCapacity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatCapacity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Wärmekapazität</rdfs:label>
        <rdfs:label xml:lang="en-us">heat capacity</rdfs:label>
        <skos:example xml:lang="en-us">A 100 g steel block has a heat capacity of 50 J/K, measured by differential scanning calorimetry</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000777"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← HeatCapacity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Wärmekapazität ist die Wärmekapazität eines Materials, die sich als die Wärmemenge manifestiert, die erforderlich ist, um seine Temperatur um eine Einheit zu erhöhen, gemessen unter bestimmten Bedingungen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Heat capacity is a thermal capability of a material that manifests as the quantity of heat required to raise its temperature by one unit, measured under specified conditions</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;heat capacity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000777.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;heat capacity&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatOfFusion -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatOfFusion">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Enthalpy"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Schmelzenthalpie</rdfs:label>
        <rdfs:label xml:lang="en-us">heat of fusion</rdfs:label>
        <skos:altLabel xml:lang="de">Schmelzwärme</skos:altLabel>
        <skos:altLabel xml:lang="en-us">enthalpy of fusion</skos:altLabel>
        <skos:altLabel xml:lang="en-us">latent heat of melting</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Enthalpy(x) ← HeatOfFusion(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Heat of fusion is an enthalpy quality of a substance that specifies the amount of thermal energy required to convert a unit mass from solid to liquid phase at constant temperature and pressure</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Schmelzenthalpie ist eine Enthalpiequalität eines Stoffes, die die thermische Energie angibt, die benötigt wird, um eine Masseneinheit bei konstanter Temperatur und konstantem Druck von der festen in die flüssige Phase umzuwandeln</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;heat of fusion&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;enthalpy&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;heat of fusion&apos; then x is a &apos;enthalpy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">ΔH_fus</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatOfVaporization -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatOfVaporization">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Enthalpy"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Verdampfungsenthalpie</rdfs:label>
        <rdfs:label xml:lang="en-us">heat of vaporization</rdfs:label>
        <skos:altLabel xml:lang="de">Verdampfungswärme</skos:altLabel>
        <skos:altLabel xml:lang="en-us">enthalpy of vaporization</skos:altLabel>
        <skos:altLabel xml:lang="en-us">latent heat of vaporization</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Enthalpy(x) ← HeatOfVaporization(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Heat of vaporization is an enthalpy quality of a substance that specifies the amount of thermal energy required to convert a unit mass from liquid to vapour phase at constant temperature and pressure</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Verdampfungsenthalpie ist eine Enthalpiequalität eines Stoffes, die die thermische Energie angibt, die benötigt wird, um eine Masseneinheit bei konstanter Temperatur und konstantem Druck von der flüssigen in die gasförmige Phase umzuwandeln</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;heat of vaporization&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;enthalpy&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;heat of vaporization&apos; then x is a &apos;enthalpy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">ΔH_vap</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatTransferCoefficient -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatTransferCoefficient">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Wärmeübergangskoeffizient</rdfs:label>
        <rdfs:label xml:lang="en-us">heat transfer coefficient</rdfs:label>
        <skos:example xml:lang="en-us">A forced convection air-cooled heat sink has a heat transfer coefficient of 100 W/(m2·K)</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Heat_transfer_coefficient"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← HeatTransferCoefficient(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Wärmeübertragungskoeffizient stellt die Proportionalitätskonstante zwischen dem Wärmefluss und der thermodynamischen Antriebskraft für den Wärmefluss dar und wird zur Berechnung der Wärmeübertragung, typischerweise durch Konvektion, verwendet</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Heat transfer coefficient represents the proportionality constant between heat flux and the thermodynamic driving force for heat flow, used in calculating heat transfer, typically by convection</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;heat transfer coefficient&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Heat_transfer_coefficient.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;heat transfer coefficient&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatingCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatingCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Aufheizfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">heating capability</rdfs:label>
        <skos:example xml:lang="en-us">An induction heater has a heating capability of 10 kW, raising a steel billet to 1200 C in 60 s</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← HeatingCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Heizfähigkeit bezieht sich auf die Fähigkeit eines Materialartefakts, einen Temperaturanstieg in einem anderen Materialobjekt zu verursachen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Heating capability refers to a material artifact&apos;s ability to cause temperature increase in another material entity</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;heating capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;heating capability&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Height -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Height">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Höhe</rdfs:label>
        <rdfs:label xml:lang="en-us">height</rdfs:label>
        <skos:example xml:lang="en-us">A steel column has a height of 3.6 m between floor and ceiling connections</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000119"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Length(x) ← Height(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Höhe ist eine eindimensionale Ausdehnungsqualität, die die vertikale Abmessung eines Objekts oder Raums beschreibt, gemessen von der Basis bis zur Spitze</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Height is a 1-D extent quality describing the vertical dimension of an object or space, measured from the base to the top</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;height&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;length&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000119.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;height&apos; then x is a &apos;length&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Humidity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Humidity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="de">Feuchtigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">humidity</rdfs:label>
        <skos:example xml:lang="en-us">A drying oven maintains relative humidity below 5 % to prevent moisture absorption in polymer samples</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← Humidity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Luftfeuchtigkeit charakterisiert den Partialdruck der Luft, der durch den Wasserdampfgehalt entsteht, definiert als das Verhältnis von Wassermasse zu Volumen des Medium-Wasser-Gemisches</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Humidity characterizes air&apos;s partial pressure exerted by water vapor content, defined as the mass of water to volume of the medium-water mixture</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;humidity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical rate quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;humidity&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ImagingCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ImagingCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/MeasurementCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Bildgebungsfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">imaging capability</rdfs:label>
        <skos:example xml:lang="en-us">A scanning electron microscope has an imaging capability resolving features down to 1 nm</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MeasurementCapability(x) ← ImagingCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Bildgebungsfähigkeit ist die Messfähigkeit, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um eine Abbildung eines bestimmten Objekts, eines Ausschnitts von eine Objekt oder einer Klasse von Objekten zu generieren</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Imaging capability involves using an artifact to generate an image of a particular object, a portion of an object, or a class of objects</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;imaging capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;MeasurementCapability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;imaging capability&apos; then x is a &apos;measurement capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ImpactEnergy -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ImpactEnergy">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Schlagenergie</rdfs:label>
        <rdfs:label xml:lang="en-us">impact energy</rdfs:label>
        <skos:altLabel xml:lang="en-us">Charpy impact energy</skos:altLabel>
        <skos:altLabel xml:lang="de">Kerbschlagenergie</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalCapability(x) ← ImpactEnergy(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Impact energy is a mechanical capability of a material that characterises the total energy absorbed by a standardised notched specimen during fracture under a single impact blow, as measured in a Charpy or Izod test</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Schlagenergie ist eine mechanische Fähigkeit eines Materials, die die gesamte Energie beschreibt, die eine standardisierte gekerbte Probe beim Bruch unter einem einzigen Schlagimpuls absorbiert, gemessen im Charpy- oder Izod-Versuch</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;impact energy&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;impact energy&apos; then x is a &apos;mechanical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">KV</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ImpactStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ImpactStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Toughness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Schlagzähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">impact strength</rdfs:label>
        <skos:altLabel xml:lang="de">Schlagfestigkeit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">mpact strength</skos:altLabel>
        <skos:example xml:lang="en-us">A Charpy impact test on notched steel gives an impact strength of 120 J, indicating good toughness</skos:example>
        <skos:prefLabel xml:lang="de">Schlagzähigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">impact strength</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Toughness(x) ← ImpactStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Impact strength is the ability of a material to absorb energy and plastically deform without fracturing under dynamic load</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Schlagzähigkeit bezeichnet die Fähigkeit eines Materials, Energie zu absorbieren und bei Anwendung einer dynamischen Last plastisch zu verformen, ohne dass es bricht</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;impact strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;toughness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;impact strength&apos; then x is a &apos;toughness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/IndentationHardness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/IndentationHardness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Indentationshärte</rdfs:label>
        <rdfs:label xml:lang="en-us">indentation hardness</rdfs:label>
        <skos:example xml:lang="en-us">The indentation hardness of a polymer measured by the Shore D scale is 75, indicating semi-rigid behavior</skos:example>
        <skos:note>Was a subclass of &apos;Hardness&apos;</skos:note>
        <skos:prefLabel xml:lang="de">Indentationshärte</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">identation hardness</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Hardness(x) ← IndentationHardness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Indentation hardness is a measure of a material&apos;s resistance to indentation</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Indentationshärte ist ein Maß für die Widerstandsfähigkeit eines Materials gegen Eindringen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;indentation hardness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;hardness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;indentation hardness&apos; then x is a &apos;hardness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Inductance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Inductance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Induktion</rdfs:label>
        <rdfs:label xml:lang="en-us">inductance</rdfs:label>
        <skos:example xml:lang="en-us">A solenoid coil of 100 turns has an inductance of 1 mH, opposing rapid current changes</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Inductance"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← Inductance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Inductance is the tendency of an electrical conductor to oppose a change in electric current through electromagnetic induction, creating back electromotive force</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Induktivität ist die Tendenz eines elektrischen Leiters, einer Änderung des elektrischen Stroms durch elektromagnetische Induktion entgegenzuwirken und so eine elektromotorische Gegenkraft zu erzeugen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;inductance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Inductance.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;inductance&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/InteratomicInteractionEnergy -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/InteratomicInteractionEnergy">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Energy"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">interatomare Wechselwirkungsenergie</rdfs:label>
        <rdfs:label xml:lang="en-us">interatomic interaction energy</rdfs:label>
        <skos:example xml:lang="en-us">The interatomic interaction energy between Fe atoms in the BCC lattice determines the cohesive strength of iron</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020155"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Energy(x) ← InteratomicInteractionEnergy(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Interatomare Wechselwirkungsenergie ist eine Energiequalität, die einem Atomaggregat innewohnt und als die Energie definiert ist, die dem System hinzugefügt oder daraus entnommen wird, wenn ein Atom unendlich vom verbleibenden Aggregat entfernt wird</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Interatomic interaction energy is an energy quality that inheres in an atom aggregate and is defined as the energy added to or removed from the system when one atom is moved infinitely away from the remaining aggregate</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;interatomic interaction energy&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;energy&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020155.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;interatomic interaction energy&apos; then x is a &apos;energy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/InternalEnergy -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/InternalEnergy">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Energy"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">innere Energie</rdfs:label>
        <rdfs:label xml:lang="en-us">internal energy</rdfs:label>
        <skos:example xml:lang="en-us">The internal energy of a gas increases when heat is added at constant volume</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020151"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Energy(x) ← InternalEnergy(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Innere Energie ist eine Energiequalität einer materiellen Einheit, die die gesamte im System gespeicherte thermodynamische Energie angibt, einschließlich der kinetischen und potentiellen Energie seiner konstituierenden Teilchen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Internal energy is an energy quality of a material entity that specifies the total thermodynamic energy stored within the system, including kinetic and potential energy of its constituent particles</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;internal energy&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;energy&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020151.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;internal energy&apos; then x is a &apos;energy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/KinematicViscosity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/KinematicViscosity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">kinematic viscosity</rdfs:label>
        <rdfs:label xml:lang="de">kinematische Viskosität</rdfs:label>
        <skos:altLabel xml:lang="en-us">kinetic viscosity</skos:altLabel>
        <skos:altLabel xml:lang="de">kinetische Viskosität</skos:altLabel>
        <skos:example xml:lang="en-us">The kinematic viscosity of water at 20 C is about 1e-6 m2/s, used in pipe flow calculations</skos:example>
        <skos:prefLabel xml:lang="en-us">kinematic viscosity</skos:prefLabel>
        <skos:prefLabel xml:lang="de">kinematische Viskosität</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Viscosity(x) ← KinematicViscosity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die kinematische Viskosität ist das Verhältnis der dynamischen Viskosität zur Dichte</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Kinematic viscosity is the ratio of dynamic viscosity to density</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;kinematic viscosity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;viscosity&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;kinematic viscosity&apos; then x is a &apos;viscosity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/DimensionQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Länge</rdfs:label>
        <rdfs:label xml:lang="en-us">length</rdfs:label>
        <skos:example xml:lang="en-us">A steel rod measures 250 mm in length between its two end faces</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000122"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">DimensionQuality(x) ← Length(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Länge charakterisiert eine 1D-Ausdehnung, die dem Abstand zwischen zwei Punkten entspricht</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Length characterizes a 1-D extent equal to the distance between two points</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;length&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;DimensionQuality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000122.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;length&apos; then x is a &apos;dimension quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LinearThermalExpansionCoefficient -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LinearThermalExpansionCoefficient">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalExpansionCoefficient"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">linear thermal expansion coefficient</rdfs:label>
        <rdfs:label xml:lang="de">linearer thermischer Ausdehnungkoeffizient</rdfs:label>
        <skos:example xml:lang="en-us">Aluminum has a linear thermal expansion coefficient of 23.1e-6 per K, causing notable dimensional changes during heating</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalExpansionCoefficient(x) ← LinearThermalExpansionCoefficient(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der lineare Wärmeausdehnungskoeffizient quantifiziert den Grad, um den sich ein Material beim Erhitzen in eine bestimmte axiale Richtung ausdehnt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Linear thermal expansion coefficient quantifies the degree to which a material expands upon heating into a specific axial direction</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;linear thermal expansion coefficient&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal expansion coefficient&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;linear thermal expansion coefficient&apos; then x is a &apos;thermal expansion coefficient&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LoadCellCapacity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LoadCellCapacity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="de">Kapazität der Wägezelle</rdfs:label>
        <rdfs:label xml:lang="en-us">load cell capacity</rdfs:label>
        <skos:example xml:lang="en-us">A tension-compression load cell has a load cell capacity of 50 kN for structural testing</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalCapability(x) ← LoadCellCapacity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Kapazität der Wägezelle ist die Messung der maximalen Kraft, die eine Wägezelle genau ablesen kann</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Load cell capacity measures the maximum force a load cell can accurately read</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;load cell capacity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;load cell capacity&apos; then x is a &apos;mechanical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LossModulus -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LossModulus">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ComplexModulus"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Verlustmodul</rdfs:label>
        <rdfs:label xml:lang="en-us">loss modulus</rdfs:label>
        <skos:example xml:lang="en-us">The loss modulus of a viscoelastic polymer at 1 Hz is 0.3 MPa, representing energy dissipation per cycle</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Dynamic_modulus"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ComplexModulus(x) ← LossModulus(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Loss modulus is the imaginary part of the complex modulus that measures the viscous portion of energy dissipated as heat per cycle in a viscoelastic material under oscillatory loading</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Verlustmodul ist der Imaginärteil des Komplexmoduls und misst den viskosen Anteil der pro Zyklus als Wärme dissipierten Energie in einem viskoelastischen Material unter schwingender Belastung</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;loss modulus&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;complex modulus&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Dynamic_modulus.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;loss modulus&apos; then x is a &apos;complex modulus&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">E&apos;&apos;</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LossTangent -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LossTangent">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicModulus"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Verlustwinkel</rdfs:label>
        <rdfs:label xml:lang="en-us">loss tangent</rdfs:label>
        <skos:example xml:lang="en-us">A PTFE cable insulator has a loss tangent of 0.0002 at 1 GHz, minimizing signal attenuation</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Dynamic_modulus"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">DynamicModulus(x) ← LossTangent(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Verlustfaktor, dargestellt als tan δ, ist das Verhältnis des Verlustmoduls zum Speichermodul in viskoelastischen Materialien und liefert ein Maß für die Dämpfung</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Loss tangent, represented as tan δ, is the ratio of the loss modulus to storage modulus in viscoelastic materials, providing a measure of damping</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;loss tangent&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;dynamic modulus&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Dynamic_modulus.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;loss tangent&apos; then x is a &apos;dynamic modulus&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LowerYieldStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LowerYieldStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/YieldStrength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">lower yield strength</rdfs:label>
        <rdfs:label xml:lang="de">untere Streckgrenze</rdfs:label>
        <skos:altLabel xml:lang="en-us">lower yield stress</skos:altLabel>
        <skos:altLabel xml:lang="de">untere Fließspannung</skos:altLabel>
        <skos:example xml:lang="en-us">The lower yield strength of mild steel is approximately 235 MPa, defining the onset of stable plastic flow</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Yield_(engineering)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">YieldStrength(x) ← LowerYieldStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Lower yield strength defines the stress at which a material exhibits plastic behavior after initial yielding</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Untere Streckgrenze beschreibt die Spannung, bei der ein Material nach dem anfänglichen Fließen plastisches Verhalten zeigt</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;lower yield strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;yield strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Yield_(engineering).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;lower yield strength&apos; then x is a &apos;yield strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LuminousEfficacy -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LuminousEfficacy">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Lichtausbeute</rdfs:label>
        <rdfs:label xml:lang="en-us">luminous efficacy</rdfs:label>
        <skos:example xml:lang="en-us">A modern LED achieves a luminous efficacy of 200 lm/W, far exceeding incandescent bulbs</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Luminous_efficacy"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← LuminousEfficacy(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Lichtausbeute misst, wie gut eine Lichtquelle sichtbares Licht erzeugt, berechnet als Lichtstrom geteilt durch Leistung, ausgedrückt in Lumen pro Watt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Luminous efficacy measures how well a light source produces visible light, calculated as luminous flux divided by power, expressed in lumens per watt</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;luminous efficacy&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical rate quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Luminous_efficacy.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;luminous efficacy&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LuminousIntensity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LuminousIntensity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Lichtstärke in cd gemessen</rdfs:label>
        <rdfs:label xml:lang="en-us">luminous intensity</rdfs:label>
        <skos:altLabel xml:lang="de">Lichtintensität</skos:altLabel>
        <skos:example xml:lang="en-us">A standard LED lamp emits a luminous intensity of 800 cd in the forward direction</skos:example>
        <skos:prefLabel xml:lang="de">Leuchtintensität</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">luminous intensity</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OpticalQuality(x) ← LuminousIntensity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Lichtstärke ist die Menge des sichtbaren Lichts, das pro Einheitswinkel in eine bestimmte Richtung von einer Quelle abgestrahlt wird, gemessen in Candela (cd)</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Luminous intensity quantifies the visible light emitted per unit solid angle in a particular direction from a source, measured in candela (cd)</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;luminous intensity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;optical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;luminous intensity&apos; then x is a &apos;optical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">magnetic capability</rdfs:label>
        <rdfs:label xml:lang="de">magnetische Fähigkeit</rdfs:label>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalCapability(x) ← MagneticCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Magnetic capability is a physical capability of a material that can be realized through interactions involving magnetic fields or magnetic ordering</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Magnetische Fähigkeit ist eine physische Fähigkeit eines Materials, die durch Wechselwirkungen mit Magnetfeldern oder magnetischer Ordnung realisiert werden kann</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;magnetic capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;magnetic capability&apos; then x is a &apos;physical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticFlux -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticFlux">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">magnetic flux</rdfs:label>
        <rdfs:label xml:lang="de">magnetischer Fluss</rdfs:label>
        <skos:altLabel xml:lang="de">Magnetfeld</skos:altLabel>
        <skos:altLabel xml:lang="en-us">magnetic field</skos:altLabel>
        <skos:example xml:lang="en-us">A transformer core carries a magnetic flux of 1 mWb through its cross-section at rated voltage</skos:example>
        <skos:prefLabel xml:lang="en-us">magnetic flux</skos:prefLabel>
        <skos:prefLabel xml:lang="de">magnetischer Fluss</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MagneticQuality(x) ← MagneticFlux(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Magnetic flux is the total number of magnetic field lines passing through a given area</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Magnetischer Fluss ist die Gesamtanzahl der Magnetfeldlinien, die durch eine bestimmte Fläche verlaufen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;magnetic flux&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;magnetic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;magnetic flux&apos; then x is a &apos;magnetic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticPermeability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticPermeability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">magnetic permeability</rdfs:label>
        <rdfs:label xml:lang="de">magnetische Permeabilität</rdfs:label>
        <skos:altLabel xml:lang="de">Permeabilität</skos:altLabel>
        <skos:altLabel xml:lang="en-us">permeability</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MagneticQuality(x) ← MagneticPermeability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Magnetic permeability is a magnetic quality of a material that quantifies its ability to support the formation of a magnetic field within itself, expressed as the ratio of magnetic flux density to the applied magnetic field intensity</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Magnetische Permeabilität ist eine magnetische Qualität eines Materials, die seine Fähigkeit quantifiziert, ein Magnetfeld in seinem Inneren zu unterstützen, ausgedrückt als Verhältnis der magnetischen Flussdichte zur aufgebrachten magnetischen Feldstärke</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;magnetic permeability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;magnetic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;magnetic permeability&apos; then x is a &apos;magnetic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">μ</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticQuality">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">magnetic quality</rdfs:label>
        <rdfs:label xml:lang="de">magnetische Qualität</rdfs:label>
        <skos:example xml:lang="en-us">The magnetic susceptibility of paramagnetic aluminum is a magnetic quality measured by a magnetometer</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← MagneticQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die magnetische Qualität charakterisiert die Reaktion eines materiellen Gebildes auf äußere Magnetfelder oder die Emission von Magnetfeldern</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Magnetic quality characterizes a material entity&apos;s response to external magnetic fields or its emission of magnetic fields</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;magnetic quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;magnetic quality&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticSusceptibility -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticSusceptibility">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">magnetic susceptibility</rdfs:label>
        <rdfs:label xml:lang="de">magnetische Suszeptibilität</rdfs:label>
        <skos:example xml:lang="en-us">Paramagnetic oxygen gas has a positive magnetic susceptibility of 3.73e-6 m3/mol at 20 C</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← MagneticSusceptibility(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Magnetic susceptibility is a physical relational quality of a material that quantifies the degree to which it becomes magnetized in response to an applied magnetic field, expressed as the dimensionless ratio of magnetization to applied field intensity</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Magnetische Suszeptibilität ist eine physikalische relationale Qualität eines Materials, die den Grad angibt, in dem es sich als Reaktion auf ein angelegtes Magnetfeld magnetisiert, ausgedrückt als dimensionsloses Verhältnis der Magnetisierung zur angelegten Feldstärke</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;magnetic susceptibility&apos; have not yet been formalized. Although χ = M/H is a well-defined ratio, a formal equivalence axiom would incorrectly classify any dimensionless relational quality of a magnetic bearer as magnetic susceptibility. Defined as a primitive subtype of &apos;physical relational quality&apos;.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;magnetic susceptibility&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">χ</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Malleability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Malleability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Ductility"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Formbarkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">malleability</rdfs:label>
        <skos:altLabel xml:lang="en-us">Malleable</skos:altLabel>
        <skos:altLabel xml:lang="de">formbar</skos:altLabel>
        <skos:example xml:lang="en-us">Gold has high malleability, allowing it to be hammered into sheets less than 100 nm thick</skos:example>
        <skos:prefLabel xml:lang="de">Formbarkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Malleability</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Ductility(x) ← Malleability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Formbarkeit beschreibt Materialien, die durch Hammern oder Walzen bearbeitet werden können und sich von Duktilität unterscheiden</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Malleability refers to a material&apos;s amenability to forming by hammering or rolling, distinct from ductility</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;malleability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;ductility&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;malleability&apos; then x is a &apos;ductility&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Mass -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Mass">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Masse</rdfs:label>
        <rdfs:label xml:lang="en-us">mass</rdfs:label>
        <skos:example xml:lang="en-us">A steel cylinder with density 7800 kg/m3 and volume 100 cm3 has a mass of 780 g</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Mass"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← Mass(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mass denotes intrinsic quality of a body, historically related to matter quantity, though distinct in modern physics with multiple definitions</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Masse bezeichnet die intrinsische Qualität eines Körpers, die historisch mit der Materiemenge zusammenhängt, in der modernen Physik jedoch mit mehreren Definitionen unterschiedlich ist</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mass&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Mass.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mass&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassConcentration -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassConcentration">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialComposition"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Massenkonzentration</rdfs:label>
        <rdfs:label xml:lang="en-us">mass concentration</rdfs:label>
        <skos:example xml:lang="en-us">A saline infusion solution has a NaCl mass concentration of 9 g/L</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Massenkonzentration"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MaterialComposition(x) ← MassConcentration(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Massenkonzentration verknüpft die Masse einer Mischungskomponente mit dem Gesamtvolumen in einer quantitativen Beschreibung, die häufig in Lösungen verwendet wird</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mass concentration links mass of a mixture component to the total volume in quantitative description, frequently used in solutions</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mass concentration&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;material composition&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Massenkonzentration.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mass concentration&apos; then x is a &apos;material composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassDiffusivity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassDiffusivity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Massendiffusivität</rdfs:label>
        <rdfs:label xml:lang="en-us">mass diffusivity</rdfs:label>
        <skos:altLabel xml:lang="de">Diffusionskoeffizient</skos:altLabel>
        <skos:altLabel xml:lang="en-us">diffusion coefficient</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← MassDiffusivity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mass diffusivity is a physical rate quality of a material that quantifies the rate at which a diffusing substance moves through it per unit concentration gradient, as described by Fick&apos;s first law</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Massendiffusivität ist eine physikalische Ratenqualität eines Materials, die die Geschwindigkeit beschreibt, mit der eine diffundierende Substanz pro Konzentrationsgradienten durch das Material transportiert wird, gemäß dem ersten Fickschen Gesetz</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mass diffusivity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical rate quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mass diffusivity&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">D</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassFlowRate -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassFlowRate">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Massendurchsatz</rdfs:label>
        <rdfs:label xml:lang="en-us">mass flow rate</rdfs:label>
        <skos:example xml:lang="en-us">A coolant pump delivers a mass flow rate of 2 kg/s of water through a heat exchanger</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Mass_flow_rate"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalProcessCharacteristic(x) ← MassFlowRate(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Massendurchfluss quantifiziert die pro Zeiteinheit fließende Masse und wird üblicherweise in Kilogramm pro Sekunde oder Pfund pro Sekunde gemessen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mass flow rate quantifies the mass passing per unit time, commonly measured in kilograms per second or pounds per second</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mass flow rate&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical process characteristic&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Mass_flow_rate.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mass flow rate&apos; then x is a &apos;physical process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassFraction -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassFraction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassRatio"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Massenanteil</rdfs:label>
        <rdfs:label xml:lang="en-us">mass fraction</rdfs:label>
        <skos:example xml:lang="en-us">A binary Al-4 wt% Cu alloy has a copper mass fraction of 0.04</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Massenanteil"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MassRatio(x) ← MassFraction(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Massenanteil beschreibt den relativen Anteil einer Masse an der Gesamtmasse einer Mischung, ein gängiges quantitatives Maß</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mass fraction describes the relative proportion of a mass to the total mass of a mixture, a common quantitative measure</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mass fraction&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mass ratio&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Massenanteil.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mass fraction&apos; then x is a &apos;mass ratio&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassMixRatio -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassMixRatio">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassRatio"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Massenmischungsverhältnis</rdfs:label>
        <rdfs:label xml:lang="en-us">mass mix ratio</rdfs:label>
        <skos:example xml:lang="en-us">A concrete mix uses a mass mix ratio of cement to aggregate of 1:4 for standard structural applications</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Massenverh%C3%A4ltnis"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MassRatio(x) ← MassMixRatio(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Das Massenmischungsverhältnis stellt das Verhältnis der Massen zweier Mischungskomponenten dar und liefert eine quantitative Beschreibung der Zusammensetzung</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mass mix ratio represents the ratio of masses of two mixture components, providing a quantitative composition description</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mass mix ratio&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mass ratio&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Massenverh%C3%A4ltnis.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mass mix ratio&apos; then x is a &apos;mass ratio&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassPotential -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassPotential">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Potential"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Massenpotential</rdfs:label>
        <rdfs:label xml:lang="en-us">mass potential</rdfs:label>
        <skos:example xml:lang="en-us">The mass potential of a raised water reservoir drives flow through a turbine at lower elevation</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Potential(x) ← MassPotential(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Das Massenpotential definiert eine skalare Größe, die die aufgrund der Position, Form oder Konfiguration eines Materials gespeicherte Energie beschreibt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mass potential defines a scalar quantity describing energy stored due to a material&apos;s position, shape, or configuration</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mass potential&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;potential&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mass potential&apos; then x is a &apos;potential&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassRatio -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassRatio">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialComposition"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Massenverhältnis</rdfs:label>
        <rdfs:label xml:lang="en-us">mass ratio</rdfs:label>
        <skos:example xml:lang="en-us">A fiber-reinforced composite has a fiber-to-matrix mass ratio of 60:40</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MaterialComposition(x) ← MassRatio(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Das Massenverhältnis bezeichnet eine relationale Qualität, die einen Massenwert im Verhältnis zu einem anderen ausdrückt und typischerweise eine dimensionslose Zahl ergibt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mass ratio denotes a relational quality expressing one mass value relative to another, typically producing a dimensionless number</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mass ratio&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;material composition&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mass ratio&apos; then x is a &apos;material composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialComposition -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialComposition">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Materialzusammensetzung</rdfs:label>
        <rdfs:label xml:lang="en-us">material composition</rdfs:label>
        <skos:example xml:lang="en-us">The material composition of 304 stainless steel includes 18 wt% Cr and 8 wt% Ni</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← MaterialComposition(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Materialzusammensetzung beschreibt das Verhältnis von Stoffen oder Komponenten, aus denen ein Material besteht, unter Berücksichtigung von Arten, Proportionen und Anordnungen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Material composition describes the ratio of substances or components making up a material, considering types, proportions, and arrangements</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;material composition&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;material composition&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialFatigue -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialFatigue">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Materialermüdung</rdfs:label>
        <rdfs:label xml:lang="en-us">material fatigue</rdfs:label>
        <skos:altLabel xml:lang="de">Ermüdung des Materials</skos:altLabel>
        <skos:altLabel xml:lang="en-us">fatigue of material</skos:altLabel>
        <skos:example xml:lang="en-us">Repeated cyclic loading at 400 MPa induces material fatigue in a steel shaft, leading to crack initiation</skos:example>
        <skos:prefLabel xml:lang="de">Materialermüdung</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">material fatigue</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalCapability(x) ← MaterialFatigue(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Material fatigue is the failure of a material caused by repeated or sustained loading below its ultimate strength.</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Materialermüdung ist das Versagen von Werkstoffen infolge wiederholter oder dauernder Belastung unterhalb der Probenfestigkeit</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;aterial fatigue&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;material fatigue&apos; then x is a &apos;mechanical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialProperty -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialProperty">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Materialeigenschaft</rdfs:label>
        <rdfs:label xml:lang="en-us">material property</rdfs:label>
        <iof-av:firstOrderLogicDefinition xml:lang="en-us">MaterialProperty(x) ↔ (PhysicalCapability(x) ∨ PhysicalQuality(x) ∨ PhysicalRelationalQuality(x))</iof-av:firstOrderLogicDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Material property is a quality or capability of a material entity used to characterize its technical performance</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Materielle Eigenschaft ist eine Qualität oder Fähigkeit einer materiellen Einheit, die zur Charakterisierung ihrer technischen Leistung verwendet wird</iof-av:naturalLanguageDefinition>
        <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-us">every instance of &apos;material property&apos; is defined as exactly an instance of &apos;physical capability&apos;, &apos;physical quality&apos; or &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">mechanical capability</rdfs:label>
        <rdfs:label xml:lang="de">mechanische Fähigkeit</rdfs:label>
        <skos:example xml:lang="en-us">A spring steel coil spring has the mechanical capability to store 50 J of elastic energy per cycle</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalCapability(x) ← MechanicalCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mechanical capability can be realized through an entity related to mechanical interaction</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Mechanische Fähigkeiten können durch eine Entität realisiert werden, die mit mechanischer Interaktion zusammenhängt</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mechanical capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mechanical capability&apos; then x is a &apos;physical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalImpulse -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalImpulse">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">mechanical impulse</rdfs:label>
        <rdfs:label xml:lang="de">mechanischer Impuls</rdfs:label>
        <skos:example xml:lang="en-us">A drop weight imparts a mechanical impulse of 50 N·s to the Charpy specimen during impact</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Impulse_(physics)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalProcessCharacteristic(x) ← MechanicalImpulse(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mechanical impulse signifies the change in momentum of an object when subjected to a force over time</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Unter mechanischem Impuls versteht man die Änderung des Impulses eines Objekts, wenn es im Laufe der Zeit einer Kraft ausgesetzt wird</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mechanical impulse&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical process characteristic&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Impulse_(physics).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mechanical impulse&apos; then x is a &apos;physical process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalQuality">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">mechanical quality</rdfs:label>
        <rdfs:label xml:lang="de">mechanische Qualität</rdfs:label>
        <skos:example xml:lang="en-us">The fatigue strength of a connecting rod is a mechanical quality critical for engine reliability</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← MechanicalQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die mechanische Qualität bezieht sich auf die Leistung eines Materials, wenn es mechanischen Belastungen standhält</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mechanical quality is related to the performance of a material when enduring mechanical loads</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mechanical quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mechanical quality&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Festigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">mechanical strength</rdfs:label>
        <skos:example xml:lang="en-us">The mechanical strength of a fiber composite increases with fiber volume fraction up to an optimum value</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strength(x) ← MechanicalStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Festigkeit in der Mechanik von Materialien bezeichnet die Fähigkeit eines Materials, eine angewandte Last ohne Versagen oder plastische Verformung zu widerstehen. Innere Kräfte werden auf der Basis einer Einheit als Spannungen ausgedrückt und bewirken eine Verformung des Materials, bekannt als Dehnung</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mechanical strength refers to a material&apos;s ability to resist applied load without failure or plastic deformation, characterized by stress and strain</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;mechanical strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mechanical strength&apos; then x is a &apos;strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MeltingPoint -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MeltingPoint">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Schmelzpunkt</rdfs:label>
        <rdfs:label xml:lang="en-us">melting point</rdfs:label>
        <skos:example xml:lang="en-us">Pure aluminum melts at 660 C, which is its melting point at standard pressure</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000851"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← MeltingPoint(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Schmelzpunkt ist eine thermodynamische Eigenschaft einer Substanz, die die Temperatur angibt, bei der sie bei einem bestimmten Druck vom festen in den flüssigen Zustand übergeht</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Melting point is a thermo dynamic quality of a substance that specifies the temperature at which it transitions from solid to liquid state at a given pressure</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;melting point&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000851.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;melting point&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MohsHardness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MohsHardness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ScratchHardness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">Mohs hardness</rdfs:label>
        <rdfs:label xml:lang="de">Mohshärte</rdfs:label>
        <skos:example xml:lang="en-us">Quartz has a Mohs hardness of 7, resisting scratching by feldspar but not by corundum</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000861"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ScratchHardness(x) ← MohsHardness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Mohs-Härte ist die Kratzhärte eines Materials, die die Kratzfestigkeit angibt. Sie wird auf der Mohs-Skala gemessen, indem das Material mit einer Reihe von Referenzmineralien verglichen wird</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Mohs hardness is a scratch hardness of a material that specifies its resistance to being scratched, measured on the Mohs scale by comparing the material against a set of reference minerals</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;Mohs hardness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;scratch hardness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000861.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;mohs hardness&apos; then x is a &apos;scratch hardness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/NumberDensity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/NumberDensity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Stoffmenge</rdfs:label>
        <rdfs:label xml:lang="en-us">number density</rdfs:label>
        <skos:example xml:lang="en-us">Austenite at 900 C has a number density of about 6e28 iron atoms per cubic meter</skos:example>
        <skos:prefLabel xml:lang="en-us">Number Density</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Density(x) ← NumberDensity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Zahlendichte misst die Anzahl der Objekte pro Volumen- oder Flächeneinheit</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Number density measures the number of objects per unit volume or area</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;number density&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;density&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;number density&apos; then x is a &apos;density&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odor -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odor">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OlfactoricQuantity"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Geruch</rdfs:label>
        <rdfs:label xml:lang="en-us">odor</rdfs:label>
        <skos:example xml:lang="en-us">The characteristic odor of acetic acid is detectable in dilute vinegar solutions</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000058"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OlfactoricQuantity(x) ← Odor(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Geruch ist eine morphologische Eigenschaft, die einem Träger innewohnt, dessen Moleküle von einem Geruchsrezeptor verteilt und wahrgenommen werden</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Odor is a morphologic quality inhering in a bearer whose molecules are dispersed and perceived by an odorant receptor</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;odor&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;olfactoric quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000058.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;odor&apos; then x is a &apos;olfactoric quantity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odorless -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odorless">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odor"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">geruchlos</rdfs:label>
        <rdfs:label xml:lang="en-us">odorless</rdfs:label>
        <skos:example xml:lang="en-us">Distilled water is odorless under standard conditions, emitting no detectable volatile compounds</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001208"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Odor(x) ← Odorless(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Geruchlos bezeichnet eine Geruchsqualität, die einem geruchlosen Träger innewohnt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Odorless denotes an odor quality inhering in a bearer lacking odor</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;odorless&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;odor&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001208.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;odorless&apos; then x is a &apos;odor&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odorous -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odorous">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odor"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">odorous</rdfs:label>
        <rdfs:label xml:lang="de">riechend</rdfs:label>
        <skos:example xml:lang="en-us">Hydrogen sulfide is odorous, detectable by humans at concentrations as low as 0.5 ppb</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001331"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Odor(x) ← Odorous(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Geruchlich bezeichnet eine Geruchsqualität, die einem Geruchsträger innewohnt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Odorous denotes an odor quality inhering in a bearer possessing odor</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;odorous&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;odor&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001331.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;odorous&apos; then x is a &apos;odor&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OlfactoricQuantity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OlfactoricQuantity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">olfactoric quality</rdfs:label>
        <rdfs:label xml:lang="de">olfaktorische Qualität</rdfs:label>
        <skos:example xml:lang="en-us">The pungent olfactoric quality of ammonia is detectable at concentrations above 5 ppm</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← OlfactoricQuantity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die olfaktorische Menge bezieht sich auf die qualitativen Eigenschaften einer materiellen Einheit, wie sie vom Duftsystem wahrgenommen werden</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Olfactoric quantity relates to a material entity&apos;s qualitative characteristics as perceived by the scent system</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;olfactoric quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;olfactoric quality&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OperationalStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OperationalStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Betriebsfestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">operational strength</rdfs:label>
        <skos:altLabel xml:lang="de">Betriebsstärke</skos:altLabel>
        <skos:altLabel xml:lang="en-us">operation strength</skos:altLabel>
        <skos:example xml:lang="en-us">The operational strength of a drive shaft is the maximum cyclic stress it sustains without fatigue failure in service</skos:example>
        <skos:prefLabel xml:lang="de">Betriebsfestigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">operational strength</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strength(x) ← OperationalStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Betriebsfestigkeit beschreibt die Fähigkeit eines Systems, seine vorgesehene Funktion in einer betrieblichen Umgebung auszuführen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Operational strength describes a system&apos;s ability to perform its intended function in an operational environment</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;operational strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;operational strength&apos; then x is a &apos;strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalAbsorptance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalAbsorptance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">optical absorptance</rdfs:label>
        <rdfs:label xml:lang="de">optische Absorption</rdfs:label>
        <skos:example xml:lang="en-us">A solar absorber coating has an optical absorptance of 0.96, converting most sunlight to heat</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← OpticalAbsorptance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die optische Absorption definiert das Verhältnis der absorbierten Strahlungsleistung zur einfallenden Strahlungsleistung und gibt Aufschluss über die Absorptionsfähigkeit eines Mediums</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Optical absorptance defines the ratio of absorbed radiant power to incident radiant power, indicating a medium&apos;s absorption capability</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;optical absorptance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical rate quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;optical absorptance&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">optical capability</rdfs:label>
        <rdfs:label xml:lang="de">optische Fähigkeit</rdfs:label>
        <skos:example xml:lang="en-us">A camera lens has an optical capability of resolving 100 line pairs per mm at the image plane</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalCapability(x) ← OpticalCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Optical capability describes interactions related to light occurring via an entity</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Optische Fähigkeit beschreibt die Wechselwirkungen im Zusammenhang mit Licht, die über eine Entität stattfinden</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;optical capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;optical capability&apos; then x is a &apos;physical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalQuality">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">optical quality</rdfs:label>
        <rdfs:label xml:lang="de">optische Qualität</rdfs:label>
        <skos:example xml:lang="en-us">The optical quality of a mirror is assessed by its surface flatness and reflectance uniformity</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← OpticalQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die optische Qualität charakterisiert die Interaktionsergebnisse materieller Einheiten mit Lichtemissionen oder deren Erzeugung von Lichtemissionen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Optical quality characterizes the interaction results of material entities with light emissions or their generation of light emissions</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;optical quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;optical quality&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalReflectance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalReflectance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">optical reflectance</rdfs:label>
        <rdfs:label xml:lang="de">optische Reflexion</rdfs:label>
        <skos:example xml:lang="en-us">A silver mirror has an optical reflectance of 98 % at 600 nm wavelength</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← OpticalReflectance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der optische Reflexionsgrad wird durch das Verhältnis der reflektierten Strahlungsleistung zur einfallenden Strahlungsleistung definiert und bewertet die Reflexionsfähigkeit</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Optical reflectance is defined by the ratio of reflected radiant power to incident radiant power, assessing reflective capacity</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;optical reflectance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical rate quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;optical reflectance&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalTransmittance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalTransmittance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">optical transmittance</rdfs:label>
        <rdfs:label xml:lang="de">optische Transmittance</rdfs:label>
        <skos:example xml:lang="en-us">A 3 mm thick soda-lime glass pane has an optical transmittance of 90 % in the visible range</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← OpticalTransmittance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die optische Durchlässigkeit wird durch das Verhältnis der übertragenen Strahlungsleistung zur einfallenden Strahlungsleistung definiert und dient der Beurteilung der Übertragungseffizienz</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Optical transmittance is defined by the ratio of transmitted radiant power to incident radiant power, assessing transmission efficiency</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;optical transmittance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical rate quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;optical transmittance&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Perimeter -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Perimeter">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Umfang</rdfs:label>
        <rdfs:label xml:lang="en-us">perimeter</rdfs:label>
        <skos:example xml:lang="en-us">The perimeter of a square cross-section beam of 50 mm side length is 200 mm</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001711"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Length(x) ← Perimeter(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Umfang misst eine eindimensionale Ausdehnung, die einem zweidimensionalen Träger innewohnt und die Entfernung um ihn herum darstellt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Perimeter measures a 1-D extent inhering in a two-dimensional bearer, representing the distance around it</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;perimeter&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;length&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001711.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;perimeter&apos; then x is a &apos;length&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhaseVelocity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhaseVelocity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Speed"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Phasengeschwindigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">phase velocity</rdfs:label>
        <skos:example xml:lang="en-us">The phase velocity of a longitudinal ultrasonic wave in steel is approximately 5900 m/s</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Speed(x) ← PhaseVelocity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Phasengeschwindigkeit bezieht sich auf die Geschwindigkeit, mit der sich die Phase einer Welle ausbreitet, definiert als Wellenlänge geteilt durch die Zeitperiode</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Phase velocity refers to the rate at which the phase of a wave propagates, defined as wavelength divided by time period</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;phase velocity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;speed&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;phase velocity&apos; then x is a &apos;speed&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalAction -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalAction">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000057"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000040"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasQuality"/>
                                        <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasProcessCharacteristic"/>
                        <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Action"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">physical action</rdfs:label>
        <rdfs:label xml:lang="de">physikalische Aktion</rdfs:label>
        <iof-av:firstOrderLogicDefinition xml:lang="en-us">PhysicalAction(x) ↔ (∃b ((obo:BFO_0000040(b) ∧ ∃c (PhysicalRelationalQuality(c) ∧ hasQuality(b, c))) ∧ obo:BFO_0000057(x, b)) ∨ ∃d (PhysicalProcessCharacteristic(d) ∧ hasProcessCharacteristic(x, d)))</iof-av:firstOrderLogicDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Körperliche Aktion stellt einen Reiz dar, der eine physische Interaktion mit einem Objekt auslöst</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Physical action represents a stimulus enacting a physical interaction with an object</iof-av:naturalLanguageDefinition>
        <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-us">every instance of &apos;physical action&apos; is defined as exactly an instance of &apos;that &apos;obo:BFO_0000057&apos; some an instance of &apos;BFO_0000040&apos; and that &apos;hasQuality&apos; some &apos;physical relational quality&apos;&apos; or &apos;that &apos;hasProcessCharacteristic&apos; some &apos;physical process characteristic&apos;&apos;</iof-av:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">physical capability</rdfs:label>
        <rdfs:label xml:lang="de">physische Fähigkeit</rdfs:label>
        <skos:example xml:lang="en-us">A superhydrophobic coating has the physical capability to repel water droplets with contact angles above 150 degrees</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Capability(x) ← PhysicalCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die physische Fähigkeit beschreibt eine Fähigkeit, die durch eine Entität in einer physischen Interaktion realisiert wird und das Interesse eines Agenten erfüllt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Physical capability describes a capability realized through an entity in a physical interaction, fulfilling an agent&apos;s interest</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;physical capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;Capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;physical capability&apos; then x is a &apos;capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/ProcessCharacteristic"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">physical process characteristic</rdfs:label>
        <rdfs:label xml:lang="de">physikalische Prozesscharakteristik</rdfs:label>
        <skos:example xml:lang="en-us">The cooling rate during quenching is a physical process characteristic influencing microstructure formation</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ProcessCharacteristic(x) ← PhysicalProcessCharacteristic(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die physikalischen Prozesseigenschaften definieren Attribute eines Prozesses, die eine physikalische Interaktion über die Zeit konkretisieren</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Physical process characteristic defines attributes of a process concretizing a physical interaction over time</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;physical process characteristic&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;ProcessCharacteristic&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;physical process characteristic&apos; then x is a &apos;process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy xml:lang="en-us">A Quality that inheres in a material entity that is an independent continuant which has some portion of matter as continuant part</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">physical quality</rdfs:label>
        <rdfs:label xml:lang="de">physische Qualität</rdfs:label>
        <skos:example xml:lang="en-us">The density of a material is a physical quality that can be measured by Archimedes&apos; principle</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">BFO_0000019(x) ← PhysicalQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die physische Qualität bezieht sich auf Eigenschaften oder Merkmale, die sich auf die physische Präsenz oder Interaktion einer Entität beziehen, unabhängig von anderen Entitäten</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Physical quality pertains to properties or characteristics related to an entity&apos;s physical presence or interaction, independent of other entities</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;physical quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;BFO_0000019&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;physical quality&apos; then x is a &apos;b f o_0000019&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">physical rate quality</rdfs:label>
        <rdfs:label xml:lang="de">physische Geschwindigkeitsqualität</rdfs:label>
        <skos:example xml:lang="en-us">The rate of thermal expansion of a metal rod during quenching is a physical rate quality</skos:example>
        <iof-av:explanatoryNote xml:lang="en-us">Rate =(def.) a measure, quantity, or frequency, typically one measured against some other quantity or measure</iof-av:explanatoryNote>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← PhysicalRateQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die physikalische Geschwindigkeitsqualität bezeichnet den Quotienten zweier physikalischer Größen in unterschiedlichen Einheiten, der die Änderungsrate einer Größe im Verhältnis zu einer anderen darstellt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Physical rate quality denotes the quotient of two physical quantities in different units, representing one quantity&apos;s rate of change in relation to another</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;physical rate quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;physical rate quality&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <AnnotationVocabulary1:explanatoryNote xml:lang="en-us">Rate =(def.) a measure, quantity, or frequency, typically one measured against some other quantity or measure</AnnotationVocabulary1:explanatoryNote>
        <AnnotationVocabulary1:naturalLanguageDefinition xml:lang="en-us">Physical rate quality denotes the quotient of two physical quantities in different units, representing one quantity&apos;s rate of change in relation to another</AnnotationVocabulary1:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/explanatoryNote"/>
        <owl:annotatedTarget xml:lang="en-us">Rate =(def.) a measure, quantity, or frequency, typically one measured against some other quantity or measure</owl:annotatedTarget>
        <AnnotationVocabulary:directSource xml:lang="en-us">New Oxford American Dictionary</AnnotationVocabulary:directSource>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
        <owl:annotatedTarget xml:lang="en-us">Physical rate quality denotes the quotient of two physical quantities in different units, representing one quantity&apos;s rate of change in relation to another</owl:annotatedTarget>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Rate_(mathematics)"/>
    </owl:Axiom>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalReaction -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalReaction">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Reaction"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">physical reaction</rdfs:label>
        <rdfs:label xml:lang="de">physikalische Antwort</rdfs:label>
        <iof-av:firstOrderLogicDefinition xml:lang="en-us">PhysicalReaction(x) ↔ ∃b (PhysicalCapability(b) ∧ obo:BFO_0000055(x, b))</iof-av:firstOrderLogicDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Physical reaction characterizes a process where a physical capability of entity X is realized in response to a physical action involving X or more material entities</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Physikalische Reaktion charakterisiert einen Prozess, bei dem eine physische Fähigkeit von Entität X als Reaktion auf eine physische Aktion realisiert wird, an der X oder mehr materielle Entitäten beteiligt sind</iof-av:naturalLanguageDefinition>
        <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-us">every instance of &apos;physical reaction&apos; is defined as exactly that &apos;obo:BFO_0000055&apos; some &apos;physical capability&apos;</iof-av:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">physical relational quality</rdfs:label>
        <rdfs:label xml:lang="de">physisch relative Qualität</rdfs:label>
        <skos:example xml:lang="en-us">The coefficient of friction between two surfaces is a physical relational quality inhering in both contacting materials</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">BFO_0000145(x) ← PhysicalRelationalQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die physische Beziehungsqualität bezieht sich auf Eigenschaften oder Merkmale einer Entität, die von ihrer Beziehung zu anderen Entitäten abhängig sind</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Physical relational quality pertains to properties or characteristics of an entity dependent on its relation to other entities</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;physical relational quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;BFO_0000145&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;physical relational quality&apos; then x is a &apos;b f o_0000145&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PiezoelectricCoefficient -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PiezoelectricCoefficient">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">piezoelectric coefficient</rdfs:label>
        <rdfs:label xml:lang="de">piezoelektrischer Koeffizient</rdfs:label>
        <skos:altLabel xml:lang="en-us">piezoelectric constant</skos:altLabel>
        <skos:altLabel xml:lang="de">piezoelektrische Konstante</skos:altLabel>
        <skos:example xml:lang="en-us">The d33 piezoelectric coefficient of PZT ceramics is about 400 pC/N, enabling sensitive force sensing</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← PiezoelectricCoefficient(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Piezoelectric coefficient is a physical relational quality of a material that quantifies the coupling between mechanical stress and electric polarization, expressed as the ratio of electric displacement to applied mechanical stress or the ratio of strain to applied electric field</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Piezoelektrischer Koeffizient ist eine physikalische relationale Qualität eines Materials, die die Kopplung zwischen mechanischer Spannung und elektrischer Polarisation quantifiziert, ausgedrückt als Verhältnis der elektrischen Verschiebung zur angelegten mechanischen Spannung oder des Dehnungsanteils zum angelegten elektrischen Feld</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;piezoelectric coefficient&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;piezoelectric coefficient&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">d</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PixelDensity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PixelDensity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/NumberDensity"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="de">Pixeldichte</rdfs:label>
        <rdfs:label xml:lang="en-us">pixel density</rdfs:label>
        <skos:example xml:lang="en-us">A 4K display panel has a pixel density of 210 ppi, providing sharp text rendering</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">NumberDensity(x) ← PixelDensity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Pixel density describes the relationship between the number of pixels and the area they occupy on a related entity</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Pixeldichte beschreibt das Verhältnis zwischen der Anzahl der Pixel und der Fläche, die sie auf einer verwandten Entität einnehmen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;pixel density&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;number density&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;pixel density&apos; then x is a &apos;number density&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PlasticStrain -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PlasticStrain">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">plastic strain</rdfs:label>
        <rdfs:label xml:lang="de">plastische Deformation</rdfs:label>
        <skos:altLabel xml:lang="en-us">plastic deformation</skos:altLabel>
        <skos:altLabel xml:lang="de">plastische Verformung</skos:altLabel>
        <skos:example xml:lang="en-us">After exceeding yield strength, a steel rod undergoes 5 % plastic strain that remains after unloading</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Plasticity_(physics)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strain(x) ← PlasticStrain(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Plastic strain describes permanent deformation occurring when a material is subjected to stress beyond its elastic limit</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Plastische Deformation beschreibt die dauerhafte Verformung, die auftritt, wenn ein Material einer Belastung ausgesetzt wird, die über seine elastische Grenze hinausgeht</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;plastic strain&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strain&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Plasticity_(physics).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;plastic strain&apos; then x is a &apos;strain&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Plasticity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Plasticity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Plastizität</rdfs:label>
        <rdfs:label xml:lang="en-us">plasticity</rdfs:label>
        <skos:example xml:lang="en-us">Low-carbon steel exhibits high plasticity, allowing deep drawing without cracking</skos:example>
        <skos:prefLabel xml:lang="de">Plastizität</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">plasticity</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strength(x) ← Plasticity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Plasticity signifies a material&apos;s ability to undergo permanent deformation without breaking or cracking</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Plastizität bezeichnet die Fähigkeit eines Materials, dauerhafte Verformungen ohne Bruch oder Riss zu erleiden</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;plasticity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;plasticity&apos; then x is a &apos;strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PoissonEffect -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PoissonEffect">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Querkontraktion</rdfs:label>
        <rdfs:label xml:lang="en-us">poisson effect</rdfs:label>
        <skos:example xml:lang="en-us">A rubber cylinder loaded axially expands radially due to the Poisson effect, with a ratio of about 0.5</skos:example>
        <skos:note>Was a subclass of &apos;Mechanical Quality&apos;</skos:note>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Poisson%27s_ratio"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalCapability(x) ← PoissonEffect(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Poisson effect describes deformation perpendicular to the direction of loading, named after Siméon Poisson</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Querkontraktion beschreibt die Deformation senkrecht zur Belastungsrichtung, benannt nach Siméon Poisson</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;poisson effect&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Poisson%27s_ratio.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;poisson effect&apos; then x is a &apos;mechanical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PoissonRatio -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PoissonRatio">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PoissonEffect"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Poissonzahl</rdfs:label>
        <rdfs:label xml:lang="en-us">poisson&apos;s ratio</rdfs:label>
        <skos:example xml:lang="en-us">Rubber has a Poisson&apos;s ratio close to 0.5, indicating nearly incompressible behavior under loading</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Poisson%27s_ratio"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PoissonEffect(x) ← PoissonRatio(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Poisson&apos;s ratio is a measure of the Poisson effect, with values typically between 0.0 and 0.5 for most materials</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Poissonzahl ist ein Maß für den Poisson-Effekt, mit Werten typischerweise zwischen 0,0 und 0,5 für die meisten Materialien</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;poisson&apos;s ratio&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;poisson effect&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Poisson%27s_ratio.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;poisson&apos;s ratio&apos; then x is a &apos;poisson effect&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Potential -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Potential">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Potenzial</rdfs:label>
        <rdfs:label xml:lang="en-us">potential</rdfs:label>
        <skos:example xml:lang="en-us">The gravitational potential at the top of a 10 m column of water corresponds to a pressure head of 98 kPa</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← Potential(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Potential describes the capacity of an entity to perform work or transform due to its position or configuration within a system</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Potenzial beschreibt die Fähigkeit einer Entität, Arbeit zu leisten oder sich aufgrund ihrer Position oder Konfiguration innerhalb eines Systems zu transformieren</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;potential&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;potential&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pressure -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pressure">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Druck</rdfs:label>
        <rdfs:label xml:lang="en-us">pressure</rdfs:label>
        <skos:example xml:lang="en-us">A car tire is inflated to a pressure of 2.5 bar above atmospheric to support the vehicle load</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000896"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← Pressure(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Druck definiert die Menge an Kraft, die pro Flächeneinheit aufgebracht wird und das Potenzial an Energie innerhalb eines Fluids oder Gases ausdrückt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Pressure defines the amount of force applied per unit area, expressing potential energy within a fluid or gas</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;pressure&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;pressure&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PressureMeasurementCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PressureMeasurementCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ForceMeasurementCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Druckmessfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">pressure measurement capability</rdfs:label>
        <skos:example xml:lang="en-us">A piezoelectric transducer has a pressure measurement capability from 0.1 bar to 1000 bar</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ForceMeasurementCapability(x) ← PressureMeasurementCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Druck Messfähigkeit ist eine Messfunktion, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um die auf ein bestimmtes Objekt oder eine Klasse von Objekten angewendete Kraft zu messen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Pressure measurement capability is a force measurement capability realized in events where an artifact is used to measure the pressure applied to a specific object</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;pressure measurement capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;force measurement capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;pressure measurement capability&apos; then x is a &apos;force measurement capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ProofStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ProofStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalStrength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Festigkeitsnachweis</rdfs:label>
        <rdfs:label xml:lang="en-us">proof strength</rdfs:label>
        <skos:altLabel xml:lang="en-us">proof stress</skos:altLabel>
        <skos:example xml:lang="en-us">The Rp0.2 proof strength of stainless steel 316L is approximately 170 MPa</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalStrength(x) ← ProofStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Dehngrenze bezieht sich auf die Spannung, die ein Material aushalten kann, bis eine geringe plastische Verformung auftritt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Proof strength refers to the stress a material can endure until exhibiting a small amount of plastic deformation</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;proof strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;proof strength&apos; then x is a &apos;mechanical strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <AnnotationVocabulary1:naturalLanguageDefinition xml:lang="en-us">Proof strength refers to the stress a material can endure until exhibiting a small amount of plastic deformation</AnnotationVocabulary1:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ProofStrength"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
        <owl:annotatedTarget xml:lang="en-us">Proof strength refers to the stress a material can endure until exhibiting a small amount of plastic deformation</owl:annotatedTarget>
        <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.corrosionpedia.com/definition/6354/proof-stress</iof-av:directSource>
    </owl:Axiom>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiantEnergy -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiantEnergy">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Strahlungsenergie</rdfs:label>
        <rdfs:label xml:lang="en-us">radiant energy</rdfs:label>
        <skos:example xml:lang="en-us">A pulsed laser delivers 1 mJ of radiant energy per pulse to the workpiece surface</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Radiant_energy"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← RadiantEnergy(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Radiant energy refers to the energy of electromagnetic radiation, calculated by integrating radiant flux over time</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsenergie bezieht sich auf die Energie elektromagnetischer Strahlung, die durch Integration des Strahlungsflusses über die Zeit berechnet wird</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;radiant energy&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Radiant_energy.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;radiant energy&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiantEnergyDensity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiantEnergyDensity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Strahlungsenergiedichte</rdfs:label>
        <rdfs:label xml:lang="en-us">radiant energy density</rdfs:label>
        <skos:example xml:lang="en-us">The radiant energy density at the focal spot of a laser is 1 GJ/m3 during material processing</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Radiant_energy"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Density(x) ← RadiantEnergyDensity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Radiant energy density quantifies radiant energy per unit volume</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsenergiedichte misst die Strahlungsenergie pro Volumeneinheit</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;radiant energy density&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;density&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Radiant_energy.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;radiant energy density&apos; then x is a &apos;density&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiantEnergyFlux -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiantEnergyFlux">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Strahlungsfluss</rdfs:label>
        <rdfs:label xml:lang="en-us">radiant energy flux</rdfs:label>
        <skos:example xml:lang="en-us">A solar panel receives a radiant energy flux of 1000 W/m2 under standard test conditions</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Radiant_energy"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalProcessCharacteristic(x) ← RadiantEnergyFlux(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Radiant energy flux describes the radiant energy emitted, reflected, transmitted, or received per unit time</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsfluss beschreibt die Strahlungsenergie, die pro Zeiteinheit emittiert, reflektiert, übertragen oder empfangen wird</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;radiant energy flux&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical process characteristic&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Radiant_energy.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;radiant energy flux&apos; then x is a &apos;physical process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationAbsorptionCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationAbsorptionCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Strahlungsabsorptionsfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">radiation absorption capability</rdfs:label>
        <skos:example xml:lang="en-us">Carbon black pigment has high radiation absorption capability, absorbing over 99 % of incident visible light</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OpticalCapability(x) ← RadiationAbsorptionCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Radiation absorption capability characterizes an entity&apos;s ability to absorb electromagnetic radiation</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsabsorptionsfähigkeit beschreibt die Fähigkeit einer Entität, elektromagnetische Strahlung zu absorbieren</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;radiation absorption capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;optical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;radiation absorption capability&apos; then x is a &apos;optical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationEmissionCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationEmissionCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Strahlungsemitter</rdfs:label>
        <rdfs:label xml:lang="en-us">radiation emitter</rdfs:label>
        <skos:example xml:lang="en-us">A cobalt-60 source is a radiation emitter used in industrial gamma-ray testing of welds</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OpticalCapability(x) ← RadiationEmissionCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Radiation emission capability refers to an entity&apos;s ability to emit light of a defined spectrum and intensity</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsemitter beschreibt die Fähigkeit einer Entität, Licht eines definierten Spektrums und Intensität zu emittieren</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;radiation emission capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;optical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;radiation emitter&apos; then x is a &apos;optical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationEmissonCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationEmissonCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Strahlungsemissionsfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">radiation emission capability</rdfs:label>
        <skos:example xml:lang="en-us">A tungsten filament at 2800 K has significant radiation emission capability, producing visible white light</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalCapability(x) ← RadiationEmissonCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die Strahlungsemissionsfähigkeit ist die physikalische Fähigkeit eines materiellen Wesens, elektromagnetische Strahlung auszusenden, die in Prozessen realisiert wird, bei denen der Träger Energie in Form elektromagnetischer Wellen ausstrahlt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Radiation emission capability is a physical capability of a material entity to emit electromagnetic radiation, realized in processes where the bearer radiates energy in the form of electromagnetic waves</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;radiation emission capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;radiation emission capability&apos; then x is a &apos;physical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationReflectionCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationReflectionCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Strahlungsreflexionsfähigkeiten</rdfs:label>
        <rdfs:label xml:lang="en-us">radiation reflection capability</rdfs:label>
        <skos:example xml:lang="en-us">Polished aluminum foil has high radiation reflection capability, reflecting 90 % of infrared radiation</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OpticalCapability(x) ← RadiationReflectionCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Radiation reflection capability characterizes an entity&apos;s ability to reflect electromagnetic radiation</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsreflexionsfähigkeit beschreibt die Fähigkeit einer Entität, elektromagnetische Strahlung zu reflektieren</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;radiation reflection capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;optical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;radiation reflection capability&apos; then x is a &apos;optical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationTransmissionCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationTransmissionCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Strahlungsübertragungsfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">radiation transmission capability</rdfs:label>
        <skos:example xml:lang="en-us">A thin beryllium window has high radiation transmission capability for soft X-rays, passing over 90 % of flux</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OpticalCapability(x) ← RadiationTransmissionCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Radiation transmission capability describes an entity&apos;s ability to transmit electromagnetic radiation</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsübertragungsfähigkeit beschreibt die Fähigkeit einer Entität, elektromagnetische Strahlung zu übertragen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;radiation transmission capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;optical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;radiation transmission capability&apos; then x is a &apos;optical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiologicQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiologicQuality">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">radiologic quality</rdfs:label>
        <rdfs:label xml:lang="de">radiologische Qualität</rdfs:label>
        <skos:example xml:lang="en-us">The dose equivalent a patient receives from a chest X-ray is a radiologic quality of the examination</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← RadiologicQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Radiologic quality pertains to properties or characteristics related to an entity&apos;s interaction with radiant energy</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Radiologische Qualität bezieht sich auf die Eigenschaften oder Merkmale im Zusammenhang mit der Wechselwirkung einer Entität mit Strahlungsenergie</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;radiologic quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;radiologic quality&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Radius -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Radius">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Radius</rdfs:label>
        <rdfs:label xml:lang="en-us">radius</rdfs:label>
        <skos:example xml:lang="en-us">A cylindrical specimen has a radius of 5 mm, giving a cross-sectional area of 78.5 mm2</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002390"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Length(x) ← Radius(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Radius is a length quality equal to the distance from the center of a circle to any endpoint on the circular boundary</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Radius ist eine Längeneigenschaft, die gleich der Entfernung vom Mittelpunkt eines Kreises zu einem beliebigen Endpunkt auf der Kreisgrenze ist</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;radius&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;length&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002390.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;radius&apos; then x is a &apos;length&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ReboundHardness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ReboundHardness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Rückprallhärte</rdfs:label>
        <rdfs:label xml:lang="en-us">rebound hardness</rdfs:label>
        <skos:example xml:lang="en-us">A rubber ball dropped from 1 m rebounds to 80 cm, indicating a high rebound hardness value</skos:example>
        <skos:note>Was a subclass of &apos;Hardness&apos;</skos:note>
        <skos:prefLabel xml:lang="de">Rückprallhärte</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">rebound hardness</skos:prefLabel>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000910"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Hardness(x) ← ReboundHardness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Rebound hardness measures the elasticity of a material, defined as the ratio of the rebound velocity to the impact velocity of a standard ball</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Rückprallhärte misst die Elastizität eines Materials, definiert als das Verhältnis der Rückprallgeschwindigkeit zur Aufprallgeschwindigkeit eines Standardballs</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;rebound hardness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;hardness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;rebound hardness&apos; then x is a &apos;hardness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Reflectivity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Reflectivity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Reflexionsvermögen</rdfs:label>
        <rdfs:label xml:lang="en-us">reflectivity</rdfs:label>
        <skos:example xml:lang="en-us">Polished silver has a reflectivity of over 95 % in the visible spectrum</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000911"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OpticalCapability(x) ← Reflectivity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Das Reflexionsvermögen ist eine optische Fähigkeit eines Materials, die sich als der Anteil der einfallenden elektromagnetischen Strahlung manifestiert, der von seiner Oberfläche reflektiert wird</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Reflectivity is an optical capability of a material that manifests as the fraction of incident electromagnetic radiation that is reflected from its surface</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;reflectivity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;optical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000911.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;reflectivity&apos; then x is a &apos;optical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Refraction -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Refraction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Brechung</rdfs:label>
        <rdfs:label xml:lang="en-us">refraction</rdfs:label>
        <skos:example xml:lang="en-us">A glass prism causes refraction of white light, separating it into its spectral colors</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000790"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OpticalCapability(x) ← Refraction(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Brechung ist eine optische Fähigkeit eines Materials, die sich in der Ablenkung elektromagnetischer Strahlung beim Durchgang durch das Material äußert und durch den Brechungsindex des Materials bestimmt wird</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Refraction is an optical capability of a material that manifests as the bending of electromagnetic radiation as it passes through the material, determined by the material&apos;s refractive index</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;refraction&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;optical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000790.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;refraction&apos; then x is a &apos;optical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RefractiveIndex -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RefractiveIndex">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Brechzahl</rdfs:label>
        <rdfs:label xml:lang="en-us">refractive index</rdfs:label>
        <skos:example xml:lang="en-us">Optical glass BK7 has a refractive index of 1.52 at 589 nm, bending light in lenses</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Refractive_index#Complex_index_of_refraction_and_absorption"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← RefractiveIndex(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Brechzahl gibt die Lichtbrechungsfähigkeit eines optischen Mediums an; umfasst einen realen und einen imaginären Teil, der als Extinktionskoeffizient bekannt ist</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Refractive index indicates an optical medium&apos;s light bending ability; encompassing a real and imaginary part known as the extinction coefficient</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;refractive index&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Refractive_index#Complex_index_of_refraction_and_absorption.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;refractive index&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RelativeIsotopicMass -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RelativeIsotopicMass">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">relative Isotopenmasse</rdfs:label>
        <rdfs:label xml:lang="en-us">relative isotopic mass</rdfs:label>
        <skos:example xml:lang="en-us">The relative isotopic mass of carbon-13 is 13.003 u, slightly heavier than carbon-12</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Atomic_mass"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← RelativeIsotopicMass(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Relative Isotopenmasse bezieht sich auf die Masse eines einzelnen Isotops im Vergleich zu 1/12 der Masse eines Kohlenstoff-12-Atoms</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Relative isotopic mass refers to the mass of a single isotope compared to 1/12 of the mass of a carbon-12 atom</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;relative isotopic mass&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical rate quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Atomic_mass.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;relative isotopic mass&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Resilience -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Resilience">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <owl:disjointWith rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Toughness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Resilienz</rdfs:label>
        <rdfs:label xml:lang="en-us">resilience</rdfs:label>
        <skos:altLabel xml:lang="de">Resilienzmodul</skos:altLabel>
        <skos:altLabel xml:lang="en-us">modulus of resilience</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalCapability(x) ← Resilience(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Elastizität ist die mechanische Fähigkeit eines Materials, bei elastischer Verformung Energie zu absorbieren und diese Energie bei Entlastung ohne bleibende Verformung abzugeben</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Resilience is a mechanical capability of a material to absorb energy when elastically deformed and release that energy upon unloading without permanent deformation</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;resilience&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;resilience&apos; then x is a &apos;mechanical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ReynoldsNumber -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ReynoldsNumber">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FluidDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">Reynolds number</rdfs:label>
        <rdfs:label xml:lang="de">Reynolds-Zahl</rdfs:label>
        <skos:example xml:lang="en-us">Flow in a 25 mm pipe at 2 m/s has a Reynolds number of about 50000, indicating turbulent regime</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Reynolds_number"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">FluidDynamicQuality(x) ← ReynoldsNumber(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Reynolds number is a dimensionless quantity predicting fluid flow patterns, measuring the ratio between inertial and viscous forces</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Reynolds-Zahl ist eine dimensionslose Größe zur Vorhersage von Strömungsmustern in Flüssigkeiten, die das Verhältnis zwischen Trägheits- und Viskosekräften misst</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;Reynolds number&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;FluidDynamicQuality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Reynolds_number.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;reynolds number&apos; then x is a &apos;fluid dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SaturationMagnetization -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SaturationMagnetization">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Sättigungsmagnetisierung</rdfs:label>
        <rdfs:label xml:lang="en-us">saturation magnetization</rdfs:label>
        <skos:altLabel xml:lang="en-us">magnetic saturation</skos:altLabel>
        <skos:altLabel xml:lang="de">magnetische Sättigung</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MagneticCapability(x) ← SaturationMagnetization(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Saturation magnetization is a magnetic capability of a material that specifies the maximum magnetic moment per unit volume achieved when all magnetic domains are aligned with an applied external field</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Sättigungsmagnetisierung ist eine magnetische Fähigkeit eines Materials, die das maximale magnetische Moment pro Volumeneinheit angibt, das erreicht wird, wenn alle magnetischen Domänen mit einem angelegten äußeren Feld ausgerichtet sind</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;saturation magnetization&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;magnetic capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;saturation magnetization&apos; then x is a &apos;magnetic capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">M_s</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ScratchHardness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ScratchHardness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Kratzhärte</rdfs:label>
        <rdfs:label xml:lang="en-us">scratch hardness</rdfs:label>
        <skos:altLabel xml:lang="de">Kratzbeständigkeit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">scratch resistance</skos:altLabel>
        <skos:example xml:lang="en-us">A mineral with a scratch hardness of 7 on the Mohs scale scratches glass but not topaz</skos:example>
        <skos:prefLabel xml:lang="de">Kratzfestigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">scratch hardness</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Hardness(x) ← ScratchHardness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Kratzhärte misst die Fähigkeit eines Materials, Kratzern zu widerstehen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Scratch hardness measures a material&apos;s ability to resist being scratched</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;scratch hardness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;hardness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;scratch hardness&apos; then x is a &apos;hardness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Semiconductivity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Semiconductivity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Halbleitfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">semiconductivity</rdfs:label>
        <skos:example xml:lang="en-us">Doped silicon exhibits semiconductivity with a resistivity of 0.01 Ω·cm, enabling transistor action</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0090001"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalCapability(x) ← Semiconductivity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Halbleiterfähigkeit ist eine elektrische Fähigkeit eines Materials, die sich in seiner Tendenz äußert, Elektrizität auf einem Niveau zwischen einem Leiter und einem Isolator zu leiten, typischerweise empfindlich gegenüber Temperatur, Dotierung und externen Feldern</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Semiconductivity is an electrical capability of a material that manifests as its tendency to conduct electricity at a level intermediate between a conductor and an insulator, typically sensitive to temperature, doping, and external fields</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;semiconductivity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0090001.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;semiconductivity&apos; then x is a &apos;electrical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ShearModulus -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ShearModulus">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Schubmodul</rdfs:label>
        <rdfs:label xml:lang="en-us">shear modulus</rdfs:label>
        <skos:example xml:lang="en-us">The shear modulus of aluminum is 26 GPa, governing torsional deformation of shafts</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Shear_modulus"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Stiffness(x) ← ShearModulus(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Schubmodul ist ein Maß für die elastische Schersteifigkeit, definiert als Verhältnis von Schubspannung zu Scherdehnung</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Shear modulus is a measure of elastic shear stiffness, defined as the ratio of shear stress to shear strain</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;shear modulus&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;stiffness&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Shear_modulus.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;shear modulus&apos; then x is a &apos;stiffness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ShearStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ShearStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BreakingStrength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Scherfestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">shear strength</rdfs:label>
        <skos:altLabel xml:lang="en-us">shear breaking strength</skos:altLabel>
        <skos:example xml:lang="en-us">Shear strength of a CFRP laminate specimen measured as 85 MPa according to ISO 14130 test conditions.</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">BreakingStrength(x) ← ShearStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Scherfestigkeit ist die maximale Scherspannung, die ein Material entlang einer zur aufgebrachten Kraft parallelen Ebene vor dem Versagen widerstehen kann</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Shear strength is the maximum shear stress a material can withstand before failure along a plane parallel to the applied force</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;shear strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;breaking strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;shear strength&apos; then x is a &apos;breaking strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ShearViscosity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ShearViscosity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Scherviskosität</rdfs:label>
        <rdfs:label xml:lang="en-us">shear viscosity</rdfs:label>
        <skos:example xml:lang="en-us">The shear viscosity of glycerol at 25 C is about 1.5 Pa·s, much higher than water</skos:example>
        <skos:prefLabel xml:lang="de">Scherviskosität</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">shear viscosity</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Viscosity(x) ← ShearViscosity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Scherviskosität misst den Widerstand eines Fluids gegen Scherfluss</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Shear viscosity measures a fluid&apos;s resistance to shear flow</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;shear viscosity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;viscosity&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;shear viscosity&apos; then x is a &apos;viscosity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SoundInsulationIndex -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SoundInsulationIndex">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Schalldämmmaß</rdfs:label>
        <rdfs:label xml:lang="en-us">sound insulation index</rdfs:label>
        <skos:example xml:lang="en-us">A 200 mm concrete wall achieves a sound insulation index of 52 dB, blocking most airborne noise</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">AcousticCapability(x) ← SoundInsulationIndex(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Schalldämmmaß quantifiziert die Fähigkeit eines Materials, die Schallübertragung zu reduzieren</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Sound insulation index quantifies the ability of a material to reduce sound transmission</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;sound insulation index&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;acoustic capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;sound insulation index&apos; then x is a &apos;acoustic capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SoundReflectionCoefficient -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SoundReflectionCoefficient">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Schallreflexionsgrad</rdfs:label>
        <rdfs:label xml:lang="en-us">sound reflection coefficient</rdfs:label>
        <skos:example xml:lang="en-us">A concrete wall has a sound reflection coefficient near 0.99 at 500 Hz, acting nearly as a perfect reflector</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">AcousticQuality(x) ← SoundReflectionCoefficient(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Schallreflexionsgrad quantifiziert den Anteil der Schallenergie, die von einer Oberfläche reflektiert wird</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Sound reflection coefficient quantifies the proportion of sound energy reflected by a surface</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;sound reflection coefficient&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;acoustic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;sound reflection coefficient&apos; then x is a &apos;acoustic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificElasticModulus -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificElasticModulus">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">specific elastic modulus</rdfs:label>
        <rdfs:label xml:lang="de">spezifischer Elastizitätsmodul</rdfs:label>
        <skos:altLabel xml:lang="en-us">specific modulus</skos:altLabel>
        <skos:altLabel xml:lang="en-us">specific stiffness</skos:altLabel>
        <skos:altLabel xml:lang="de">spezifische Steifigkeit</skos:altLabel>
        <skos:altLabel xml:lang="de">spezifischer Modul</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Stiffness(x) ← SpecificElasticModulus(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Specific elastic modulus is a stiffness quality of a material expressed as the ratio of its elastic modulus to its density, representing the material&apos;s elastic stiffness per unit mass</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Spezifischer Elastizitätsmodul ist eine Steifigkeitsqualität eines Materials, ausgedrückt als Verhältnis seines Elastizitätsmoduls zu seiner Dichte und repräsentiert die elastische Steifigkeit des Materials je Masseneinheit</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;specific elastic modulus&apos; have not yet been formalized. Although specific elastic modulus is defined as a ratio of elastic modulus to density, a co-inherence axiom cannot uniquely identify this quality among all stiffness qualities of the same bearer. The term is defined as a specific subtype of &apos;stiffness&apos;.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;specific elastic modulus&apos; then x is a &apos;stiffness&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificHeatCapacity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificHeatCapacity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">specific heat capacity</rdfs:label>
        <rdfs:label xml:lang="de">spezifische Wärmekapazität</rdfs:label>
        <skos:example xml:lang="en-us">Water has a specific heat capacity of 4182 J/(kg·K), making it an effective coolant</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← SpecificHeatCapacity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Specific heat capacity is the heat capacity of a sample divided by its mass, representing the heat required to raise temperature by one unit</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Spezifische Wärmekapazität ist die Wärmekapazität einer Probe geteilt durch ihre Masse und repräsentiert die erforderliche Wärme, um die Temperatur um eine Einheit zu erhöhen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;specific heat capacity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;specific heat capacity&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <AnnotationVocabulary1:naturalLanguageDefinition xml:lang="en-us">Specific heat capacity is the heat capacity of a sample divided by its mass, representing the heat required to raise temperature by one unit</AnnotationVocabulary1:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificHeatCapacity"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
        <owl:annotatedTarget xml:lang="en-us">Specific heat capacity is the heat capacity of a sample divided by its mass, representing the heat required to raise temperature by one unit</owl:annotatedTarget>
        <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Specific_heat_capacity</iof-av:directSource>
    </owl:Axiom>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">specific strength</rdfs:label>
        <rdfs:label xml:lang="de">spezifische Festigkeit</rdfs:label>
        <skos:altLabel xml:lang="de">Festigkeit-Gewichts-Verhältnis</skos:altLabel>
        <skos:altLabel xml:lang="en-us">strength-to-weight ratio</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strength(x) ← SpecificStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Specific strength is a strength quality of a material expressed as the ratio of a strength measure to its density, representing the material&apos;s load-bearing capacity per unit mass</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Spezifische Festigkeit ist eine Festigkeitsqualität eines Materials, ausgedrückt als Verhältnis einer Festigkeitsgröße zu seiner Dichte und repräsentiert die Tragfähigkeit des Materials je Masseneinheit</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;specific strength&apos; have not yet been formalized. Although specific strength is defined as a ratio of strength to density, a co-inherence axiom cannot uniquely identify this quality among all strength qualities of the same bearer. The term is defined as a specific subtype of &apos;strength&apos;.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;specific strength&apos; then x is a &apos;strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificSurfaceArea -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificSurfaceArea">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">specific surface area</rdfs:label>
        <rdfs:label xml:lang="de">spezifische Oberfläche</rdfs:label>
        <skos:example xml:lang="en-us">Activated carbon has a specific surface area exceeding 1000 m2/g, enabling high adsorption capacity</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000942"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← SpecificSurfaceArea(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Die spezifische Oberfläche ist eine physikalische Eigenschaft eines Materials, die die Gesamtoberfläche pro Masseneinheit angibt und die verfügbare Oberfläche für Reaktionen oder Wechselwirkungen darstellt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Specific surface area is a physical quality of a material that specifies the total surface area per unit of mass, representing the available surface for reactions or interactions</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;specific surface area&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000942.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;specific surface area&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Speed -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Speed">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Geschwindigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">speed</rdfs:label>
        <skos:example xml:lang="en-us">If a train takes 1 hour to travel 100 kilometers, it has a speed of 100 kilometers per hour (62 mph)</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://simple.wikipedia.org/wiki/Speed"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalProcessCharacteristic(x) ← Speed(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Geschwindigkeit beschreibt die Entfernung, die ein Objekt in einer bestimmten Zeit zurücklegt, immer positiv</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Speed describes the distance an object moves in a given amount of time, always positive</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;speed&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical process characteristic&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://simple.wikipedia.org/wiki/Speed.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;speed&apos; then x is a &apos;physical process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpeedOfSound -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpeedOfSound">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Schallgeschwindigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">speed of sound</rdfs:label>
        <skos:example xml:lang="en-us">The speed of sound in air at 20 C is 343 m/s, used to calibrate acoustic sensors</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000947"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">AcousticCapability(x) ← SpeedOfSound(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Schallgeschwindigkeit ist eine akustische Fähigkeit eines Materials, die sich in der Geschwindigkeit äußert, mit der sich Schallwellen durch das Material ausbreiten, abhängig von der Elastizität und Dichte des Materials</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Speed of sound is an acoustic capability of a material that manifests as the rate at which sound waves propagate through it, dependent on the material&apos;s elasticity and density</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;speed of sound&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;acoustic capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000947.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;speed of sound&apos; then x is a &apos;acoustic capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Elasticity"/>
        <obo:IAO_0000116 xml:lang="en-us">While Stiffness characterizes a body&apos;s response, taking into account its geometry and materials. Elastic Modulus aims to be agnostic to geometry and specific for the material</obo:IAO_0000116>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="de">Steifigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">stiffness</rdfs:label>
        <skos:example xml:lang="en-us">A carbon fiber reinforced beam has high stiffness, deflecting only 0.1 mm under 1 kN lateral load</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000949"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Elasticity(x) ← Stiffness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Steifigkeit ist das Maß, bis zu dem ein Objekt einer Verformung als Reaktion auf eine einwirkende Kraft widersteht</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Stiffness is the extent to which an object resists deformation in response to an applied force</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;stiffness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;elasticity&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;stiffness&apos; then x is a &apos;elasticity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/StorageModulus -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/StorageModulus">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ComplexModulus"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Speichermodul</rdfs:label>
        <rdfs:label xml:lang="en-us">storage modulus</rdfs:label>
        <skos:example xml:lang="en-us">The storage modulus of a polyurethane foam at 1 Hz and 25 C is 0.5 MPa, reflecting its elastic stiffness</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Dynamic_modulus"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ComplexModulus(x) ← StorageModulus(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Speichermodul ist der Realteil des Komplexmoduls und misst den elastischen Anteil der gespeicherten und zurückgewonnenen Energie pro Zyklus in einem viskoelastischen Material unter schwingender Belastung</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Storage modulus is the real part of the complex modulus that measures the elastic portion of energy stored and recovered per cycle in a viscoelastic material under oscillatory loading</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;storage modulus&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;complex modulus&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Dynamic_modulus.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;storage modulus&apos; then x is a &apos;complex modulus&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">E&apos;</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Deformation"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Dehnung</rdfs:label>
        <rdfs:label xml:lang="en-us">strain</rdfs:label>
        <skos:example xml:lang="en-us">Under a tensile load, a polymer film exhibits a strain of 2 % before yielding</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Strain_(mechanics)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Deformation(x) ← Strain(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Dehnung ist als relative Verformung definiert, verglichen mit einer Referenzpositionskonfiguration</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Strain is defined as relative deformation, compared to a reference position configuration</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;strain&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;deformation&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Strain_(mechanics).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;strain&apos; then x is a &apos;deformation&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/StrainAtBreak -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/StrainAtBreak">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Bruchdehnung</rdfs:label>
        <rdfs:label xml:lang="en-us">strain at break</rdfs:label>
        <skos:altLabel xml:lang="en-us">elongation at break</skos:altLabel>
        <skos:example xml:lang="en-us">Strain at break of a thermoplastic polyurethane specimen measured as 450% under ISO 527 test conditions.</skos:example>
        <iof-av:firstOrderLogicDefinition xml:lang="en-us">StrainAtBreak(x) ↔ Strain(x) ∧ ∃b∃p∃i(obo:BFO_0000040(b) ∧ MeasurementProcess(p) ∧ MeasurementInformationContentEntity(i) ∧ bearerOf(b, x) ∧ describes(i, x) ∧ isOutputOf(i, p) ∧ ∃t(TimeOfBreak(t) ∧ occupiesTemporalRegion(p, t)))</iof-av:firstOrderLogicDefinition>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Bruchdehnung ist die Dehnung einer Probe im Moment des Bruchs, bestimmt unter Zugbelastung gemäß anwendbaren Prüfnormen</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Strain at break is the strain of a specimen at the moment of fracture, determined under tensile load according to applicable test standards</iof-av:naturalLanguageDefinition>
        <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en-us">every instance of &apos;strain at break&apos; is defined as exactly an instance of &apos;strain&apos; that inheres in some &apos;material entity&apos;, and there exists a &apos;measurement information content entity&apos; that &apos;describes&apos; it, which &apos;is output of&apos; some &apos;measurement process&apos; that &apos;occupies temporal region&apos; some &apos;time of break&apos;</iof-av:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Stärke</rdfs:label>
        <rdfs:label xml:lang="en-us">strength</rdfs:label>
        <skos:altLabel xml:lang="de">Festigkeit</skos:altLabel>
        <skos:example xml:lang="en-us">A welded joint must exceed the strength of the base metal in a qualification test</skos:example>
        <skos:prefLabel xml:lang="de">Stärke</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">strength</skos:prefLabel>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000952"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MechanicalCapability(x) ← Strength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Strength refers to the capacity of an object or substance to withstand great force or pressure</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Stärke bezeichnet die Fähigkeit eines Objekts oder Stoffes, großer Kraft oder Druck standzuhalten</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;mechanical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;strength&apos; then x is a &apos;mechanical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stress -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stress">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pressure"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Spannung</rdfs:label>
        <rdfs:label xml:lang="en-us">stress</rdfs:label>
        <skos:example xml:lang="en-us">A cross-section of a loaded steel column bears a compressive stress of 150 MPa</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Pressure(x) ← Stress(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Spannung ist die innere Kraft pro Flächeneinheit, die ein Material unter äußerer Belastung erfährt, und wird häufig als Zug-, Druck- oder Scherspannung beschrieben</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Stress is the internal force per unit area a material experiences under external load, commonly described in tensile, compressive, or shear forms</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;stress&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;pressure&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;stress&apos; then x is a &apos;pressure&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/StressRelaxation -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/StressRelaxation">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Spannungsrelaxation</rdfs:label>
        <rdfs:label xml:lang="en-us">stress relaxation</rdfs:label>
        <skos:altLabel xml:lang="de">Relaxationsgrad</skos:altLabel>
        <skos:altLabel xml:lang="en-us">relaxation ratio</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRelationalQuality(x) ← StressRelaxation(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Spannungsrelaxation ist eine physikalische relationale Qualität eines Materials, die das Verhältnis der Restspannung zur anfänglich aufgebrachten Spannung nach einem definierten Zeitintervall bei konstanter Dehnung ausdrückt und die Neigung des Materials zur internen Spannungsumverteilung über die Zeit quantifiziert</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Stress relaxation is a physical relational quality of a material that expresses the ratio of residual stress to initial applied stress after a defined time interval under constant strain, quantifying the material&apos;s tendency to internally redistribute stress over time</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;stress relaxation&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical relational quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;stress relaxation&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SublimationPoint -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SublimationPoint">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Sublimationspunkt</rdfs:label>
        <rdfs:label xml:lang="en-us">sublimation point</rdfs:label>
        <skos:example xml:lang="en-us">Dry ice sublimates at -78.5 C at atmospheric pressure, transitioning directly from solid to gas</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000961"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← SublimationPoint(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Sublimationspunkt ist eine thermodynamische Eigenschaft einer Substanz, die die Temperatur angibt, bei der sie bei einem bestimmten Druck direkt vom festen in den gasförmigen Zustand übergeht</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Sublimation point is a thermo dynamic quality of a substance that specifies the temperature at which it transitions directly from solid to gaseous state at a given pressure</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;sublimation point&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000961.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;sublimation point&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Superconducting -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Superconducting">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Supraleitung</rdfs:label>
        <rdfs:label xml:lang="en-us">superconducting</rdfs:label>
        <skos:example xml:lang="en-us">Lead becomes superconducting below 7.2 K, conducting electricity with zero resistance</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000111"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ElectricalCapability(x) ← Superconducting(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Superconducting is an electrical capability of a material that manifests as its tendency to conduct electricity with zero electrical resistance below a critical temperature</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Supraleitung ist die elektrische Fähigkeit eines Materials, die sich in seiner Tendenz äußert, Elektrizität ohne elektrischen Widerstand unterhalb einer kritischen Temperatur zu leiten</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;superconducting&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;electrical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000111.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;superconducting&apos; then x is a &apos;electrical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SurfaceEnergy -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SurfaceEnergy">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Energy"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Oberflächenenergie</rdfs:label>
        <rdfs:label xml:lang="en-us">surface energy</rdfs:label>
        <skos:altLabel xml:lang="de">freie Oberflächenenergie</skos:altLabel>
        <skos:altLabel xml:lang="en-us">surface free energy</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Energy(x) ← SurfaceEnergy(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Oberflächenenergie ist eine Energiequalität eines Materials, die die überschüssige Energie an seiner Oberfläche im Vergleich zum Volumen quantifiziert, die durch nicht abgesättigte molekulare Bindungen an der Grenzfläche entsteht</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Surface energy is an energy quality of a material that quantifies the excess energy at its surface relative to the bulk, arising from unsatisfied molecular bonds at the interface</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;surface energy&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;energy&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;surface energy&apos; then x is a &apos;energy&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">γ</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SurfaceRoughness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SurfaceRoughness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Oberflächenrauheit</rdfs:label>
        <rdfs:label xml:lang="en-us">surface roughness</rdfs:label>
        <skos:altLabel xml:lang="de">Oberflächentextur</skos:altLabel>
        <skos:altLabel xml:lang="de">Rauheit</skos:altLabel>
        <skos:altLabel xml:lang="en-us">roughness</skos:altLabel>
        <skos:altLabel xml:lang="en-us">surface texture</skos:altLabel>
        <skos:example xml:lang="en-us">A ground steel surface has an Ra roughness of 0.4 µm, suitable for bearing fits</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← SurfaceRoughness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Oberflächenrauheit ist eine physikalische Qualität der Oberfläche eines Materials, die die Abweichung des Oberflächenprofils von einer idealen Referenzebene quantifiziert, typischerweise als arithmetisches Mittel der absoluten Profilabweichungen ausgedrückt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Surface roughness is a physical quality of a material&apos;s surface that quantifies the deviation of the surface profile from an ideal flat reference plane, typically expressed as the arithmetic mean of absolute profile deviations</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;surface roughness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;surface roughness&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">Ra</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SurfaceTension -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SurfaceTension">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Adhesion"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Oberflächenspannung</rdfs:label>
        <rdfs:label xml:lang="en-us">surface tension</rdfs:label>
        <skos:altLabel xml:lang="en-us">surface stress</skos:altLabel>
        <skos:example xml:lang="en-us">Water has a surface tension of 72.8 mN/m at 20 C, enabling capillary rise in fine tubes</skos:example>
        <skos:prefLabel xml:lang="de">Oberflächenspannung</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">surface tension</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Adhesion(x) ← SurfaceTension(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Oberflächenspannung bezeichnet den Effekt innerhalb der Oberflächenschicht einer Flüssigkeit, der durch Wechselwirkungskräfte zwischen ihren Molekülen verursacht wird</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Surface tension refers to the effect within the surface layer of a liquid, caused by intermolecular forces between its molecules</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;surface tension&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;adhesion&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;surface tension&apos; then x is a &apos;adhesion&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Temperature -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Temperature">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="de">Temperatur</rdfs:label>
        <rdfs:label xml:lang="en-us">temperature</rdfs:label>
        <skos:example xml:lang="en-us">The cure temperature of an epoxy adhesive is 120 C for one hour under pressure</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.merriam-webster.com/dictionary/temperature"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← Temperature(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Temperatur beschreibt den Grad der Hitze oder Kälte, gemessen auf einer bestimmten Skala</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Temperature characterizes the degree of hotness or coldness measured on a definite scale</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;temperature&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.merriam-webster.com/dictionary/temperature.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;temperature&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TemperatureMeasurementCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TemperatureMeasurementCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/MeasurementCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Temperaturmessfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">temperature measurement capability</rdfs:label>
        <skos:altLabel xml:lang="de">Temperaturmessungsfähigkeit</skos:altLabel>
        <skos:example xml:lang="en-us">A platinum resistance thermometer has a temperature measurement capability from -200 C to 850 C</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MeasurementCapability(x) ← TemperatureMeasurementCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Temperature measurement capability involves using an artifact to measure the temperature of an object or space</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Temperaturmessfähigkeit bezeichnet die Messfähigkeit, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um die Temperatur eines Objekts oder Raums zu messen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;temperature measurement capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;MeasurementCapability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;temperature measurement capability&apos; then x is a &apos;measurement capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TemperatureProfile -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TemperatureProfile">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Temperaturprofil</rdfs:label>
        <rdfs:label xml:lang="en-us">temperature profile</rdfs:label>
        <skos:example xml:lang="en-us">The temperature profile along a quenched steel bar varies from 850 C at the surface to 200 C at the core</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalProcessCharacteristic(x) ← TemperatureProfile(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Temperatur Profil beschreibt Änderungen der Temperatur eines materiellen Wesens oder Raums über die Zeit</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Temperature profile describes changes in the temperature of a material entity or space over time</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;temperature profile&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical process characteristic&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;temperature profile&apos; then x is a &apos;physical process characteristic&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TensileStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TensileStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BreakingStrength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Zugfestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">tensile strength</rdfs:label>
        <skos:altLabel xml:lang="en-us">ultimate tensile strength</skos:altLabel>
        <skos:example xml:lang="en-us">A high-strength bolt grade 10.9 has a tensile strength of at least 1040 MPa</skos:example>
        <skos:prefLabel xml:lang="de">Zugfestigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">ultimate tensile strength</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">BreakingStrength(x) ← TensileStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Tensile strength measures the maximum stress a material can withstand while being stretched or pulled before breaking</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Zugfestigkeit misst die maximale Spannung, die ein Material aushalten kann, während es gestreckt oder gezogen wird, bevor es bricht</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;tensile strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;breaking strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;tensile strength&apos; then x is a &apos;breaking strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">thermal capability</rdfs:label>
        <rdfs:label xml:lang="de">thermische Fähigkeit</rdfs:label>
        <skos:example xml:lang="en-us">Refractory bricks have a high thermal capability, withstanding furnace temperatures above 1600 C</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalCapability(x) ← ThermalCapability(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thermal capability can be realized through an entity related to thermodynamic interaction</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Thermische Fähigkeit kann durch eine Entität im Zusammenhang mit thermischer Wechselwirkung realisiert werden</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thermal capability&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thermal capability&apos; then x is a &apos;physical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapacity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapacity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="en-us">thermal capacity</rdfs:label>
        <rdfs:label xml:lang="de">thermische Kapazität</rdfs:label>
        <skos:altLabel xml:lang="de">Wärmekapazität</skos:altLabel>
        <skos:altLabel xml:lang="en-us">heat capacity</skos:altLabel>
        <skos:example xml:lang="en-us">A steel block of 1 kg has a thermal capacity of 500 J/K, absorbing heat with moderate temperature rise</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Heat_capacity"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← ThermalCapacity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thermal capacity, or heat capacity, is defined as the amount of heat required to produce a unit change in temperature of an object</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Wärmekapazität, auch als thermische Kapazität bekannt, ist die Menge an Wärme, die erforderlich ist, um eine Änderung der Temperatur eines Objekts um eine Einheit zu erzeugen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thermal capacity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Heat_capacity.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thermal capacity&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <AnnotationVocabulary1:naturalLanguageDefinition xml:lang="en-us">Thermal capacity, or heat capacity, is defined as the amount of heat required to produce a unit change in temperature of an object</AnnotationVocabulary1:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapacity"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
        <owl:annotatedTarget xml:lang="en-us">Thermal capacity, or heat capacity, is defined as the amount of heat required to produce a unit change in temperature of an object</owl:annotatedTarget>
        <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Heat_capacity</iof-av:directSource>
    </owl:Axiom>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalConductance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalConductance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">thermal conductance</rdfs:label>
        <rdfs:label xml:lang="de">thermische Leitfähigkeit</rdfs:label>
        <skos:example xml:lang="en-us">A copper heat spreader of 2 mm thickness has a high thermal conductance, efficiently dissipating chip heat</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← ThermalConductance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thermal conduction refers to the process by which heat is transferred from the hotter end to the colder end of an object, characterized by conductance</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Thermische Leitung beschreibt den Prozess, bei dem Wärme vom heißeren zum kälteren Ende eines Objekts übertragen wird, gekennzeichnet durch Leitfähigkeit</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thermal conductance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thermal conductance&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalConductivity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalConductivity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Wärmeleitfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">thermal conductivity</rdfs:label>
        <skos:example xml:lang="en-us">Diamond has the highest thermal conductivity of any natural material at about 2200 W/(m·K)</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000978"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← ThermalConductivity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thermal conductivity is a thermal capability of a material that manifests as its ability to conduct heat, expressed as the rate of heat transfer through unit thickness per unit temperature gradient</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Wärmeleitfähigkeit ist die thermische Fähigkeit eines Materials, die sich in seiner Fähigkeit zur Wärmeleitung äußert, ausgedrückt als Wärmeübertragungsrate durch eine Dickeneinheit pro Temperaturgradienteneinheit</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thermal conductivity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000978.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thermal conductivity&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalDiffusivity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalDiffusivity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Temperaturleitfähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">thermal diffusivity</rdfs:label>
        <skos:altLabel xml:lang="de">Thermische Diffusivität</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← ThermalDiffusivity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Temperaturleitfähigkeit ist eine physikalische Ratenqualität eines Materials, die die Geschwindigkeit beschreibt, mit der Wärmeenergie im Verhältnis zur Wärmespeicherkapazität geleitet wird, ausgedrückt als Verhältnis der Wärmeleitfähigkeit zum Produkt aus Dichte und spezifischer Wärmekapazität</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thermal diffusivity is a physical rate quality of a material that quantifies the rate at which thermal energy is conducted relative to its capacity to store heat, expressed as the ratio of thermal conductivity to the product of density and specific heat capacity</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thermal diffusivity&apos; have not yet been formalized. Although thermal diffusivity is defined as a ratio of thermal conductivity to the product of density and specific heat capacity, a co-inherence axiom cannot uniquely identify this quality among all rate qualities of the same bearer. The term is defined as a specific subtype of &apos;physical rate quality&apos;.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thermal diffusivity&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">α</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalExpansionCoefficient -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalExpansionCoefficient">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">thermal expansion coefficient</rdfs:label>
        <rdfs:label xml:lang="de">thermischer Ausdehnungkoeffizient</rdfs:label>
        <skos:example xml:lang="en-us">The thermal expansion coefficient of borosilicate glass is 3.3e-6 per K, enabling thermal shock resistance</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← ThermalExpansionCoefficient(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thermal expansion coefficient quantifies the degree to which a material expands upon heating, representing fractional change per degree temperature increase</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Thermischer Ausdehnungkoeffizient quantifiziert den Grad, in dem ein Material beim Erhitzen expandiert, und stellt die proportionale Änderung pro Temperaturanstieg dar</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thermal expansion coefficient&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thermal expansion coefficient&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalInsulation -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalInsulation">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
        <rdfs:label xml:lang="en-us">thermal insulation</rdfs:label>
        <rdfs:label xml:lang="de">thermische Isolierung</rdfs:label>
        <skos:example xml:lang="en-us">Glass wool with a thermal conductivity of 0.04 W/(m·K) provides effective thermal insulation in building walls</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Thermal_insulation"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← ThermalInsulation(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thermal insulation reduces heat transfer between objects in thermal contact or radiative influence, achieved with engineered methods or material properties</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Thermische Isolierung verringert den Wärmeaustausch zwischen Objekten, die in thermischem Kontakt oder Strahlungseinfluss stehen, realisiert durch spezielle Konstruktionsmethoden oder Materialien</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thermal insulation&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Thermal_insulation.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thermal insulation&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalShockResistance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalShockResistance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Thermoschockbeständigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">thermal shock resistance</rdfs:label>
        <skos:altLabel xml:lang="de">Temperaturwechselbeständigkeit</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalCapability(x) ← ThermalShockResistance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thermal shock resistance is a thermal capability of a material that characterises its ability to withstand rapid and large changes in temperature without cracking, spalling, or loss of mechanical integrity</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Thermoschockbeständigkeit ist eine thermische Fähigkeit eines Materials, die seine Fähigkeit beschreibt, schnelle und große Temperaturänderungen ohne Rissbildung, Abplatzungen oder Verlust der mechanischen Integrität zu überstehen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thermal shock resistance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thermal shock resistance&apos; then x is a &apos;thermal capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">thermo dynamic quality</rdfs:label>
        <rdfs:label xml:lang="de">thermodynamische Qualität</rdfs:label>
        <skos:example xml:lang="en-us">The melting point of iron at 1538 C is a thermo dynamic quality governing its processing in a blast furnace</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalQuality(x) ← ThermoDynamicQuality(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thermo dynamic quality characterizes a material entity&apos;s behavior or state in relation to thermal heating or cooling</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Thermodynamische Qualität beschreibt das Verhalten oder den Zustand eines materiellen Wesens in Bezug auf thermische Erwärmung oder Kühlung</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thermo dynamic quality&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thermo dynamic quality&apos; then x is a &apos;physical quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Thickness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Thickness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Dicke</rdfs:label>
        <rdfs:label xml:lang="en-us">thickness</rdfs:label>
        <skos:example xml:lang="en-us">A sheet metal blank has a thickness of 1.5 mm, verified by micrometer measurement</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000915"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Length(x) ← Thickness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Dicke stellt das Ausmaß eines Objekts entgegen seinen seitlichen Abmessungen dar und bietet ein Maß für die Tiefe</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thickness represents the extent of an object opposing its lateral dimensions, providing a measure of depth</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thickness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;length&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000915.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thickness&apos; then x is a &apos;length&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Thrust -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Thrust">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Schubkraft</rdfs:label>
        <rdfs:label xml:lang="en-us">thrust</rdfs:label>
        <skos:example xml:lang="en-us">A jet engine produces 150 kN of thrust at takeoff conditions</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Thrust"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Force(x) ← Thrust(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Schubkraft ist eine von Newtons drittem Gesetz beschriebene Kraft, bei der Massenbeschleunigung in eine Richtung eine gleich große Kraft in die entgegengesetzte Richtung verursacht</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Thrust is a force described by Newton&apos;s third law, where mass expulsion in one direction causes an equal force in the opposite direction</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;thrust&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;force&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Thrust.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;thrust&apos; then x is a &apos;force&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TimeOfBreak -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TimeOfBreak">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000148"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Bruchzeitpunkt</rdfs:label>
        <rdfs:label xml:lang="en-us">time of break</rdfs:label>
        <skos:example xml:lang="en-us">In a tensile test, the time of break is the moment when the specimen fractures and load drops to zero</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ZeroDimensionalTemporalRegion(x) ← TimeOfBreak(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Time of break refers to the instant when a part or specimen fractures during a mechanical test</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Unter Bruchzeit versteht man den Zeitpunkt, an dem ein Teil oder eine Probe während einer mechanischen Prüfung bricht</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;time of break&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;BFO_0000148&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;time of break&apos; then x is a &apos;zero-dimensional temporal region&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Toughness -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Toughness">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Zähigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">toughness</rdfs:label>
        <skos:example xml:lang="en-us">High-toughness tool steel absorbs 80 J before fracture in a Charpy V-notch test at room temperature</skos:example>
        <skos:prefLabel xml:lang="de">Zähigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">toughness</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strength(x) ← Toughness(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Toughness describes the resistance of a material to fracture or crack propagation, determined by its ability to absorb mechanical energy during deformation</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Zähigkeit beschreibt die Widerstandsfähigkeit eines Werkstoffs gegen Bruch oder Rissausbreitung, bestimmt durch die Fähigkeit zur Absorption von mechanischer Energie bei Verformung</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;toughness&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;toughness&apos; then x is a &apos;strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TriplePoint -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TriplePoint">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Tripelpunkt</rdfs:label>
        <rdfs:label xml:lang="en-us">triple point</rdfs:label>
        <skos:example xml:lang="en-us">Water reaches its triple point at 0.01 C and 611.7 Pa, where ice, liquid, and vapor coexist</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000996"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← TriplePoint(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der Tripelpunkt ist eine thermodynamische Eigenschaft einer Substanz, die die einzigartige Kombination von Temperatur und Druck angibt, bei der feste, flüssige und gasförmige Phasen im thermodynamischen Gleichgewicht koexistieren</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Triple point is a thermo dynamic quality of a substance that specifies the unique combination of temperature and pressure at which solid, liquid, and gaseous phases coexist in thermodynamic equilibrium</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;triple point&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000996.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;triple point&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TrueStrain -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TrueStrain">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">true strain</rdfs:label>
        <rdfs:label xml:lang="de">wahre Dehnung</rdfs:label>
        <skos:altLabel xml:lang="en-us">Hencky strain</skos:altLabel>
        <skos:altLabel xml:lang="en-us">logarithmic strain</skos:altLabel>
        <skos:example xml:lang="en-us">At a cross-section reduction of 50 %, the true strain is ln(2) = 0.693</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Strain_(mechanics)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strain(x) ← TrueStrain(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">True strain, or logarithmic strain, integrates incrementally over deformation; related to engineering strain as ε=ln(1+e)</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Wahre Dehnung, auch als logarithmische Dehnung bekannt, integriert sich schrittweise über die Verformung; in Beziehung zum technischen Dehnungsmaß als ε=ln(1+e)</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;true strain&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strain&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Strain_(mechanics).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;true strain&apos; then x is a &apos;strain&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TrueStress -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TrueStress">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stress"/>
        <obo:IAO_0000116 xml:lang="en-us">The true stress in accordance with the cauchy stress tensor. It always relates to the current size of the surface of a filled volume element of a material entity. It can be assumed equal to the engineering stress for very small deformations (lower then 0.01 %)</obo:IAO_0000116>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">true stress</rdfs:label>
        <rdfs:label xml:lang="de">wahre Spannung</rdfs:label>
        <skos:example xml:lang="en-us">At 10 % engineering strain in a tensile test, the true stress exceeds the engineering stress by the same factor</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Stress(x) ← TrueStress(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">True stress is defined using the cauchy stress tensor, relating stress to the current surface size of a volume element</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Wahre Spannung wird unter Verwendung des Cauchy-Spannungstensors definiert und bezieht die Spannung auf die aktuelle Oberflächengröße eines Volumenelements</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;true stress&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;stress&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;true stress&apos; then x is a &apos;stress&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/UpperYieldStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/UpperYieldStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/YieldStrength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">obere Streckgrenze</rdfs:label>
        <rdfs:label xml:lang="en-us">upper yield strength</rdfs:label>
        <skos:altLabel xml:lang="de">obere Fließspannung</skos:altLabel>
        <skos:altLabel xml:lang="en-us">upper yield stress</skos:altLabel>
        <skos:example xml:lang="en-us">Mild steel exhibits an upper yield strength of about 300 MPa, followed by a yield drop to the lower yield point</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Yield_(engineering)"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">YieldStrength(x) ← UpperYieldStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Obere Streckgrenze charakterisiert die maximale Spannung, die vor dem plastischen Fließen eines Materials angewendet werden kann</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Upper yield strength characterizes the maximum stress that can be applied before a material begins to yield plastically</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;upper yield strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;yield strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Yield_(engineering).</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;upper yield strength&apos; then x is a &apos;yield strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VaporPressure -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VaporPressure">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Dampfdruck</rdfs:label>
        <rdfs:label xml:lang="en-us">vapor pressure</rdfs:label>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermoDynamicQuality(x) ← VaporPressure(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Dampfdruck ist eine thermodynamische Qualität eines Stoffes, die den Druck angibt, den sein Dampf ausübt, wenn er sich bei einer gegebenen Temperatur im thermodynamischen Gleichgewicht mit seiner kondensierten Phase befindet</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Vapor pressure is a thermodynamic quality of a substance that specifies the pressure exerted by its vapor when in thermodynamic equilibrium with its condensed phase at a given temperature</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;vapor pressure&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermo dynamic quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;vapor pressure&apos; then x is a &apos;thermo dynamic quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">p*</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscoelasticity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscoelasticity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Viscoelastizität</rdfs:label>
        <rdfs:label xml:lang="en-us">viscoelasticity</rdfs:label>
        <skos:altLabel xml:lang="de">Viskoelastizität</skos:altLabel>
        <skos:altLabel xml:lang="en-us">elasticity of viscosity</skos:altLabel>
        <skos:example xml:lang="en-us">Polymers exhibit viscoelasticity, showing both elastic recovery and creep under constant load</skos:example>
        <skos:prefLabel xml:lang="de">Viscoelastizität</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">viscoelasticity</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Strength(x) ← Viscoelasticity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Viscoelasticity describes materials exhibiting both viscous and elastic characteristics during deformation</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Viscoelastizität beschreibt Materialien, die sowohl viskose als auch elastische Eigenschaften während der Verformung zeigen</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;viscoelasticity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;viscoelasticity&apos; then x is a &apos;strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Plasticity"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Viskosität</rdfs:label>
        <rdfs:label xml:lang="en-us">viscosity</rdfs:label>
        <skos:example xml:lang="en-us">Honey at 25 C has a viscosity of about 10 Pa·s, flowing slowly under gravity</skos:example>
        <skos:prefLabel xml:lang="de">Viskosität</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">viscosity</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Plasticity(x) ← Viscosity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Viscosity measures a fluid&apos;s resistance to flow</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Viskosität misst den Widerstand eines Fluids gegen den Fluss</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;viscosity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;plasticity&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;viscosity&apos; then x is a &apos;plasticity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Volume -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Volume">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/DimensionQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Volumen</rdfs:label>
        <rdfs:label xml:lang="en-us">volume</rdfs:label>
        <skos:example xml:lang="en-us">A cylindrical billet has a volume of 0.002 m3, determined from its radius and height</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000918"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">DimensionQuality(x) ← Volume(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Volume signifies the 3-D extent quality inhering due to the bearer&apos;s occupied space</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Volumen bezeichnet die 3-D-Ausdehnungsqualität, die aufgrund des vom Träger besetzten Raums entsteht</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;volume&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;DimensionQuality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000918.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;volume&apos; then x is a &apos;dimension quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeConcentration -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeConcentration">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeRatio"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Volumenkonzentration</rdfs:label>
        <rdfs:label xml:lang="en-us">volume concentration</rdfs:label>
        <skos:example xml:lang="en-us">A paint pigment dispersion has a TiO2 volume concentration of 20 %</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Volumenkonzentration"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">VolumeRatio(x) ← VolumeConcentration(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Volume concentration links the volume of a mixture component to the total volume, crucial for quantitative composition description</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Volumenkonzentration verbindet das Volumen eines Mischbestandteils mit dem Gesamtvolumen, entscheidend für die quantitative Zusammensetzungsbeschreibung</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;volume concentration&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;volume ratio&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Volumenkonzentration.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;volume concentration&apos; then x is a &apos;volume ratio&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeFraction -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeFraction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeRatio"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Volumenanteil</rdfs:label>
        <rdfs:label xml:lang="en-us">volume fraction</rdfs:label>
        <skos:example xml:lang="en-us">A dual-phase steel contains a martensite volume fraction of 20 %, controlling its strength-ductility balance</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Volumenkonzentration"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">VolumeRatio(x) ← VolumeFraction(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Volume fraction describes the volume of a mixture component relative to the sum of all components&apos; volumes</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Volumenanteil beschreibt das Volumen eines Mischbestandteils im Verhältnis zur Summe der Volumina aller Bestandteile</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;volume fraction&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;volume ratio&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Volumenkonzentration.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;volume fraction&apos; then x is a &apos;volume ratio&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeMixRatio -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeMixRatio">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeRatio"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Mischengehaltverhältnis</rdfs:label>
        <rdfs:label xml:lang="en-us">volume mix ratio</rdfs:label>
        <skos:example xml:lang="en-us">An epoxy adhesive is mixed in a volume mix ratio of 2:1 resin to hardener</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Volumenverh%C3%A4ltnis"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">VolumeRatio(x) ← VolumeMixRatio(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Mischengehaltverhältnis definiert das Verhältnis der Volumina von zwei Mischbestandteilen zueinander</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Volume mix ratio defines the ratio of volumes of two mixture components to each other</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;volume mix ratio&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;volume ratio&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Volumenverh%C3%A4ltnis.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;volume mix ratio&apos; then x is a &apos;volume ratio&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeRatio -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeRatio">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialComposition"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Volumenverhältnis</rdfs:label>
        <rdfs:label xml:lang="en-us">volume ratio</rdfs:label>
        <skos:example xml:lang="en-us">A foam material has a pore-to-solid volume ratio of 4:1, indicating 80 % porosity</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">MaterialComposition(x) ← VolumeRatio(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Volume ratio represents a relational quality expressing one volume value relative to another, typically resulting in a dimensionless number</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Volumenverhältnis stellt eine relationale Qualität dar, die einen Volumenwert im Verhältnis zu einem anderen ausdrückt, typischerweise resultierend in einer dimensionslosen Zahl</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;volume ratio&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;material composition&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;volume ratio&apos; then x is a &apos;material composition&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeViscosity -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeViscosity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Volumenviskosität</rdfs:label>
        <rdfs:label xml:lang="en-us">volume viscosity</rdfs:label>
        <skos:example xml:lang="en-us">Water has a volume viscosity of about 3 mPa·s at 25 C, relevant in acoustic wave propagation</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Viscosity(x) ← VolumeViscosity(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Volume viscosity measures a fluid&apos;s resistance to volumetric stress</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Volumenviskosität misst den Widerstand eines Fluids gegenüber volumetrischer Belastung</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;volume viscosity&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;viscosity&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;volume viscosity&apos; then x is a &apos;viscosity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumetricThermalExpansionCoefficient -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumetricThermalExpansionCoefficient">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalExpansionCoefficient"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">thermischer Volumenausdehnungskoeffizient</rdfs:label>
        <rdfs:label xml:lang="en-us">volumetric thermal expansion coefficient</rdfs:label>
        <skos:example xml:lang="en-us">Liquid water near 4 C has a near-zero volumetric thermal expansion coefficient, giving maximum density</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">ThermalExpansionCoefficient(x) ← VolumetricThermalExpansionCoefficient(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Der volumetrische Wärmeausdehnungskoeffizient quantifiziert den Grad, um den sich ein Material beim gleichzeitigen Erhitzen in alle drei axialen Richtungen ausdehnt</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Volumetric thermal expansion coefficient quantifies the degree to which a material expands upon heating into all three axial directions simultaneously</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;volumetric thermal expansion coefficient&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;thermal expansion coefficient&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;volumetric thermal expansion coefficient&apos; then x is a &apos;thermal expansion coefficient&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/WaterAbsorption -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/WaterAbsorption">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Wasseraufnahme</rdfs:label>
        <rdfs:label xml:lang="en-us">water absorption</rdfs:label>
        <skos:example xml:lang="en-us">Water absorption of a nylon 6 specimen immersed for 24 hours expressed as 2.5% of its dry mass, measured according to ISO 62.</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalCapability(x) ← WaterAbsorption(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Wasseraufnahme ist eine physische Fähigkeit eines Materials, Wasser aufzunehmen, quantifiziert als Massenzunahme einer Probe im Verhältnis zur anfänglichen Trockenmasse</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Water absorption is a physical capability of a material to take up water, quantified as the increase in mass of a specimen relative to its initial dry mass</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;water absorption&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical capability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;water absorption&apos; then x is a &apos;physical capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Wavelength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Wavelength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Wellenlänge</rdfs:label>
        <rdfs:label xml:lang="en-us">wavelength</rdfs:label>
        <skos:example xml:lang="en-us">A green laser pointer emits light at a wavelength of 532 nm</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://www.oxfordreference.com/display/10.1093/oi/authority.20110803121421585"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Length(x) ← Wavelength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Wavelength is the distance between successive peaks or troughs of a wave, equal to wave speed divided by frequency</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Wellenlänge ist die Entfernung zwischen aufeinanderfolgenden Gipfeln oder Tälern einer Welle, gleich der Wellenbewegungsgeschwindigkeit geteilt durch die Frequenz</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;wavelength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;length&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.oxfordreference.com/display/10.1093/oi/authority.20110803121421585.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;wavelength&apos; then x is a &apos;length&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/WearResistance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/WearResistance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Durability"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Verschleißfestigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">wear resistance</rdfs:label>
        <skos:altLabel xml:lang="en-us">resistance to wear</skos:altLabel>
        <skos:altLabel xml:lang="de">widerstand gegen Verschleiß</skos:altLabel>
        <skos:example xml:lang="en-us">Hardened tool steel has high wear resistance, maintaining a cutting edge through thousands of machining cycles</skos:example>
        <skos:prefLabel xml:lang="de">Verschleißfestigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">wear resistance</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Durability(x) ← WearResistance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Verschleißfestigkeit ist die Fähigkeit eines Materials, mechanischen Aktionen wie Reiben, Kratzen oder Erosion zu widerstehen, die dazu tendieren, Material allmählich von seiner Oberfläche zu entfernen.</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Wear resistance is the ability of a material to resist mechanical actions such as rubbing, scraping or erosion that tend to progressively remove material from its surface.</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;wear resistance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;durability&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;wear resistance&apos; then x is a &apos;durability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/WeatheringResistance -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/WeatheringResistance">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OperationalStrength"/>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Witterungsbeständigkeit</rdfs:label>
        <rdfs:label xml:lang="en-us">weathering resistance</rdfs:label>
        <skos:altLabel xml:lang="en-us">weather resistant</skos:altLabel>
        <skos:altLabel xml:lang="de">wetterbeständig</skos:altLabel>
        <skos:example xml:lang="en-us">HDPE pipes show high weathering resistance, retaining mechanical properties after years of UV exposure</skos:example>
        <skos:note xml:lang="en-us">Was a subclass of &apos;Operational Strength&apos;;

But &apos;Operational Strength&apos; does not appear to be Quality.</skos:note>
        <skos:prefLabel xml:lang="de">Witterungsbeständigkeit</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">weathering resistance</skos:prefLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">OperationalStrength(x) ← WeatheringResistance(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Ability of a material to resist the effects of weathering, such as wind, rain, and sunlight.</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Fähigkeit eines Materials, den Auswirkungen von Witterungseinflüssen wie Wind, Regen und Sonnenlicht standzuhalten.</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;weathering resistance&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;operational strength&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;weathering resistance&apos; then x is a &apos;operational strength&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Weight -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Weight">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Gewicht</rdfs:label>
        <rdfs:label xml:lang="en-us">weight</rdfs:label>
        <skos:example xml:lang="en-us">A concrete block has a weight of 2.5 kN in the gravitational field at sea level</skos:example>
        <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Weight"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Force(x) ← Weight(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">In der Wissenschaft und Technik ist das Gewicht eines Objekts die Kraft, die aufgrund der Erdbeschleunigung auf das Objekt einwirkt.</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">In science and engineering, the weight of an object, is the force acting on the object due to acceleration of gravity.</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;weight&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;force&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Weight.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;weight&apos; then x is a &apos;force&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Width -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Width">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Breite</rdfs:label>
        <rdfs:label xml:lang="en-us">width</rdfs:label>
        <skos:altLabel xml:lang="en-us">breadth</skos:altLabel>
        <skos:example xml:lang="en-us">A flat tensile specimen has a width of 25 mm in the gauge section</skos:example>
        <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000921"/>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Length(x) ← Width(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Breite beschreibt eine 1- Dimension, die von Seite zu Seite auf einem Objekt oder Raum gemessen wird und die laterale Dimension betont</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Width describes a 1-D extent measured side-to-side on an object or space, emphasizing the lateral dimension</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;width&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;length&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000921.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;width&apos; then x is a &apos;length&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/WorkHardeningCoefficient -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/WorkHardeningCoefficient">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Verfestigungsexponent</rdfs:label>
        <rdfs:label xml:lang="en-us">work hardening coefficient</rdfs:label>
        <skos:altLabel xml:lang="de">Kaltverfestigungsexponent</skos:altLabel>
        <skos:altLabel xml:lang="en-us">strain hardening exponent</skos:altLabel>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">PhysicalRateQuality(x) ← WorkHardeningCoefficient(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Verfestigungsexponent ist eine physikalische Ratenqualität eines Materials, die die Geschwindigkeit beschreibt, mit der die Fließspannung bei plastischer Verformung während der Kaltumformung zunimmt, ausgedrückt als Exponent n in der Hollomon-Potenzgesetzbeziehung</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Work hardening coefficient is a physical rate quality of a material that quantifies the rate at which flow stress increases with plastic strain during cold working, expressed as the exponent n in the Hollomon power-law relation</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;work hardening coefficient&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;physical rate quality&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;work hardening coefficient&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <iof-av:symbol xml:lang="en-us">n</iof-av:symbol>
    </owl:Class>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/YieldStrength -->

    <owl:Class rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/YieldStrength">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Plasticity"/>
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">Fließgrenze</rdfs:label>
        <rdfs:label xml:lang="en-us">yield strength</rdfs:label>
        <skos:altLabel xml:lang="en-us">yield stress</skos:altLabel>
        <skos:example xml:lang="en-us">The yield strength of mild steel is approximately 250 MPa, beyond which permanent deformation begins</skos:example>
        <iof-av:firstOrderLogicAxiom xml:lang="en-us">Plasticity(x) ← YieldStrength(x)</iof-av:firstOrderLogicAxiom>
        <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
        <iof-av:naturalLanguageDefinition xml:lang="de">Fließgrenze bezeichnet das Spannungsniveau, bei dem sich Material beginnt, plastisch zu verformen und das Ende des elastischen Verhaltens markiert</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Yield strength signfies the stress level at which material begins to deform plastically, marking the end of elastic behavior</iof-av:naturalLanguageDefinition>
        <iof-av:primitiveRationale xml:lang="en-us">Necessary and sufficient conditions for &apos;yield strength&apos; have not yet been formalized. The term is defined as a specific subtype of &apos;plasticity&apos;. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
        <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-us">if x is a &apos;yield strength&apos; then x is a &apos;plasticity&apos;</iof-av:semiFormalNaturalLanguageAxiom>
        <AnnotationVocabulary1:naturalLanguageDefinition xml:lang="en-us">Yield strength signfies the stress level at which material begins to deform plastically, marking the end of elastic behavior</AnnotationVocabulary1:naturalLanguageDefinition>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/YieldStrength"/>
        <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
        <owl:annotatedTarget xml:lang="en-us">Yield strength signfies the stress level at which material begins to deform plastically, marking the end of elastic behavior</owl:annotatedTarget>
        <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Yield_(engineering)</iof-av:directSource>
    </owl:Axiom>
    


