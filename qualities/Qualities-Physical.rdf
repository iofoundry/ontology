     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:iof-core="https://spec.industrialontologies.org/ontology/core/Core/"
     xmlns:AnnotationVocabulary="https://www.omg.org/spec/Commons/AnnotationVocabulary/"
     xmlns:AnnotationVocabulary1="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/">
    <owl:Ontology rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/">
        <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202507/qualities/Qualities-Physical/"/>
        <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
        <dcterms:abstract xml:lang="en-us">The IOF Physical Qualities Ontology represents Qualities found in material entities (e.g., Mass).</dcterms:abstract>
        <dcterms:contributor xml:lang="en-us">Thomas Hanke, Fraunhofer IWM</dcterms:contributor>
        <dcterms:creator xml:lang="en-us">IOF Materials Working Group</dcterms:creator>
        <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
        <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
        <dcterms:references rdf:resource="http://spec.org/dc/terms/"/>
        <dcterms:references rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
        <dcterms:title xml:lang="en-us">Industrial Ontology Foundry (IOF) Physical Qualities Ontology</dcterms:title>
        <rdfs:label xml:lang="en-us">Physical Qualities Ontology</rdfs:label>
        <owl:versionInfo>202507</owl:versionInfo>
        <iof-av:copyright xml:lang="en-us">Copyright (c) 2025 Industrial Ontology Foundry (IOF)</iof-av:copyright>
        <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
    </owl:Ontology>
    


