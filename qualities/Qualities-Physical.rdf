    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/isTriggeredBy -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/isTriggeredBy">
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="en-us">is triggered by</rdfs:label>
        <rdfs:label xml:lang="de">wird ausgelöst durch</rdfs:label>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Is triggered by relates a response process to the stimulus process that caused or initiated it</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="de">Ist ausgelöst durch bezieht einen Reaktionsprozess auf den Stimulusprozess, der ihn verursacht oder eingeleitet hat</iof-av:naturalLanguageDefinition>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/triggers -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/triggers">
        <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
        <rdfs:label xml:lang="de">löst aus</rdfs:label>
        <rdfs:label xml:lang="en-us">triggers</rdfs:label>
        <iof-av:naturalLanguageDefinition xml:lang="de">Löst aus bezieht einen Stimulusprozess auf den Reaktionsprozess, den er verursacht oder einleitet</iof-av:naturalLanguageDefinition>
        <iof-av:naturalLanguageDefinition xml:lang="en-us">Triggers relates a stimulus process to the response process that it causes or initiates</iof-av:naturalLanguageDefinition>
    </owl:AnnotationProperty>
    


