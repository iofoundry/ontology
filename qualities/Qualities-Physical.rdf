    <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalReflectance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/created">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Inductance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:label xml:lang="de">Induktion</rdfs:label>
    <rdfs:label xml:lang="en-US">inductance</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Inductance"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Inductance is the tendency of an electrical conductor to oppose a change in electric current through electromagnetic induction, creating back electromotive force</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Induktivität ist die Tendenz eines elektrischen Leiters, einer Änderung des elektrischen Stroms durch elektromagnetische Induktion entgegenzuwirken und so eine elektromotorische Gegenkraft zu erzeugen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'inductance' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Inductance.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhysicalRelationalQuality(x) ← Inductance(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;inductance&apos; then x is a &apos;physical relational quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A solenoid coil of 100 turns has an inductance of 1 mH, opposing rapid current changes</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/triggers">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
    <rdfs:label xml:lang="en-US">triggers</rdfs:label>
    <rdfs:label xml:lang="de">löst aus</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Triggers relates a stimulus process to the response process that it causes or initiates</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Löst aus bezieht einen Stimulusprozess auf den Reaktionsprozess, den er verursacht oder einleitet</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/core/Core/hasCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RelativeIsotopicMass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <rdfs:label xml:lang="de">relative Isotopenmasse</rdfs:label>
    <rdfs:label xml:lang="en-US">relative isotopic mass</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Atomic_mass"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Relative Isotopenmasse bezieht sich auf die Masse eines einzelnen Isotops im Vergleich zu 1/12 der Masse eines Kohlenstoff-12-Atoms</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Relative isotopic mass refers to the mass of a single isotope compared to 1/12 of the mass of a carbon-12 atom</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'relative isotopic mass' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Atomic_mass.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhysicalRateQuality(x) ← RelativeIsotopicMass(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;relative isotopic mass&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The relative isotopic mass of carbon-13 is 13.003 u, slightly heavier than carbon-12</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EModulus1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElasticModulus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalReflectance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <rdfs:label xml:lang="en-US">optical reflectance</rdfs:label>
    <rdfs:label xml:lang="de">optische Reflexion</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Optical reflectance is defined by the ratio of reflected radiant power to incident radiant power, assessing reflective capacity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der optische Reflexionsgrad wird durch das Verhältnis der reflektierten Strahlungsleistung zur einfallenden Strahlungsleistung definiert und bewertet die Reflexionsfähigkeit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'optical reflectance' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PhysicalRateQuality(x) ← OpticalReflectance(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;optical reflectance&apos; then x is a &apos;physical rate quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A silver mirror has an optical reflectance of 98 % at 600 nm wavelength</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N2db92aac0331469981ea34640d749030">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasQuality"/>
