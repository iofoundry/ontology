  <rdf:Description rdf:nodeID="Nce6eba50479946c8ad374b458b0a911f">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
