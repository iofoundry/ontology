<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/"
   xmlns:AnnotationVocabulary="https://www.omg.org/spec/Commons/AnnotationVocabulary/"
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:iof-av="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"
   xmlns:iof-core="https://spec.industrialontologies.org/ontology/core/Core/"
   xmlns:obo="http://purl.obolibrary.org/obo/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/DimensionQuality"/>
    <rdfs:label xml:lang="de">Länge</rdfs:label>
    <rdfs:label xml:lang="en">length</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000122"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Length characterizes a 1-D extent equal to the distance between two points</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'length' have not yet been formalized. The term is defined as a specific subtype of 'DimensionQuality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000122.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LinearThermalExpansionCoefficient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalExpansionCoefficient"/>
    <rdfs:label xml:lang="en">linear thermal expansion coefficient</rdfs:label>
    <rdfs:label xml:lang="de">linearer thermischer Ausdehnungkoeffizient</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Linear thermal expansion coefficient quantifies the degree to which a material expands upon heating into a specific axial direction</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'linear thermal expansion coefficient' have not yet been formalized. The term is defined as a specific subtype of 'thermal expansion coefficient'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicViscosity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity"/>
    <rdfs:label xml:lang="en">dynamic viscosity</rdfs:label>
    <rdfs:label xml:lang="de">dynamische Viskosität</rdfs:label>
    <skos:prefLabel xml:lang="en">dynamic viscosity</skos:prefLabel>
    <skos:prefLabel xml:lang="de">dynamische Viskosität</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die dynamische Viskosität ist ein Maß für den Widerstand eines Fluids gegen eine allmähliche Verformung durch Scher- oder Zugspannung. Es ist ein Maß für den inneren Widerstand des Fluids gegen den Fluss und kann als Maß für die Flüssigkeitsreibung betrachtet werden</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Dynamic viscosity measures a fluid's resistance to gradual deformation by shear stress or tensile stress, indicative of the fluid's internal friction</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'dynamic viscosity' have not yet been formalized. The term is defined as a specific subtype of 'viscosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdfs:label xml:lang="en">thermo dynamic quality</rdfs:label>
    <rdfs:label xml:lang="de">thermodynamische Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Thermo dynamic quality characterizes a material entity's behavior or state in relation to thermal heating or cooling</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Thermodynamische Qualität beschreibt das Verhalten oder den Zustand eines materiellen Wesens in Bezug auf thermische Erwärmung oder Kühlung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'thermo dynamic quality' have not yet been formalized. The term is defined as a specific subtype of 'physical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectromotiveForce">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <rdfs:label xml:lang="de">Quellenspannung</rdfs:label>
    <rdfs:label xml:lang="en">electromotive force</rdfs:label>
    <iof-av:abbreviation xml:lang="en">EMP</iof-av:abbreviation>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Electromotive_force"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electromotive force refers to energy transferred to an electric circuit per unit charge, measured in volts, produced by transducers converting forms of energy to electrical energy</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electromotive force' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Electromotive_force.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:label xml:lang="en">physical rate quality</rdfs:label>
    <rdfs:label xml:lang="de">physische Geschwindigkeitsqualität</rdfs:label>
    <iof-av:explanatoryNote xml:lang="en">Rate =(def.) a measure, quantity, or frequency, typically one measured against some other quantity or measure</iof-av:explanatoryNote>
    <iof-av:naturalLanguageDefinition xml:lang="en">Physical rate quality denotes the quotient of two physical quantities in different units, representing one quantity's rate of change in relation to another</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'physical rate quality' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N07201ca9e145450d9f349ab1303dacce">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
    <owl:annotatedTarget xml:lang="en">Physical rate quality denotes the quotient of two physical quantities in different units, representing one quantity's rate of change in relation to another</owl:annotatedTarget>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Rate_(mathematics)"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Plasticity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
    <rdfs:label xml:lang="de">Plastizität</rdfs:label>
    <rdfs:label xml:lang="en">plasticity</rdfs:label>
    <skos:prefLabel xml:lang="de">Plastizität</skos:prefLabel>
    <skos:prefLabel xml:lang="en">plasticity</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Plasticity signifies a material's ability to undergo permanent deformation without breaking or cracking</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Plastizität bezeichnet die Fähigkeit eines Materials, dauerhafte Verformungen ohne Bruch oder Riss zu erleiden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'plasticity' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalConductance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
    <rdfs:label xml:lang="en">thermal conductance</rdfs:label>
    <rdfs:label xml:lang="de">thermische Leitfähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Thermal conduction refers to the process by which heat is transferred from the hotter end to the colder end of an object, characterized by conductance</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Thermische Leitung beschreibt den Prozess, bei dem Wärme vom heißeren zum kälteren Ende eines Objekts übertragen wird, gekennzeichnet durch Leitfähigkeit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'thermal conductance' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/YieldStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Plasticity"/>
    <rdfs:label xml:lang="de">Fließgrenze</rdfs:label>
    <rdfs:label xml:lang="en">yield strength</rdfs:label>
    <skos:altLabel xml:lang="en">yield stress</skos:altLabel>
    <iof-av:naturalLanguageDefinition xml:lang="de">Fließgrenze bezeichnet das Spannungsniveau, bei dem sich Material beginnt, plastisch zu verformen und das Ende des elastischen Verhaltens markiert</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Yield strength signfies the stress level at which material begins to deform plastically, marking the end of elastic behavior</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'yield strength' have not yet been formalized. The term is defined as a specific subtype of 'plasticity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AgingTemperature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Temperature"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Alterungstemperatur</rdfs:label>
    <rdfs:label xml:lang="en">aging temperature</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Aging temperature refers to variable temperature during an aging process depending on the desired deposition formations</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'aging temperature' have not yet been formalized. The term is defined as a specific subtype of 'temperature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificHeatCapacity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
    <rdfs:label xml:lang="en">specific heat capacity</rdfs:label>
    <rdfs:label xml:lang="de">spezifische Wärmekapazität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Specific heat capacity is the heat capacity of a sample divided by its mass, representing the heat required to raise temperature by one unit</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Spezifische Wärmekapazität ist die Wärmekapazität einer Probe geteilt durch ihre Masse und repräsentiert die erforderliche Wärme, um die Temperatur um eine Einheit zu erhöhen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'specific heat capacity' have not yet been formalized. The term is defined as a specific subtype of 'thermo dynamic quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TensileStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BreakingStrength"/>
    <rdfs:label xml:lang="de">Zugfestigkeit</rdfs:label>
    <rdfs:label xml:lang="en">tensile strength</rdfs:label>
    <skos:altLabel xml:lang="en">ultimate tensile strength</skos:altLabel>
    <skos:prefLabel xml:lang="de">Zugfestigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">ultimate tensile strength</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Tensile strength measures the maximum stress a material can withstand while being stretched or pulled before breaking</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zugfestigkeit misst die maximale Spannung, die ein Material aushalten kann, während es gestreckt oder gezogen wird, bevor es bricht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'tensile strength' have not yet been formalized. The term is defined as a specific subtype of 'breaking strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElasticModulus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness"/>
    <rdfs:label xml:lang="de">Elastizitätsmodul</rdfs:label>
    <rdfs:label xml:lang="en">elastic modulus</rdfs:label>
    <skos:altLabel xml:lang="en">Young's modulus</skos:altLabel>
    <skos:altLabel xml:lang="en">modulus of elasticity</skos:altLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Elastic modulus represents the quotient of change of stress and change of percentage extension in the evaluation range, recommending reporting in GPa rounded to the nearest 0.1 GPa according to ISO 80000-1</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Quotient der Änderung der Spannung ΔR und Änderung der prozentualen Dehnung Δe in dem untersuchten Bereich multipliziert mit 100 %. Anmerkung: Es wird empfohlen, den Wert in GPa, gerundet auf 0,1 GPa, und nach ISO 80000-1 anzugeben</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'elastic modulus' have not yet been formalized. The term is defined as a specific subtype of 'stiffness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TrueStrain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
    <rdfs:label xml:lang="en">true strain</rdfs:label>
    <rdfs:label xml:lang="de">wahre Dehnung</rdfs:label>
    <skos:altLabel xml:lang="en">logarithmic strain</skos:altLabel>
    <skos:altLabel xml:lang="en">Hencky strain</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Strain_(mechanics)"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">True strain, or logarithmic strain, integrates incrementally over deformation; related to engineering strain as ε=ln(1+e)</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Wahre Dehnung, auch als logarithmische Dehnung bekannt, integriert sich schrittweise über die Verformung; in Beziehung zum technischen Dehnungsmaß als ε=ln(1+e)</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'true strain' have not yet been formalized. The term is defined as a specific subtype of 'strain'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Strain_(mechanics).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ShearViscosity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity"/>
    <rdfs:label xml:lang="de">Scherviskosität</rdfs:label>
    <rdfs:label xml:lang="en">shear viscosity</rdfs:label>
    <skos:prefLabel xml:lang="de">Scherviskosität</skos:prefLabel>
    <skos:prefLabel xml:lang="en">shear viscosity</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="de">Scherviskosität misst den Widerstand eines Fluids gegen Scherfluss</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shear viscosity measures a fluid's resistance to shear flow</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'shear viscosity' have not yet been formalized. The term is defined as a specific subtype of 'viscosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EngineeringStrain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
    <rdfs:label xml:lang="en">engineering strain</rdfs:label>
    <rdfs:label xml:lang="de">technische Dehnung</rdfs:label>
    <skos:altLabel xml:lang="en">Cauchy strain</skos:altLabel>
    <skos:altLabel xml:lang="en">technical strain</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Strain_(mechanics)"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Engineering strain, or Cauchy strain, expresses total deformation relative to the initial dimension of the material under load, reflecting elongation in axial loading</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'engineering strain' have not yet been formalized. The term is defined as a specific subtype of 'strain'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Strain_(mechanics).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricCharge">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalQuality"/>
    <rdfs:label xml:lang="en">electric charge</rdfs:label>
    <rdfs:label xml:lang="de">elektrische Ladung</rdfs:label>
    <skos:altLabel xml:lang="de">elektrische Ladung</skos:altLabel>
    <skos:prefLabel xml:lang="en">electric charge</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electric charge refers to the physical property of matter causing it to experience a force when placed in an electromagnetic field</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electric charge' have not yet been formalized. The term is defined as a specific subtype of 'electrical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
    <rdfs:label xml:lang="en">thermal capability</rdfs:label>
    <rdfs:label xml:lang="de">thermische Fähigkeit</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Thermal capability can be realized through an entity related to thermodynamic interaction</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Thermische Fähigkeit kann durch eine Entität im Zusammenhang mit thermischer Wechselwirkung realisiert werden</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'thermal capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Volume">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/DimensionQuality"/>
    <rdfs:label xml:lang="de">Volumen</rdfs:label>
    <rdfs:label xml:lang="en">volume</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000918"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Volume signifies the 3-D extent quality inhering due to the bearer's occupied space</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Volumen bezeichnet die 3-D-Ausdehnungsqualität, die aufgrund des vom Träger besetzten Raums entsteht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'volume' have not yet been formalized. The term is defined as a specific subtype of 'DimensionQuality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000918.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/materials/Materials/HardnessMeasurementCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/MeasurementCapability"/>
    <rdfs:label xml:lang="en">hardness measurement capability</rdfs:label>
    <skos:altLabel xml:lang="de">Indentierungsartefaktfunktionalität</skos:altLabel>
    <skos:altLabel xml:lang="en">indenting Artifact Functionality</skos:altLabel>
    <skos:prefLabel xml:lang="de">Härte-Messfähigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">hardness measurement capability</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Hardness measurement capability is a function that is realized during events in which an artifact is used to create an impression in a wide object</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Härte Messfähigkeit ist eine Funktion, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um einen Eindruck in ein weiter Objekt zu erzeugen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'hardness measurement capability' have not yet been formalized. The term is defined as a specific subtype of 'MeasurementCapability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/WearResistance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Durability"/>
    <rdfs:label xml:lang="de">Verschleißfestigkeit</rdfs:label>
    <rdfs:label xml:lang="en">wear resistance</rdfs:label>
    <skos:altLabel xml:lang="en">resistance to wear</skos:altLabel>
    <skos:altLabel xml:lang="de">widerstand gegen Verschleiß</skos:altLabel>
    <skos:prefLabel xml:lang="de">Verschleißfestigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">wear resistance</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="de">Verschleißfestigkeit ist die Fähigkeit eines Materials, mechanischen Aktionen wie Reiben, Kratzen oder Erosion zu widerstehen, die dazu tendieren, Material allmählich von seiner Oberfläche zu entfernen.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Wear resistance is the ability of a material to resist mechanical actions such as rubbing, scraping or erosion that tend to progressively remove material from its surface.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'wear resistance' have not yet been formalized. The term is defined as a specific subtype of 'durability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SunLigthingProcess1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <obo:BFO_0000055 rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SunLigthing1"/>
    <obo:BFO_0000057 rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Sun"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationEmissonCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
    <rdfs:label xml:lang="en">radiation emission capability</rdfs:label>
    <rdfs:label xml:lang="de">Strahlungsemissionsfähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Radiation emission capability is a physical capability of a material entity to emit electromagnetic radiation, realized in processes where the bearer radiates energy in the form of electromagnetic waves</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'radiation emission capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ImpactStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Toughness"/>
    <rdfs:label xml:lang="de">Schlagzähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">impact strength</rdfs:label>
    <skos:altLabel xml:lang="de">Schlagfestigkeit</skos:altLabel>
    <skos:altLabel xml:lang="en">mpact strength</skos:altLabel>
    <skos:prefLabel xml:lang="de">Schlagzähigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">impact strength</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Impact strength is the ability of a material to absorb energy and plastically deform without fracturing under dynamic load</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schlagzähigkeit bezeichnet die Fähigkeit eines Materials, Energie zu absorbieren und bei Anwendung einer dynamischen Last plastisch zu verformen, ohne dass es bricht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'impact strength' have not yet been formalized. The term is defined as a specific subtype of 'toughness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TemperatureProfile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
    <rdfs:label xml:lang="de">Temperaturprofil</rdfs:label>
    <rdfs:label xml:lang="en">temperature profile</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="de">Temperatur Profil beschreibt Änderungen der Temperatur eines materiellen Wesens oder Raums über die Zeit</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Temperature profile describes changes in the temperature of a material entity or space over time</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'temperature profile' have not yet been formalized. The term is defined as a specific subtype of 'physical process characteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Thrust">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force"/>
    <rdfs:label xml:lang="de">Schubkraft</rdfs:label>
    <rdfs:label xml:lang="en">thrust</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Thrust"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schubkraft ist eine von Newtons drittem Gesetz beschriebene Kraft, bei der Massenbeschleunigung in eine Richtung eine gleich große Kraft in die entgegengesetzte Richtung verursacht</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Thrust is a force described by Newton's third law, where mass expulsion in one direction causes an equal force in the opposite direction</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'thrust' have not yet been formalized. The term is defined as a specific subtype of 'force'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Thrust.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TensionForceMeasurementCapability1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/materials/Materials/ForceMeasurementCapability"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nebfc032f7e4c44cb90e790cf0226b8b6">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapacity"/>
    <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
    <owl:annotatedTarget xml:lang="en">Thermal capacity, or heat capacity, is defined as the amount of heat required to produce a unit change in temperature of an object</owl:annotatedTarget>
    <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Heat_capacity</iof-av:directSource>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Displacement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/SpatialRelationalQuality"/>
    <rdfs:label xml:lang="de">Verschiebung</rdfs:label>
    <rdfs:label xml:lang="en">displacement</rdfs:label>
    <skos:altLabel xml:lang="de">Auslenkung</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Displacement_(geometry)"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">In geometry and mechanics, displacement is a vector representing the shortest distance from the initial to the final position of a point undergoing motion</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'displacement' have not yet been formalized. The term is defined as a specific subtype of 'SpatialRelationalQuality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Displacement_(geometry).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElasticResponse1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <obo:BFO_0000055 rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EModulus1"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeRatio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialComposition"/>
    <rdfs:label xml:lang="de">Volumenverhältnis</rdfs:label>
    <rdfs:label xml:lang="en">volume ratio</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Volume ratio represents a relational quality expressing one volume value relative to another, typically resulting in a dimensionless number</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Volumenverhältnis stellt eine relationale Qualität dar, die einen Volumenwert im Verhältnis zu einem anderen ausdrückt, typischerweise resultierend in einer dimensionslosen Zahl</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'volume ratio' have not yet been formalized. The term is defined as a specific subtype of 'material composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PlasticStrain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
    <rdfs:label xml:lang="en">plastic strain</rdfs:label>
    <rdfs:label xml:lang="de">plastische Deformation</rdfs:label>
    <skos:altLabel xml:lang="en">plastic deformation</skos:altLabel>
    <skos:altLabel xml:lang="de">plastische Verformung</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Plasticity_(physics)"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Plastic strain describes permanent deformation occurring when a material is subjected to stress beyond its elastic limit</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Plastische Deformation beschreibt die dauerhafte Verformung, die auftritt, wenn ein Material einer Belastung ausgesetzt wird, die über seine elastische Grenze hinausgeht</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'plastic strain' have not yet been formalized. The term is defined as a specific subtype of 'strain'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Plasticity_(physics).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odorless">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odor"/>
    <rdfs:label xml:lang="de">geruchlos</rdfs:label>
    <rdfs:label xml:lang="en">odorless</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001208"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Odorless denotes an odor quality inhering in a bearer lacking odor</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'odorless' have not yet been formalized. The term is defined as a specific subtype of 'odor'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001208.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Friction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force"/>
    <rdfs:label xml:lang="de">Reibung</rdfs:label>
    <rdfs:label xml:lang="en">friction</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/friction"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Friction is the force resisting the sliding or rolling of one solid object over another, arising from shear between contact regions of microscopic irregularities</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'friction' have not yet been formalized. The term is defined as a specific subtype of 'force'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/friction.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialFatigue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
    <rdfs:label xml:lang="de">Materialermüdung</rdfs:label>
    <rdfs:label xml:lang="en">material fatigue</rdfs:label>
    <skos:altLabel xml:lang="de">Ermüdung des Materials</skos:altLabel>
    <skos:altLabel xml:lang="en">fatigue of material</skos:altLabel>
    <skos:prefLabel xml:lang="de">Materialermüdung</skos:prefLabel>
    <skos:prefLabel xml:lang="en">material fatigue</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Material fatigue is the failure of a material caused by repeated or sustained loading below its ultimate strength.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Materialermüdung ist das Versagen von Werkstoffen infolge wiederholter oder dauernder Belastung unterhalb der Probenfestigkeit</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'aterial fatigue' have not yet been formalized. The term is defined as a specific subtype of 'mechanical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SoundInsulationIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticCapability"/>
    <rdfs:label xml:lang="de">Schalldämmmaß</rdfs:label>
    <rdfs:label xml:lang="en">sound insulation index</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schalldämmmaß quantifiziert die Fähigkeit eines Materials, die Schallübertragung zu reduzieren</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Sound insulation index quantifies the ability of a material to reduce sound transmission</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'sound insulation index' have not yet been formalized. The term is defined as a specific subtype of 'acoustic capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:isDefinedBy xml:lang="en">A Quality that inheres in a material entity that is an independent continuant which has some portion of matter as continuant part</rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">physical quality</rdfs:label>
    <rdfs:label xml:lang="de">physische Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Physical quality pertains to properties or characteristics related to an entity's physical presence or interaction, independent of other entities</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'physical quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000019'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalInsulation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="en">thermal insulation</rdfs:label>
    <rdfs:label xml:lang="de">thermische Isolierung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Thermal_insulation"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Thermal insulation reduces heat transfer between objects in thermal contact or radiative influence, achieved with engineered methods or material properties</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Thermische Isolierung verringert den Wärmeaustausch zwischen Objekten, die in thermischem Kontakt oder Strahlungseinfluss stehen, realisiert durch spezielle Konstruktionsmethoden oder Materialien</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'thermal insulation' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Thermal_insulation.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalConductance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability"/>
    <rdfs:label xml:lang="en">electrical conductance</rdfs:label>
    <rdfs:label xml:lang="de">elektrische Leitfähigkeit</rdfs:label>
    <skos:altLabel xml:lang="de">Leitfähigkeit</skos:altLabel>
    <skos:altLabel xml:lang="de">Stromleitfähigkeit</skos:altLabel>
    <skos:prefLabel xml:lang="en">electrical conductance</skos:prefLabel>
    <skos:prefLabel xml:lang="de">elektrische Leitfähigkeit</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electrical conductance represents the reciprocal of a conductor's electrical resistance, measuring its ability to conduct an electric current, denoted in siemens (S)</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electrical conductance' have not yet been formalized. The term is defined as a specific subtype of 'electrical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Humidity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Feuchtigkeit</rdfs:label>
    <rdfs:label xml:lang="en">humidity</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Humidity characterizes air's partial pressure exerted by water vapor content, defined as the mass of water to volume of the medium-water mixture</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'humidity' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LuminousIntensity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalQuality"/>
    <rdfs:label xml:lang="de">Lichtstärke in cd gemessen</rdfs:label>
    <rdfs:label xml:lang="en">luminous intensity</rdfs:label>
    <skos:altLabel xml:lang="de">Lichtintensität</skos:altLabel>
    <skos:prefLabel xml:lang="de">Leuchtintensität</skos:prefLabel>
    <skos:prefLabel xml:lang="en">luminous intensity</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="de">Lichtstärke ist die Menge des sichtbaren Lichts, das pro Einheitswinkel in eine bestimmte Richtung von einer Quelle abgestrahlt wird, gemessen in Candela (cd)</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Luminous intensity quantifies the visible light emitted per unit solid angle in a particular direction from a source, measured in candela (cd)</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'luminous intensity' have not yet been formalized. The term is defined as a specific subtype of 'optical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricFluxDensity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density"/>
    <rdfs:label xml:lang="en">electric flux density</rdfs:label>
    <rdfs:label xml:lang="de">elektrische Flussdichte</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/electric-flux"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electric flux density measures the total number of electric lines of force intersecting a given area, originating on positive charges and terminating on negative charges</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electric flux density' have not yet been formalized. The term is defined as a specific subtype of 'density'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/electric-flux.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202507/qualities/Qualities-Physical/"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <dcterms:abstract xml:lang="en-us">The IOF Physical Qualities Ontology represents Qualities found in material entities (e.g., Mass).</dcterms:abstract>
    <dcterms:contributor xml:lang="en-us">Thomas Hanke, Fraunhofer IWM</dcterms:contributor>
    <dcterms:creator xml:lang="en-us">IOF Materials Working Group</dcterms:creator>
    <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
    <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
    <dcterms:references rdf:resource="http://spec.org/dc/terms/"/>
    <dcterms:references rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    <dcterms:title xml:lang="en-us">Industrial Ontology Foundry (IOF) Physical Qualities Ontology</dcterms:title>
    <rdfs:label xml:lang="en">Physical Qualities Ontology</rdfs:label>
    <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/Provisional"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalAction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="Ndb8a92457b494c2d85e736f5bc119524"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Action"/>
    <rdfs:label xml:lang="en">physical action</rdfs:label>
    <rdfs:label xml:lang="de">physikalische Aktion</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Physical action represents a stimulus enacting a physical interaction with an object</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en">PhysicalAction(x) ↔ (∃b ((obo:BFO_0000040(b) ∧ ∃c (PhysicalRelationalQuality(c) ∧ hasQuality(b, c))) ∧ obo:BFO_0000057(x, b)) ∨ ∃d (PhysicalProcessCharacteristic(d) ∧ hasProcessCharacteristic(x, d)))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en">every instance of 'physical action' is defined as exactly an instance of 'that 'obo:BFO_0000057' some an instance of 'BFO_0000040' and that 'hasQuality' some 'physical relational quality'' or 'that 'hasProcessCharacteristic' some 'physical process characteristic''</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiantEnergyFlux">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
    <rdfs:label xml:lang="de">Strahlungsfluss</rdfs:label>
    <rdfs:label xml:lang="en">radiant energy flux</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Radiant_energy"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Radiant energy flux describes the radiant energy emitted, reflected, transmitted, or received per unit time</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsfluss beschreibt die Strahlungsenergie, die pro Zeiteinheit emittiert, reflektiert, übertragen oder empfangen wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'radiant energy flux' have not yet been formalized. The term is defined as a specific subtype of 'physical process characteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Radiant_energy.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Depth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
    <rdfs:label xml:lang="de">Tiefe</rdfs:label>
    <rdfs:label xml:lang="en">depth</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001595"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Depth characterizes a 1-D extent measured from the front to the back, or inward, distinguishing it from width and length</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'depth' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001595.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhaseVelocity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Speed"/>
    <rdfs:label xml:lang="de">Phasengeschwindigkeit</rdfs:label>
    <rdfs:label xml:lang="en">phase velocity</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Phase velocity refers to the rate at which the phase of a wave propagates, defined as wavelength divided by time period</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'phase velocity' have not yet been formalized. The term is defined as a specific subtype of 'speed'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AtomicMass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Mass"/>
    <rdfs:label xml:lang="de">Atommasse</rdfs:label>
    <rdfs:label xml:lang="en">atomic mass</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Atomic_mass"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Atomic mass refers to the mass of an atom, often expressed in the non-SI unit dalton, where 1 Da is defined as 1/12 of the mass of a free carbon-12 atom at rest in its ground state</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'atomic mass' have not yet been formalized. The term is defined as a specific subtype of 'mass'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Atomic_mass.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Thickness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
    <rdfs:label xml:lang="de">Dicke</rdfs:label>
    <rdfs:label xml:lang="en">thickness</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000915"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Dicke stellt das Ausmaß eines Objekts entgegen seinen seitlichen Abmessungen dar und bietet ein Maß für die Tiefe</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Thickness represents the extent of an object opposing its lateral dimensions, providing a measure of depth</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'thickness' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000915.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepResistance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Durability"/>
    <rdfs:label xml:lang="de">Kriechfestigkeit</rdfs:label>
    <rdfs:label xml:lang="en">creep resistance</rdfs:label>
    <skos:altLabel xml:lang="en">Creep Resistant</skos:altLabel>
    <skos:altLabel xml:lang="de">Kriechfestig</skos:altLabel>
    <skos:prefLabel xml:lang="en">Creep Resistance</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Kriechfestigkeit</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Creep resistance is the ability of a material to resist deformation under load over time</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Kriechfestigkeit ist die Fähigkeit eines Materials, unter Last über einen bestimmten Zeitraum eine Deformation zu widerstehen</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'creep resistance' have not yet been formalized. The term is defined as a specific subtype of 'durability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/materials/Materials/ForceRate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
    <obo:IAO_0000116 xml:lang="en">second derivative of momentum with respect to time</obo:IAO_0000116>
    <rdfs:label xml:lang="de">Kraftrate</rdfs:label>
    <rdfs:label xml:lang="en">force rate</rdfs:label>
    <skos:altLabel xml:lang="de">Ruck</skos:altLabel>
    <skos:altLabel xml:lang="en">yank</skos:altLabel>
    <iof-av:naturalLanguageDefinition xml:lang="de">In der Physik wird der Begriff "Ruck" manchmal verwendet, um die Ableitung der Kraft in Bezug auf die Zeit oder die mit dem Ruck multiplizierte Masse zu bezeichnen. In der relativistischen Physik wird dieser Begriff als die zweite Ableitung des Impulses in Bezug auf die Zeit ausgedrückt, da die Masse geschwindigkeitsabhängig ist. Obwohl nicht allgemein als offizieller Begriff für diese Größe anerkannt, wird der Begriff "Ruck" häufig von Physikbegeisterten verwendet</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">In physics, yank is sometimes used to denote the derivative of force with respect to time or mass multiplied by jerk. In relativistic physics, it is expressed as the second derivative of momentum with respect to time, because the mass is velocity-dependent. Though not universally accepted as an official term for this quantity, the term "yank" is commonly used among physics enthusiasts</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition_source xml:lang="en">https://en-academic.com/dic.nsf/enwiki/1620873</iof-av:naturalLanguageDefinition_source>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'force rate' have not yet been formalized. The term is defined as a specific subtype of 'physical process characteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RefractiveIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:label xml:lang="de">Brechzahl</rdfs:label>
    <rdfs:label xml:lang="en">refractive index</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Refractive_index#Complex_index_of_refraction_and_absorption"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Brechzahl gibt die Lichtbrechungsfähigkeit eines optischen Mediums an; umfasst einen realen und einen imaginären Teil, der als Extinktionskoeffizient bekannt ist</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Refractive index indicates an optical medium's light bending ability; encompassing a real and imaginary part known as the extinction coefficient</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'refractive index' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Refractive_index#Complex_index_of_refraction_and_absorption.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pull2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <obo:BFO_0000057 rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Specimen1"/>
    <iof-core:hasProcessCharacteristic rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TensionRate1"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odorous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odor"/>
    <rdfs:label xml:lang="en">odorous</rdfs:label>
    <rdfs:label xml:lang="de">riechend</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001331"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Odorous denotes an odor quality inhering in a bearer possessing odor</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'odorous' have not yet been formalized. The term is defined as a specific subtype of 'odor'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001331.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdfs:label xml:lang="en">acoustic quality</rdfs:label>
    <rdfs:label xml:lang="de">akustische Qualität</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Acoustic quality pertains to properties related to sound or the science of sound, including aspects like pitch, volume, tone, timbre, echo, absorption, or sound wave propagation</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'acoustic quality' have not yet been formalized. The term is defined as a specific subtype of 'physical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Exposure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalQuality"/>
    <rdfs:label xml:lang="de">Belichtungszeit</rdfs:label>
    <rdfs:label xml:lang="en">exposure</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Exposure_(photography)"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Exposure in photography refers to the amount of light per unit area reaching film or sensor, determined by shutter speed, lens F-number, and scene luminance</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'exposure' have not yet been formalized. The term is defined as a specific subtype of 'optical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Exposure_(photography).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OperationalStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
    <rdfs:label xml:lang="de">Betriebsfestigkeit</rdfs:label>
    <rdfs:label xml:lang="en">operational strength</rdfs:label>
    <skos:altLabel xml:lang="de">Betriebsstärke</skos:altLabel>
    <skos:altLabel xml:lang="en">operation strength</skos:altLabel>
    <skos:prefLabel xml:lang="de">Betriebsfestigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">operational strength</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="de">Betriebsfestigkeit beschreibt die Fähigkeit eines Systems, seine vorgesehene Funktion in einer betrieblichen Umgebung auszuführen</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Operational strength describes a system's ability to perform its intended function in an operational environment</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'operational strength' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Malleability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Ductility"/>
    <rdfs:label xml:lang="de">Formbarkeit</rdfs:label>
    <rdfs:label xml:lang="en">malleability</rdfs:label>
    <skos:altLabel xml:lang="en">Malleable</skos:altLabel>
    <skos:altLabel xml:lang="de">formbar</skos:altLabel>
    <skos:prefLabel xml:lang="de">Formbarkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Malleability</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="de">Formbarkeit beschreibt Materialien, die durch Hammern oder Walzen bearbeitet werden können und sich von Duktilität unterscheiden</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Malleability refers to a material's amenability to forming by hammering or rolling, distinct from ductility</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'malleability' have not yet been formalized. The term is defined as a specific subtype of 'ductility'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticFlux">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticQuality"/>
    <rdfs:label xml:lang="en">magnetic flux</rdfs:label>
    <rdfs:label xml:lang="de">magnetischer Fluss</rdfs:label>
    <skos:altLabel xml:lang="de">Magnetfeld</skos:altLabel>
    <skos:altLabel xml:lang="en">magnetic field</skos:altLabel>
    <skos:prefLabel xml:lang="en">magnetic flux</skos:prefLabel>
    <skos:prefLabel xml:lang="de">magnetischer Fluss</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Magnetic flux is the total number of magnetic field lines passing through a given area</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Magnetischer Fluss ist die Gesamtanzahl der Magnetfeldlinien, die durch eine bestimmte Fläche verlaufen</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'magnetic flux' have not yet been formalized. The term is defined as a specific subtype of 'magnetic quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SurfaceTension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Adhesion"/>
    <rdfs:label xml:lang="de">Oberflächenspannung</rdfs:label>
    <rdfs:label xml:lang="en">surface tension</rdfs:label>
    <skos:altLabel xml:lang="en">surface stress</skos:altLabel>
    <skos:prefLabel xml:lang="de">Oberflächenspannung</skos:prefLabel>
    <skos:prefLabel xml:lang="en">surface tension</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="de">Oberflächenspannung bezeichnet den Effekt innerhalb der Oberflächenschicht einer Flüssigkeit, der durch Wechselwirkungskräfte zwischen ihren Molekülen verursacht wird</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Surface tension refers to the effect within the surface layer of a liquid, caused by intermolecular forces between its molecules</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'surface tension' have not yet been formalized. The term is defined as a specific subtype of 'adhesion'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdfs:label xml:lang="en">electrical quality</rdfs:label>
    <rdfs:label xml:lang="de">elektrische Qualität</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electrical quality characterizes a material entity's behavior or state concerning electricity</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electrical quality' have not yet been formalized. The term is defined as a specific subtype of 'physical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassMixRatio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassRatio"/>
    <rdfs:label xml:lang="de">Massenmischungsverhältnis</rdfs:label>
    <rdfs:label xml:lang="en">mass mix ratio</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Massenverh%C3%A4ltnis"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mass mix ratio represents the ratio of masses of two mixture components, providing a quantitative composition description</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mass mix ratio' have not yet been formalized. The term is defined as a specific subtype of 'mass ratio'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Massenverh%C3%A4ltnis.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapacity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Wärmekapazität</rdfs:label>
    <rdfs:label xml:lang="en">thermal capacity</rdfs:label>
    <skos:altLabel xml:lang="en">heat capacity</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Heat_capacity"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Thermal capacity, or heat capacity, is defined as the amount of heat required to produce a unit change in temperature of an object</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Wärmekapazität, auch als thermische Kapazität bekannt, ist die Menge an Wärme, die erforderlich ist, um eine Änderung der Temperatur eines Objekts um eine Einheit zu erzeugen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'thermal capacity' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Heat_capacity.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricPotential">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Potential"/>
    <rdfs:label xml:lang="en">electric potential</rdfs:label>
    <rdfs:label xml:lang="de">elektrisches Potential</rdfs:label>
    <skos:altLabel xml:lang="en">voltage</skos:altLabel>
    <skos:altLabel xml:lang="de">Stromspannung</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/electric-potential"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electric potential characterizes the amount of work needed to move a unit charge from a reference point to a specific point against an electric field, typically from Earth or any point beyond the field's influence</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electric potential' have not yet been formalized. The term is defined as a specific subtype of 'potential'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LightReflexion1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <obo:BFO_0000055 rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RelaxtionCap1"/>
    <isTriggeredBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SunExposureProcess1"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PixelDensity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/NumberDensity"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Pixeldichte</rdfs:label>
    <rdfs:label xml:lang="en">pixel density</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Pixel density describes the relationship between the number of pixels and the area they occupy on a related entity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Pixeldichte beschreibt das Verhältnis zwischen der Anzahl der Pixel und der Fläche, die sie auf einer verwandten Entität einnehmen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'pixel density' have not yet been formalized. The term is defined as a specific subtype of 'number density'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatTransferCoefficient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:label xml:lang="de">Wärmeübergangskoeffizient</rdfs:label>
    <rdfs:label xml:lang="en">heat transfer coefficient</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Heat_transfer_coefficient"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Heat transfer coefficient represents the proportionality constant between heat flux and the thermodynamic driving force for heat flow, used in calculating heat transfer, typically by convection</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'heat transfer coefficient' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Heat_transfer_coefficient.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricFieldStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalQuality"/>
    <rdfs:label xml:lang="en">electric field strength</rdfs:label>
    <rdfs:label xml:lang="de">elektrische Feldstärke</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/electric-field"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electric field strength, or intensity, refers to the magnitude and direction of the electric field at a point, crucial for determining effects on electric charges near that point</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electric field strength' have not yet been formalized. The term is defined as a specific subtype of 'electrical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/electric-field.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapacitance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability"/>
    <rdfs:label xml:lang="en">electrical capacitance</rdfs:label>
    <rdfs:label xml:lang="de">elektrische Kapazität</rdfs:label>
    <skos:altLabel xml:lang="en">electrical capacity</skos:altLabel>
    <skos:altLabel xml:lang="de">elektrische Kapazität</skos:altLabel>
    <skos:prefLabel xml:lang="en">electrical capacitance</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electrical capacitance refers to an entity's ability to store electric charge, expressed as the amount of electric charge stored per given electric potential</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electrical capacitance' have not yet been formalized. The term is defined as a specific subtype of 'electrical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassFraction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassRatio"/>
    <rdfs:label xml:lang="de">Massenanteil</rdfs:label>
    <rdfs:label xml:lang="en">mass fraction</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Massenanteil"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mass fraction describes the relative proportion of a mass to the total mass of a mixture, a common quantitative measure</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mass fraction' have not yet been formalized. The term is defined as a specific subtype of 'mass ratio'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Massenanteil.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Entropy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
    <rdfs:label xml:lang="de">Entropie</rdfs:label>
    <rdfs:label xml:lang="en">entropy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/entropy-physics"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Entropy measures the thermal energy per unit temperature unavailable for work in a system, indicating molecular disorder or randomness</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'entropy' have not yet been formalized. The term is defined as a specific subtype of 'thermo dynamic quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/entropy-physics.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/ProcessCharacteristic"/>
    <rdfs:label xml:lang="en">physical process characteristic</rdfs:label>
    <rdfs:label xml:lang="de">physikalische Prozesscharakteristik</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Physical process characteristic defines attributes of a process concretizing a physical interaction over time</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'physical process characteristic' have not yet been formalized. The term is defined as a specific subtype of 'ProcessCharacteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Frequency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
    <rdfs:label xml:lang="de">Frequenz</rdfs:label>
    <rdfs:label xml:lang="en">frequency</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/frequency-physics"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Frequency describes the number of waves passing a fixed point in unit time, or cycles undergone by a body in periodic motion</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'frequency' have not yet been formalized. The term is defined as a specific subtype of 'physical process characteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/frequency-physics.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FatigueStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
    <rdfs:label xml:lang="de">Ermüdungsfestigkeit</rdfs:label>
    <rdfs:label xml:lang="en">fatigue strength</rdfs:label>
    <skos:altLabel xml:lang="de">Ermüdungsfestigkeit</skos:altLabel>
    <skos:altLabel xml:lang="en">fatigue strength</skos:altLabel>
    <skos:prefLabel xml:lang="de">Ermüdungsfestigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">fatigue strength</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ermüdungsfestigkeit bezeichnet die Fähigkeit eines Materials, Ermüdung oder zyklische Belastung zu widerstehen</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Fatigue strength denotes a material's ability to resist fatigue or cyclic loading</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'fatigue strength' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Elasticity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
    <rdfs:label xml:lang="de">Elastizität</rdfs:label>
    <rdfs:label xml:lang="en">elasticity</rdfs:label>
    <skos:altLabel xml:lang="de">Widerstandsfähigkeit</skos:altLabel>
    <skos:altLabel xml:lang="en">elastic</skos:altLabel>
    <skos:altLabel xml:lang="de">elastisch</skos:altLabel>
    <skos:altLabel xml:lang="en">resilience</skos:altLabel>
    <skos:prefLabel xml:lang="de">Elastizität</skos:prefLabel>
    <skos:prefLabel xml:lang="en">elasticity</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Elasticity is the ability of an object or material to resume its normal shape after deformation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Elastizität ist die Fähigkeit eines Objekts oder Materials, nach Deformation seine normale Form wiederherzustellen</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'elasticity' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Temperature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Temperatur</rdfs:label>
    <rdfs:label xml:lang="en">temperature</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.merriam-webster.com/dictionary/temperature"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Temperatur beschreibt den Grad der Hitze oder Kälte, gemessen auf einer bestimmten Skala</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Temperature characterizes the degree of hotness or coldness measured on a definite scale</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'temperature' have not yet been formalized. The term is defined as a specific subtype of 'thermo dynamic quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.merriam-webster.com/dictionary/temperature.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ShearModulus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness"/>
    <rdfs:label xml:lang="de">Schubmodul</rdfs:label>
    <rdfs:label xml:lang="en">shear modulus</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Shear_modulus"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schubmodul ist ein Maß für die elastische Schersteifigkeit, definiert als Verhältnis von Schubspannung zu Scherdehnung</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Shear modulus is a measure of elastic shear stiffness, defined as the ratio of shear stress to shear strain</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'shear modulus' have not yet been formalized. The term is defined as a specific subtype of 'stiffness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Shear_modulus.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Plasticity"/>
    <rdfs:label xml:lang="de">Viskosität</rdfs:label>
    <rdfs:label xml:lang="en">viscosity</rdfs:label>
    <skos:prefLabel xml:lang="de">Viskosität</skos:prefLabel>
    <skos:prefLabel xml:lang="en">viscosity</skos:prefLabel>
    <iof-av:isPrimitive xml:lang="en">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Viscosity measures a fluid's resistance to flow</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Viskosität misst den Widerstand eines Fluids gegen den Fluss</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'viscosity' have not yet been formalized. The term is defined as a specific subtype of 'plasticity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LossTangent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicModulus"/>
    <rdfs:label xml:lang="de">Verlustwinkel</rdfs:label>
    <rdfs:label xml:lang="en">loss tangent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Dynamic_modulus"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Loss tangent, represented as tan δ, is the ratio of the loss modulus to storage modulus in viscoelastic materials, providing a measure of damping</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'loss tangent' have not yet been formalized. The term is defined as a specific subtype of 'dynamic modulus'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Dynamic_modulus.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pressure"/>
    <rdfs:label xml:lang="de">Spannung</rdfs:label>
    <rdfs:label xml:lang="en">stress</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="de">Spannung ist die innere Kraft pro Flächeneinheit, die ein Material unter äußerer Belastung erfährt, und wird häufig als Zug-, Druck- oder Scherspannung beschrieben</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Stress is the internal force per unit area a material experiences under external load, commonly described in tensile, compressive, or shear forms</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'stress' have not yet been formalized. The term is defined as a specific subtype of 'pressure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ReboundHardness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardness"/>
    <rdfs:label xml:lang="de">Rückprallhärte</rdfs:label>
    <rdfs:label xml:lang="en">rebound hardness</rdfs:label>
    <skos:note>Was a subclass of 'Hardness'</skos:note>
    <skos:prefLabel xml:lang="de">Rückprallhärte</skos:prefLabel>
    <skos:prefLabel xml:lang="en">rebound hardness</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Rebound hardness measures the elasticity of a material, defined as the ratio of the rebound velocity to the impact velocity of a standard ball</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Rückprallhärte misst die Elastizität eines Materials, definiert als das Verhältnis der Rückprallgeschwindigkeit zur Aufprallgeschwindigkeit eines Standardballs</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'rebound hardness' have not yet been formalized. The term is defined as a specific subtype of 'hardness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LoadCellCapacity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Kapazität der Wägezelle</rdfs:label>
    <rdfs:label xml:lang="en">load cell capacity</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kapazität der Wägezelle ist die Messung der maximalen Kraft, die eine Wägezelle genau ablesen kann</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Load cell capacity measures the maximum force a load cell can accurately read</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'load cell capacity' have not yet been formalized. The term is defined as a specific subtype of 'mechanical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nba1e2019f3214d2bb5f98a5e2eecd163">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density"/>
    <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
    <owl:annotatedTarget xml:lang="en">Density, or specific mass, is a substance's mass per unit of volume, typically denoted by ρ, defined as mass divided by volume: ρ = m / V</owl:annotatedTarget>
    <iof-av:directSource>https://en.wikipedia.org/wiki/Density</iof-av:directSource>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassConcentration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialComposition"/>
    <rdfs:label xml:lang="de">Massenkonzentration</rdfs:label>
    <rdfs:label xml:lang="en">mass concentration</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Massenkonzentration"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mass concentration links mass of a mixture component to the total volume in quantitative description, frequently used in solutions</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mass concentration' have not yet been formalized. The term is defined as a specific subtype of 'material composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Massenkonzentration.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
    <rdfs:label xml:lang="en">optical capability</rdfs:label>
    <rdfs:label xml:lang="de">optische Fähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Optical capability describes interactions related to light occurring via an entity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Optische Fähigkeit beschreibt die Wechselwirkungen im Zusammenhang mit Licht, die über eine Entität stattfinden</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'optical capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
    <rdfs:label xml:lang="de">Stärke</rdfs:label>
    <rdfs:label xml:lang="en">strength</rdfs:label>
    <skos:altLabel xml:lang="de">Festigkeit</skos:altLabel>
    <skos:prefLabel xml:lang="de">Stärke</skos:prefLabel>
    <skos:prefLabel xml:lang="en">strength</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Strength refers to the capacity of an object or substance to withstand great force or pressure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Stärke bezeichnet die Fähigkeit eines Objekts oder Stoffes, großer Kraft oder Druck standzuhalten</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'strength' have not yet been formalized. The term is defined as a specific subtype of 'mechanical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ProofStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalStrength"/>
    <rdfs:label xml:lang="de">Festigkeitsnachweis</rdfs:label>
    <rdfs:label xml:lang="en">proof strength</rdfs:label>
    <skos:altLabel xml:lang="en">proof stress</skos:altLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Proof strength refers to the stress a material can endure until exhibiting a small amount of plastic deformation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'proof strength' have not yet been formalized. The term is defined as a specific subtype of 'mechanical strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TemperatureMeasurementCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/MeasurementCapability"/>
    <rdfs:label xml:lang="de">Temperaturmessfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">temperature measurement capability</rdfs:label>
    <skos:altLabel xml:lang="de">Temperaturmessungsfähigkeit</skos:altLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Temperature measurement capability involves using an artifact to measure the temperature of an object or space</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Temperaturmessfähigkeit bezeichnet die Messfähigkeit, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um die Temperatur eines Objekts oder Raums zu messen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'temperature measurement capability' have not yet been formalized. The term is defined as a specific subtype of 'MeasurementCapability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepStrain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
    <rdfs:label xml:lang="de">Kriechverformung</rdfs:label>
    <rdfs:label xml:lang="en">creep strain</rdfs:label>
    <skos:altLabel xml:lang="de">Kriechbeanspruchung</skos:altLabel>
    <skos:altLabel xml:lang="en">creeping strain</skos:altLabel>
    <skos:prefLabel xml:lang="de">Kriechverformung</skos:prefLabel>
    <skos:prefLabel xml:lang="en">creep strain</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Creep strain occurs when a material is subjected to constant stress over a long period of time</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Eine Kriechverformung tritt auf, wenn ein Material einer konstanten Belastung über einen langen Zeitraum ausgesetzt ist</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'creep strain' have not yet been formalized. The term is defined as a specific subtype of 'strain'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Angle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/SpatialRelationalQuality"/>
    <rdfs:label xml:lang="de">Winkel</rdfs:label>
    <rdfs:label xml:lang="en">angle</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Angle"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">In Euclidean geometry, angle refers to the figure formed by two rays sharing a common endpoint, called the vertex of the angle</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'angle' have not yet been formalized. The term is defined as a specific subtype of 'SpatialRelationalQuality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Angle.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/materials/Materials/ImagingCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/MeasurementCapability"/>
    <rdfs:label xml:lang="de">Bildgebungsfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">imaging capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="de">Bildgebungsfähigkeit ist die Messfähigkeit, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um eine Abbildung eines bestimmten Objekts, eines Ausschnitts von eine Objekt oder einer Klasse von Objekten zu generieren</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Imaging capability involves using an artifact to generate an image of a particular object, a portion of an object, or a class of objects</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'imaging capability' have not yet been formalized. The term is defined as a specific subtype of 'MeasurementCapability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CoolingCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
    <rdfs:label xml:lang="de">Abkühlfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">cooling capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Cooling capability refers to a material artifact's ability to cause temperature decrease in another material entity</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'cooling capability' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalImpulse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
    <rdfs:label xml:lang="en">mechanical impulse</rdfs:label>
    <rdfs:label xml:lang="de">mechanischer Impuls</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Impulse_(physics)"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mechanical impulse signifies the change in momentum of an object when subjected to a force over time</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mechanical impulse' have not yet been formalized. The term is defined as a specific subtype of 'physical process characteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Impulse_(physics).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdfs:label xml:lang="en">optical quality</rdfs:label>
    <rdfs:label xml:lang="de">optische Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Optical quality characterizes the interaction results of material entities with light emissions or their generation of light emissions</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'optical quality' have not yet been formalized. The term is defined as a specific subtype of 'physical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialComposition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:label xml:lang="de">Materialzusammensetzung</rdfs:label>
    <rdfs:label xml:lang="en">material composition</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Material composition describes the ratio of substances or components making up a material, considering types, proportions, and arrangements</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'material composition' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/HeatingCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
    <rdfs:label xml:lang="de">Aufheizfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">heating capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Heating capability refers to a material artifact's ability to cause temperature increase in another material entity</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'heating capability' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalReaction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="N28fb5a7ed1a844b8adcf2bdab24f1ea1"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/Reaction"/>
    <rdfs:label xml:lang="en">physical reaction</rdfs:label>
    <rdfs:label xml:lang="de">physikalische Antwort</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Physical reaction characterizes a process where a physical capability of entity X is realized in response to a physical action involving X or more material entities</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en">PhysicalReaction(x) ↔ ∃b (PhysicalCapability(b) ∧ obo:BFO_0000055(x, b))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en">every instance of 'physical reaction' is defined as exactly that 'obo:BFO_0000055' some 'physical capability'</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassRatio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialComposition"/>
    <rdfs:label xml:lang="de">Massenverhältnis</rdfs:label>
    <rdfs:label xml:lang="en">mass ratio</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mass ratio denotes a relational quality expressing one mass value relative to another, typically producing a dimensionless number</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mass ratio' have not yet been formalized. The term is defined as a specific subtype of 'material composition'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Radius">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
    <rdfs:label xml:lang="de">Radius</rdfs:label>
    <rdfs:label xml:lang="en">radius</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002390"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Radius is a length quality equal to the distance from the center of a circle to any endpoint on the circular boundary</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Radius ist eine Längeneigenschaft, die gleich der Entfernung vom Mittelpunkt eines Kreises zu einem beliebigen Endpunkt auf der Kreisgrenze ist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'radius' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002390.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PoissonEffect">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
    <rdfs:label xml:lang="de">Querkontraktion</rdfs:label>
    <rdfs:label xml:lang="en">poisson effect</rdfs:label>
    <skos:note>Was a subclass of 'Mechanical Quality'</skos:note>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Poisson%27s_ratio"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Poisson effect describes deformation perpendicular to the direction of loading, named after Siméon Poisson</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Querkontraktion beschreibt die Deformation senkrecht zur Belastungsrichtung, benannt nach Siméon Poisson</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'poisson effect' have not yet been formalized. The term is defined as a specific subtype of 'mechanical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Poisson%27s_ratio.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/WeatheringResistance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OperationalStrength"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
    <rdfs:label xml:lang="de">Witterungsbeständigkeit</rdfs:label>
    <rdfs:label xml:lang="en">weathering resistance</rdfs:label>
    <skos:altLabel xml:lang="en">weather resistant</skos:altLabel>
    <skos:altLabel xml:lang="de">wetterbeständig</skos:altLabel>
    <skos:note xml:lang="en">Was a subclass of 'Operational Strength';

But 'Operational Strength' does not appear to be Quality.</skos:note>
    <skos:prefLabel xml:lang="de">Witterungsbeständigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">weathering resistance</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Ability of a material to resist the effects of weathering, such as wind, rain, and sunlight.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Fähigkeit eines Materials, den Auswirkungen von Witterungseinflüssen wie Wind, Regen und Sonnenlicht standzuhalten.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'weathering resistance' have not yet been formalized. The term is defined as a specific subtype of 'operational strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/materials/Materials/DistanceMeasurementCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/MeasurementCapability"/>
    <rdfs:label xml:lang="de">Entfernungsmessungsfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">distance measurement capability</rdfs:label>
    <skos:altLabel xml:lang="de">Entfernungsmessungsfähigkeit</skos:altLabel>
    <skos:prefLabel xml:lang="en">Distance Measurement Capability</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Distance measurement capability involves the use of an artifact to ascertain the distance between two objects or points in space</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Entfernungsmessungsfähigkeit ist die Messfähigkeit, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um eine Entfernung zwischen zwei Objekten oder Punkten im Raum zu messen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'distance measurement capability' have not yet been formalized. The term is defined as a specific subtype of 'MeasurementCapability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ReynoldsNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FluidDynamicQuality"/>
    <rdfs:label xml:lang="en">Reynolds number</rdfs:label>
    <rdfs:label xml:lang="de">Reynolds-Zahl</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Reynolds_number"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Reynolds number is a dimensionless quantity predicting fluid flow patterns, measuring the ratio between inertial and viscous forces</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Reynolds-Zahl ist eine dimensionslose Größe zur Vorhersage von Strömungsmustern in Flüssigkeiten, die das Verhältnis zwischen Trägheits- und Viskosekräften misst</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'Reynolds number' have not yet been formalized. The term is defined as a specific subtype of 'FluidDynamicQuality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Reynolds_number.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/materials/Materials/PressureMeasurementCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/materials/Materials/ForceMeasurementCapability"/>
    <rdfs:label xml:lang="de">Druckmessfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">pressure measurement capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Pressure measurement capability is a force measurement capability realized in events where an artifact is used to measure the pressure applied to a specific object</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Druck Messfähigkeit ist eine Messfunktion, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um die auf ein bestimmtes Objekt oder eine Klasse von Objekten angewendete Kraft zu messen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'pressure measurement capability' have not yet been formalized. The term is defined as a specific subtype of 'force measurement capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Toughness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
    <rdfs:label xml:lang="de">Zähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">toughness</rdfs:label>
    <skos:prefLabel xml:lang="de">Zähigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">toughness</skos:prefLabel>
    <iof-av:isPrimitive xml:lang="en">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Toughness describes the resistance of a material to fracture or crack propagation, determined by its ability to absorb mechanical energy during deformation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Zähigkeit beschreibt die Widerstandsfähigkeit eines Werkstoffs gegen Bruch oder Rissausbreitung, bestimmt durch die Fähigkeit zur Absorption von mechanischer Energie bei Verformung</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'toughness' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N7ed87ccecbdb446896aa7e6654e2a79e">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/YieldStrength"/>
    <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
    <owl:annotatedTarget xml:lang="en">Yield strength signfies the stress level at which material begins to deform plastically, marking the end of elastic behavior</owl:annotatedTarget>
    <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Yield_(engineering)</iof-av:directSource>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Ductility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
    <rdfs:label xml:lang="de">Duktilität</rdfs:label>
    <rdfs:label xml:lang="en">ductility</rdfs:label>
    <skos:altLabel xml:lang="de">Biegsamkeit</skos:altLabel>
    <skos:altLabel xml:lang="en">flexibility</skos:altLabel>
    <skos:prefLabel xml:lang="de">Duktilität</skos:prefLabel>
    <skos:prefLabel xml:lang="en">ductility</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Ductility is the ability of a material to deform plastically without breaking</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Duktilität ist die Fähigkeit eines Materials, plastisch zu verformen, ohne zu brechen</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'ductility' have not yet been formalized. The term is defined as a specific subtype of 'mechanical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationAbsorptionCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
    <rdfs:label xml:lang="de">Strahlungsabsorptionsfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">radiation absorption capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Radiation absorption capability characterizes an entity's ability to absorb electromagnetic radiation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsabsorptionsfähigkeit beschreibt die Fähigkeit einer Entität, elektromagnetische Strahlung zu absorbieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'radiation absorption capability' have not yet been formalized. The term is defined as a specific subtype of 'optical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OlfactoricQuantity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdfs:label xml:lang="en">olfactoric quality</rdfs:label>
    <rdfs:label xml:lang="de">olfaktorische Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Olfactoric quantity relates to a material entity's qualitative characteristics as perceived by the scent system</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'olfactoric quality' have not yet been formalized. The term is defined as a specific subtype of 'physical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000116">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">Editor Note</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeMixRatio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeRatio"/>
    <rdfs:label xml:lang="de">Mischengehaltverhältnis</rdfs:label>
    <rdfs:label xml:lang="en">volume mix ratio</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Volumenverh%C3%A4ltnis"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Mischengehaltverhältnis definiert das Verhältnis der Volumina von zwei Mischbestandteilen zueinander</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Volume mix ratio defines the ratio of volumes of two mixture components to each other</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'volume mix ratio' have not yet been formalized. The term is defined as a specific subtype of 'volume ratio'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Volumenverh%C3%A4ltnis.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Speed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
    <rdfs:label xml:lang="de">Geschwindigkeit</rdfs:label>
    <rdfs:label xml:lang="en">speed</rdfs:label>
    <skos:example xml:lang="en">If a train takes 1 hour to travel 100 kilometers, it has a speed of 100 kilometers per hour (62 mph)</skos:example>
    <iof-av:adaptedFrom rdf:resource="https://simple.wikipedia.org/wiki/Speed"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Speed describes the distance an object moves in a given amount of time, always positive</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'speed' have not yet been formalized. The term is defined as a specific subtype of 'physical process characteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://simple.wikipedia.org/wiki/Speed.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiantEnergy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
    <rdfs:label xml:lang="de">Strahlungsenergie</rdfs:label>
    <rdfs:label xml:lang="en">radiant energy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Radiant_energy"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Radiant energy refers to the energy of electromagnetic radiation, calculated by integrating radiant flux over time</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'radiant energy' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Radiant_energy.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
    <rdfs:label xml:lang="de">Härte</rdfs:label>
    <rdfs:label xml:lang="en">hardness</rdfs:label>
    <skos:prefLabel xml:lang="de">Härte</skos:prefLabel>
    <skos:prefLabel xml:lang="en">hardness</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Hardness quantifies the resistance of a material to localized deformation or plasticity caused by mechanical action, such as bending, crushing, or scratching</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Härte ist die Widerstandsfähigkeit eines Materials gegen lokalisierte Verformung oder Plastizität, die durch mechanische Einwirkung wie Biegen, Quetschen oder Kratzen verursacht wird</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'hardness' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicModulus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscoelasticity"/>
    <rdfs:label xml:lang="en">dynamic modulus</rdfs:label>
    <rdfs:label xml:lang="de">dynamischer Modul</rdfs:label>
    <skos:altLabel xml:lang="en">complex modulus</skos:altLabel>
    <skos:altLabel xml:lang="en">complex shear modulus</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Dynamic_modulus"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Dynamic modulus is the ratio of stress to strain under vibratory conditions, typically measured in shear, compression, or elongation tests, and characterizes viscoelastic materials</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'dynamic modulus' have not yet been formalized. The term is defined as a specific subtype of 'viscoelasticity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Dynamic_modulus.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeFraction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeRatio"/>
    <rdfs:label xml:lang="de">Volumenanteil</rdfs:label>
    <rdfs:label xml:lang="en">volume fraction</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Volumenkonzentration"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Volume fraction describes the volume of a mixture component relative to the sum of all components' volumes</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Volumenanteil beschreibt das Volumen eines Mischbestandteils im Verhältnis zur Summe der Volumina aller Bestandteile</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'volume fraction' have not yet been formalized. The term is defined as a specific subtype of 'volume ratio'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Volumenkonzentration.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nfc3bdebaa6b441ceb2bf4be84a3bd84c">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
    <rdf:rest rdf:nodeID="Nfcc3a343c52648f3a7f22853ed972896"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiantEnergyDensity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density"/>
    <rdfs:label xml:lang="de">Strahlungsenergiedichte</rdfs:label>
    <rdfs:label xml:lang="en">radiant energy density</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Radiant_energy"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Radiant energy density quantifies radiant energy per unit volume</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsenergiedichte misst die Strahlungsenergie pro Volumeneinheit</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'radiant energy density' have not yet been formalized. The term is defined as a specific subtype of 'density'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Radiant_energy.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Deformation"/>
    <rdfs:label xml:lang="de">Dehnung</rdfs:label>
    <rdfs:label xml:lang="en">strain</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Strain_(mechanics)"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="de">Dehnung ist als relative Verformung definiert, verglichen mit einer Referenzpositionskonfiguration</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Strain is defined as relative deformation, compared to a reference position configuration</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'strain' have not yet been formalized. The term is defined as a specific subtype of 'deformation'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Strain_(mechanics).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElasticStrain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strain"/>
    <rdfs:label xml:lang="en">elastic strain</rdfs:label>
    <rdfs:label xml:lang="de">elastische Deformation</rdfs:label>
    <skos:altLabel xml:lang="en">elastic deformation</skos:altLabel>
    <skos:altLabel xml:lang="de">elastische Verformung</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Plasticity_(physics)"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Elastic strain is a strain quality of a material entity characterized by reversible deformation that disappears upon removal of the applied load</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'elastic strain' have not yet been formalized. The term is defined as a specific subtype of 'strain'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Plasticity_(physics).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/UniversalTestingMachine1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/PieceOfEquipment"/>
    <iof-core:hasCapability rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TensionForceMeasurementCapability1"/>
    <iof-core:hasQuality rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TensionForce1"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Naee9d01de7874caab6cb4f3f4097a04b">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="Nfc3bdebaa6b441ceb2bf4be84a3bd84c"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalExpansionCoefficient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalCapability"/>
    <rdfs:label xml:lang="en">thermal expansion coefficient</rdfs:label>
    <rdfs:label xml:lang="de">thermischer Ausdehnungkoeffizient</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Thermal expansion coefficient quantifies the degree to which a material expands upon heating, representing fractional change per degree temperature increase</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Thermischer Ausdehnungkoeffizient quantifiziert den Grad, in dem ein Material beim Erhitzen expandiert, und stellt die proportionale Änderung pro Temperaturanstieg dar</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'thermal expansion coefficient' have not yet been formalized. The term is defined as a specific subtype of 'thermal capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/materials/Materials/ForceMeasurementCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/MeasurementCapability"/>
    <rdfs:label xml:lang="en">force measurement capability</rdfs:label>
    <skos:altLabel xml:lang="de">Kraft Messfähigkeit</skos:altLabel>
    <skos:prefLabel xml:lang="en">Force Measurement Capability</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Force measurement capability involves using an artifact to measure the force applied to a specific object or class of objects</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kraft Messfähigkeit ist die Messfähigkeit, die während Ereignissen realisiert wird, in denen ein Artefakt verwendet wird, um die auf ein bestimmtes Objekt oder eine Klasse von Objekten angewendete Kraft zu messen</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition_source rdf:resource="https://en.wikipedia.org/wiki/Force_measurement"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'force measurement capability' have not yet been formalized. The term is defined as a specific subtype of 'MeasurementCapability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Deformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalQuality"/>
    <obo:IAO_0000116 xml:lang="en">excludes any rigid body motion</obo:IAO_0000116>
    <rdfs:label xml:lang="de">Verformung</rdfs:label>
    <rdfs:label xml:lang="en">deformation</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Deformation_(physics)"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Deformation refers to the change in shape or size of an object, quantified as the residual displacement of particles in a non-rigid body, excluding average translation and rotation</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'deformation' have not yet been formalized. The term is defined as a specific subtype of 'mechanical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Deformation_(physics).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PoissonRatio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PoissonEffect"/>
    <rdfs:label xml:lang="de">Poissonzahl</rdfs:label>
    <rdfs:label xml:lang="en">poisson's ratio</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Poisson%27s_ratio"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Poisson's ratio is a measure of the Poisson effect, with values typically between 0.0 and 0.5 for most materials</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Poissonzahl ist ein Maß für den Poisson-Effekt, mit Werten typischerweise zwischen 0,0 und 0,5 für die meisten Materialien</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'poisson's ratio' have not yet been formalized. The term is defined as a specific subtype of 'poisson effect'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Poisson%27s_ratio.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
    <rdfs:label xml:lang="en">electrical capability</rdfs:label>
    <rdfs:label xml:lang="de">elektrische Fähigkeit</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electrical capability entails realization through an entity related to electric interaction</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electrical capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LowerYieldStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/YieldStrength"/>
    <rdfs:label xml:lang="en">lower yield strength</rdfs:label>
    <rdfs:label xml:lang="de">untere Streckgrenze</rdfs:label>
    <skos:altLabel xml:lang="en">lower yield stress</skos:altLabel>
    <skos:altLabel xml:lang="de">untere Fließspannung</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Yield_(engineering)"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Lower yield strength defines the stress at which a material exhibits plastic behavior after initial yielding</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Untere Streckgrenze beschreibt die Spannung, bei der ein Material nach dem anfänglichen Fließen plastisches Verhalten zeigt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'lower yield strength' have not yet been formalized. The term is defined as a specific subtype of 'yield strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Yield_(engineering).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DoseEquivalent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:label xml:lang="en">dose equivalent</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.nrc.gov/reading-rm/basic-ref/glossary/dose-equivalent.html"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Dose equivalent measures biological damage to living tissue from radiation exposure, calculated as absorbed dose multiplied by a quality factor, and expressed in rems or sieverts</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'dose equivalent' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.nrc.gov/reading-rm/basic-ref/glossary/dose-equivalent.html.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalAbsorptance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <rdfs:label xml:lang="en">optical absorptance</rdfs:label>
    <rdfs:label xml:lang="de">optische Absorption</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Optical absorptance defines the ratio of absorbed radiant power to incident radiant power, indicating a medium's absorption capability</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'optical absorptance' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FlexuralStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BreakingStrength"/>
    <rdfs:label xml:lang="de">Biegefestigkeit</rdfs:label>
    <rdfs:label xml:lang="en">flexural strength</rdfs:label>
    <skos:altLabel xml:lang="en">bending strength</skos:altLabel>
    <skos:prefLabel xml:lang="de">Biegefestigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">flexural strength</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="de">Biegefestigkeit bezeichnet die Fähigkeit eines Materials, unter Biegelast Deformationen zu widerstehen</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Flexural strength indicates a material's ability to resist deformation under flexural load</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'flexural strength' have not yet been formalized. The term is defined as a specific subtype of 'breaking strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Specimen1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <iof-core:hasCapability rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EModulus1"/>
    <iof-core:hasCapability rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RelaxtionCap1"/>
    <iof-core:hasQuality rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/reflectance1"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DendriticFieldSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Volume"/>
    <rdfs:label xml:lang="de">Dendritische Feldgröße</rdfs:label>
    <rdfs:label xml:lang="en">dendritic field size</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0070064"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Dendritic field size characterizes a 3-D extent defined by the maximal span of a dendritic arbor</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'dendritic field size' have not yet been formalized. The term is defined as a specific subtype of 'volume'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0070064.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SoundReflectionCoefficient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticQuality"/>
    <rdfs:label xml:lang="de">Schallreflexionsgrad</rdfs:label>
    <rdfs:label xml:lang="en">sound reflection coefficient</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="de">Schallreflexionsgrad quantifiziert den Anteil der Schallenergie, die von einer Oberfläche reflektiert wird</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Sound reflection coefficient quantifies the proportion of sound energy reflected by a surface</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'sound reflection coefficient' have not yet been formalized. The term is defined as a specific subtype of 'acoustic quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SunExposureProcess1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <obo:BFO_0000057 rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Specimen1"/>
    <isTriggeredBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SunLigthingProcess1"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectroMagneticWave">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="N22f98b5660d54308b9a9ffb605adc5db"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
    <rdfs:label xml:lang="en">electro magnetic wave</rdfs:label>
    <rdfs:label xml:lang="de">elektromagnetische Welle</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electromagnetic wave characterizes radiation generated by vibrating electrically charged particles, traveling as waves with specific wavelengths and intensities</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition_source rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://ec.europa.eu/health/scientific_committees/opinions_layman/en/energy-saving-lamps/glossary/def/electromagnetic-wave.htm</iof-av:naturalLanguageDefinition_source>
    <iof-av:firstOrderLogicDefinition xml:lang="en">ElectroMagneticWave(x) ↔ ∃b (Wavelength(b) ∧ hasQuality(x, b))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en">every instance of 'electro magnetic wave' is defined as exactly that 'hasQuality' some 'wavelength'</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumetricThermalExpansionCoefficient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermalExpansionCoefficient"/>
    <rdfs:label xml:lang="de">thermischer Volumenausdehnungskoeffizient</rdfs:label>
    <rdfs:label xml:lang="en">volumetric thermal expansion coefficient</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Volumetric thermal expansion coefficient quantifies the degree to which a material expands upon heating into all three axial directions simultaneously</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'volumetric thermal expansion coefficient' have not yet been formalized. The term is defined as a specific subtype of 'thermal expansion coefficient'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
    <rdfs:label xml:lang="en">physical relational quality</rdfs:label>
    <rdfs:label xml:lang="de">physisch relative Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Physical relational quality pertains to properties or characteristics of an entity dependent on its relation to other entities</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'physical relational quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000145'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EngineeringStress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stress"/>
    <obo:IAO_0000116 xml:lang="en">Assumes unchanged size of Area the force is normalized to. Changes in the Area can only be neglected for very small deformations</obo:IAO_0000116>
    <rdfs:label xml:lang="en">engineering stress</rdfs:label>
    <rdfs:label xml:lang="de">technische Spannung</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Engineering stress quantifies the internal force per unit area a material experiences under load, assuming the area remains constant</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Technische Spannung beschreibt die innere Kraft pro Fläche, die ein Material unter Last erfährt, unter der Annahme, dass die Fläche konstant bleibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'engineering stress' have not yet been formalized. The term is defined as a specific subtype of 'stress'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nfd53bd64afb34df8bd52028fbfbe381b">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="Nc46bc285ec044116aa304d5f4593e393"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AcousticCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
    <rdfs:label xml:lang="en">acoustic capability</rdfs:label>
    <rdfs:label xml:lang="de">akustische Fähigkeit</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Acoustic capability entails realization through an entity related to sound interaction</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'acoustic capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BulkModulus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness"/>
    <rdfs:label xml:lang="de">Kompressionsmodul</rdfs:label>
    <rdfs:label xml:lang="en">bulk modulus</rdfs:label>
    <skos:altLabel xml:lang="de">Kompressionsmodul</skos:altLabel>
    <skos:prefLabel xml:lang="en">bulk modulus</skos:prefLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Bulk_modulus"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Bulk modulus is a measure of the resistance of a substance to bulk compression, defined as the ratio of infinitesimal pressure increase to relative volume decrease</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'bulk modulus' have not yet been formalized. The term is defined as a specific subtype of 'stiffness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Bulk_modulus.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N76ce143222c1421da7bf6413059d4a76">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SpecificHeatCapacity"/>
    <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
    <owl:annotatedTarget xml:lang="en">Specific heat capacity is the heat capacity of a sample divided by its mass, representing the heat required to raise temperature by one unit</owl:annotatedTarget>
    <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Specific_heat_capacity</iof-av:directSource>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/BreakingStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Toughness"/>
    <rdfs:label xml:lang="de">Bruchfestigkeit</rdfs:label>
    <rdfs:label xml:lang="en">breaking strength</rdfs:label>
    <skos:altLabel xml:lang="de">Bruchspannung</skos:altLabel>
    <skos:altLabel xml:lang="en">fracture stress</skos:altLabel>
    <skos:altLabel xml:lang="en">strength at break</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Fracture"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Breaking strength is a toughness quality of a specimen that denotes the stress at which the specimen fails via fracture, recorded as the final point on a stress-strain curve</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'breaking strength' have not yet been formalized. The term is defined as a specific subtype of 'toughness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Fracture.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Wavelength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
    <rdfs:label xml:lang="de">Wellenlänge</rdfs:label>
    <rdfs:label xml:lang="en">wavelength</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.oxfordreference.com/display/10.1093/oi/authority.20110803121421585"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Wavelength is the distance between successive peaks or troughs of a wave, equal to wave speed divided by frequency</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Wellenlänge ist die Entfernung zwischen aufeinanderfolgenden Gipfeln oder Tälern einer Welle, gleich der Wellenbewegungsgeschwindigkeit geteilt durch die Frequenz</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'wavelength' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.oxfordreference.com/display/10.1093/oi/authority.20110803121421585.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Width">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
    <rdfs:label xml:lang="de">Breite</rdfs:label>
    <rdfs:label xml:lang="en">width</rdfs:label>
    <skos:altLabel xml:lang="en">breadth</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000921"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Breite beschreibt eine 1- Dimension, die von Seite zu Seite auf einem Objekt oder Raum gemessen wird und die laterale Dimension betont</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Width describes a 1-D extent measured side-to-side on an object or space, emphasizing the lateral dimension</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'width' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000921.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepModulus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscoelasticity"/>
    <rdfs:label xml:lang="de">Kriechmodul</rdfs:label>
    <rdfs:label xml:lang="en">creep modulus</rdfs:label>
    <skos:prefLabel xml:lang="de">Kriechmodul</skos:prefLabel>
    <skos:prefLabel xml:lang="en">creep modulus</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Creep modulus measures a material's viscoelasticity, indicating its ability to deform under stress over time</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Kriechmodul ist ein Maß für die Viskoelastizität eines Materials, das seine Fähigkeit zur Verformung unter Belastung im Laufe der Zeit beschreibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'creep modulus' have not yet been formalized. The term is defined as a specific subtype of 'viscoelasticity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationEmissionCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
    <rdfs:label xml:lang="de">Strahlungsemitter</rdfs:label>
    <rdfs:label xml:lang="en">radiation emission capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Radiation emission capability refers to an entity's ability to emit light of a defined spectrum and intensity</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsemitter beschreibt die Fähigkeit einer Entität, Licht eines definierten Spektrums und Intensität zu emittieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'radiation emission capability' have not yet been formalized. The term is defined as a specific subtype of 'optical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DryMass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassRatio"/>
    <rdfs:label xml:lang="de">Trockenmasse</rdfs:label>
    <rdfs:label xml:lang="en">dry mass</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Dry mass denotes mass after removing all humidity from an object, typically using qualified heating methods in an oven</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'dry mass' have not yet been formalized. The term is defined as a specific subtype of 'mass ratio'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ScratchHardness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardness"/>
    <rdfs:label xml:lang="de">Kratzhärte</rdfs:label>
    <rdfs:label xml:lang="en">scratch hardness</rdfs:label>
    <skos:altLabel xml:lang="de">Kratzbeständigkeit</skos:altLabel>
    <skos:altLabel xml:lang="en">scratch resistance</skos:altLabel>
    <skos:prefLabel xml:lang="de">Kratzfestigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">scratch hardness</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="de">Kratzhärte misst die Fähigkeit eines Materials, Kratzern zu widerstehen</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Scratch hardness measures a material's ability to resist being scratched</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'scratch hardness' have not yet been formalized. The term is defined as a specific subtype of 'hardness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationTransmissionCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
    <rdfs:label xml:lang="de">Strahlungsübertragungsfähigkeit</rdfs:label>
    <rdfs:label xml:lang="en">radiation transmission capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Radiation transmission capability describes an entity's ability to transmit electromagnetic radiation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsübertragungsfähigkeit beschreibt die Fähigkeit einer Entität, elektromagnetische Strahlung zu übertragen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'radiation transmission capability' have not yet been formalized. The term is defined as a specific subtype of 'optical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Perimeter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
    <rdfs:label xml:lang="de">Umfang</rdfs:label>
    <rdfs:label xml:lang="en">perimeter</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001711"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Perimeter measures a 1-D extent inhering in a two-dimensional bearer, representing the distance around it</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'perimeter' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001711.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/UpperYieldStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/YieldStrength"/>
    <rdfs:label xml:lang="de">obere Streckgrenze</rdfs:label>
    <rdfs:label xml:lang="en">upper yield strength</rdfs:label>
    <skos:altLabel xml:lang="de">obere Fließspannung</skos:altLabel>
    <skos:altLabel xml:lang="en">upper yield stress</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Yield_(engineering)"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Obere Streckgrenze charakterisiert die maximale Spannung, die vor dem plastischen Fließen eines Materials angewendet werden kann</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Upper yield strength characterizes the maximum stress that can be applied before a material begins to yield plastically</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'upper yield strength' have not yet been formalized. The term is defined as a specific subtype of 'yield strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Yield_(engineering).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Durability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
    <rdfs:label xml:lang="de">Dauerhaftigkeit</rdfs:label>
    <rdfs:label xml:lang="en">durability</rdfs:label>
    <skos:altLabel xml:lang="de">Langlebigkeit</skos:altLabel>
    <skos:altLabel xml:lang="en">longevity</skos:altLabel>
    <skos:prefLabel xml:lang="de">Dauerhaftigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">durability</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Dauerhaftigkeit ist die Fähigkeit eines Materials, Abnutzung, Rissbildung und andere Arten von Schäden im Laufe der Zeit zu widerstehen</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Durability is the ability of a material to resist wear, tear, and other types of damage over time</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'durability' have not yet been formalized. The term is defined as a specific subtype of 'mechanical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ndb8a92457b494c2d85e736f5bc119524">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="Nce91bfc9e8654bb198d53122211286be"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
    <rdfs:label xml:lang="en">mechanical capability</rdfs:label>
    <rdfs:label xml:lang="de">mechanische Fähigkeit</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mechanical capability can be realized through an entity related to mechanical interaction</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mechanical capability' have not yet been formalized. The term is defined as a specific subtype of 'physical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N28fb5a7ed1a844b8adcf2bdab24f1ea1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalTransmittance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <rdfs:label xml:lang="en">optical transmittance</rdfs:label>
    <rdfs:label xml:lang="de">optische Transmittance</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Optical transmittance is defined by the ratio of transmitted radiant power to incident radiant power, assessing transmission efficiency</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'optical transmittance' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscoelasticity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
    <rdfs:label xml:lang="de">Viscoelastizität</rdfs:label>
    <rdfs:label xml:lang="en">viscoelasticity</rdfs:label>
    <skos:altLabel xml:lang="de">Viskoelastizität</skos:altLabel>
    <skos:altLabel xml:lang="en">elasticity of viscosity</skos:altLabel>
    <skos:prefLabel xml:lang="de">Viscoelastizität</skos:prefLabel>
    <skos:prefLabel xml:lang="en">viscoelasticity</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Viscoelasticity describes materials exhibiting both viscous and elastic characteristics during deformation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Viscoelastizität beschreibt Materialien, die sowohl viskose als auch elastische Eigenschaften während der Verformung zeigen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'viscoelasticity' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/NumberDensity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density"/>
    <rdfs:label xml:lang="de">Stoffmenge</rdfs:label>
    <rdfs:label xml:lang="en">number density</rdfs:label>
    <skos:prefLabel xml:lang="en">Number Density</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Number density measures the number of objects per unit volume or area</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'number density' have not yet been formalized. The term is defined as a specific subtype of 'density'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/FluidDynamicQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdfs:label xml:lang="de">Strömungsqualität</rdfs:label>
    <rdfs:label xml:lang="en">fluid dynamic quality</rdfs:label>
    <skos:altLabel xml:lang="de">Qualität der Strömungslehre</skos:altLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Fluid dynamic quality characterizes a material entity's behavior or state in relation to fluidic interaction</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'fluid dynamic quality' have not yet been formalized. The term is defined as a specific subtype of 'physical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MagneticQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdfs:label xml:lang="en">magnetic quality</rdfs:label>
    <rdfs:label xml:lang="de">magnetische Qualität</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Magnetic quality characterizes a material entity's response to external magnetic fields or its emission of magnetic fields</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'magnetic quality' have not yet been formalized. The term is defined as a specific subtype of 'physical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ClampingPressure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pressure"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Klemmdruck</rdfs:label>
    <rdfs:label xml:lang="en">clamping pressure</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Clamping pressure describes the force per area used during the mounting process of a sample, typically involving grips or similar tools</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Klemmdruck ist die Eigenschaft, die als quantitativer Wert die Kraft pro Fläche beschreibt, die beim Einbau einer Probe, eines Prüfkörpers oder eines Prüfstücks aufgebracht wird, typischerweise verbunden mit einer Art von Klemm- oder Spannzubehör</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'clamping pressure' have not yet been formalized. The term is defined as a specific subtype of 'pressure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AnteriorPosteriorDiameter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Diameter"/>
    <rdfs:label xml:lang="de">Antero Posteraler Durchmesser</rdfs:label>
    <rdfs:label xml:lang="en">anterior-posterior diameter</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002041"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Anterior-posterior diameter characterizes the diameter along the anterior-posterior axis</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'anterior-posterior diameter' have not yet been formalized. The term is defined as a specific subtype of 'diameter'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0002041.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Diameter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
    <rdfs:label xml:lang="de">Durchmesser</rdfs:label>
    <rdfs:label xml:lang="en">diameter</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001334"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Diameter is a length quality equal to any straight line segment passing through the center of a circle with endpoints on the circular boundary</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'diameter' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001334.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/StorageModulus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicModulus"/>
    <rdfs:label xml:lang="de">Speichermodul</rdfs:label>
    <rdfs:label xml:lang="en">storage modulus</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Dynamic_modulus"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Speichermodul misst den elastischen Teil der gespeicherten Energie in viskoelastischen Materialien</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Storage modulus measures the elastic portion of stored energy in viscoelastic materials</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'storage modulus' have not yet been formalized. The term is defined as a specific subtype of 'dynamic modulus'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Dynamic_modulus.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassPotential">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Potential"/>
    <rdfs:label xml:lang="de">Massenpotential</rdfs:label>
    <rdfs:label xml:lang="en">mass potential</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mass potential defines a scalar quantity describing energy stored due to a material's position, shape, or configuration</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mass potential' have not yet been formalized. The term is defined as a specific subtype of 'potential'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Area">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/DimensionQuality"/>
    <rdfs:label xml:lang="de">Fläche</rdfs:label>
    <rdfs:label xml:lang="en">area</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001323"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Area signifies a 2-D extent quality inhering by virtue of the bearer's two-dimensional extent</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'area' have not yet been formalized. The term is defined as a specific subtype of 'DimensionQuality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001323.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Kraft</rdfs:label>
    <rdfs:label xml:lang="en">force</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.merriam-webster.com/dictionary/force"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Force refers to an influence causing an object to change its velocity, defined mathematically as a vector quantity measured in newtons (N)</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'force' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.merriam-webster.com/dictionary/force.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DeformationSpeed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Speed"/>
    <rdfs:label xml:lang="de">Deformationsgeschwindigkeit</rdfs:label>
    <rdfs:label xml:lang="en">deformation speed</rdfs:label>
    <skos:altLabel xml:lang="de">Dehnrate</skos:altLabel>
    <skos:altLabel xml:lang="en">strain rate</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Strain_rate"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Deformation speed measures the rate at which distances of adjacent material parcels change with time near a specific point, including expansion and shear rates</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'deformation speed' have not yet been formalized. The term is defined as a specific subtype of 'speed'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Strain_rate.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ExtinctionCoefficient">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RefractiveIndex"/>
    <rdfs:label xml:lang="de">Extinktionskoeffizient</rdfs:label>
    <rdfs:label xml:lang="en">extinction coefficient</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Refractive_index#Complex_index_of_refraction_and_absorption"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Extinction coefficient, the imaginary component of the complex refractive index, indicates attenuation of electromagnetic waves through a material</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'extinction coefficient' have not yet been formalized. The term is defined as a specific subtype of 'refractive index'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Refractive_index#Complex_index_of_refraction_and_absorption.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N0dd92482463a47a6b0dc8adb4b93cb5a">
    <rdf:first rdf:nodeID="N244b3c0fea5848039e18d2058478051f"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nfa90171025094ccaab15d47a79f1f581">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force"/>
    <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
    <owl:annotatedTarget xml:lang="en">Force refers to an influence causing an object to change its velocity, defined mathematically as a vector quantity measured in newtons (N)</owl:annotatedTarget>
    <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://en.wikipedia.org/wiki/Force</iof-av:directSource>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000412">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">Imported From</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Mass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdfs:label xml:lang="de">Masse</rdfs:label>
    <rdfs:label xml:lang="en">mass</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Mass"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mass denotes intrinsic quality of a body, historically related to matter quantity, though distinct in modern physics with multiple definitions</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mass' have not yet been formalized. The term is defined as a specific subtype of 'physical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Mass.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000119">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">Definition Source</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiologicQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdfs:label xml:lang="en">radiologic quality</rdfs:label>
    <rdfs:label xml:lang="de">radiologische Qualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Radiologic quality pertains to properties or characteristics related to an entity's interaction with radiant energy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Radiologische Qualität bezieht sich auf die Eigenschaften oder Merkmale im Zusammenhang mit der Wechselwirkung einer Entität mit Strahlungsenergie</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'radiologic quality' have not yet been formalized. The term is defined as a specific subtype of 'physical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/CreepStress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stress"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Kriechspannung</rdfs:label>
    <rdfs:label xml:lang="en">creep stress</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Creep stress is characterized by strain occurring with time when a constant force is applied to a physical body</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'creep stress' have not yet been formalized. The term is defined as a specific subtype of 'stress'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MassFlowRate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
    <rdfs:label xml:lang="de">Massendurchsatz</rdfs:label>
    <rdfs:label xml:lang="en">mass flow rate</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Mass_flow_rate"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mass flow rate quantifies the mass passing per unit time, commonly measured in kilograms per second or pounds per second</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mass flow rate' have not yet been formalized. The term is defined as a specific subtype of 'physical process characteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Mass_flow_rate.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nfcc3a343c52648f3a7f22853ed972896">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdf:rest rdf:nodeID="Nce6eba50479946c8ad374b458b0a911f"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition_source">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Enthalpy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ThermoDynamicQuality"/>
    <rdfs:label xml:lang="de">Enthalpie</rdfs:label>
    <rdfs:label xml:lang="en">enthalpy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/science/enthalpy"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Enthalpy, denoted as H, represents the sum of internal energy and the product of pressure and volume in a thermodynamic system, crucial for energy calculations</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'enthalpy' have not yet been formalized. The term is defined as a specific subtype of 'thermo dynamic quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/science/enthalpy.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Weight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force"/>
    <rdfs:label xml:lang="de">Gewicht</rdfs:label>
    <rdfs:label xml:lang="en">weight</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Weight"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">In science and engineering, the weight of an object, is the force acting on the object due to acceleration of gravity.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'weight' have not yet been formalized. The term is defined as a specific subtype of 'force'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Weight.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/KinematicViscosity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity"/>
    <rdfs:label xml:lang="en">kinematic viscosity</rdfs:label>
    <rdfs:label xml:lang="de">kinematische Viskosität</rdfs:label>
    <skos:altLabel xml:lang="en">kinetic viscosity</skos:altLabel>
    <skos:altLabel xml:lang="de">kinetische Viskosität</skos:altLabel>
    <skos:prefLabel xml:lang="en">kinematic viscosity</skos:prefLabel>
    <skos:prefLabel xml:lang="de">kinematische Viskosität</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die kinematische Viskosität ist das Verhältnis der dynamischen Viskosität zur Dichte</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Kinematic viscosity is the ratio of dynamic viscosity to density</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'kinematic viscosity' have not yet been formalized. The term is defined as a specific subtype of 'viscosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeConcentration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeRatio"/>
    <rdfs:label xml:lang="de">Volumenkonzentration</rdfs:label>
    <rdfs:label xml:lang="en">volume concentration</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://de.wikipedia.org/wiki/Volumenkonzentration"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Volume concentration links the volume of a mixture component to the total volume, crucial for quantitative composition description</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Volumenkonzentration verbindet das Volumen eines Mischbestandteils mit dem Gesamtvolumen, entscheidend für die quantitative Zusammensetzungsbeschreibung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'volume concentration' have not yet been formalized. The term is defined as a specific subtype of 'volume ratio'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://de.wikipedia.org/wiki/Volumenkonzentration.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LossModulus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DynamicModulus"/>
    <rdfs:label xml:lang="de">Verlustmodul</rdfs:label>
    <rdfs:label xml:lang="en">loss modulus</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Dynamic_modulus"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Loss modulus measures the viscous portion of stored energy in viscoelastic materials</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'loss modulus' have not yet been formalized. The term is defined as a specific subtype of 'dynamic modulus'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Dynamic_modulus.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalQuality"/>
    <rdfs:label xml:lang="en">mechanical quality</rdfs:label>
    <rdfs:label xml:lang="de">mechanische Qualität</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mechanical quality is related to the performance of a material when enduring mechanical loads</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mechanical quality' have not yet been formalized. The term is defined as a specific subtype of 'physical quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Brittleness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalCapability"/>
    <rdfs:label xml:lang="de">Sprödigkeit</rdfs:label>
    <rdfs:label xml:lang="en">brittleness</rdfs:label>
    <skos:altLabel xml:lang="de">Zerbrechlichkeit</skos:altLabel>
    <skos:altLabel xml:lang="en">fragility</skos:altLabel>
    <skos:prefLabel xml:lang="de">Sprödigkeit</skos:prefLabel>
    <skos:prefLabel xml:lang="en">brittleness</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Opposite to toughness, brittleness is the property of being easily broken or damaged</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Sprödigkeit ist die Eigenschaft, leicht zu brechen oder zu beschädigen</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'brittleness' have not yet been formalized. The term is defined as a specific subtype of 'mechanical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nd9c46088c5da4dcda6df82e9ce8d0558">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ProofStrength"/>
    <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/naturalLanguageDefinition"/>
    <owl:annotatedTarget xml:lang="en">Proof strength refers to the stress a material can endure until exhibiting a small amount of plastic deformation</owl:annotatedTarget>
    <iof-av:directSource rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.corrosionpedia.com/definition/6354/proof-stress</iof-av:directSource>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/VolumeViscosity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity"/>
    <rdfs:label xml:lang="de">Volumenviskosität</rdfs:label>
    <rdfs:label xml:lang="en">volume viscosity</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Volume viscosity measures a fluid's resistance to volumetric stress</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Volumenviskosität misst den Widerstand eines Fluids gegenüber volumetrischer Belastung</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'volume viscosity' have not yet been formalized. The term is defined as a specific subtype of 'viscosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/IndentationHardness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Hardness"/>
    <rdfs:label xml:lang="de">Indentationshärte</rdfs:label>
    <rdfs:label xml:lang="en">indentation hardness</rdfs:label>
    <skos:note>Was a subclass of 'Hardness'</skos:note>
    <skos:prefLabel xml:lang="de">Indentationshärte</skos:prefLabel>
    <skos:prefLabel xml:lang="en">identation hardness</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Indentation hardness is a measure of a material's resistance to indentation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Indentationshärte ist ein Maß für die Widerstandsfähigkeit eines Materials gegen Eindringen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'indentation hardness' have not yet been formalized. The term is defined as a specific subtype of 'hardness'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EnvironmentalTemperature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Temperature"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Umgebungstemperatur</rdfs:label>
    <rdfs:label xml:lang="en">environmental temperature</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Environmental temperature describes the observed temperature surrounding a tangible object, including room temperature and temperatures measured in test chambers</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Umgebungstemperatur ist die Eigenschaft, die die beobachtete Temperatur in der Umgebung eines betrachteten materiellen Objekts beschreibt. Dazu gehören Raumtemperatur und die in Prüfkammern gemessenen Temperaturen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'environmental temperature' have not yet been formalized. The term is defined as a specific subtype of 'temperature'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stiffness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Elasticity"/>
    <obo:IAO_0000116 xml:lang="en">While Stiffness characterizes a body's response, taking into account its geometry and materials. Elastic Modulus aims to be agnostic to geometry and specific for the material</obo:IAO_0000116>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/pmd/co"/>
    <rdfs:label xml:lang="de">Steifigkeit</rdfs:label>
    <rdfs:label xml:lang="en">stiffness</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="de">Steifigkeit ist das Maß, bis zu dem ein Objekt einer Verformung als Reaktion auf eine einwirkende Kraft widersteht</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Stiffness is the extent to which an object resists deformation in response to an applied force</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'stiffness' have not yet been formalized. The term is defined as a specific subtype of 'elasticity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Circumference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Perimeter"/>
    <rdfs:label xml:lang="de">Kreisumfang</rdfs:label>
    <rdfs:label xml:lang="en">circumference</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0001648"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Circumference characterizes a 1-D extent equal to the length of the closed curve of a circle</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'circumference' have not yet been formalized. The term is defined as a specific subtype of 'perimeter'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0001648.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Density">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:label xml:lang="de">Dichte</rdfs:label>
    <rdfs:label xml:lang="en">density</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Density, or specific mass, is a substance's mass per unit of volume, typically denoted by ρ, defined as mass divided by volume: ρ = m / V</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'density' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/materials/Materials/TimeOfBreak">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000148"/>
    <rdfs:label xml:lang="de">Bruchzeitpunkt</rdfs:label>
    <rdfs:label xml:lang="en">time of break</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Time of break refers to the instant when a part or specimen fractures during a mechanical test</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'time of break' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000148'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationReflectionCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalCapability"/>
    <rdfs:label xml:lang="de">Strahlungsreflexionsfähigkeiten</rdfs:label>
    <rdfs:label xml:lang="en">radiation reflection capability</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Radiation reflection capability characterizes an entity's ability to reflect electromagnetic radiation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Strahlungsreflexionsfähigkeit beschreibt die Fähigkeit einer Entität, elektromagnetische Strahlung zu reflektieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'radiation reflection capability' have not yet been formalized. The term is defined as a specific subtype of 'optical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nc46bc285ec044116aa304d5f4593e393">
    <rdf:first rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
    <rdf:rest rdf:nodeID="N7e36637838464bb7a38ed0dfa1656f3f"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N1c4fc9c47f30426db5315aba26352f83">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <owl:annotatedProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/explanatoryNote"/>
    <owl:annotatedTarget xml:lang="en">Rate =(def.) a measure, quantity, or frequency, typically one measured against some other quantity or measure</owl:annotatedTarget>
    <AnnotationVocabulary:directSource xml:lang="en">New Oxford American Dictionary</AnnotationVocabulary:directSource>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TensionForce1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Force"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pull1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <obo:BFO_0000055 rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TensionForceMeasurementCapability1"/>
    <obo:BFO_0000057 rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Specimen1"/>
    <triggers rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElasticResponse1"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/AdhesionStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
    <rdfs:label xml:lang="de">Haftfestigkeit</rdfs:label>
    <rdfs:label xml:lang="en">adhesion strength</rdfs:label>
    <skos:altLabel xml:lang="en">Adhesive Strength</skos:altLabel>
    <skos:altLabel xml:lang="de">Klebkraft</skos:altLabel>
    <skos:prefLabel xml:lang="en">Adhesion Strength</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Haftfestigkeit</skos:prefLabel>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">Adhesion strength measures the force required to separate two surfaces bonded together</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Haftfestigkeit ist das Maß für die Kraft, die erforderlich ist, um zwei miteinander verbundene Oberflächen zu trennen</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'adhesion strength' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MaterialProperty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="Naee9d01de7874caab6cb4f3f4097a04b"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
    <rdfs:label xml:lang="de">Materialeigenschaft</rdfs:label>
    <rdfs:label xml:lang="en">material property</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Material property is a quality or capability of a material entity used to characterize its technical performance</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicDefinition xml:lang="en">MaterialProperty(x) ↔ (PhysicalCapability(x) ∨ PhysicalQuality(x) ∨ PhysicalRelationalQuality(x))</iof-av:firstOrderLogicDefinition>
    <iof-av:semiFormalNaturalLanguageDefinition xml:lang="en">every instance of 'material property' is defined as exactly an instance of 'physical capability', 'physical quality' or 'physical relational quality'</iof-av:semiFormalNaturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000114">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">Has Curation Status</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
    <rdfs:label xml:lang="en">physical capability</rdfs:label>
    <rdfs:label xml:lang="de">physische Fähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Physical capability describes a capability realized through an entity in a physical interaction, fulfilling an agent's interest</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'physical capability' have not yet been formalized. The term is defined as a specific subtype of 'Capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Odor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OlfactoricQuantity"/>
    <rdfs:label xml:lang="de">Geruch</rdfs:label>
    <rdfs:label xml:lang="en">odor</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000058"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Odor is a morphologic quality inhering in a bearer whose molecules are dispersed and perceived by an odorant receptor</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'odor' have not yet been formalized. The term is defined as a specific subtype of 'olfactoric quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000058.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricCurrent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
    <rdfs:label xml:lang="en">electric current</rdfs:label>
    <rdfs:label xml:lang="de">elektrischer Strom</rdfs:label>
    <skos:prefLabel xml:lang="en">electric current</skos:prefLabel>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electric current is the flow of electric charge per unit time</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electric current' have not yet been formalized. The term is defined as a specific subtype of 'physical process characteristic'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pressure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:label xml:lang="de">Druck</rdfs:label>
    <rdfs:label xml:lang="en">pressure</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="de">Druck definiert die Menge an Kraft, die pro Flächeneinheit aufgebracht wird und das Potenzial an Energie innerhalb eines Fluids oder Gases ausdrückt</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Pressure defines the amount of force applied per unit area, expressing potential energy within a fluid or gas</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'pressure' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Height">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Length"/>
    <rdfs:label xml:lang="de">Höhe</rdfs:label>
    <rdfs:label xml:lang="en">height</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0000119"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Height is a 1-D extent quality describing the vertical dimension of an object or space, measured from the base to the top</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'height' have not yet been formalized. The term is defined as a specific subtype of 'length'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: http://purl.obolibrary.org/obo/PATO_0000119.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N244b3c0fea5848039e18d2058478051f">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/hasProcessCharacteristic"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalProcessCharacteristic"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RelaxtionCap1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationReflectionCapability"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ExtentionalViscosity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Viscosity"/>
    <rdfs:label xml:lang="de">Dehnviskosität</rdfs:label>
    <rdfs:label xml:lang="en">extentional viscosity</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Dehnviskosität ist die Messung des Widerstands einer Flüssigkeit gegen den Fluss bei Dehnspannung</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Extentional viscosity measures a fluid's resistance to tension flow</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'extentional viscosity' have not yet been formalized. The term is defined as a specific subtype of 'viscosity'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nce91bfc9e8654bb198d53122211286be">
    <rdf:first rdf:nodeID="N3c2921ef8e35458bbf5d6b540aafc782"/>
    <rdf:rest rdf:nodeID="N0dd92482463a47a6b0dc8adb4b93cb5a"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/MechanicalStrength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Strength"/>
    <rdfs:label xml:lang="de">Festigkeit</rdfs:label>
    <rdfs:label xml:lang="en">mechanical strength</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="de">Festigkeit in der Mechanik von Materialien bezeichnet die Fähigkeit eines Materials, eine angewandte Last ohne Versagen oder plastische Verformung zu widerstehen. Innere Kräfte werden auf der Basis einer Einheit als Spannungen ausgedrückt und bewirken eine Verformung des Materials, bekannt als Dehnung</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Mechanical strength refers to a material's ability to resist applied load without failure or plastic deformation, characterized by stress and strain</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'mechanical strength' have not yet been formalized. The term is defined as a specific subtype of 'strength'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/LuminousEfficacy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <rdfs:label xml:lang="de">Lichtausbeute</rdfs:label>
    <rdfs:label xml:lang="en">luminous efficacy</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Luminous_efficacy"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Luminous efficacy measures how well a light source produces visible light, calculated as luminous flux divided by power, expressed in lumens per watt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'luminous efficacy' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Luminous_efficacy.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/SunLigthing1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RadiationEmissonCapability"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Potential">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:label xml:lang="de">Potenzial</rdfs:label>
    <rdfs:label xml:lang="en">potential</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Potential describes the capacity of an entity to perform work or transform due to its position or configuration within a system</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Potenzial beschreibt die Fähigkeit einer Entität, Arbeit zu leisten oder sich aufgrund ihrer Position oder Konfiguration innerhalb eines Systems zu transformieren</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'potential' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TrueStress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Stress"/>
    <obo:IAO_0000116 xml:lang="en">The true stress in accordance with the cauchy stress tensor. It always relates to the current size of the surface of a filled volume element of a material entity. It can be assumed equal to the engineering stress for very small deformations (lower then 0.01 %)</obo:IAO_0000116>
    <rdfs:label xml:lang="en">true stress</rdfs:label>
    <rdfs:label xml:lang="de">wahre Spannung</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">True stress is defined using the cauchy stress tensor, relating stress to the current surface size of a volume element</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Wahre Spannung wird unter Verwendung des Cauchy-Spannungstensors definiert und bezieht die Spannung auf die aktuelle Oberflächengröße eines Volumenelements</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'true stress' have not yet been formalized. The term is defined as a specific subtype of 'stress'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N3c2921ef8e35458bbf5d6b540aafc782">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000057"/>
    <owl:someValuesFrom rdf:nodeID="Nfd53bd64afb34df8bd52028fbfbe381b"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalResistance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElectricalCapability"/>
    <rdfs:label xml:lang="en">electrical resistance</rdfs:label>
    <rdfs:label xml:lang="de">elektrischer Widerstand</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://www.britannica.com/technology/resistance-electronics"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Electrical resistance pertains to a circuit's capability to transform electric energy into heat energy, opposing electric current through particle collisions, characteristic of resistors, lamps, and wires</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'electrical resistance' have not yet been formalized. The term is defined as a specific subtype of 'electrical capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://www.britannica.com/technology/resistance-electronics.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Adhesion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Pressure"/>
    <rdfs:label xml:lang="de">Adhäsion</rdfs:label>
    <rdfs:label xml:lang="en">adhesion</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Adhesion describes the ability of substances to bind to each other, involving attractive force between two bodies of different substances in contact and influencing material performance in scientific and industrial contexts</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'adhesion' have not yet been formalized. The term is defined as a specific subtype of 'pressure'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/TensionRate1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/DeformationSpeed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/reflectance1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalReflectance"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/created">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/Inductance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRelationalQuality"/>
    <rdfs:label xml:lang="de">Induktion</rdfs:label>
    <rdfs:label xml:lang="en">inductance</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Inductance"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Inductance is the tendency of an electrical conductor to oppose a change in electric current through electromagnetic induction, creating back electromotive force</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'inductance' have not yet been formalized. The term is defined as a specific subtype of 'physical relational quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Inductance.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/triggers">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label xml:lang="en">triggers</rdfs:label>
    <rdfs:label xml:lang="de">löst aus</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Triggers relates a stimulus process to the response process that it causes or initiates</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/core/Core/hasCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/RelativeIsotopicMass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <rdfs:label xml:lang="de">relative Isotopenmasse</rdfs:label>
    <rdfs:label xml:lang="en">relative isotopic mass</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://en.wikipedia.org/wiki/Atomic_mass"/>
    <iof-av:naturalLanguageDefinition xml:lang="de">Relative Isotopenmasse bezieht sich auf die Masse eines einzelnen Isotops im Vergleich zu 1/12 der Masse eines Kohlenstoff-12-Atoms</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">Relative isotopic mass refers to the mass of a single isotope compared to 1/12 of the mass of a carbon-12 atom</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'relative isotopic mass' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://en.wikipedia.org/wiki/Atomic_mass.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/EModulus1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/ElasticModulus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/OpticalReflectance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-Physical/PhysicalRateQuality"/>
    <rdfs:label xml:lang="en">optical reflectance</rdfs:label>
    <rdfs:label xml:lang="de">optische Reflexion</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Optical reflectance is defined by the ratio of reflected radiant power to incident radiant power, assessing reflective capacity</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'optical reflectance' have not yet been formalized. The term is defined as a specific subtype of 'physical rate quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N2db92aac0331469981ea34640d749030">
