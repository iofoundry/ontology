<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:iof-av="https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
>
  <!-- =========================================================
       MaterialStructureQuality — root quality class
       ========================================================= -->
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="en">material structure quality</rdfs:label>
    <rdfs:label xml:lang="de">Materialstrukturqualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Material structure quality is a quality of a material entity that pertains to its internal structural arrangement at the microstructural or crystallographic level</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'material structure quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000019'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>

  <!-- =========================================================
       MaterialStructureCapability — root capability class
       ========================================================= -->
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
    <rdfs:label xml:lang="en">material structure capability</rdfs:label>
    <rdfs:label xml:lang="de">Materialstruktur-Fähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">Material structure capability is a capability of a material entity that is realized in processes involving structural transformation or reorganization of its internal arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'material structure capability' have not yet been formalized. The term is defined as a specific subtype of 'Capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
  </rdf:Description>

  <!-- =========================================================
       Qualities
       ========================================================= -->
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/CrystalStructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en">crystal structure</rdfs:label>
    <rdfs:label xml:lang="de">Kristallstruktur</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Crystal structure is a material structure quality of a crystal that specifies the periodic geometric arrangement of its constituent entities in a crystal lattice</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'crystal structure' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000591.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/CrystallographicTexture">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en">crystallographic texture</rdfs:label>
    <rdfs:label xml:lang="de">kristallographische Textur</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Crystallographic texture is a material structure quality of a polycrystal that specifies the statistical distribution of crystallographic orientations of its constituent grains</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'crystallographic texture' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000853.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/DefectDensity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en">defect density</rdfs:label>
    <rdfs:label xml:lang="de">Defektdichte</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000595"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Defect density is a material structure quality of a material that specifies the number of structural defects per unit volume or area, which can affect its mechanical and electronic properties</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'defect density' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000595.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/GrainSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en">grain size</rdfs:label>
    <rdfs:label xml:lang="de">Korngröße</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020243"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Grain size is a material structure quality of a polycrystal that specifies the average size of its constituent grains</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'grain size' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020243.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/ASTMGrainSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/GrainSize"/>
    <rdfs:label xml:lang="en">ASTM grain size</rdfs:label>
    <rdfs:label xml:lang="de">ASTM-Korngröße</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000503"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">ASTM grain size is a grain size quality measured through a process that follows the ASTM standard for determining average grain size in metallic materials</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'ASTM grain size' have not yet been formalized. The term is defined as a specific subtype of 'grain size'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000503.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/GrainSizeDistribution">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en">grain size distribution</rdfs:label>
    <rdfs:label xml:lang="de">Korngrößenverteilung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020112"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Grain size distribution is a material structure quality of a polycrystal that specifies the statistical distribution of sizes of its constituent grains</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'grain size distribution' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020112.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MetallicGrainStructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en">metallic grain structure</rdfs:label>
    <rdfs:label xml:lang="de">metallisches Korngefüge</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0025003"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Metallic grain structure is a material structure quality of a metallic material that specifies the distinct phases and morphological arrangement in its microscopic structure</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'metallic grain structure' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0025003.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/OrderScale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en">order scale</rdfs:label>
    <rdfs:label xml:lang="de">Ordnungsskala</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020220"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Order scale is a material structure quality of a material that specifies the characteristic length over which structural correlations persist</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'order scale' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020220.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/AngleOfMisalignment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en">angle of misalignment</rdfs:label>
    <rdfs:label xml:lang="de">Fehlorientierungswinkel</rdfs:label>
    <skos:altLabel xml:lang="en">angle of misalignment (crystallography)</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020241"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Angle of misalignment is a material structure quality of a grain boundary that specifies the smallest rotation angle needed to bring one crystal orientation into coincidence with the neighboring orientation</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'angle of misalignment' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020241.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/BurgersVector">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en">Burgers vector</rdfs:label>
    <rdfs:label xml:lang="de">Burgersvektor</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020237"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Burgers vector is a material structure quality of a dislocation that specifies the magnitude and direction of the lattice distortion caused by the dislocation in a crystal</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'Burgers vector' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020237.</iof-av:primitiveRationale>
  </rdf:Description>

  <!-- =========================================================
       Capabilities / Dispositions
       ========================================================= -->
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/PolymorphismOfCrystal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureCapability"/>
    <rdfs:label xml:lang="en">polymorphism of crystal</rdfs:label>
    <rdfs:label xml:lang="de">Polymorphismus eines Kristalls</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020212"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Polymorphism of crystal is a material structure capability of a crystal that is realized as a change of its crystal structure while retaining the same chemical composition</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'polymorphism of crystal' have not yet been formalized. The term is defined as a specific subtype of 'material structure capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020212.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/AllotropyOfAnElementalCrystal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/PolymorphismOfCrystal"/>
    <rdfs:label xml:lang="en">allotropy of an elemental crystal</rdfs:label>
    <rdfs:label xml:lang="de">Allotropie eines Elementkristalls</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020211"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Allotropy of an elemental crystal is a polymorphism capability of an elemental crystal that is realized as a change of its crystal structure while retaining the same elemental composition</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'allotropy of an elemental crystal' have not yet been formalized. The term is defined as a specific subtype of 'polymorphism of crystal'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020211.</iof-av:primitiveRationale>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/DispositionOfAPhaseToTransform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureCapability"/>
    <rdfs:label xml:lang="en">disposition of a phase to transform</rdfs:label>
    <rdfs:label xml:lang="de">Disposition einer Phase zur Umwandlung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020165"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">Disposition of a phase to transform is a material structure capability of a phase that is realized as a transition into another phase in a phase transformation process</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Necessary and sufficient conditions for 'disposition of a phase to transform' have not yet been formalized. The term is defined as a specific subtype of 'material structure capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020165.</iof-av:primitiveRationale>
  </rdf:Description>

</rdf:RDF>
