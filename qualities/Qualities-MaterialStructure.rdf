<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
   xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
>
  <!-- =========================================================
       MaterialStructureQuality — root quality class
       ========================================================= -->
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="en-US">material structure quality</rdfs:label>
    <rdfs:label xml:lang="de">Materialstrukturqualität</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Material structure quality is a quality of a material entity that pertains to its internal structural arrangement at the microstructural or crystallographic level</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Qualität der Materialstruktur ist eine Qualität einer Materialeinheit, die sich auf ihre interne Strukturanordnung auf mikrostruktureller oder kristallografischer Ebene bezieht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'material structure quality' have not yet been formalized. The term is defined as a specific subtype of 'BFO_0000019'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">BFO_0000019(x) ← MaterialStructureQuality(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;material structure quality&apos; then x is a &apos;b f o_0000019&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The face-centered cubic arrangement of atoms in annealed copper is a material structure quality that determines its ductility</skos:example>
  </rdf:Description>

  <!-- =========================================================
       MaterialStructureCapability — root capability class
       ========================================================= -->
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/Capability"/>
    <rdfs:label xml:lang="en-US">material structure capability</rdfs:label>
    <rdfs:label xml:lang="de">Materialstruktur-Fähigkeit</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Material structure capability is a capability of a material entity that is realized in processes involving structural transformation or reorganization of its internal arrangement</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Fähigkeit zur materiellen Struktur ist die Fähigkeit einer materiellen Einheit, die in Prozessen realisiert wird, die eine strukturelle Transformation oder Neuorganisation ihrer inneren Anordnung beinhalten</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'material structure capability' have not yet been formalized. The term is defined as a specific subtype of 'Capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">Capability(x) ← MaterialStructureCapability(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;material structure capability&apos; then x is a &apos;capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Cold-rolled steel exhibits a material structure capability realized as recrystallization upon annealing above 600 degrees C</skos:example>
  </rdf:Description>

  <!-- =========================================================
       Qualities
       ========================================================= -->
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/CrystalStructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en-US">crystal structure</rdfs:label>
    <rdfs:label xml:lang="de">Kristallstruktur</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000591"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Crystal structure is a material structure quality of a crystal that specifies the periodic geometric arrangement of its constituent entities in a crystal lattice</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Kristallstruktur ist eine Materialstrukturqualität eines Kristalls, die die periodische geometrische Anordnung seiner Bestandteile in einem Kristallgitter angibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'crystal structure' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000591.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureQuality(x) ← CrystalStructure(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;crystal structure&apos; then x is a &apos;material structure quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Alpha-iron adopts a body-centered cubic crystal structure with a lattice parameter of 0.287 nm at room temperature</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/CrystallographicTexture">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en-US">crystallographic texture</rdfs:label>
    <rdfs:label xml:lang="de">kristallographische Textur</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000853"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Crystallographic texture is a material structure quality of a polycrystal that specifies the statistical distribution of crystallographic orientations of its constituent grains</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die kristallografische Textur ist eine Materialstrukturqualität eines Polykristalls, die die statistische Verteilung der kristallografischen Orientierungen seiner konstituierenden Körner angibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'crystallographic texture' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000853.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureQuality(x) ← CrystallographicTexture(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;crystallographic texture&apos; then x is a &apos;material structure quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Hot-rolled aluminum sheet develops a rolling texture with a strong Copper component due to preferred grain orientation</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/DefectDensity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en-US">defect density</rdfs:label>
    <rdfs:label xml:lang="de">Defektdichte</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000595"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Defect density is a material structure quality of a material that specifies the number of structural defects per unit volume or area, which can affect its mechanical and electronic properties</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Defektdichte ist eine Materialstrukturqualität eines Materials, die die Anzahl struktureller Defekte pro Volumen- oder Flächeneinheit angibt, die sich auf seine mechanischen und elektronischen Eigenschaften auswirken können</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'defect density' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000595.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureQuality(x) ← DefectDensity(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;defect density&apos; then x is a &apos;material structure quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Heavily cold-worked copper has a dislocation density of approximately 10 to the power 15 per square meter</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/GrainSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en-US">grain size</rdfs:label>
    <rdfs:label xml:lang="de">Korngröße</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020243"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Grain size is a material structure quality of a polycrystal that specifies the average size of its constituent grains</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Korngröße ist eine Materialstrukturqualität eines Polykristalls, die die durchschnittliche Größe seiner konstituierenden Körner angibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'grain size' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020243.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureQuality(x) ← GrainSize(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;grain size&apos; then x is a &apos;material structure quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The average grain size of solution-annealed austenitic stainless steel AISI 316L is approximately 30 micrometers</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/ASTMGrainSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/GrainSize"/>
    <rdfs:label xml:lang="en-US">ASTM grain size</rdfs:label>
    <rdfs:label xml:lang="de">ASTM-Korngröße</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0000503"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">ASTM grain size is a grain size quality measured through a process that follows the ASTM standard for determining average grain size in metallic materials</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die ASTM-Korngröße ist eine Korngrößenqualität, die durch ein Verfahren gemessen wird, das dem ASTM-Standard zur Bestimmung der durchschnittlichen Korngröße in metallischen Materialien folgt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'ASTM grain size' have not yet been formalized. The term is defined as a specific subtype of 'grain size'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0000503.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">GrainSize(x) ← ASTMGrainSize(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;astm grain size&apos; then x is a &apos;grain size&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The forged titanium alloy Ti-6Al-4V exhibits an ASTM grain size number of 10 corresponding to an average diameter of 11 micrometers</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/GrainSizeDistribution">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en-US">grain size distribution</rdfs:label>
    <rdfs:label xml:lang="de">Korngrößenverteilung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020112"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Grain size distribution is a material structure quality of a polycrystal that specifies the statistical distribution of sizes of its constituent grains</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Korngrößenverteilung ist eine Materialstrukturqualität eines Polykristalls, die die statistische Größenverteilung seiner konstituierenden Körner angibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'grain size distribution' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020112.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureQuality(x) ← GrainSizeDistribution(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;grain size distribution&apos; then x is a &apos;material structure quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A bimodal grain size distribution in dual-phase steel consists of ferrite grains ranging from 5 to 30 micrometers</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MetallicGrainStructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en-US">metallic grain structure</rdfs:label>
    <rdfs:label xml:lang="de">metallisches Korngefüge</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0025003"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Metallic grain structure is a material structure quality of a metallic material that specifies the distinct phases and morphological arrangement in its microscopic structure</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die metallische Kornstruktur ist eine Materialstrukturqualität eines metallischen Materials, die die unterschiedlichen Phasen und die morphologische Anordnung in seiner mikroskopischen Struktur angibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'metallic grain structure' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0025003.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureQuality(x) ← MetallicGrainStructure(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;metallic grain structure&apos; then x is a &apos;material structure quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The Widmanstatten metallic grain structure of slowly cooled beta-titanium shows needle-like alpha-phase lamellae within prior beta grains</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/OrderScale">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en-US">order scale</rdfs:label>
    <rdfs:label xml:lang="de">Ordnungsskala</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020220"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Order scale is a material structure quality of a material that specifies the characteristic length over which structural correlations persist</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Ordnungsmaßstab ist eine Materialstrukturqualität eines Materials, die die charakteristische Länge angibt, über die strukturelle Korrelationen bestehen bleiben</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'order scale' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020220.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureQuality(x) ← OrderScale(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;order scale&apos; then x is a &apos;material structure quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Amorphous silicon dioxide exhibits short-range order at the scale of Si-O tetrahedral units of about 0.16 nm but no long-range order</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/AngleOfMisalignment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en-US">angle of misalignment</rdfs:label>
    <rdfs:label xml:lang="de">Fehlorientierungswinkel</rdfs:label>
    <skos:altLabel xml:lang="en-US">angle of misalignment (crystallography)</skos:altLabel>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020241"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Angle of misalignment is a material structure quality of a grain boundary that specifies the smallest rotation angle needed to bring one crystal orientation into coincidence with the neighboring orientation</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Fehlausrichtungswinkel ist eine Materialstrukturqualität einer Korngrenze, die den kleinsten Rotationswinkel angibt, der erforderlich ist, um eine Kristallorientierung mit der benachbarten Orientierung in Übereinstimmung zu bringen</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'angle of misalignment' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020241.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureQuality(x) ← AngleOfMisalignment(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;angle of misalignment&apos; then x is a &apos;material structure quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">A low-angle grain boundary in aluminum with an angle of misalignment of 2 degrees consists of a regular array of edge dislocations</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/BurgersVector">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureQuality"/>
    <rdfs:label xml:lang="en-US">Burgers vector</rdfs:label>
    <rdfs:label xml:lang="de">Burgersvektor</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020237"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Burgers vector is a material structure quality of a dislocation that specifies the magnitude and direction of the lattice distortion caused by the dislocation in a crystal</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Der Burgers-Vektor ist eine Materialstrukturqualität einer Versetzung, die das Ausmaß und die Richtung der durch die Versetzung in einem Kristall verursachten Gitterverzerrung angibt</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'Burgers vector' have not yet been formalized. The term is defined as a specific subtype of 'material structure quality'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020237.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureQuality(x) ← BurgersVector(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;burgers vector&apos; then x is a &apos;material structure quality&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">The Burgers vector of a full dislocation in face-centered cubic nickel is a/2 times the 110 direction with magnitude 0.249 nm</skos:example>
  </rdf:Description>

  <!-- =========================================================
       Capabilities / Dispositions
       ========================================================= -->
  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/PolymorphismOfCrystal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureCapability"/>
    <rdfs:label xml:lang="en-US">polymorphism of crystal</rdfs:label>
    <rdfs:label xml:lang="de">Polymorphismus eines Kristalls</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020212"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Polymorphism of crystal is a material structure capability of a crystal that is realized as a change of its crystal structure while retaining the same chemical composition</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Polymorphismus eines Kristalls ist eine Materialstrukturfähigkeit eines Kristalls, die sich in einer Änderung seiner Kristallstruktur unter Beibehaltung der gleichen chemischen Zusammensetzung verwirklicht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'polymorphism of crystal' have not yet been formalized. The term is defined as a specific subtype of 'material structure capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020212.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureCapability(x) ← PolymorphismOfCrystal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;polymorphism of crystal&apos; then x is a &apos;material structure capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Iron undergoes a polymorphism of crystal from body-centered cubic alpha phase to face-centered cubic gamma phase at 912 degrees C</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/AllotropyOfAnElementalCrystal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/PolymorphismOfCrystal"/>
    <rdfs:label xml:lang="en-US">allotropy of an elemental crystal</rdfs:label>
    <rdfs:label xml:lang="de">Allotropie eines Elementkristalls</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020211"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Allotropy of an elemental crystal is a polymorphism capability of an elemental crystal that is realized as a change of its crystal structure while retaining the same elemental composition</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Allotropie eines Elementarkristalls ist die Polymorphismusfähigkeit eines Elementarkristalls, die sich in einer Änderung seiner Kristallstruktur unter Beibehaltung der gleichen Elementzusammensetzung verwirklicht</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'allotropy of an elemental crystal' have not yet been formalized. The term is defined as a specific subtype of 'polymorphism of crystal'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020211.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">PolymorphismOfCrystal(x) ← AllotropyOfAnElementalCrystal(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;allotropy of an elemental crystal&apos; then x is a &apos;polymorphism of crystal&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Carbon exhibits allotropy of an elemental crystal appearing as graphite with hexagonal layered structure or diamond with cubic tetrahedral bonding</skos:example>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="https://spec.industrialontologies.org/ontology/202507/qualities/Qualities-MaterialStructure/"/>
    <owl:versionInfo>202507</owl:versionInfo>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities/"/>
    <dcterms:abstract xml:lang="en-us">The IOF Material Structure Qualities Ontology represents qualities related to the internal structural arrangement of material entities at microstructural and crystallographic levels.</dcterms:abstract>
    <dcterms:contributor xml:lang="en-us">Thomas Hanke, Fraunhofer IWM</dcterms:contributor>
    <dcterms:creator xml:lang="en-us">IOF Materials Working Group</dcterms:creator>
    <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://opensource.org/licenses/MIT</dcterms:license>
    <dcterms:publisher>Industrial Ontology Foundry</dcterms:publisher>
    <dcterms:title xml:lang="en-us">Industrial Ontology Foundry (IOF) Material Structure Qualities Ontology</dcterms:title>
    <rdfs:label xml:lang="en-US">Material Structure Qualities Ontology</rdfs:label>
    <iof-av:copyright xml:lang="en-US">Copyright (c) 2025 Industrial Ontology Foundry (IOF)</iof-av:copyright>
    <iof-av:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
  </rdf:Description>

  <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/DispositionOfAPhaseToTransform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/qualities/Qualities-MaterialStructure/MaterialStructureCapability"/>
    <rdfs:label xml:lang="en-US">disposition of a phase to transform</rdfs:label>
    <rdfs:label xml:lang="de">Disposition einer Phase zur Umwandlung</rdfs:label>
    <iof-av:adaptedFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020165"/>
    <iof-av:naturalLanguageDefinition xml:lang="en-US">Disposition of a phase to transform is a material structure capability of a phase that is realized as a transition into another phase in a phase transformation process</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="de">Die Disposition einer Phase zur Transformation ist eine materielle Strukturfähigkeit einer Phase, die als Übergang in eine andere Phase in einem Phasentransformationsprozess realisiert wird</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en-US">Necessary and sufficient conditions for 'disposition of a phase to transform' have not yet been formalized. The term is defined as a specific subtype of 'material structure capability'. Distinguishing criteria are domain-specific and depend on measurement conventions or source terminology not yet expressed as OWL restrictions. The definition is adapted from: https://w3id.org/pmd/co/PMD_0020165.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en-US">MaterialStructureCapability(x) ← DispositionOfAPhaseToTransform(x)</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en-US">if x is a &apos;disposition of a phase to transform&apos; then x is a &apos;material structure capability&apos;</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:example xml:lang="en-US">Metastable retained austenite in high-carbon steel has a disposition of a phase to transform into martensite under applied stress</skos:example>
  </rdf:Description>

</rdf:RDF>
